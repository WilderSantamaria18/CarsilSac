<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Facturas - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290142">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <!-- Botón para ocultar/mostrar barra -->

            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-receipt"></i>
                            Gestión de Facturas
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Usuario' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %>
                            </div>
                        </div>
                    </div>
                </nav>


                <div class="container-fluid py-4">
                    <!-- Mensajes flash -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>
                            <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <!-- Stats Cards -->
                                    <div class="stats-grid">
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                                                <i class="bi bi-receipt text-white"></i>
                                            </div>
                                            <h6 class="text-muted">Total Facturas</h6>
                                            <h3 class="text-primary">
                                                <%= facturas ? facturas.length : 0 %>
                                            </h3>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #ffeaa7, #fdcb6e);">
                                                <i class="bi bi-clock text-warning"></i>
                                            </div>
                                            <h6 class="text-muted">Pendientes</h6>
                                            <h3 class="text-warning">
                                                <%= facturas ? facturas.filter(f=> f.Estado === 'PENDIENTE').length : 0
                                                    %>
                                            </h3>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #55efc4, #00b894);">
                                                <i class="bi bi-check-circle text-success"></i>
                                            </div>
                                            <h6 class="text-muted">Pagadas</h6>
                                            <h3 class="text-success">
                                                <%= facturas ? facturas.filter(f=> f.Estado === 'PAGADA').length : 0 %>
                                            </h3>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #17a2b8, #138496);">
                                                <i class="bi bi-cash-stack text-info"></i>
                                            </div>
                                            <h6 class="text-muted">Total Ventas</h6>
                                            <h3 class="text-info">S/ <%= facturas ? facturas.filter(f=> f.Estado ===
                                                    'PAGADA').reduce((sum, f) => sum + parseFloat(f.Total || 0),
                                                    0).toLocaleString('es-PE', {minimumFractionDigits: 2}) : '0.00' %>
                                            </h3>
                                        </div>
                                    </div>

                                    <!-- Search and Actions -->
                                    <div class="search-container">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="search-box flex-grow-1 me-3">
                                                <div class="d-flex gap-2">
                                                    <select class="form-select" id="campoFiltro"
                                                        style="max-width: 180px;">
                                                        <option value="0">Código</option>
                                                        <option value="1">Cliente</option>
                                                        <option value="2">Fecha</option>
                                                        <option value="3">Total</option>
                                                        <option value="4">Estado</option>
                                                        <option value="5">Proforma</option>
                                                    </select>
                                                    <input type="text" class="form-control" id="valorFiltro"
                                                        placeholder="Buscar facturas...">
                                                </div>
                                            </div>
                                            <a href="/facturas/nueva" class="btn btn-primary-modern btn-modern">
                                                <i class="bi bi-plus-circle"></i>
                                                Nueva Factura
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Tabla de facturas modernizada -->
                                    <div class="card-modern">
                                        <div class="table-responsive">
                                            <table class="table table-modern mb-0">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 40px;"><input
                                                                class="form-check-input custom-checkbox"
                                                                type="checkbox"></th>
                                                        <th>Código <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Cliente <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Fecha <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Total <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Estado <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Proforma <i class="bi bi-arrow-down-up"></i></th>
                                                        <th class="text-center">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (facturas && facturas.length> 0) { %>
                                                        <% facturas.forEach(function(factura) { %>
                                                            <tr>
                                                                <td><input class="form-check-input custom-checkbox"
                                                                        type="checkbox"></td>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <i class="bi bi-receipt text-primary me-2"></i>
                                                                        <strong>
                                                                            <%= factura.Codigo %>
                                                                        </strong>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="item-info">
                                                                        <div class="item-avatar">
                                                                            <%= (factura.ClienteNombre &&
                                                                                factura.ClienteNombre.length> 0) ?
                                                                                factura.ClienteNombre.charAt(0).toUpperCase()
                                                                                : 'C' %>
                                                                        </div>
                                                                        <div class="item-details">
                                                                            <% if (factura.ClienteNombre &&
                                                                                factura.ClienteNombre.trim() !=='' ) {
                                                                                %>
                                                                                <strong>
                                                                                    <%= factura.ClienteNombre %>
                                                                                </strong>
                                                                                <% if (factura.ClienteDocumento &&
                                                                                    factura.ClienteDocumento.trim()
                                                                                    !=='' ) { %>
                                                                                    <span class="text-muted">RUC: <%=
                                                                                            factura.ClienteDocumento %>
                                                                                            </span>
                                                                                    <% } %>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="text-warning">Cliente
                                                                                                ID: <%=
                                                                                                    factura.IdCliente %>
                                                                                                    </span>
                                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <i class="bi bi-calendar3 text-muted me-1"></i>
                                                                    <%= factura.FechaEmision ? new
                                                                        Date(factura.FechaEmision).toLocaleDateString('es-ES')
                                                                        : '-' %>
                                                                </td>
                                                                <td>
                                                                    <strong class="amount-highlight"
                                                                        style="font-size: 1.1rem;">
                                                                        S/ <%= parseFloat(factura.Total ||
                                                                            0).toLocaleString('es-PE',
                                                                            {minimumFractionDigits: 2}) %>
                                                                    </strong>
                                                                </td>
                                                                <td>
                                                                    <span class="badge-modern <%= 
                                                factura.Estado === 'PENDIENTE' ? 'badge-pendiente' : 
                                                factura.Estado === 'PAGADA' ? 'badge-pagada' : 
                                                factura.Estado === 'VENCIDA' ? 'badge-vencida' : 
                                                'badge-anulada'
                                            %>">
                                                                        <i class="bi <%= 
                                                    factura.Estado === 'PENDIENTE' ? 'bi-clock' : 
                                                    factura.Estado === 'PAGADA' ? 'bi-check-circle' : 
                                                    factura.Estado === 'VENCIDA' ? 'bi-exclamation-triangle' : 
                                                    'bi-x-circle'
                                                %>"></i>
                                                                        <%= factura.Estado || 'SIN ESTADO' %>
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <% if (factura.ProformaCodigo) { %>
                                                                        <span class="badge bg-info text-white">
                                                                            <i class="bi bi-file-earmark-text me-1"></i>
                                                                            <%= factura.ProformaCodigo %>
                                                                        </span>
                                                                        <% } else { %>
                                                                            <span class="text-muted">-</span>
                                                                            <% } %>
                                                                </td>
                                                                <td class="text-center">
                                                                    <div
                                                                        class="action-buttons justify-content-center flex-wrap">
                                                                        <a href="/facturas/<%= factura.IdFactura %>"
                                                                            class="btn-action-icon btn-action-view"
                                                                            title="Ver detalle">
                                                                            <i class="bi bi-eye"></i>
                                                                        </a>
                                                                        <a href="/facturas/<%= factura.IdFactura %>/editar"
                                                                            class="btn-action-icon btn-action-edit"
                                                                            title="Editar">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </a>

                                                                        <!-- Botón de marcar como pagada (solo si está pendiente) -->
                                                                        <% if (factura.Estado==='PENDIENTE' ) { %>
                                                                            <button type="button"
                                                                                class="btn-action-icon btn-action-view"
                                                                                style="background: var(--success); color: white;"
                                                                                onclick="cambiarEstado('<%= factura.IdFactura %>', 'PAGADA')"
                                                                                title="Marcar como pagada">
                                                                                <i class="bi bi-check-circle"></i>
                                                                            </button>
                                                                            <% } %>

                                                                                <button type="button"
                                                                                    class="btn-action-icon btn-action-delete"
                                                                                    onclick="eliminarFactura('<%= factura.IdFactura %>')"
                                                                                    title="Eliminar">
                                                                                    <i class="bi bi-trash"></i>
                                                                                </button>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            <% }); %>
                                                                <% } else { %>
                                                                    <tr>
                                                                        <td colspan="7" class="text-center py-5">
                                                                            <i class="bi bi-receipt text-muted"
                                                                                style="font-size: 3rem;"></i>
                                                                            <p class="text-muted mt-2">No hay facturas
                                                                                registradas.</p>
                                                                            <a href="/facturas/nueva"
                                                                                class="btn btn-primary-modern btn-modern">
                                                                                <i class="bi bi-plus-circle"></i>
                                                                                Crear primera factura
                                                                            </a>
                                                                        </td>
                                                                    </tr>
                                                                    <% } %>
                                                </tbody>
                                            </table>

                                            <!-- Paginación Modernizada -->
                                            <div class="pagination-modern">
                                                <div class="pagination-info">
                                                    Showing 1 - <%= facturas ? facturas.length : 0 %> of <%= facturas ?
                                                            facturas.length : 0 %>
                                                </div>
                                                <ul class="pagination-controls">
                                                    <li><button class="page-item-modern disabled"><i
                                                                class="bi bi-chevron-left"></i></button></li>
                                                    <li><button class="page-item-modern active">1</button></li>
                                                    <li><button class="page-item-modern disabled"><i
                                                                class="bi bi-chevron-right"></i></button></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');

            // Toggle sidebar
            toggleBtn.addEventListener('click', function () {
                sidebar.classList.toggle('hide');
                mainContent.classList.toggle('full');
                if (sidebar.classList.contains('hide')) {
                    toggleIcon.classList.remove('bi-chevron-left');
                    toggleIcon.classList.add('bi-chevron-right');
                } else {
                    toggleIcon.classList.remove('bi-chevron-right');
                    toggleIcon.classList.add('bi-chevron-left');
                }
            });

            // Filtro de tabla
            const campoFiltro = document.getElementById('campoFiltro');
            const valorFiltro = document.getElementById('valorFiltro');
            if (campoFiltro && valorFiltro) {
                valorFiltro.addEventListener('input', filtrarTabla);
                campoFiltro.addEventListener('change', filtrarTabla);
            }

            function filtrarTabla() {
                const col = parseInt(campoFiltro.value);
                const searchTerm = valorFiltro.value.toLowerCase();
                const rows = document.querySelectorAll('tbody tr');

                rows.forEach(row => {
                    // Skip si es la fila de "no hay facturas"
                    if (row.querySelectorAll('td').length < 7) return;

                    const cell = row.querySelectorAll('td')[col];
                    let cellText = cell.textContent.toLowerCase();

                    // Para campo de total (eliminar S/ para buscar por número)
                    if (col === 3) {
                        cellText = cellText.replace('s/', '').trim();
                    }

                    if (cell && cellText.includes(searchTerm)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }
        });

        // Función para cambiar estado de factura
        async function cambiarEstado(idFactura, estado) {
            if (await liquidGlassConfirm(`¿Está seguro de que desea marcar esta factura como ${estado}?`)) {
                fetch(`/facturas/${idFactura}/estado`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ estado: estado })
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert('Estado actualizado exitosamente');
                            location.reload();
                        } else {
                            alert('Error al cambiar estado: ' + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error al cambiar estado');
                    });
            }
        }

        // Función para eliminar factura
        async function eliminarFactura(idFactura) {
            if (await liquidGlassConfirm('¿Está seguro de que desea eliminar esta factura? Esta acción no se puede deshacer.')) {
                fetch(`/facturas/${idFactura}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert('Factura eliminada exitosamente');
                            location.reload();
                        } else {
                            alert('Error al eliminar: ' + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error al eliminar factura');
                    });
            }
        }
    </script>
    <script src="/publico/js/layout.js?v=1772427290142"></script>
</body>

</html>