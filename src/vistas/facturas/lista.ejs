<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Facturas - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290135">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
    </style>
</head>
<body class="bg-[#f6f6f8] text-slate-900 font-display">
<div class="wrapper">
    <%- include("../parciales/sidebar") %>

    <div class="main-content" id="main-content">

        <!-- Top Nav -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-10 shadow-sm">
            <div class="flex items-center gap-2">
                <span class="text-slate-400 text-sm">Panel</span>
                <span class="material-symbols-outlined text-sm text-slate-300">chevron_right</span>
                <span class="font-semibold text-sm">Gestión de Facturas</span>
            </div>
            <div class="flex items-center gap-3">
                <div class="relative">
                    <span class="material-symbols-outlined p-2 text-slate-500 hover:bg-slate-100 rounded-full cursor-pointer transition-colors">notifications</span>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                </div>
                <div class="h-8 w-px bg-slate-200"></div>
                <div class="w-8 h-8 rounded-full bg-[#3b4bc9] flex items-center justify-center text-white text-xs font-bold">
                    <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                </div>
                <span class="text-sm font-medium hidden sm:inline-block">
                    <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                </span>
            </div>
        </header>

        <!-- Content -->
        <div class="p-8">

            <!-- Page Title -->
            <div class="mb-8">
                <h2 class="text-3xl font-black tracking-tight mb-2">Gestión de Facturas</h2>
                <p class="text-slate-500">Administra y monitorea las facturas emitidas por CARSIL.</p>
            </div>

            <!-- Flash messages -->
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                <span><%= success %></span>
            </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-rose-500">error</span>
                <span><%= error %></span>
            </div>
            <% } %>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-[#3b4bc9]">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total Facturas</p>
                    <p class="text-3xl font-bold text-[#3b4bc9]"><%= facturas ? facturas.length : 0 %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-amber-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pendientes</p>
                    <p class="text-3xl font-bold text-amber-600"><%= facturas ? facturas.filter(f => f.Estado === 'PENDIENTE').length : 0 %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-emerald-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pagadas</p>
                    <p class="text-3xl font-bold text-emerald-600"><%= facturas ? facturas.filter(f => f.Estado === 'PAGADA').length : 0 %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-violet-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total Cobrado</p>
                    <p class="text-xl font-bold text-violet-600">S/ <%= facturas ? facturas.filter(f => f.Estado === 'PAGADA').reduce((s,f) => s + parseFloat(f.Total||0), 0).toLocaleString('es-PE',{minimumFractionDigits:2}) : '0.00' %></p>
                </div>
            </div>

            <!-- Filter Bar -->
            <div class="bg-white p-4 rounded-xl border border-slate-100 mb-6 flex flex-wrap gap-4 items-center shadow-sm">
                <div class="flex-1 min-w-[260px] relative group">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#3b4bc9] transition-colors">search</span>
                    <input id="valorFiltro"
                           class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] transition-all text-sm outline-none"
                           placeholder="Buscar facturas..." type="text" />
                </div>
                <select id="campoFiltro"
                        class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                    <option value="0">Código</option>
                    <option value="1">Cliente</option>
                    <option value="2">Estado</option>
                    <option value="3">Proforma</option>
                </select>
                <a href="/facturas/nueva"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 hover:shadow-lg transition-all text-sm">
                    <span class="material-symbols-outlined text-sm">add_circle</span>
                    Nueva Factura
                </a>
            </div>

            <!-- Data Table -->
            <div class="bg-white rounded-xl border border-slate-100 shadow-md overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200">
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Código</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Cliente</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Fecha</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Total</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Estado</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Proforma</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100" id="tbodyFacturas">
                            <% if (facturas && facturas.length > 0) { %>
                            <% facturas.forEach(function(factura) { %>
                            <tr class="hover:bg-slate-50/60 transition-colors">
                                <!-- Código -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[#3b4bc9] text-lg">receipt_long</span>
                                        <span class="font-mono font-bold text-[#3b4bc9] text-sm"><%= factura.Codigo %></span>
                                    </div>
                                </td>
                                <!-- Cliente -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 font-bold text-sm flex-shrink-0">
                                            <%= (factura.ClienteNombre && factura.ClienteNombre.length > 0) ? factura.ClienteNombre.charAt(0).toUpperCase() : 'C' %>
                                        </div>
                                        <div>
                                            <% if (factura.ClienteNombre && factura.ClienteNombre.trim() !== '') { %>
                                            <p class="text-sm font-semibold leading-tight"><%= factura.ClienteNombre %></p>
                                            <% if (factura.ClienteDocumento) { %>
                                            <p class="text-xs text-slate-400 font-mono mt-0.5">RUC: <%= factura.ClienteDocumento %></p>
                                            <% } %>
                                            <% } else { %>
                                            <p class="text-sm text-amber-600 font-medium">ID: <%= factura.IdCliente %></p>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                <!-- Fecha -->
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                    <div class="flex items-center gap-1.5">
                                        <span class="material-symbols-outlined text-sm text-slate-400">calendar_today</span>
                                        <%= factura.FechaEmision ? new Date(factura.FechaEmision).toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'numeric'}) : '—' %>
                                    </div>
                                </td>
                                <!-- Total -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-base font-bold text-emerald-700">
                                        S/ <%= parseFloat(factura.Total || 0).toLocaleString('es-PE',{minimumFractionDigits:2}) %>
                                    </span>
                                </td>
                                <!-- Estado -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <%
                                    const estadoBadge = {
                                        'PENDIENTE': 'bg-amber-50 text-amber-700',
                                        'PAGADA':    'bg-emerald-50 text-emerald-700',
                                        'VENCIDA':   'bg-rose-50 text-rose-700',
                                        'ANULADA':   'bg-slate-100 text-slate-500'
                                    };
                                    const estadoIcon = {
                                        'PENDIENTE': 'schedule',
                                        'PAGADA':    'check_circle',
                                        'VENCIDA':   'warning',
                                        'ANULADA':   'cancel'
                                    };
                                    %>
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider <%= estadoBadge[factura.Estado] || 'bg-slate-100 text-slate-500' %>">
                                        <span class="material-symbols-outlined text-[13px]"><%= estadoIcon[factura.Estado] || 'help' %></span>
                                        <%= factura.Estado || 'SIN ESTADO' %>
                                    </span>
                                </td>
                                <!-- Proforma -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (factura.ProformaCodigo) { %>
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold bg-sky-50 text-sky-700">
                                        <span class="material-symbols-outlined text-[13px]">description</span>
                                        <%= factura.ProformaCodigo %>
                                    </span>
                                    <% } else { %>
                                    <span class="text-slate-300 text-sm">—</span>
                                    <% } %>
                                </td>
                                <!-- Acciones -->
                                <td class="px-6 py-4 whitespace-nowrap text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <!-- Ver detalle -->
                                        <a href="/facturas/<%= factura.IdFactura %>"
                                           class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                           title="Ver detalle">
                                            <span class="material-symbols-outlined text-lg leading-none">visibility</span>
                                        </a>
                                        <!-- Editar -->
                                        <a href="/facturas/<%= factura.IdFactura %>/editar"
                                           class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                           title="Editar">
                                            <span class="material-symbols-outlined text-lg leading-none">edit</span>
                                        </a>
                                        <!-- Marcar pagada -->
                                        <% if (factura.Estado === 'PENDIENTE') { %>
                                        <form action="/facturas/<%= factura.IdFactura %>/estado" method="POST" class="inline">
                                            <input type="hidden" name="Estado" value="PAGADA">
                                            <button type="submit"
                                                    class="p-1.5 hover:bg-emerald-50 rounded-lg transition-colors text-slate-500 hover:text-emerald-600"
                                                    title="Marcar como pagada"
                                                    onclick="return confirm('¿Marcar factura <%= factura.Codigo %> como PAGADA?')">
                                                <span class="material-symbols-outlined text-lg leading-none">check_circle</span>
                                            </button>
                                        </form>
                                        <% } %>
                                        <!-- Eliminar -->
                                        <form action="/facturas/<%= factura.IdFactura %>/eliminar" method="POST" class="inline">
                                            <button type="submit"
                                                    class="p-1.5 hover:bg-rose-50 rounded-lg transition-colors text-slate-500 hover:text-rose-600"
                                                    title="Eliminar"
                                                    onclick="return confirm('¿Eliminar la factura <%= factura.Codigo %>?')">
                                                <span class="material-symbols-outlined text-lg leading-none">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                            <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-16">
                                    <span class="material-symbols-outlined text-5xl text-slate-300 block mb-3">receipt_long</span>
                                    <p class="text-slate-500 font-medium mb-1">No hay facturas registradas</p>
                                    <p class="text-slate-400 text-sm mb-5">Genere su primera factura desde una proforma o directamente.</p>
                                    <a href="/facturas/nueva"
                                       class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 transition-all text-sm">
                                        <span class="material-symbols-outlined text-sm">add_circle</span>
                                        Nueva Factura
                                    </a>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <!-- Footer -->
                <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                    <p class="text-sm text-slate-500">
                        Mostrando <span id="visibleCount"><%= facturas ? facturas.length : 0 %></span>
                        de <strong><%= facturas ? facturas.length : 0 %></strong> facturas
                    </p>
                </div>
            </div>

        </div><!-- /p-8 -->
    </div><!-- /main-content -->
</div><!-- /wrapper -->


<script>
    const campoFiltro = document.getElementById('campoFiltro');
    const valorFiltro = document.getElementById('valorFiltro');

    const colRealMap = [0, 1, 4, 5]; // Código, Cliente, Estado, Proforma

    if (campoFiltro && valorFiltro) {
        [campoFiltro, valorFiltro].forEach(el =>
            el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', filtrarTabla)
        );
        function filtrarTabla() {
            const col = colRealMap[parseInt(campoFiltro.value)] ?? 0;
            const term = valorFiltro.value.toLowerCase();
            let vis = 0;
            document.querySelectorAll('#tbodyFacturas tr').forEach(row => {
                const cell = row.querySelectorAll('td')[col];
                const show = cell && cell.textContent.toLowerCase().includes(term);
                row.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            const vc = document.getElementById('visibleCount');
            if (vc) vc.textContent = vis;
        }
    }
</script>
<script src="/publico/js/layout.js?v=1772427290135"></script>
</body>
</html>
