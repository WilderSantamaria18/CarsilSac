<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Factura - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290135">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
        .producto-original { background: #f0f4ff; border-left: 3px solid #3b4bc9; }
        .producto-adicional { background: #f0fdf4; border-left: 3px solid #10b981; }
    </style>
</head>
<body class="bg-[#f6f6f8] text-slate-900 font-display">
<div class="wrapper">
    <%- include("../parciales/sidebar") %>

    <div class="main-content" id="main-content">

        <!-- Top Nav -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-10 shadow-sm">
            <div class="flex items-center gap-2">
                <span class="text-slate-400 text-sm">Facturas</span>
                <span class="material-symbols-outlined text-sm text-slate-300">chevron_right</span>
                <a href="/facturas" class="text-slate-400 text-sm hover:text-[#3b4bc9] transition-colors">Listado</a>
                <span class="material-symbols-outlined text-sm text-slate-300">chevron_right</span>
                <span class="font-semibold text-sm">Editar Factura</span>
            </div>
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#3b4bc9] flex items-center justify-center text-white text-xs font-bold">
                    <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                </div>
                <span class="text-sm font-medium hidden sm:inline-block">
                    <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                </span>
            </div>
        </header>

        <!-- Content -->
        <div class="p-8 max-w-5xl mx-auto">

            <!-- Page Title -->
            <div class="mb-8 flex items-start justify-between">
                <div>
                    <h2 class="text-3xl font-black tracking-tight mb-2">Editar Factura</h2>
                    <p class="text-slate-500">Modifica los datos de la factura <span class="font-mono font-bold text-[#3b4bc9]"><%= factura.Codigo %></span>.</p>
                </div>
                <%
                const estadoBadgeMap = {
                    'PENDIENTE': 'bg-amber-50 text-amber-700',
                    'PAGADA':    'bg-emerald-50 text-emerald-700',
                    'VENCIDA':   'bg-rose-50 text-rose-700',
                    'ANULADA':   'bg-slate-100 text-slate-500'
                };
                %>
                <span id="estadoBadge" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider <%= estadoBadgeMap[factura.Estado] || 'bg-slate-100 text-slate-500' %>">
                    <span class="material-symbols-outlined text-[14px]">flag</span>
                    <%= factura.Estado || 'PENDIENTE' %>
                </span>
            </div>

            <!-- Flash messages -->
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-rose-500">error</span>
                <span><%= error %></span>
            </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                <span><%= success %></span>
            </div>
            <% } %>

            <form action="/facturas/<%= factura.IdFactura %>/actualizar" method="POST" id="editFacturaForm">
                <% if (factura.IdProforma) { %>
                <input type="hidden" name="IdProforma" value="<%= factura.IdProforma %>">
                <% } %>
                <div id="productosModificadosHidden"></div>

                <!-- Alerta proforma -->
                <% if (factura.IdProforma && factura.ProformaCodigo) { %>
                <div class="mb-6 flex items-start gap-3 bg-sky-50 border border-sky-200 text-sky-800 px-5 py-4 rounded-xl text-sm">
                    <span class="material-symbols-outlined text-sky-500 mt-0.5">description</span>
                    <div>
                        <p class="font-semibold mb-1">Factura generada desde una Proforma</p>
                        <p class="text-sky-700">Código de Proforma: <strong class="font-mono"><%= factura.ProformaCodigo %></strong></p>
                        <a href="/proformas/<%= factura.IdProforma %>"
                           class="inline-flex items-center gap-1 mt-2 text-xs font-semibold text-sky-700 hover:text-sky-900 underline underline-offset-2">
                            <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                            Ver Proforma Original
                        </a>
                    </div>
                </div>
                <% } %>

                <!-- SECCIÓN: Información Básica -->
                <div class="bg-white rounded-xl border border-slate-100 shadow-sm mb-6 overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[#3b4bc9]">info</span>
                        <h3 class="font-bold text-slate-800 uppercase tracking-wider text-xs">Información Básica</h3>
                    </div>
                    <div class="p-6 grid grid-cols-1 md:grid-cols-3 gap-5">
                        <!-- Código (readonly) -->
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Código</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">tag</span>
                                <input type="text" name="Codigo" value="<%= factura.Codigo %>" readonly
                                       class="w-full pl-9 pr-3 py-2.5 bg-slate-100 border border-slate-200 rounded-lg text-sm font-mono text-slate-500 cursor-not-allowed outline-none">
                            </div>
                            <p class="text-[11px] text-slate-400 mt-1">No se puede modificar</p>
                        </div>

                        <!-- Estado -->
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Estado <span class="text-rose-500">*</span></label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">flag</span>
                                <select id="Estado" name="Estado" required
                                        class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none">
                                    <option value="PENDIENTE" <%= factura.Estado === 'PENDIENTE' ? 'selected' : '' %>>Pendiente</option>
                                    <option value="PAGADA"    <%= factura.Estado === 'PAGADA'    ? 'selected' : '' %>>Pagada</option>
                                    <option value="VENCIDA"   <%= factura.Estado === 'VENCIDA'   ? 'selected' : '' %>>Vencida</option>
                                    <option value="ANULADA"   <%= factura.Estado === 'ANULADA'   ? 'selected' : '' %>>Anulada</option>
                                </select>
                            </div>
                        </div>

                        <!-- Cliente -->
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Cliente <span class="text-rose-500">*</span></label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">person</span>
                                <select id="IdCliente" name="IdCliente" required
                                        class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none">
                                    <option value="">Seleccionar cliente</option>
                                    <% if (clientes) { clientes.forEach(function(cliente) { %>
                                    <option value="<%= cliente.IdCliente %>" <%= factura.IdCliente == cliente.IdCliente ? 'selected' : '' %>>
                                        <%= cliente.RazonSocial %> - <%= cliente.Documento %>
                                    </option>
                                    <% }); } %>
                                </select>
                            </div>
                        </div>

                        <!-- Fecha Emisión -->
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Fecha de Emisión <span class="text-rose-500">*</span></label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">calendar_today</span>
                                <input id="FechaEmision" type="date" name="FechaEmision" required
                                       value="<%= factura.FechaEmision ? new Date(factura.FechaEmision).toISOString().split('T')[0] : '' %>"
                                       class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                            </div>
                        </div>

                        <!-- Fecha Vencimiento -->
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Fecha de Vencimiento</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">event_busy</span>
                                <input id="FechaVencimiento" type="date" name="FechaVencimiento"
                                       value="<%= factura.FechaVencimiento ? new Date(factura.FechaVencimiento).toISOString().split('T')[0] : '' %>"
                                       class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                            </div>
                        </div>

                        <!-- Forma de Pago -->
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Forma de Pago</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">credit_card</span>
                                <select id="FormaPago" name="FormaPago"
                                        class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none">
                                    <option value="">Seleccionar forma de pago</option>
                                    <option value="CONTADO"       <%= factura.FormaPago === 'CONTADO'       ? 'selected' : '' %>>Contado</option>
                                    <option value="CREDITO_30"    <%= factura.FormaPago === 'CREDITO_30'    ? 'selected' : '' %>>Crédito 30 días</option>
                                    <option value="CREDITO_60"    <%= factura.FormaPago === 'CREDITO_60'    ? 'selected' : '' %>>Crédito 60 días</option>
                                    <option value="CREDITO_90"    <%= factura.FormaPago === 'CREDITO_90'    ? 'selected' : '' %>>Crédito 90 días</option>
                                    <option value="TRANSFERENCIA" <%= factura.FormaPago === 'TRANSFERENCIA' ? 'selected' : '' %>>Transferencia bancaria</option>
                                    <option value="CHEQUE"        <%= factura.FormaPago === 'CHEQUE'        ? 'selected' : '' %>>Cheque</option>
                                </select>
                            </div>
                        </div>

                        <!-- Observaciones -->
                        <div class="md:col-span-3">
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Observaciones</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-3 top-3 text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">chat</span>
                                <textarea id="Observaciones" name="Observaciones" rows="3"
                                          placeholder="Observaciones adicionales..."
                                          class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none resize-none"><%= factura.Observaciones || '' %></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN: Productos -->
                <div class="bg-white rounded-xl border border-slate-100 shadow-sm mb-6 overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#3b4bc9]">inventory_2</span>
                            <h3 class="font-bold text-slate-800 uppercase tracking-wider text-xs">Productos de la Factura</h3>
                        </div>
                        <button type="button" id="addProductBtn"
                                class="inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-600 text-white text-xs font-semibold rounded-lg hover:bg-emerald-700 transition-colors">
                            <span class="material-symbols-outlined text-sm">add_circle</span>
                            Agregar Producto
                        </button>
                    </div>

                    <!-- Cabecera tabla -->
                    <div class="px-6 py-3 bg-slate-50 border-b border-slate-100 grid grid-cols-12 gap-3 text-xs font-bold text-slate-400 uppercase tracking-wider">
                        <span class="col-span-5">Producto</span>
                        <span class="col-span-2 text-center">Cantidad</span>
                        <span class="col-span-1 text-center">U.M.</span>
                        <span class="col-span-2 text-center">P. Unit.</span>
                        <span class="col-span-1 text-right">Total</span>
                        <span class="col-span-1"></span>
                    </div>

                    <!-- Productos existentes -->
                    <div id="productosOriginales" class="divide-y divide-slate-100 px-4">
                        <% if (detalles && detalles.length > 0) { %>
                        <% detalles.forEach(function(detalle) { %>
                        <% const esOriginal = detalle.IdDetalleProforma || detalle.TipoDetalle === 'ORIGINAL'; %>
                        <div class="py-3 px-2 rounded-lg my-1.5 <%= esOriginal ? 'producto-original' : 'producto-adicional' %> producto-row"
                             data-detalle-id="<%= detalle.IdDetalleFactura %>"
                             data-tipo="<%= esOriginal ? 'ORIGINAL' : 'ADICIONAL' %>">
                            <div class="grid grid-cols-12 gap-3 items-center">
                                <div class="col-span-5">
                                    <div class="flex items-center gap-2">
                                        <% if (esOriginal) { %>
                                        <span class="inline-flex items-center gap-1 px-1.5 py-0.5 text-[10px] font-bold bg-[#3b4bc9]/10 text-[#3b4bc9] rounded whitespace-nowrap">
                                            <span class="material-symbols-outlined text-[10px]">shield</span>Proforma
                                        </span>
                                        <% } else { %>
                                        <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold bg-emerald-100 text-emerald-700 rounded whitespace-nowrap">Adicional</span>
                                        <% } %>
                                        <div>
                                            <p class="text-sm font-semibold"><%= detalle.ProductoNombre || 'Producto' %></p>
                                            <% if (detalle.DescripcionAdicional) { %>
                                            <p class="text-xs text-slate-400"><%= detalle.DescripcionAdicional %></p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-span-2 text-center">
                                    <% if (esOriginal) { %>
                                    <span class="text-sm font-semibold text-slate-600"><%= detalle.Cantidad %></span>
                                    <% } else { %>
                                    <input type="number" min="0.01" step="0.01" value="<%= detalle.Cantidad %>"
                                           data-detalle-id="<%= detalle.IdDetalleFactura %>"
                                           class="cantidad-input w-full text-center py-1.5 px-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                                    <% } %>
                                </div>
                                <div class="col-span-1 text-center text-xs text-slate-500 font-medium"><%= detalle.UnidadMedida || 'UNID' %></div>
                                <div class="col-span-2 text-center">
                                    <% if (esOriginal) { %>
                                    <span class="text-sm font-semibold text-slate-600">S/ <%= parseFloat(detalle.PrecioUnitario||0).toFixed(2) %></span>
                                    <% } else { %>
                                    <input type="number" min="0" step="0.01" value="<%= detalle.PrecioUnitario %>"
                                           data-detalle-id="<%= detalle.IdDetalleFactura %>"
                                           class="precio-input w-full text-center py-1.5 px-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                                    <% } %>
                                </div>
                                <div class="col-span-1 text-right">
                                    <span class="total-producto text-sm font-bold text-emerald-700">S/ <%= parseFloat(detalle.Total||0).toFixed(2) %></span>
                                </div>
                                <div class="col-span-1 text-right">
                                    <% if (!esOriginal) { %>
                                    <button type="button" data-detalle-id="<%= detalle.IdDetalleFactura %>"
                                            class="btn-remove-product p-1.5 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-lg transition-colors">
                                        <span class="material-symbols-outlined text-lg leading-none">delete</span>
                                    </button>
                                    <% } else { %>
                                    <span class="material-symbols-outlined text-lg text-[#3b4bc9]/40" title="Protegido">shield_lock</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <% }); } %>
                    </div>

                    <!-- Nuevos productos adicionales -->
                    <div id="nuevosProductosAdicionales" class="px-4 divide-y divide-slate-100"></div>

                    <!-- Totales -->
                    <div class="m-4 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden">
                        <div class="px-5 py-3 bg-slate-100 border-b border-slate-200 flex items-center gap-2">
                            <span class="material-symbols-outlined text-slate-600 text-sm">calculate</span>
                            <h4 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Resumen de Totales</h4>
                        </div>
                        <div class="p-5 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <p class="text-xs font-bold text-[#3b4bc9] uppercase tracking-wider mb-3">Productos Originales</p>
                                <div class="flex justify-between text-sm text-slate-600"><span>Subtotal:</span><strong id="subtotalOriginal">S/ 0.00</strong></div>
                                <div class="flex justify-between text-sm text-slate-600"><span>IGV (18%):</span><strong id="igvOriginal">S/ 0.00</strong></div>
                                <div class="flex justify-between text-sm font-bold text-slate-800 pt-2 border-t border-slate-200"><span>Total Original:</span><strong id="totalOriginal">S/ 0.00</strong></div>
                            </div>
                            <div class="space-y-2">
                                <p class="text-xs font-bold text-emerald-600 uppercase tracking-wider mb-3">Productos Adicionales</p>
                                <div class="flex justify-between text-sm text-slate-600"><span>Subtotal:</span><strong id="subtotalAdicionales">S/ 0.00</strong></div>
                                <div class="flex justify-between text-sm text-slate-600"><span>IGV (18%):</span><strong id="igvAdicionales">S/ 0.00</strong></div>
                                <div class="flex justify-between text-sm font-bold text-slate-800 pt-2 border-t border-slate-200"><span>Total Adicionales:</span><strong id="totalAdicionales">S/ 0.00</strong></div>
                            </div>
                        </div>
                        <div class="px-5 py-4 bg-[#3b4bc9] flex items-center justify-between">
                            <span class="text-white font-bold text-base uppercase tracking-wider">TOTAL FINAL</span>
                            <strong id="totalFinal" class="text-white text-2xl font-black">S/ <%= factura.Total || '0.00' %></strong>
                        </div>
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="bg-white rounded-xl border border-slate-100 shadow-sm px-6 py-5 flex flex-wrap items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <a href="/facturas" class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-lg transition-colors border border-slate-200">
                            <span class="material-symbols-outlined text-sm">arrow_back</span>Volver al Listado
                        </a>
                        <a href="/facturas/<%= factura.IdFactura %>" class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-[#3b4bc9] hover:bg-[#3b4bc9]/5 rounded-lg transition-colors border border-[#3b4bc9]/30">
                            <span class="material-symbols-outlined text-sm">visibility</span>Ver Detalle
                        </a>
                    </div>
                    <button type="submit" id="submitBtn"
                            class="inline-flex items-center gap-2 px-7 py-2.5 bg-[#3b4bc9] text-white font-bold rounded-lg hover:bg-[#3b4bc9]/90 shadow-lg shadow-[#3b4bc9]/20 transition-all text-sm">
                        <span class="material-symbols-outlined text-sm">save</span>Actualizar Factura
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let productosDisponibles = [];
    let contadorNuevosProductos = 0;
    let productosModificados = [];
    let productosEliminados = [];

    cargarProductosDisponibles();
    document.getElementById('addProductBtn').addEventListener('click', agregarNuevoProducto);
    document.getElementById('editFacturaForm').addEventListener('submit', validarYEnviarFormulario);
    calcularTotales();

    document.querySelectorAll('.cantidad-input, .precio-input').forEach(input => {
        input.addEventListener('input', function() { actualizarProductoExistente(this.dataset.detalleId); });
    });
    document.querySelectorAll('.btn-remove-product').forEach(btn => {
        btn.addEventListener('click', function() { eliminarProductoAdicional(this.dataset.detalleId); });
    });

    async function cargarProductosDisponibles() {
        try {
            const r = await fetch('/productos/api/listar');
            if (r.ok) { const d = await r.json(); productosDisponibles = d.productos || []; }
        } catch(e) { console.error(e); }
    }

    function agregarNuevoProducto() {
        if (!productosDisponibles.length) { alert('No hay productos disponibles.'); return; }
        contadorNuevosProductos++;
        const nid = `nuevo_${contadorNuevosProductos}`;
        const fila = document.createElement('div');
        fila.className = 'py-3 px-2 rounded-lg my-1.5 producto-adicional producto-row';
        fila.dataset.nuevoId = nid;
        fila.innerHTML = `
            <div class="grid grid-cols-12 gap-3 items-start">
                <div class="col-span-5">
                    <select class="producto-select w-full py-2 px-3 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none" data-nuevo-id="${nid}" required>
                        <option value="">Seleccionar producto...</option>
                        ${productosDisponibles.map(p => `<option value="${p.IdProducto}" data-precio="${p.PrecioUnitario}" data-unidad="${p.UnidadMedida}">${p.Nombre}${p.Marca?' - '+p.Marca:''}${p.Modelo?' '+p.Modelo:''}</option>`).join('')}
                    </select>
                    <input type="text" placeholder="Descripción adicional (opcional)" data-nuevo-id="${nid}" data-field="descripcion"
                           class="mt-1.5 w-full py-1.5 px-3 bg-white border border-slate-200 rounded-lg text-xs outline-none focus:border-[#3b4bc9]">
                </div>
                <div class="col-span-2 text-center">
                    <input type="number" class="cantidad-nueva w-full text-center py-1.5 px-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none"
                           min="0.01" step="0.01" value="1" data-nuevo-id="${nid}" required>
                </div>
                <div class="col-span-1 text-center text-xs text-slate-500 font-medium unidad-display pt-2">UNID</div>
                <div class="col-span-2 text-center">
                    <input type="number" class="precio-nuevo w-full text-center py-1.5 px-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none"
                           min="0" step="0.01" value="0" data-nuevo-id="${nid}" required>
                </div>
                <div class="col-span-1 text-right pt-2">
                    <span class="total-producto text-sm font-bold text-emerald-700">S/ 0.00</span>
                </div>
                <div class="col-span-1 text-right">
                    <button type="button" class="remove-nuevo p-1.5 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-lg transition-colors">
                        <span class="material-symbols-outlined text-lg leading-none">delete</span>
                    </button>
                </div>
            </div>
        `;
        document.getElementById('nuevosProductosAdicionales').appendChild(fila);
        fila.querySelector('.producto-select').addEventListener('change', function() {
            const opt = this.options[this.selectedIndex];
            if (opt.value) {
                fila.querySelector('.precio-nuevo').value = parseFloat(opt.dataset.precio) || 0;
                fila.querySelector('.unidad-display').textContent = opt.dataset.unidad || 'UNID';
                calcTotalNuevo(nid);
            }
        });
        fila.querySelector('.cantidad-nueva').addEventListener('input', () => calcTotalNuevo(nid));
        fila.querySelector('.precio-nuevo').addEventListener('input', () => calcTotalNuevo(nid));
        fila.querySelector('.remove-nuevo').addEventListener('click', () => {
            if (confirm('¿Eliminar este producto?')) { fila.remove(); calcularTotales(); }
        });
    }

    function calcTotalNuevo(nid) {
        const f = document.querySelector(`[data-nuevo-id="${nid}"]`);
        if (!f) return;
        const t = (parseFloat(f.querySelector('.cantidad-nueva').value)||0) * (parseFloat(f.querySelector('.precio-nuevo').value)||0);
        f.querySelector('.total-producto').textContent = `S/ ${t.toFixed(2)}`;
        calcularTotales();
    }

    function actualizarProductoExistente(detalleId) {
        const f = document.querySelector(`[data-detalle-id="${detalleId}"]`);
        if (!f) return;
        const cant = parseFloat(f.querySelector('.cantidad-input')?.value)||0;
        const prec = parseFloat(f.querySelector('.precio-input')?.value)||0;
        const total = cant * prec;
        f.querySelector('.total-producto').textContent = `S/ ${total.toFixed(2)}`;
        const idx = productosModificados.findIndex(p => p.IdDetalleFactura == detalleId);
        const obj = { IdDetalleFactura: detalleId, Cantidad: cant, PrecioUnitario: prec, Total: total };
        idx >= 0 ? productosModificados[idx] = obj : productosModificados.push(obj);
        calcularTotales();
    }

    function eliminarProductoAdicional(detalleId) {
        if (!confirm('¿Eliminar este producto adicional?')) return;
        const f = document.querySelector(`[data-detalle-id="${detalleId}"]`);
        if (f && f.dataset.tipo === 'ADICIONAL') { f.remove(); productosEliminados.push(detalleId); calcularTotales(); }
    }

    function calcularTotales() {
        let sO = 0, sA = 0;
        document.querySelectorAll('[data-tipo="ORIGINAL"] .total-producto').forEach(el => { sO += parseFloat(el.textContent.replace('S/ ',''))||0; });
        document.querySelectorAll('[data-tipo="ADICIONAL"] .total-producto').forEach(el => {
            const f = el.closest('.producto-row');
            if (f && !productosEliminados.includes(f.dataset.detalleId)) sA += parseFloat(el.textContent.replace('S/ ',''))||0;
        });
        document.querySelectorAll('#nuevosProductosAdicionales .total-producto').forEach(el => { sA += parseFloat(el.textContent.replace('S/ ',''))||0; });
        const igvO=sO*0.18, tO=sO+igvO, igvA=sA*0.18, tA=sA+igvA;
        document.getElementById('subtotalOriginal').textContent   = `S/ ${sO.toFixed(2)}`;
        document.getElementById('igvOriginal').textContent        = `S/ ${igvO.toFixed(2)}`;
        document.getElementById('totalOriginal').textContent      = `S/ ${tO.toFixed(2)}`;
        document.getElementById('subtotalAdicionales').textContent= `S/ ${sA.toFixed(2)}`;
        document.getElementById('igvAdicionales').textContent     = `S/ ${igvA.toFixed(2)}`;
        document.getElementById('totalAdicionales').textContent   = `S/ ${tA.toFixed(2)}`;
        document.getElementById('totalFinal').textContent         = `S/ ${(tO+tA).toFixed(2)}`;
    }

    function actualizarInputsHidden() {
        const c = document.getElementById('productosModificadosHidden');
        c.innerHTML = '';
        productosModificados.forEach((p,i) => {
            c.innerHTML += `<input type="hidden" name="productosModificados[${i}][IdDetalleFactura]" value="${p.IdDetalleFactura}">
                            <input type="hidden" name="productosModificados[${i}][Cantidad]" value="${p.Cantidad}">
                            <input type="hidden" name="productosModificados[${i}][PrecioUnitario]" value="${p.PrecioUnitario}">`;
        });
        productosEliminados.forEach((id,i) => { c.innerHTML += `<input type="hidden" name="productosEliminados[${i}]" value="${id}">`; });
        document.querySelectorAll('#nuevosProductosAdicionales .producto-row').forEach((f,i) => {
            const sel=f.querySelector('.producto-select'), cant=f.querySelector('.cantidad-nueva'),
                  prec=f.querySelector('.precio-nuevo'), desc=f.querySelector('input[data-field="descripcion"]');
            if (sel && sel.value) {
                c.innerHTML += `<input type="hidden" name="nuevosProductos[${i}][IdProducto]" value="${sel.value}">
                                <input type="hidden" name="nuevosProductos[${i}][Cantidad]" value="${cant.value}">
                                <input type="hidden" name="nuevosProductos[${i}][PrecioUnitario]" value="${prec.value}">
                                <input type="hidden" name="nuevosProductos[${i}][DescripcionAdicional]" value="${desc?desc.value:''}">`;
            }
        });
    }

    async function validarYEnviarFormulario(e) {
        e.preventDefault();
        actualizarInputsHidden();
        if (!document.getElementById('Estado').value || !document.getElementById('IdCliente').value || !document.getElementById('FechaEmision').value) {
            alert('Complete todos los campos obligatorios.'); return;
        }
        for (const f of document.querySelectorAll('#nuevosProductosAdicionales .producto-row')) {
            const sel=f.querySelector('.producto-select'), cant=f.querySelector('.cantidad-nueva'), prec=f.querySelector('.precio-nuevo');
            if (!sel.value || !cant.value || cant.value<=0 || prec.value<0) { alert('Complete correctamente los productos adicionales.'); return; }
        }
        if (confirm('¿Actualizar esta factura?')) {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span> Actualizando...';
            e.target.submit();
        }
    }

    // Auto-calcular fecha vencimiento
    const fpSelect = document.getElementById('FormaPago');
    const feInput  = document.getElementById('FechaEmision');
    const fvInput  = document.getElementById('FechaVencimiento');
    function calcFechaVenc() {
        const fp=fpSelect.value, fe=feInput.value;
        if (!fe) return;
        if (fp.startsWith('CREDITO_')) { const d=new Date(fe); d.setDate(d.getDate()+parseInt(fp.split('_')[1])); fvInput.value=d.toISOString().split('T')[0]; }
        else if (fp==='CONTADO') fvInput.value=fe;
    }
    fpSelect.addEventListener('change', calcFechaVenc);
    feInput.addEventListener('change', calcFechaVenc);

    // Actualizar badge estado
    document.getElementById('Estado').addEventListener('change', function() {
        const map = { PENDIENTE:'bg-amber-50 text-amber-700', PAGADA:'bg-emerald-50 text-emerald-700', VENCIDA:'bg-rose-50 text-rose-700', ANULADA:'bg-slate-100 text-slate-500' };
        const b = document.getElementById('estadoBadge');
        b.className = `inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider ${map[this.value]||'bg-slate-100 text-slate-500'}`;
        b.innerHTML = `<span class="material-symbols-outlined text-[14px]">flag</span>${this.value}`;
    });
});
</script>
