<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Roles - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290148">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-shield-lock"></i>
                        Gestión de Roles
                    </h5>
                    <div class="user-profile ms-auto">
                        <span>Administrador</span>
                        <div class="user-avatar">A</div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Estadísticas -->
                <div class="stats-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h3 class="text-primary fw-bold mb-1"><%= roles ? roles.length : 0 %></h3>
                            <p class="text-muted mb-0">Roles configurados en el sistema</p>
                        </div>
                        <div class="stat-icon">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                    </div>
                </div>

                <!-- Alertas -->
                <% if (messages && messages.success && messages.success.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i><%= messages.success[0] %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (messages && messages.error && messages.error.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i><%= messages.error[0] %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- Header con botón -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="page-title">
                        <i class="bi bi-shield-lock"></i>
                        Lista de Roles
                    </h3>
                    <a href="/roles/crear" class="btn btn-primary-modern btn-modern">
                        <i class="bi bi-plus-circle"></i>
                        Nuevo Rol
                    </a>
                </div>

                <!-- Tabla modernizada -->
                <div class="card-modern">
                    <div class="table-responsive">
                        <table class="table table-modern mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"><input class="form-check-input custom-checkbox" type="checkbox" onchange="toggleAll(this)"></th>
                                    <th>ID</th>
                                    <th>Descripción</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (roles && roles.length > 0) { %>
                                    <% roles.forEach(function(rol) { %>
                                        <tr>
                                            <td><input class="form-check-input custom-checkbox row-checkbox" type="checkbox"></td>
                                            <td>
                                                <span class="fw-bold text-primary">
                                                    #<%= rol.IdRol || rol.idrol || rol.id || rol.ID %>
                                                </span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-shield-lock text-primary me-2"></i>
                                                    <span><%= rol.Descripcion || rol.descripcion || '-' %></span>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <div class="action-buttons justify-content-center">

                                                    <a href="/roles/editar/<%= rol.IdRol || rol.idrol || rol.id || rol.ID %>" 
                                                       class="btn-action-icon btn-action-edit" 
                                                       title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a href="/roles/eliminar/<%= rol.IdRol || rol.idrol || rol.id || rol.ID %>" 
                                                       class="btn-action-icon btn-action-delete" 
                                                       onclick="return confirm('¿Está seguro de eliminar este rol?');" 
                                                       title="Eliminar">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            
</div></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="text-center py-5">
                                            <i class="bi bi-shield-lock text-muted" style="font-size: 3rem;"></i>
                                            <p class="text-muted mt-2">No hay roles registrados.</p>
                                            <a href="/roles/crear" class="btn btn-primary-modern btn-modern">
                                                <i class="bi bi-plus-circle"></i>
                                                Crear primer rol
                                            </a>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        const menuItems = document.querySelectorAll('.menu-item');
        const userAvatar = document.querySelector('.user-avatar');
        const userName = 'Administrador';
        userAvatar.textContent = userName.charAt(0);

        // Toggle sidebar
        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });
        
        // Menú activo});
    </script>
    <script src="/publico/js/layout.js?v=1772427290148"></script>
</body>
</html>
