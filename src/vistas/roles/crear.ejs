</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <%- include("../parciales/sidebar") %>
        <!-- Botón para ocultar/mostrar barra -->
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
                <div class="container-fluid">
                    <span class="navbar-brand ms-3">Panel de Control</span>
                    <div class="user-profile ms-auto">
                        <span>Administrador</span>
                        <div class="user-avatar">A</div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid py-4">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="form-container">
                            <h2 class="form-title">
                                <i class="bi bi-shield-lock"></i>
                                Crear Nuevo Rol
                            </h2>
                            
                            <% if (messages.error && messages.error.length > 0) { %>
                                <div class="alert alert-danger alert-dismissible fade show">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <%= messages.error[0] %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            <% } %>
                            <% if (messages.success && messages.success.length > 0) { %>
                                <div class="alert alert-success alert-dismissible fade show">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    <%= messages.success[0] %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            <% } %>
                            
                            <form action="/roles/crear" method="POST">
                                <div class="mb-4">
                                    <label for="nombre" class="form-label">
                                        <i class="bi bi-tag"></i>
                                        Nombre del Rol
                                    </label>
                                    <input type="text" class="form-control-modern" id="nombre" name="nombre" required placeholder="Ej: Administrador, Supervisor, etc.">
                                    <div class="form-text">Ingrese un nombre único para identificar este rol</div>
                                </div>
                                
                                <div class="mb-4">
                                    <label for="descripcion" class="form-label">
                                        <i class="bi bi-text-paragraph"></i>
                                        Descripción
                                    </label>
                                    <textarea class="form-control-modern" id="descripcion" name="descripcion" rows="4" style="min-height: 100px;" placeholder="Describa las funciones y responsabilidades de este rol"></textarea>
                                    <div class="form-text">Esta descripción ayudará a entender el propósito del rol</div>
                                </div>
                                
                                <!-- Sección de permisos (puedes descomentar si necesitas incluir permisos) -->
                                <!--
                                <div class="permissions-section">
                                    <h5 class="permissions-title">
                                        <i class="bi bi-key"></i>
                                        Asignar Permisos
                                    </h5>
                                    
                                    <div class="permission-card">
                                        <div class="permission-group">Módulo Usuarios</div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="create-user">
                                            <label class="form-check-label" for="create-user">Crear usuarios</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="edit-user">
                                            <label class="form-check-label" for="edit-user">Editar usuarios</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="delete-user">
                                            <label class="form-check-label" for="delete-user">Eliminar usuarios</label>
                                        </div>
                                    </div>
                                    
                                    <div class="permission-card">
                                        <div class="permission-group">Módulo Clientes</div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="create-client">
                                            <label class="form-check-label" for="create-client">Crear clientes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="edit-client">
                                            <label class="form-check-label" for="edit-client">Editar clientes</label>
                                        </div>
                                    </div>
                                </div>
                                -->
                                
                                <div class="d-flex justify-content-between align-items-center mt-5">
                                    <a href="/roles" class="btn-form btn-form-cancel">
                                        <i class="bi bi-arrow-left me-2"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn-form btn-form-primary">
                                        <i class="bi bi-save me-2"></i>Guardar Rol
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        const menuItems = document.querySelectorAll('.menu-item');
        const userAvatar = document.querySelector('.user-avatar');
        const userName = 'Administrador';
        userAvatar.textContent = userName.charAt(0);

        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });});
    </script>
    <script src="/publico/js/layout.js?v=1772427290147"></script>
</body>
</html>
