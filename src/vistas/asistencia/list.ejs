<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Asistencias - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290134">
    <link rel="stylesheet" href="/publico/css/list-views.css">
    <link rel="stylesheet" href="/publico/css/asistencia.css">
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-calendar-check"></i>
                        Gestión de Asistencias
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Mensajes flash eliminados (success/error) según solicitud del usuario -->

                <!-- Debug section (temporary) -->
                <% if (asistencias.length > 0 && !asistencias[0].Nombres) { %>
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Advertencia:</strong> Los datos de empleados no se están cargando correctamente. 
                        Verificar que las tablas EMPLEADO y USUARIO tengan datos y estén relacionadas correctamente.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6f42c1, #6610f2);">
                            <i class="bi bi-calendar-check text-white"></i>
                        </div>
                        <h6 class="text-muted">Total Registros</h6>
                        <h3 class="text-primary"><%= asistencias ? asistencias.length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #28a745, #20c997);">
                            <i class="bi bi-check-circle text-white"></i>
                        </div>
                        <h6 class="text-muted">Presentes</h6>
                        <h3 class="text-success"><%= asistencias ? asistencias.filter(a => a.Estado === 'PRESENTE').length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ffc107, #fd7e14);">
                            <i class="bi bi-clock text-white"></i>
                        </div>
                        <h6 class="text-muted">Tardanzas</h6>
                        <h3 class="text-warning"><%= asistencias ? asistencias.filter(a => a.Estado === 'TARDANZA').length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #dc3545, #c82333);">
                            <i class="bi bi-x-circle text-white"></i>
                        </div>
                        <h6 class="text-muted">Ausentes</h6>
                        <h3 class="text-danger"><%= asistencias ? asistencias.filter(a => a.Estado === 'AUSENTE').length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #17a2b8, #138496);">
                            <i class="bi bi-stopwatch text-white"></i>
                        </div>
                        <h6 class="text-muted">Total Horas</h6>
                        <h3 class="text-info">
                            <%= asistencias ? 
                                asistencias.reduce((total, a) => total + (parseFloat(a.HorasTrabajadas) || 0), 0).toFixed(1) : 0 %>h
                        </h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6f42c1, #6610f2);">
                            <i class="bi bi-calendar-plus text-white"></i>
                        </div>
                        <h6 class="text-muted">Días Extra</h6>
                        <h3 class="text-purple"><%= asistencias ? asistencias.filter(a => a.TipoAsistencia === 'EXTRA').length : 0 %></h3>
                    </div>
                </div>

                <% if (asistencias.length === 0) { %>
                    <!-- Estado vacío -->
                    <div class="card-modern">
                        <div class="empty-state">
                            <i class="bi bi-calendar-x empty-state-icon"></i>
                            <h5 class="mt-3">No hay registros de asistencia</h5>
                            <p class="text-muted">Comience registrando una nueva asistencia</p>
                            <a href="/asistencia/create" class="btn btn-primary-modern btn-modern">
                                <i class="bi bi-plus-circle"></i>
                                Registrar Asistencia
                            </a>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Search and Actions -->
                    <div class="search-container">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="search-box flex-grow-1 me-3">
                                <div class="d-flex gap-2">
                                    <select class="form-select" id="campoFiltro" style="max-width: 180px;">
                                        <option value="0">Empleado</option>
                                        <option value="1">Fecha</option>
                                        <option value="2">Entrada</option>
                                        <option value="3">Salida</option>
                                        <option value="4">Horas</option>
                                        <option value="5">Estado</option>
                                        <option value="6">Tipo</option>
                                    </select>
                                    <input type="text" class="form-control" id="valorFiltro" placeholder="Buscar asistencias...">
                                </div>
                            </div>
                            <a href="/asistencia/create" class="btn btn-primary-modern btn-modern">
                                <i class="bi bi-plus-circle"></i>
                                Nueva Asistencia
                            </a>
                        </div>
                    </div>

                    <!-- Tabla de asistencias modernizada -->
                    <div class="card-modern">
                        <div class="table-responsive">
                            <table class="table table-modern mb-0">
                                <thead>
                                    <tr>
                                    <th style="width: 40px;"><input class="form-check-input custom-checkbox" type="checkbox" onchange="toggleAll(this)"></th>
                                    <th><i class="bi bi-person me-1"></i>Empleado</th>
                                        <th><i class="bi bi-calendar-event me-1"></i>Fecha</th>
                                        <th><i class="bi bi-clock-fill me-1"></i>Jornada</th>
                                        <th><i class="bi bi-clock me-1"></i>Entrada</th>
                                        <th><i class="bi bi-clock-history me-1"></i>Salida</th>
                                        <th><i class="bi bi-stopwatch me-1"></i>Horas</th>
                                        <th><i class="bi bi-toggle-on me-1"></i>Estado</th>
                                        <th><i class="bi bi-tag me-1"></i>Tipo</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% asistencias.forEach(asistencia => { %>
                                        <tr>
                                            <td><input class="form-check-input custom-checkbox row-checkbox" type="checkbox"></td>
                                            <td>
                                                <div class="employee-info">
                                                    <div class="item-avatar">
                                                        <%= (asistencia.Nombres && asistencia.Apellidos) ? 
                                                            asistencia.Nombres.charAt(0) + asistencia.Apellidos.charAt(0) : 
                                                            'NN' %>
                                                    </div>
                                                    <div>
                                                        <strong>
                                                            <% if (asistencia.Nombres && asistencia.Apellidos) { %>
                                                                <%= asistencia.Apellidos %>, <%= asistencia.Nombres %>
                                                            <% } else if (asistencia.NombreCompleto) { %>
                                                                <%= asistencia.NombreCompleto %>
                                                            <% } else { %>
                                                                Empleado ID: <%= asistencia.IdEmpleado %>
                                                            <% } %>
                                                        </strong>
                                                        <div class="text-muted small">
                                                            <%= asistencia.Cargo || (asistencia.Area ? asistencia.Area : 'Sin cargo asignado') %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong><%= new Date(asistencia.Fecha).toLocaleDateString('es-PE', { weekday: 'short', day: '2-digit', month: 'short' }) %></strong>
                                                    <div class="text-muted small"><%= new Date(asistencia.Fecha).getFullYear() %></div>
                                                </div>
                                            </td>
                                            <td>
                                                <% if (asistencia.JornadaLaboral) { %>
                                                    <span class="badge badge-modern <%= 
                                                        asistencia.JornadaLaboral === 'COMPLETA' ? 'badge-jornada-completa' : 
                                                        asistencia.JornadaLaboral === 'MEDIO_MANANA' ? 'badge-jornada-manana' : 
                                                        asistencia.JornadaLaboral === 'MEDIO_TARDE' ? 'badge-jornada-tarde' : 
                                                        asistencia.JornadaLaboral === 'NOCTURNO' ? 'badge-jornada-nocturno' : 
                                                        'badge-jornada-personalizado'
                                                    %>">
                                                        <i class="bi <%= 
                                                            asistencia.JornadaLaboral === 'COMPLETA' ? 'bi-sun' : 
                                                            asistencia.JornadaLaboral === 'MEDIO_MANANA' ? 'bi-sunrise' : 
                                                            asistencia.JornadaLaboral === 'MEDIO_TARDE' ? 'bi-sunset' : 
                                                            asistencia.JornadaLaboral === 'NOCTURNO' ? 'bi-moon' : 
                                                            'bi-gear'
                                                        %>"></i>
                                                        <%= 
                                                            asistencia.JornadaLaboral === 'COMPLETA' ? 'Completa' : 
                                                            asistencia.JornadaLaboral === 'MEDIO_MANANA' ? 'Mañana' : 
                                                            asistencia.JornadaLaboral === 'MEDIO_TARDE' ? 'Tarde' : 
                                                            asistencia.JornadaLaboral === 'NOCTURNO' ? 'Nocturno' : 
                                                            'Personalizado'
                                                        %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-muted small">Sin definir</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (asistencia.HoraEntrada) { %>
                                                    <span class="badge badge-modern badge-time">
                                                        <i class="bi bi-clock"></i>
                                                        <%= asistencia.HoraEntrada.slice(0,5) %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-muted small">Sin registrar</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (asistencia.HoraSalida) { %>
                                                    <span class="badge badge-modern badge-time">
                                                        <i class="bi bi-clock-history"></i>
                                                        <%= asistencia.HoraSalida.slice(0,5) %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-muted small">Sin registrar</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (asistencia.HorasTrabajadas && asistencia.HorasTrabajadas > 0) { %>
                                                    <span class="hours-badge">
                                                        <i class="bi bi-stopwatch"></i>
                                                        <%= parseFloat(asistencia.HorasTrabajadas).toFixed(2) %>h
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-muted small">0.00h</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <span class="badge badge-modern <%= 
                                                    asistencia.Estado === 'PRESENTE' ? 'badge-presente' : 
                                                    asistencia.Estado === 'AUSENTE' ? 'badge-ausente' : 
                                                    'badge-tardanza'
                                                %>">
                                                    <i class="bi <%= 
                                                        asistencia.Estado === 'PRESENTE' ? 'bi-check-circle' : 
                                                        asistencia.Estado === 'AUSENTE' ? 'bi-x-circle' : 
                                                        'bi-clock'
                                                    %>"></i>
                                                    <%= asistencia.Estado %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge badge-modern <%= 
                                                    asistencia.TipoAsistencia === 'REGULAR' ? 'badge-regular' : 
                                                    asistencia.TipoAsistencia === 'FERIADO' ? 'badge-feriado' : 
                                                    'badge-extra'
                                                %>">
                                                    <i class="bi <%= 
                                                        asistencia.TipoAsistencia === 'REGULAR' ? 'bi-calendar-day' : 
                                                        asistencia.TipoAsistencia === 'FERIADO' ? 'bi-calendar-heart' : 
                                                        'bi-calendar-plus'
                                                    %>"></i>
                                                    <%= asistencia.TipoAsistencia || 'REGULAR' %>
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="action-buttons justify-content-center">

                                                    <a href="/asistencia/<%= asistencia.IdAsistencia %>/edit" 
                                                       class="btn-action-icon btn-action-edit" 
                                                       title="Editar"
                                                       data-bs-toggle="tooltip">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form action="/asistencia/<%= asistencia.IdAsistencia %>/delete" 
                                                          method="POST" 
                                                          class="d-inline"
                                                          onsubmit="return confirm('¿Está seguro de eliminar este registro?');">
                                                        <button type="submit" 
                                                                class="btn-action-icon btn-action-delete" 
                                                                title="Eliminar"
                                                                data-bs-toggle="tooltip">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                    <% if (asistencia.Observaciones) { %>
                                                        <button class="btn-action-icon btn-action-view" 
                                                                title="Ver observaciones"
                                                                data-bs-toggle="tooltip"
                                                                data-observaciones="<%= asistencia.Observaciones %>"
                                                                onclick="mostrarObservaciones(this)">
                                                            <i class="bi bi-chat-left-text"></i>
                                                        </button>
                                                    <% } %>
                                                </div>
                                            
</div></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {// Inicializar tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        // Filtro único con combo box y campo de texto para asistencias
        const campoFiltro = document.getElementById('campoFiltro');
        const valorFiltro = document.getElementById('valorFiltro');
        if (campoFiltro && valorFiltro) {
            valorFiltro.addEventListener('input', filtrarTabla);
            campoFiltro.addEventListener('change', filtrarTabla);
            
            function filtrarTabla() {
                const col = parseInt(campoFiltro.value);
                const searchTerm = valorFiltro.value.toLowerCase();
                const rows = document.querySelectorAll('tbody tr');
                
                rows.forEach(row => {
                    const cell = row.querySelectorAll('td')[col];
                    if (cell) {
                        if (cell.textContent.toLowerCase().includes(searchTerm)) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    }
                });
            }
        }

        // Función para mostrar observaciones
        function mostrarObservaciones(button) {
            const observaciones = button.getAttribute('data-observaciones');
            alert('Observaciones:\n\n' + observaciones);
        }
    </script>
    <script src="/publico/js/layout.js?v=1772427290134"></script>
</body>
</html>
