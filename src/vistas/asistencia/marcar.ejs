<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marcar Asistencia - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=<%= Date.now() %>">
    <style>
        .time-display {
            font-size: 5rem;
            font-weight: 300;
            line-height: 1;
            letter-spacing: -2px;
            font-variant-numeric: tabular-nums;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .date-display {
            font-size: 1.25rem;
            font-weight: 500;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        .punch-card {
            background: linear-gradient(145deg, #ffffff, #f8f9fa);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 1.5rem;
            padding: 3rem 2rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
            margin-bottom: 2rem;
        }

        .punch-action-container {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            margin-top: 2rem;
        }

        .btn-punch {
            flex: 1;
            max-width: 250px;
            padding: 1.25rem 1.5rem;
            border-radius: 1rem;
            font-size: 1.1rem;
            font-weight: 600;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            border: none;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .btn-punch-in {
            background: var(--text-primary);
            color: white;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        }

        .btn-punch-in:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.15);
            background: #000;
        }

        .btn-punch-out {
            background: white;
            color: var(--text-primary);
            border: 1px solid rgba(0, 0, 0, 0.1);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
        }

        .btn-punch-out:hover:not(:disabled) {
            transform: translateY(-2px);
            border-color: rgba(0, 0, 0, 0.2);
            box-shadow: 0 8px 12px rgba(0, 0, 0, 0.05);
        }

        .btn-punch:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
            background: var(--bg-page);
            color: var(--text-muted);
            border: 1px solid var(--border);
        }

        .punch-time-badge {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 0.9rem;
            padding: 0.25rem 0.75rem;
            background: rgba(0, 0, 0, 0.06);
            border-radius: 0.5rem;
            font-weight: 500;
        }

        .btn-punch-in .punch-time-badge {
            background: rgba(255, 255, 255, 0.15);
        }

        .avatar-large {
            width: 80px;
            height: 80px;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 1.5rem;
        }

        .history-card {
            background: white;
            border-radius: 1rem;
            border: 1px solid var(--border-light);
            overflow: hidden;
        }

        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border-light);
            font-size: 0.95rem;
        }

        .history-item:last-child {
            border-bottom: none;
        }

        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .dot-in {
            background-color: var(--success);
        }

        .dot-out {
            background-color: var(--warning);
        }

        .alert-domingo {
            background: #fffbeb;
            border: 1px solid #fde68a;
            color: #92400e;
            padding: 1.5rem;
            border-radius: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 500;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-clock-history"></i>
                            Registro de Asistencia
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= empleado.NombreCompleto %>
                            </span>
                            <div class="user-avatar"><i class="bi bi-person"></i></div>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid py-4" style="max-width: 900px; margin: 0 auto;">

                    <% if (messages.success && messages.success.length> 0) { %>
                        <div class="alert alert-success d-flex align-items-center mb-4" role="alert"
                            style="border-radius: 1rem; border: none; background: #dcfce7; color: #166534;">
                            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
                            <div>
                                <%= messages.success[0] %>
                            </div>
                        </div>
                        <% } %>

                            <% if (messages.error && messages.error.length> 0) { %>
                                <div class="alert alert-danger d-flex align-items-center mb-4" role="alert"
                                    style="border-radius: 1rem; border: none; background: #fee2e2; color: #991b1b;">
                                    <i class="bi bi-exclamation-circle-fill fs-4 me-3"></i>
                                    <div>
                                        <%= messages.error[0] %>
                                    </div>
                                </div>
                                <% } %>

                                    <div class="row g-4">
                                        <div class="col-lg-7">
                                            <div class="punch-card">
                                                <div class="avatar-large">
                                                    <i class="bi bi-person-badge"></i>
                                                </div>
                                                <h4 class="fw-bold mb-1">
                                                    <%= empleado.NombreCompleto %>
                                                </h4>
                                                <p class="text-muted mb-4">
                                                    <%= empleado.Cargo || 'Empleado' %> • <%= empleado.Area
                                                            || 'Sin Área' %>
                                                </p>

                                                <div class="time-display" id="horaDisplay">00:00</div>
                                                <div class="date-display" id="fechaDisplay">Cargando...</div>

                                                <% if (esDomingo) { %>
                                                    <div class="alert-domingo justify-content-center mx-auto"
                                                        style="max-width: 400px;">
                                                        <i class="bi bi-calendar-x fs-4"></i>
                                                        <div>No hay marcado de asistencia los domingos.</div>
                                                    </div>
                                                    <% } else { %>
                                                        <div class="punch-action-container">
                                                            <form action="/asistencia/marcar-entrada" method="POST"
                                                                style="margin: 0; flex: 1;">
                                                                <button type="submit"
                                                                    class="btn-punch btn-punch-in w-100" <%=registroHoy
                                                                    ? 'disabled' : '' %>>
                                                                    <span><i
                                                                            class="bi bi-box-arrow-in-right mb-1 fs-4"></i><br>Entrada</span>
                                                                    <span class="punch-time-badge">
                                                                        <%= registroHoy && registroHoy.HoraEntrada ?
                                                                            registroHoy.HoraEntrada.slice(0,5) : '--:--'
                                                                            %>
                                                                    </span>
                                                                </button>
                                                            </form>

                                                            <form action="/asistencia/marcar-salida" method="POST"
                                                                style="margin: 0; flex: 1;">
                                                                <button type="submit"
                                                                    class="btn-punch btn-punch-out w-100"
                                                                    <%=!registroHoy || registroHoy.HoraSalida
                                                                    ? 'disabled' : '' %>>
                                                                    <span><i
                                                                            class="bi bi-box-arrow-right mb-1 fs-4"></i><br>Salida</span>
                                                                    <span class="punch-time-badge">
                                                                        <%= registroHoy && registroHoy.HoraSalida ?
                                                                            registroHoy.HoraSalida.slice(0,5) : '--:--'
                                                                            %>
                                                                    </span>
                                                                </button>
                                                            </form>
                                                        </div>
                                                        <% } %>
                                            </div>
                                        </div>

                                        <div class="col-lg-5">
                                            <h6 class="text-uppercase text-muted fw-bold mb-3"
                                                style="letter-spacing: 1px; font-size: 0.85rem;"><i
                                                    class="bi bi-journal-check me-2"></i>Historial Reciente</h6>
                                            <div class="history-card">
                                                <% if (historialReciente && historialReciente.length> 0) { %>
                                                    <% historialReciente.slice(0, 6).forEach(registro=> {
                                                        const fecha = new Date(registro.Fecha);
                                                        const fechaFormat = fecha.toLocaleDateString('es-PE', { weekday:
                                                        'short', day: '2-digit', month: 'short' });
                                                        %>
                                                        <div class="history-item">
                                                            <span class="fw-medium text-capitalize">
                                                                <%= fechaFormat %>
                                                            </span>
                                                            <div class="d-flex gap-3 text-muted font-monospace"
                                                                style="font-size: 0.9rem;">
                                                                <span title="Entrada"><span
                                                                        class="status-dot dot-in"></span>
                                                                    <%= registro.HoraEntrada ?
                                                                        registro.HoraEntrada.slice(0,5) : '--:--' %>
                                                                </span>
                                                                <span title="Salida"><span
                                                                        class="status-dot dot-out"></span>
                                                                    <%= registro.HoraSalida ?
                                                                        registro.HoraSalida.slice(0,5) : '--:--' %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <% }); %>
                                                            <% } else { %>
                                                                <div class="p-4 text-center text-muted">
                                                                    <i class="bi bi-inbox fs-2 mb-2"></i>
                                                                    <p class="mb-0">No hay registros recientes</p>
                                                                </div>
                                                                <% } %>
                                            </div>

                                            <!-- Logout para kiosko -->
                                            <div class="mt-4 text-center">
                                                <a href="/logout"
                                                    class="text-muted text-decoration-none d-inline-flex align-items-center gap-2 hover-danger"
                                                    style="font-size: 0.95rem; font-weight: 500;">
                                                    <i class="bi bi-box-arrow-left"></i> Cerrar Sesión Segura
                                                </a>
                                            </div>
                                        </div>
                                    </div>

                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function actualizarReloj() {
            const ahora = new Date();

            const dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            const meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];

            document.getElementById('fechaDisplay').textContent =
                dias[ahora.getDay()] + ', ' + ahora.getDate() + ' de ' + meses[ahora.getMonth()];

            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');

            document.getElementById('horaDisplay').textContent =
                horas + ':' + minutos;
        }

        actualizarReloj();
        setInterval(actualizarReloj, 10000);
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>