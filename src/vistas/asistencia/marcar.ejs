<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Marcar Asistencia - CARSIL</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        :root {
            --bg: #0d1117;
            --bg-card: #161b22;
            --bg-card-hover: #1c2230;
            --border: rgba(255, 255, 255, 0.08);
            --border-light: rgba(255, 255, 255, 0.04);
            --accent: #137fec;
            --accent-glow: rgba(19, 127, 236, 0.3);
            --accent-light: rgba(19, 127, 236, 0.12);
            --success: #2ea043;
            --success-glow: rgba(46, 160, 67, 0.25);
            --warning: #e3b341;
            --warning-bg: rgba(227, 179, 65, 0.12);
            --text-primary: #e6edf3;
            --text-secondary: #7d8590;
            --text-muted: #484f58;
            --white: #ffffff;
            --danger: #f85149;
            --danger-bg: rgba(248, 81, 73, 0.12);
        }

        html,
        body {
            height: 100%;
            background: var(--bg);
            color: var(--text-primary);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            overflow-x: hidden;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            min-height: 100dvh;
        }

        /* ─── TOP BAR ─── */
        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border);
            background: rgba(13, 17, 23, 0.95);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .company-name {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.4rem 0.75rem;
            border-radius: 0.5rem;
            border: 1px solid var(--border);
            background: transparent;
            transition: all 0.2s ease;
        }

        .logout-btn:hover,
        .logout-btn:active {
            color: var(--danger);
            border-color: rgba(248, 81, 73, 0.4);
            background: var(--danger-bg);
        }

        /* ─── MAIN SCROLL AREA ─── */
        .scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem 1.25rem 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        /* ─── ALERTS ─── */
        .alert-banner {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 0.875rem 1rem;
            border-radius: 0.875rem;
            font-size: 0.875rem;
            font-weight: 500;
            animation: slideIn 0.3s ease;
        }

        .alert-banner.success {
            background: rgba(46, 160, 67, 0.15);
            border: 1px solid rgba(46, 160, 67, 0.3);
            color: #4caf7d;
        }

        .alert-banner.error {
            background: var(--danger-bg);
            border: 1px solid rgba(248, 81, 73, 0.3);
            color: #ff6b6b;
        }

        .alert-icon {
            font-size: 1.1rem;
            flex-shrink: 0;
            margin-top: 0.05rem;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ─── PROFILE CARD ─── */
        .profile-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 1.25rem;
            padding: 1.75rem 1.5rem;
            text-align: center;
        }

        .employee-avatar {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, var(--accent-light), rgba(19, 127, 236, 0.2));
            border: 2px solid var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            color: var(--accent);
            margin: 0 auto 1rem;
            box-shadow: 0 0 20px var(--accent-glow);
        }

        .employee-name {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 0.3rem;
        }

        .employee-role {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .role-dot {
            display: inline-block;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--text-muted);
            margin: 0 0.4rem;
            vertical-align: middle;
        }

        /* ─── CLOCK ─── */
        .clock-section {
            text-align: center;
            padding: 0.5rem 0;
        }

        .clock-time {
            font-size: 4.5rem;
            font-weight: 300;
            letter-spacing: -3px;
            font-variant-numeric: tabular-nums;
            color: var(--white);
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .clock-time span.clock-separator {
            animation: blink 1s step-end infinite;
            opacity: 1;
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.2;
            }
        }

        .clock-date {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-secondary);
            letter-spacing: 0.02em;
        }

        /* ─── SUNDAY ALERT ─── */
        .sunday-alert {
            background: var(--warning-bg);
            border: 1px solid rgba(227, 179, 65, 0.3);
            border-radius: 1rem;
            padding: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.875rem;
            color: var(--warning);
            font-weight: 500;
            font-size: 0.9rem;
        }

        .sunday-alert-icon {
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        /* ─── PUNCH BUTTONS ─── */
        .punch-buttons {
            display: flex;
            flex-direction: column;
            gap: 0.875rem;
        }

        .btn-punch {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            padding: 1.125rem 1.375rem;
            border-radius: 1rem;
            border: none;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
            min-height: 72px;
            position: relative;
            overflow: hidden;
        }

        .btn-punch::before {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0);
            transition: background 0.2s ease;
        }

        .btn-punch:active::before {
            background: rgba(255, 255, 255, 0.08);
        }

        .btn-punch-left {
            display: flex;
            align-items: center;
            gap: 0.875rem;
        }

        .btn-punch-icon {
            width: 42px;
            height: 42px;
            border-radius: 0.625rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .btn-punch-text {
            text-align: left;
        }

        .btn-punch-label {
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .btn-punch-sublabel {
            font-size: 0.75rem;
            font-weight: 400;
            opacity: 0.7;
            margin-top: 0.15rem;
        }

        .btn-punch-time {
            font-size: 1.1rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.5px;
            font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        }

        /* ENTRADA button */
        .btn-entrada {
            background: linear-gradient(135deg, var(--accent), #0f6fd4);
            color: var(--white);
            box-shadow: 0 4px 20px var(--accent-glow);
        }

        .btn-entrada:not(:disabled):hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 28px var(--accent-glow);
        }

        .btn-entrada .btn-punch-icon {
            background: rgba(255, 255, 255, 0.15);
            color: white;
        }

        /* SALIDA button */
        .btn-salida {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        .btn-salida:not(:disabled):hover {
            background: var(--bg-card-hover);
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-1px);
        }

        .btn-salida .btn-punch-icon {
            background: rgba(255, 255, 255, 0.06);
            color: var(--text-secondary);
        }

        /* DISABLED state */
        .btn-punch:disabled {
            opacity: 0.35;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        /* ─── STATUS SUMMARY ─── */
        .status-summary {
            display: flex;
            gap: 0.75rem;
        }

        .status-pill {
            flex: 1;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 0.875rem;
            padding: 0.875rem 1rem;
            text-align: center;
        }

        .status-pill-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 0.3rem;
        }

        .status-pill-value {
            font-size: 1.1rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        }

        .status-pill-value.in {
            color: #4caf7d;
        }

        .status-pill-value.out {
            color: var(--warning);
        }

        .status-pill-value.empty {
            color: var(--text-muted);
        }

        /* ─── HISTORY SECTION ─── */
        .history-section {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 1.25rem;
            overflow: hidden;
        }

        .history-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border-light);
        }

        .history-title {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .history-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.875rem 1.25rem;
            border-bottom: 1px solid var(--border-light);
            transition: background 0.15s ease;
        }

        .history-item:last-child {
            border-bottom: none;
        }

        .history-date {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-primary);
            text-transform: capitalize;
        }

        .history-times {
            display: flex;
            align-items: center;
            gap: 0.875rem;
        }

        .history-time {
            display: flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.85rem;
            font-family: ui-monospace, 'SF Mono', Menlo, monospace;
            font-weight: 500;
        }

        .history-time-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .history-time-dot.in {
            background: var(--success);
        }

        .history-time-dot.out {
            background: var(--warning);
        }

        .history-time.in {
            color: #7d8590;
        }

        .history-time.out {
            color: #7d8590;
        }

        .history-empty {
            padding: 2rem 1.25rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .history-empty i {
            font-size: 2rem;
            display: block;
            margin-bottom: 0.5rem;
        }
    </style>
</head>

<body>

    <!-- TOP BAR -->
    <div class="top-bar">
        <span class="company-name">CARSIL Servicios</span>
        <a href="/logout" class="logout-btn">
            <i class="bi bi-box-arrow-left"></i>
            Salir
        </a>
    </div>

    <!-- MAIN SCROLL AREA -->
    <div class="scroll-area">

        <!-- ALERTS -->
        <% if (messages.success && messages.success.length> 0) { %>
            <div class="alert-banner success">
                <i class="bi bi-check-circle-fill alert-icon"></i>
                <span>
                    <%= messages.success[0] %>
                </span>
            </div>
            <% } %>

                <% if (messages.error && messages.error.length> 0) { %>
                    <div class="alert-banner error">
                        <i class="bi bi-exclamation-circle-fill alert-icon"></i>
                        <span>
                            <%= messages.error[0] %>
                        </span>
                    </div>
                    <% } %>

                        <!-- PROFILE CARD -->
                        <div class="profile-card">
                            <div class="employee-avatar">
                                <i class="bi bi-person-badge"></i>
                            </div>
                            <div class="employee-name">
                                <%= empleado.NombreCompleto %>
                            </div>
                            <div class="employee-role">
                                <%= empleado.Cargo || 'Empleado' %><span class="role-dot"></span>
                                    <%= empleado.Area || 'Sin Área' %>
                            </div>
                        </div>

                        <!-- CLOCK -->
                        <div class="clock-section">
                            <div class="clock-time" id="horaDisplay">
                                <span id="horaH">00</span><span class="clock-separator">:</span><span
                                    id="horaM">00</span>
                            </div>
                            <div class="clock-date" id="fechaDisplay">Cargando...</div>
                        </div>

                        <!-- ESTADO DOMINICAL -->
                        <% if (esDomingo) { %>
                            <div class="sunday-alert">
                                <i class="bi bi-calendar-x sunday-alert-icon"></i>
                                <div>
                                    <strong>Día de descanso</strong><br>
                                    No se registra asistencia los domingos.
                                </div>
                            </div>
                            <% } else { %>

                                <!-- STATUS SUMMARY -->
                                <div class="status-summary">
                                    <div class="status-pill">
                                        <div class="status-pill-label"><i class="bi bi-box-arrow-in-right"></i> Entrada
                                        </div>
                                        <div
                                            class="status-pill-value <%= registroHoy && registroHoy.HoraEntrada ? 'in' : 'empty' %>">
                                            <%= registroHoy && registroHoy.HoraEntrada ?
                                                registroHoy.HoraEntrada.slice(0,5) : '--:--' %>
                                        </div>
                                    </div>
                                    <div class="status-pill">
                                        <div class="status-pill-label"><i class="bi bi-box-arrow-right"></i> Salida
                                        </div>
                                        <div
                                            class="status-pill-value <%= registroHoy && registroHoy.HoraSalida ? 'out' : 'empty' %>">
                                            <%= registroHoy && registroHoy.HoraSalida ?
                                                registroHoy.HoraSalida.slice(0,5) : '--:--' %>
                                        </div>
                                    </div>
                                </div>

                                <!-- PUNCH BUTTONS -->
                                <div class="punch-buttons">
                                    <form action="/asistencia/marcar-entrada" method="POST" style="margin:0">
                                        <button type="submit" class="btn-punch btn-entrada" <%=registroHoy ? 'disabled'
                                            : '' %>>
                                            <div class="btn-punch-left">
                                                <div class="btn-punch-icon">
                                                    <i class="bi bi-box-arrow-in-right"></i>
                                                </div>
                                                <div class="btn-punch-text">
                                                    <div class="btn-punch-label">MARCAR ENTRADA</div>
                                                    <div class="btn-punch-sublabel">
                                                        <%= registroHoy && registroHoy.HoraEntrada ? 'Registrada a las '
                                                            + registroHoy.HoraEntrada.slice(0,5) : 'Toca para registrar'
                                                            %>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="btn-punch-time">
                                                <%= registroHoy && registroHoy.HoraEntrada ?
                                                    registroHoy.HoraEntrada.slice(0,5) : '' %>
                                                    <% if (!(registroHoy && registroHoy.HoraEntrada)) { %>
                                                        <i class="bi bi-chevron-right"
                                                            style="font-size:1rem; opacity:0.7;"></i>
                                                        <% } %>
                                            </div>
                                        </button>
                                    </form>

                                    <form action="/asistencia/marcar-salida" method="POST" style="margin:0">
                                        <button type="submit" class="btn-punch btn-salida" <%=!registroHoy ||
                                            registroHoy.HoraSalida ? 'disabled' : '' %>>
                                            <div class="btn-punch-left">
                                                <div class="btn-punch-icon">
                                                    <i class="bi bi-box-arrow-right"></i>
                                                </div>
                                                <div class="btn-punch-text">
                                                    <div class="btn-punch-label">MARCAR SALIDA</div>
                                                    <div class="btn-punch-sublabel">
                                                        <%= registroHoy && registroHoy.HoraSalida ? 'Registrada a las '
                                                            + registroHoy.HoraSalida.slice(0,5) : (!registroHoy
                                                            ? 'Primero registra tu entrada' : 'Toca para registrar' ) %>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="btn-punch-time">
                                                <%= registroHoy && registroHoy.HoraSalida ?
                                                    registroHoy.HoraSalida.slice(0,5) : '' %>
                                                    <% if (!(registroHoy && registroHoy.HoraSalida) && registroHoy) { %>
                                                        <i class="bi bi-chevron-right"
                                                            style="font-size:1rem; opacity:0.7;"></i>
                                                        <% } %>
                                            </div>
                                        </button>
                                    </form>
                                </div>

                                <% } %>

                                    <!-- HISTORIAL RECIENTE -->
                                    <div class="history-section">
                                        <div class="history-header">
                                            <i class="bi bi-journal-check"
                                                style="color: var(--text-muted); font-size:0.875rem;"></i>
                                            <span class="history-title">Historial Reciente</span>
                                        </div>

                                        <% if (historialReciente && historialReciente.length> 0) { %>
                                            <% historialReciente.slice(0, 7).forEach(registro=> {
                                                const fecha = new Date(registro.Fecha);
                                                const fechaFormat = fecha.toLocaleDateString('es-PE', { weekday:
                                                'short', day: '2-digit', month: 'short' });
                                                %>
                                                <div class="history-item">
                                                    <span class="history-date">
                                                        <%= fechaFormat %>
                                                    </span>
                                                    <div class="history-times">
                                                        <span class="history-time in">
                                                            <span class="history-time-dot in"></span>
                                                            <%= registro.HoraEntrada ? registro.HoraEntrada.slice(0,5)
                                                                : '--:--' %>
                                                        </span>
                                                        <span class="history-time out">
                                                            <span class="history-time-dot out"></span>
                                                            <%= registro.HoraSalida ? registro.HoraSalida.slice(0,5)
                                                                : '--:--' %>
                                                        </span>
                                                    </div>
                                                </div>
                                                <% }); %>
                                                    <% } else { %>
                                                        <div class="history-empty">
                                                            <i class="bi bi-inbox"></i>
                                                            No hay registros recientes
                                                        </div>
                                                        <% } %>
                                    </div>

    </div><!-- end scroll-area -->

    <script>
        function actualizarReloj() {
            const ahora = new Date();

            const dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            const meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];

            document.getElementById('fechaDisplay').textContent =
                dias[ahora.getDay()] + ', ' + ahora.getDate() + ' de ' + meses[ahora.getMonth()];

            const hH = document.getElementById('horaH');
            const hM = document.getElementById('horaM');
            if (hH) hH.textContent = String(ahora.getHours()).padStart(2, '0');
            if (hM) hM.textContent = String(ahora.getMinutes()).padStart(2, '0');
        }

        actualizarReloj();
        setInterval(actualizarReloj, 1000);

        // Auto-dismiss alerts
        setTimeout(() => {
            document.querySelectorAll('.alert-banner').forEach(el => {
                el.style.transition = 'opacity 0.5s ease, max-height 0.5s ease, margin 0.5s ease';
                el.style.opacity = '0';
                el.style.maxHeight = '0';
                el.style.overflow = 'hidden';
                el.style.marginBottom = '0';
            });
        }, 4000);
    </script>

</body>

</html>