<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Asistencia - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#3b4bc9",
                        "background-light": "#f6f6f8",
                    },
                    fontFamily: { "display": ["Inter"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
    </style>
</head>
<body class="bg-[#f6f6f8] text-slate-900">
<div class="wrapper">
    <%- include("../parciales/sidebar") %>

    <div class="main-content" id="main-content">

        <!-- Content -->
        <div class="p-8">
            <!-- Page Title -->
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Editar Asistencia</h2>
                <p class="text-slate-500">Actualice los detalles de la jornada laboral del colaborador.</p>
            </div>

            <!-- Card -->
            <div class="bg-white w-full max-w-3xl mx-auto rounded-xl shadow-lg overflow-hidden border border-slate-200">

                <!-- Card Header -->
                <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
                    <div>
                        <h3 class="text-xl font-bold text-slate-900 tracking-tight">Editar Registro de Asistencia</h3>
                        <p class="text-slate-500 text-sm mt-1">Actualice los detalles de la jornada laboral del colaborador.</p>
                    </div>
                    <a href="/asistencia"
                       class="text-slate-400 hover:text-slate-600 transition-colors">
                        <span class="material-symbols-outlined">close</span>
                    </a>
                </div>

                <!-- Card Body -->
                <form action="/asistencia/<%= asistencia.IdAsistencia %>" method="POST">
                    <input type="hidden" name="_method" value="PUT">

                    <div class="px-8 py-6 space-y-8">

                        <!-- Empleado Info -->
                        <div class="flex items-center gap-5 p-4 bg-slate-50 rounded-lg border border-slate-100">
                            <div class="h-16 w-16 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] border-2 border-[#3b4bc9]/20 text-xl font-bold flex-shrink-0">
                                <% if (asistencia.Nombres && asistencia.Apellidos) { %>
                                    <%= asistencia.Nombres.charAt(0) %><%= asistencia.Apellidos.charAt(0) %>
                                <% } else { %>
                                    NN
                                <% } %>
                            </div>
                            <div>
                                <span class="text-lg font-bold text-slate-900 leading-tight block">
                                    <% if (asistencia.Nombres && asistencia.Apellidos) { %>
                                        <%= asistencia.Apellidos %>, <%= asistencia.Nombres %>
                                    <% } else { %>
                                        Empleado #<%= asistencia.IdEmpleado %>
                                    <% } %>
                                </span>
                                <div class="flex items-center gap-3 mt-1">
                                    <span class="text-xs font-semibold px-2 py-0.5 bg-slate-200 text-slate-600 rounded uppercase tracking-wider">
                                        ID: EMP-<%= asistencia.IdEmpleado %>
                                    </span>
                                    <% if (asistencia.Cargo || asistencia.Area) { %>
                                    <span class="text-xs font-medium text-slate-500">
                                        • <%= asistencia.Cargo || asistencia.Area %>
                                    </span>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <!-- Form Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                            <!-- Fecha -->
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[#3b4bc9] text-lg">calendar_today</span>
                                    Fecha de Registro
                                </label>
                                <input type="date" id="Fecha" name="Fecha"
                                       value="<%= new Date(asistencia.Fecha).toISOString().split('T')[0] %>"
                                       readonly
                                       class="w-full rounded-lg border border-slate-200 bg-slate-50 text-slate-500 px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#3b4bc9]/30 focus:border-[#3b4bc9] outline-none cursor-not-allowed">
                            </div>

                            <!-- Jornada -->
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[#3b4bc9] text-lg">schedule</span>
                                    Asignar Turno
                                </label>
                                <select id="JornadaLaboral" name="JornadaLaboral" required
                                        class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#3b4bc9]/30 focus:border-[#3b4bc9] outline-none">
                                    <option value="">Seleccione la jornada laboral</option>
                                    <option value="COMPLETA" data-entrada="08:00" data-salida="17:00" data-tolerancia="08:30"
                                        <%= asistencia.JornadaLaboral === 'COMPLETA' ? 'selected' : '' %>>
                                        Tiempo Completo (8:00 AM - 5:00 PM)
                                    </option>
                                    <option value="MEDIO_MANANA" data-entrada="08:00" data-salida="12:00" data-tolerancia="08:30"
                                        <%= asistencia.JornadaLaboral === 'MEDIO_MANANA' ? 'selected' : '' %>>
                                        Medio Tiempo Mañana (8:00 AM - 12:00 PM)
                                    </option>
                                    <option value="MEDIO_TARDE" data-entrada="13:00" data-salida="17:50" data-tolerancia="13:30"
                                        <%= asistencia.JornadaLaboral === 'MEDIO_TARDE' ? 'selected' : '' %>>
                                        Medio Tiempo Tarde (1:00 PM - 5:50 PM)
                                    </option>
                                    <option value="NOCTURNO" data-entrada="22:00" data-salida="06:00" data-tolerancia="22:30"
                                        <%= asistencia.JornadaLaboral === 'NOCTURNO' ? 'selected' : '' %>>
                                        Turno Nocturno (10:00 PM - 6:00 AM)
                                    </option>
                                    <option value="PERSONALIZADO"
                                        <%= asistencia.JornadaLaboral === 'PERSONALIZADO' ? 'selected' : '' %>>
                                        Personalizado
                                    </option>
                                </select>
                            </div>

                            <!-- Hora Entrada -->
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[#3b4bc9] text-lg">login</span>
                                    Hora de Entrada
                                </label>
                                <input type="time" id="HoraEntrada" name="HoraEntrada"
                                       value="<%= asistencia.HoraEntrada ? asistencia.HoraEntrada.slice(0,5) : '' %>"
                                       class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#3b4bc9]/30 focus:border-[#3b4bc9] outline-none">
                                <p class="text-xs text-slate-400">Se autocompleta según la jornada</p>
                            </div>

                            <!-- Hora Salida -->
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[#3b4bc9] text-lg">logout</span>
                                    Hora de Salida
                                </label>
                                <input type="time" id="HoraSalida" name="HoraSalida"
                                       value="<%= asistencia.HoraSalida ? asistencia.HoraSalida.slice(0,5) : '' %>"
                                       class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#3b4bc9]/30 focus:border-[#3b4bc9] outline-none">
                                <p class="text-xs text-slate-400">Se autocompleta según la jornada</p>
                            </div>
                        </div>

                        <!-- Horas calculadas -->
                        <div id="horasCalculadasInfo" class="hidden flex items-center gap-3 px-4 py-3 bg-[#3b4bc9]/5 border border-[#3b4bc9]/20 rounded-lg text-sm text-[#3b4bc9]">
                            <span class="material-symbols-outlined text-lg">timer</span>
                            <span>Total trabajado: <strong id="horasCalculadas">0.00</strong> horas</span>
                            <span class="text-xs text-slate-400 ml-1">— calculado automáticamente</span>
                        </div>

                        <!-- Tipo de Asistencia -->
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[#3b4bc9] text-lg">label</span>
                                Tipo de Asistencia
                            </label>
                            <select id="TipoAsistencia" name="TipoAsistencia" required
                                    class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#3b4bc9]/30 focus:border-[#3b4bc9] outline-none">
                                <option value="REGULAR" <%= asistencia.TipoAsistencia === 'REGULAR' ? 'selected' : '' %>>Regular</option>
                                <option value="FERIADO" <%= asistencia.TipoAsistencia === 'FERIADO' ? 'selected' : '' %>>Feriado</option>
                                <option value="EXTRA" <%= asistencia.TipoAsistencia === 'EXTRA' ? 'selected' : '' %>>Extra</option>
                            </select>
                        </div>

                        <!-- Estado -->
                        <div class="flex flex-col gap-3">
                            <label class="text-sm font-semibold text-slate-700">Estado de Asistencia</label>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

                                <!-- Presente -->
                                <label class="cursor-pointer group">
                                    <input class="peer hidden" type="radio" name="Estado" value="PRESENTE"
                                           <%= asistencia.Estado === 'PRESENTE' ? 'checked' : '' %>>
                                    <div class="flex flex-col items-center justify-center p-3 rounded-lg border-2 border-slate-100 bg-slate-50 peer-checked:border-emerald-500 peer-checked:bg-emerald-50 transition-all">
                                        <span class="material-symbols-outlined text-emerald-500 mb-1">check_circle</span>
                                        <span class="text-xs font-bold text-slate-600 group-hover:text-emerald-600">Presente</span>
                                    </div>
                                </label>

                                <!-- Tardanza -->
                                <label class="cursor-pointer group">
                                    <input class="peer hidden" type="radio" name="Estado" value="TARDANZA"
                                           <%= asistencia.Estado === 'TARDANZA' ? 'checked' : '' %>>
                                    <div class="flex flex-col items-center justify-center p-3 rounded-lg border-2 border-slate-100 bg-slate-50 peer-checked:border-amber-500 peer-checked:bg-amber-50 transition-all">
                                        <span class="material-symbols-outlined text-amber-500 mb-1">history</span>
                                        <span class="text-xs font-bold text-slate-600 group-hover:text-amber-600">Tardanza</span>
                                    </div>
                                </label>

                                <!-- Ausente -->
                                <label class="cursor-pointer group">
                                    <input id="EstadoAusente" class="peer hidden" type="radio" name="Estado" value="AUSENTE"
                                           <%= asistencia.Estado === 'AUSENTE' ? 'checked' : '' %>>
                                    <div class="flex flex-col items-center justify-center p-3 rounded-lg border-2 border-slate-100 bg-slate-50 peer-checked:border-rose-500 peer-checked:bg-rose-50 transition-all">
                                        <span class="material-symbols-outlined text-rose-500 mb-1">cancel</span>
                                        <span class="text-xs font-bold text-slate-600 group-hover:text-rose-600">Ausente</span>
                                    </div>
                                </label>

                                <!-- Justificado -->
                                <label class="cursor-pointer group">
                                    <input class="peer hidden" type="radio" name="Estado" value="JUSTIFICADO"
                                           <%= asistencia.Estado === 'JUSTIFICADO' ? 'checked' : '' %>>
                                    <div class="flex flex-col items-center justify-center p-3 rounded-lg border-2 border-slate-100 bg-slate-50 peer-checked:border-[#3b4bc9] peer-checked:bg-[#3b4bc9]/5 transition-all">
                                        <span class="material-symbols-outlined text-[#3b4bc9] mb-1">description</span>
                                        <span class="text-xs font-bold text-slate-600 group-hover:text-[#3b4bc9]">Justificado</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Info jornada -->
                            <div id="jornadaInfo" class="hidden flex items-center gap-2 text-xs text-[#3b4bc9] mt-1">
                                <span class="material-symbols-outlined text-base">info</span>
                                <span id="jornadaDetalles"></span>
                            </div>

                            <!-- Aviso ausente -->
                            <p id="observacionesRequeridas" class="hidden text-xs text-rose-600 flex items-center gap-1">
                                <span class="material-symbols-outlined text-base">warning</span>
                                Las observaciones son obligatorias cuando el empleado está ausente.
                            </p>
                        </div>

                        <!-- Observaciones -->
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[#3b4bc9] text-lg">chat</span>
                                Observaciones
                                <span class="text-xs font-normal text-slate-400 ml-1">Opcional</span>
                            </label>
                            <textarea id="Observaciones" name="Observaciones" rows="3"
                                      placeholder="Ingrese el motivo de la tardanza o cualquier observación relevante..."
                                      class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#3b4bc9]/30 focus:border-[#3b4bc9] outline-none resize-none"><%= asistencia.Observaciones || '' %></textarea>
                        </div>

                    </div><!-- /px-8 py-6 -->

                    <!-- Footer -->
                    <div class="px-8 py-5 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row gap-3 justify-end">
                        <a href="/asistencia"
                           class="px-6 py-2.5 rounded-lg border border-slate-300 text-slate-700 font-semibold text-sm hover:bg-slate-100 transition-colors text-center">
                            Cancelar
                        </a>
                        <button type="submit"
                                class="px-6 py-2.5 rounded-lg bg-[#3b4bc9] text-white font-semibold text-sm hover:bg-[#3b4bc9]/90 shadow-lg shadow-[#3b4bc9]/25 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">save</span>
                            Guardar Cambios
                        </button>
                    </div>

                </form>
            </div><!-- /card -->
        </div><!-- /p-8 -->
    </div><!-- /main-content -->
</div><!-- /wrapper -->

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const jornadaSelect = document.getElementById('JornadaLaboral');
        const horaEntrada = document.getElementById('HoraEntrada');
        const horaSalida = document.getElementById('HoraSalida');
        const jornadaInfo = document.getElementById('jornadaInfo');
        const jornadaDetalles = document.getElementById('jornadaDetalles');
        const horasCalculadasInfo = document.getElementById('horasCalculadasInfo');
        const horasCalculadas = document.getElementById('horasCalculadas');

        const jornadas = {
            'COMPLETA':     { entrada: '08:00', salida: '17:00', tolerancia: '08:30' },
            'MEDIO_MANANA': { entrada: '08:00', salida: '12:00', tolerancia: '08:30' },
            'MEDIO_TARDE':  { entrada: '13:00', salida: '17:50', tolerancia: '13:30' },
            'NOCTURNO':     { entrada: '22:00', salida: '06:00', tolerancia: '22:30' }
        };

        jornadaSelect.addEventListener('change', function () {
            const jornada = jornadas[this.value];
            if (jornada) {
                horaEntrada.value = jornada.entrada;
                horaSalida.value = jornada.salida;
                jornadaInfo.classList.remove('hidden');
                jornadaInfo.classList.add('flex');
                jornadaDetalles.textContent = `Entrada: ${jornada.entrada} | Salida: ${jornada.salida} | Tolerancia: ${jornada.tolerancia}`;
                calcularHoras();
            } else if (this.value === 'PERSONALIZADO') {
                jornadaInfo.classList.add('hidden');
                jornadaInfo.classList.remove('flex');
                calcularHoras();
            } else {
                jornadaInfo.classList.add('hidden');
                jornadaInfo.classList.remove('flex');
                horasCalculadasInfo.classList.add('hidden');
                horasCalculadasInfo.classList.remove('flex');
            }
        });

        function calcularHoras() {
            const entrada = horaEntrada.value;
            const salida = horaSalida.value;
            if (entrada && salida) {
                const [hE, mE] = entrada.split(':').map(Number);
                const [hS, mS] = salida.split(':').map(Number);
                let mins = hS < hE
                    ? (24 - hE) * 60 - mE + hS * 60 + mS
                    : (hS - hE) * 60 + (mS - mE);
                horasCalculadas.textContent = (mins / 60).toFixed(2);
                horasCalculadasInfo.classList.remove('hidden');
                horasCalculadasInfo.classList.add('flex');
            } else {
                horasCalculadasInfo.classList.add('hidden');
                horasCalculadasInfo.classList.remove('flex');
            }
        }

        horaEntrada.addEventListener('change', calcularHoras);
        horaSalida.addEventListener('change', calcularHoras);
        calcularHoras();

        // Mostrar info jornada al cargar
        if (jornadaSelect.value && jornadas[jornadaSelect.value]) {
            const j = jornadas[jornadaSelect.value];
            jornadaInfo.classList.remove('hidden');
            jornadaInfo.classList.add('flex');
            jornadaDetalles.textContent = `Entrada: ${j.entrada} | Salida: ${j.salida} | Tolerancia: ${j.tolerancia}`;
        }

        // Auto estado según entrada
        horaEntrada.addEventListener('change', function () {
            const j = jornadas[jornadaSelect.value];
            if (j && horaEntrada.value) {
                const radio = horaEntrada.value <= j.tolerancia
                    ? document.querySelector('input[value="PRESENTE"]')
                    : document.querySelector('input[value="TARDANZA"]');
                if (radio) radio.checked = true;
            }
        });

        // Observaciones requeridas si Ausente
        const estadoInputs = document.querySelectorAll('input[name="Estado"]');
        const obsInput = document.getElementById('Observaciones');
        const obsReq = document.getElementById('observacionesRequeridas');

        function toggleAusente() {
            const ausente = document.getElementById('EstadoAusente').checked;
            if (ausente) {
                obsReq.classList.remove('hidden');
                obsReq.classList.add('flex');
                obsInput.setAttribute('required', 'required');
                horaEntrada.value = '';
                horaSalida.value = '';
                horasCalculadasInfo.classList.add('hidden');
                horasCalculadasInfo.classList.remove('flex');
            } else {
                obsReq.classList.add('hidden');
                obsReq.classList.remove('flex');
                obsInput.removeAttribute('required');
                if (jornadaSelect.value && jornadas[jornadaSelect.value]) {
                    const j = jornadas[jornadaSelect.value];
                    horaEntrada.value = j.entrada;
                    horaSalida.value = j.salida;
                    calcularHoras();
                }
            }
        }

        estadoInputs.forEach(i => i.addEventListener('change', toggleAusente));
        toggleAusente();

        // Validación submit
        document.querySelector('form').addEventListener('submit', function (e) {
            if (document.getElementById('EstadoAusente').checked && !obsInput.value.trim()) {
                e.preventDefault();
                alert('Debe ingresar una observación cuando el estado es AUSENTE');
                obsInput.focus();
                return;
            }
            if (!jornadaSelect.value) {
                e.preventDefault();
                alert('Debe seleccionar un tipo de jornada laboral');
                jornadaSelect.focus();
            }
        });
    });
</script>
<script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>
</html>
