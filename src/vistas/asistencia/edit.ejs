<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Asistencia - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290133">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290133">
    
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        <!-- Botón para ocultar/mostrar barra -->
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
                <div class="container-fluid">
                    <span class="navbar-brand ms-3">Panel de Control</span>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>
            <div class="container py-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="card-title mb-0">Editar Asistencia</h5>
                    </div>
                    <div class="card-body">
                        <!-- Mensaje de error eliminado según solicitud del usuario -->
                        <form action="/asistencia/<%= asistencia.IdAsistencia %>" method="POST">
                            <input type="hidden" name="_method" value="PUT">
                            <div class="form-section">
                                <h6 class="form-section-title"><i class="bi bi-info-circle me-2"></i> Información de la Asistencia</h6>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Empleado</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                                            <input type="text" class="form-control-modern" value="<%= asistencia.Apellidos %>, <%= asistencia.Nombres %>" readonly>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="Fecha" class="form-label">Fecha</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                                            <input type="date" class="form-control-modern" id="Fecha" name="Fecha" value="<%= new Date(asistencia.Fecha).toISOString().split('T')[0] %>" readonly>
                                        </div>
                                    </div>
                                </div>
                                <!-- Jornada Laboral -->
                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        <div class="form-group-header">
                                                <label for="JornadaLaboral" class="form-label">Jornada Laboral</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <select class="form-control-modern form-select-modern" id="JornadaLaboral" name="JornadaLaboral" required>
                                                <option value="">Seleccione la jornada laboral</option>
                                                <option value="COMPLETA" data-entrada="08:00" data-salida="17:00" data-tolerancia="08:30" <%= asistencia.JornadaLaboral === 'COMPLETA' ? 'selected' : '' %>>Tiempo Completo (8:00 AM - 5:00 PM)</option>
                                                <option value="MEDIO_MANANA" data-entrada="08:00" data-salida="12:00" data-tolerancia="08:30" <%= asistencia.JornadaLaboral === 'MEDIO_MANANA' ? 'selected' : '' %>>Medio Tiempo Mañana (8:00 AM - 12:00 PM)</option>
                                                <option value="MEDIO_TARDE" data-entrada="13:00" data-salida="17:50" data-tolerancia="13:30" <%= asistencia.JornadaLaboral === 'MEDIO_TARDE' ? 'selected' : '' %>>Medio Tiempo Tarde (1:00 PM - 5:50 PM)</option>
                                                <option value="NOCTURNO" data-entrada="22:00" data-salida="06:00" data-tolerancia="22:30" <%= asistencia.JornadaLaboral === 'NOCTURNO' ? 'selected' : '' %>>Turno Nocturno (10:00 PM - 6:00 AM)</option>
                                                <option value="PERSONALIZADO" data-entrada="" data-salida="" data-tolerancia="" <%= asistencia.JornadaLaboral === 'PERSONALIZADO' ? 'selected' : '' %>>Personalizado</option>
                                            </select>
                                                    <i class="input-icon bi bi-clock-fill"></i>
                                                </div>
                                        <div class="form-text">Seleccione el tipo de jornada para autocompletar horarios</div>
                                    </div>
                                </div>
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label for="HoraEntrada" class="form-label">Hora de Entrada</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-clock"></i></span>
                                        <input type="time" class="form-control-modern" id="HoraEntrada" name="HoraEntrada" value="<%= asistencia.HoraEntrada ? asistencia.HoraEntrada.slice(0,5) : '' %>">
                                    </div>
                                    <div class="form-text">Se autocompleta según la jornada seleccionada</div>
                                </div>
                                <div class="col-md-4">
                                    <label for="HoraSalida" class="form-label">Hora de Salida</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-clock-history"></i></span>
                                        <input type="time" class="form-control-modern" id="HoraSalida" name="HoraSalida" value="<%= asistencia.HoraSalida ? asistencia.HoraSalida.slice(0,5) : '' %>">
                                    </div>
                                    <div class="form-text">Se autocompleta según la jornada seleccionada</div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group-header">
                                                <label for="TipoAsistencia" class="form-label">Tipo de Asistencia</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <select class="form-control-modern form-select-modern" id="TipoAsistencia" name="TipoAsistencia" required>
                                            <option value="REGULAR" <%= asistencia.TipoAsistencia === 'REGULAR' ? 'selected' : '' %>>Regular</option>
                                            <option value="FERIADO" <%= asistencia.TipoAsistencia === 'FERIADO' ? 'selected' : '' %>>Feriado</option>
                                            <option value="EXTRA" <%= asistencia.TipoAsistencia === 'EXTRA' ? 'selected' : '' %>>Extra</option>
                                        </select>
                                                    <i class="input-icon bi bi-tag"></i>
                                                </div>
                                </div>
                            </div>
                                
                                <!-- Información de horas calculadas -->
                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        <div class="alert alert-info d-none" id="horasCalculadasInfo">
                                            <h6><i class="bi bi-calculator me-2"></i>Horas Trabajadas Calculadas</h6>
                                            <div class="d-flex align-items-center gap-3">
                                                <span>Total: <strong id="horasCalculadas">0.00</strong> horas</span>
                                                <small class="text-muted">Se calcula automáticamente al registrar entrada y salida</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="form-label">Estado de Asistencia</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-flag"></i></span>
                                        <div class="d-flex gap-4 align-items-center ms-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="Estado" 
                                                       id="EstadoPresente" value="PRESENTE" <%= asistencia.Estado === 'PRESENTE' ? 'checked' : '' %>>
                                                <label class="form-check-label text-success fw-semibold" for="EstadoPresente">
                                                    <i class="bi bi-check-circle me-1"></i>Presente
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="Estado" 
                                                       id="EstadoTardanza" value="TARDANZA" <%= asistencia.Estado === 'TARDANZA' ? 'checked' : '' %>>
                                                <label class="form-check-label text-warning fw-semibold" for="EstadoTardanza">
                                                    <i class="bi bi-clock me-1"></i>Tardanza
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="Estado" 
                                                       id="EstadoAusente" value="AUSENTE" <%= asistencia.Estado === 'AUSENTE' ? 'checked' : '' %>>
                                                <label class="form-check-label text-danger fw-semibold" for="EstadoAusente">
                                                    <i class="bi bi-x-circle me-1"></i>Ausente
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-text mt-2">
                                        <small id="estadoInfo">
                                            <strong>Presente:</strong> Llegó a tiempo según su jornada |
                                            <strong>Tardanza:</strong> Llegó tarde según su jornada |
                                            <strong>Ausente:</strong> No asistió
                                        </small>
                                        <div id="jornadaInfo" class="mt-1 text-primary d-none">
                                            <i class="bi bi-info-circle me-1"></i>
                                            <span id="jornadaDetalles"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                                <div class="mb-3">
                                    <div class="form-group-header">
                                                <label for="Observaciones" class="form-label">Observaciones</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <textarea class="form-control-modern" id="Observaciones" name="Observaciones" rows="3" placeholder="Ingrese observaciones adicionales..."><%= asistencia.Observaciones || '' %></textarea>
                                                    <i class="input-icon bi bi-chat-left-text"></i>
                                                </div>
                                    <div class="form-text">
                                        <span id="observacionesRequeridas" class="text-danger d-none">
                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                            Las observaciones son obligatorias cuando el empleado está ausente
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2">
                                <a href="/asistencia" class="btn btn-form btn-form-cancel"><i class="bi bi-x-circle me-1"></i>Cancelar</a>
                                <button type="submit" class="btn-form btn-form-primary btn-form-primary"><i class="bi bi-save me-1"></i>Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        const menuItems = document.querySelectorAll('.menu-item');
        const userAvatar = document.querySelector('.user-avatar');
        const userName = '<%= user && user.Nombres ? user.Nombres : "Administrador" %>';
        if(userAvatar) userAvatar.textContent = userName.charAt(0);

        if(toggleBtn) toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });// Manejar cambio de jornada laboral
        const jornadaSelect = document.getElementById('JornadaLaboral');
        const horaEntrada = document.getElementById('HoraEntrada');
        const horaSalida = document.getElementById('HoraSalida');
        const jornadaInfo = document.getElementById('jornadaInfo');
        const jornadaDetalles = document.getElementById('jornadaDetalles');
        const horasCalculadasInfo = document.getElementById('horasCalculadasInfo');
        const horasCalculadas = document.getElementById('horasCalculadas');

        // Definir horarios para cada jornada
        const jornadas = {
            'COMPLETA': { entrada: '08:00', salida: '17:00', tolerancia: '08:30' },
            'MEDIO_MANANA': { entrada: '08:00', salida: '12:00', tolerancia: '08:30' },
            'MEDIO_TARDE': { entrada: '13:00', salida: '17:50', tolerancia: '13:30' },
            'NOCTURNO': { entrada: '22:00', salida: '06:00', tolerancia: '22:30' }
        };

        // Manejar cambio de jornada
        if (jornadaSelect) {
            jornadaSelect.addEventListener('change', function() {
                const jornada = jornadas[this.value];
                
                if (jornada) {
                    horaEntrada.value = jornada.entrada;
                    horaSalida.value = jornada.salida;
                    
                    // Mostrar información de la jornada
                    jornadaInfo.classList.remove('d-none');
                    jornadaDetalles.textContent = `Entrada: ${jornada.entrada}, Salida: ${jornada.salida}, Tolerancia hasta: ${jornada.tolerancia}`;
                    
                    // Calcular horas automáticamente
                    calcularHoras();
                } else if (this.value === 'PERSONALIZADO') {
                    jornadaInfo.classList.add('d-none');
                    calcularHoras(); // Calcular con las horas actuales
                } else {
                    jornadaInfo.classList.add('d-none');
                    horasCalculadasInfo.classList.add('d-none');
                }
            });
        }

        // Función para calcular horas trabajadas
        function calcularHoras() {
            const entrada = horaEntrada.value;
            const salida = horaSalida.value;

            if (entrada && salida) {
                const [horaE, minE] = entrada.split(':').map(Number);
                const [horaS, minS] = salida.split(':').map(Number);
                
                let totalMinutos = 0;
                
                // Manejar turnos nocturnos (cuando salida es al día siguiente)
                if (horaS < horaE) {
                    // Turno nocturno
                    totalMinutos = (24 - horaE) * 60 - minE + horaS * 60 + minS;
                } else {
                    // Turno normal
                    totalMinutos = (horaS - horaE) * 60 + (minS - minE);
                }
                
                const horas = (totalMinutos / 60).toFixed(2);
                horasCalculadas.textContent = horas;
                horasCalculadasInfo.classList.remove('d-none');
            } else {
                horasCalculadasInfo.classList.add('d-none');
            }
        }

        // Calcular horas cuando se cambien manualmente
        horaEntrada.addEventListener('change', calcularHoras);
        horaSalida.addEventListener('change', calcularHoras);

        // Calcular horas al cargar la página
        calcularHoras();

        // Mostrar información de jornada al cargar si hay una seleccionada
        if (jornadaSelect.value && jornadas[jornadaSelect.value]) {
            const jornada = jornadas[jornadaSelect.value];
            jornadaInfo.classList.remove('d-none');
            jornadaDetalles.textContent = `Entrada: ${jornada.entrada}, Salida: ${jornada.salida}, Tolerancia hasta: ${jornada.tolerancia}`;
        }

        // Validación mejorada considerando la jornada
        function validarAsistencia() {
            const jornada = jornadas[jornadaSelect.value];
            const entrada = horaEntrada.value;
            
            if (jornada && entrada) {
                const estadoPresente = document.getElementById('EstadoPresente');
                const estadoTardanza = document.getElementById('EstadoTardanza');
                
                if (entrada <= jornada.tolerancia) {
                    estadoPresente.checked = true;
                } else {
                    estadoTardanza.checked = true;
                }
            }
        }

        // Validar estado al cambiar hora de entrada
        horaEntrada.addEventListener('change', validarAsistencia);

        // Validar que si el estado es AUSENTE, se ingrese una observación
        const form = document.querySelector('form');
        const estadoInputs = document.querySelectorAll('input[name="Estado"]');
        const observacionesInput = document.getElementById('Observaciones');
        const observacionesRequeridas = document.getElementById('observacionesRequeridas');

        // Función para mostrar/ocultar el mensaje de observaciones requeridas
        function toggleObservacionesRequeridas() {
            const estadoAusente = document.getElementById('EstadoAusente').checked;
            if (estadoAusente) {
                observacionesRequeridas.classList.remove('d-none');
                observacionesInput.setAttribute('required', 'required');
                // Limpiar horas cuando está ausente
                horaEntrada.value = '';
                horaSalida.value = '';
                horasCalculadasInfo.classList.add('d-none');
            } else {
                observacionesRequeridas.classList.add('d-none');
                observacionesInput.removeAttribute('required');
                // Restaurar horas de la jornada seleccionada
                if (jornadaSelect.value && jornadas[jornadaSelect.value]) {
                    const jornada = jornadas[jornadaSelect.value];
                    horaEntrada.value = jornada.entrada;
                    horaSalida.value = jornada.salida;
                    calcularHoras();
                }
            }
        }

        // Escuchar cambios en los radio buttons del estado
        estadoInputs.forEach(input => {
            input.addEventListener('change', toggleObservacionesRequeridas);
        });

        // Ejecutar al cargar la página
        toggleObservacionesRequeridas();

        form.addEventListener('submit', function(e) {
            const estadoAusente = document.getElementById('EstadoAusente').checked;
            const observaciones = observacionesInput.value.trim();
            
            if (estadoAusente && !observaciones) {
                e.preventDefault();
                alert('Debe ingresar una observación cuando el estado es AUSENTE');
                observacionesInput.focus();
                return;
            }

            // Validar que se haya seleccionado una jornada
            if (!jornadaSelect.value) {
                e.preventDefault();
                alert('Debe seleccionar un tipo de jornada laboral');
                jornadaSelect.focus();
                return;
            }
        });
    });
    </script>
    <script src="/publico/js/layout.js?v=1772427290133"></script>
</body>
</html>
