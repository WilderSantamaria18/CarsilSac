<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Asistencia - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=<%= Date.now() %>">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-calendar-check"></i>
                            Editar Asistencia
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="form-container">
                    <div class="form-card">
                        <div class="form-header-title">
                            <i class="bi bi-pencil-square"></i> Editar Asistencia
                        </div>

                        <div class="form-body">
                            <form action="/asistencia/<%= asistencia.IdAsistencia %>" method="POST">
                                <input type="hidden" name="_method" value="PUT">

                                <!-- Información de la Asistencia -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-info-circle"></i> Información de la Asistencia
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="form-label"><i class="bi bi-person"></i> Empleado</label>
                                                <input type="text" class="form-control-modern"
                                                    value="<%= asistencia.Apellidos %>, <%= asistencia.Nombres %>"
                                                    readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Fecha" class="form-label"><i class="bi bi-calendar"></i>
                                                    Fecha</label>
                                                <input type="date" class="form-control-modern" id="Fecha" name="Fecha"
                                                    value="<%= new Date(asistencia.Fecha).toISOString().split('T')[0] %>"
                                                    readonly>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Jornada y Horarios -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-clock"></i> Jornada y Horarios
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label for="JornadaLaboral" class="form-label"><i
                                                        class="bi bi-clock-fill"></i> Jornada Laboral</label>
                                                <select class="form-control-modern form-select-modern"
                                                    id="JornadaLaboral" name="JornadaLaboral" required>
                                                    <option value="">Seleccione la jornada laboral</option>
                                                    <option value="COMPLETA" data-entrada="08:00" data-salida="17:00"
                                                        data-tolerancia="08:30"
                                                        <%=asistencia.JornadaLaboral==='COMPLETA' ? 'selected' : '' %>
                                                        >Tiempo Completo (8:00 AM - 5:00 PM)</option>
                                                    <option value="MEDIO_MANANA" data-entrada="08:00"
                                                        data-salida="12:00" data-tolerancia="08:30"
                                                        <%=asistencia.JornadaLaboral==='MEDIO_MANANA' ? 'selected' : ''
                                                        %>>Medio Tiempo Mañana (8:00 AM - 12:00 PM)</option>
                                                    <option value="MEDIO_TARDE" data-entrada="13:00" data-salida="17:50"
                                                        data-tolerancia="13:30"
                                                        <%=asistencia.JornadaLaboral==='MEDIO_TARDE' ? 'selected' : ''
                                                        %>>Medio Tiempo Tarde (1:00 PM - 5:50 PM)</option>
                                                    <option value="NOCTURNO" data-entrada="22:00" data-salida="06:00"
                                                        data-tolerancia="22:30"
                                                        <%=asistencia.JornadaLaboral==='NOCTURNO' ? 'selected' : '' %>
                                                        >Turno Nocturno (10:00 PM - 6:00 AM)</option>
                                                    <option value="PERSONALIZADO" data-entrada="" data-salida=""
                                                        data-tolerancia=""
                                                        <%=asistencia.JornadaLaboral==='PERSONALIZADO' ? 'selected' : ''
                                                        %>>Personalizado</option>
                                                </select>
                                                <small class="form-text text-muted">Seleccione el tipo de jornada para
                                                    autocompletar horarios</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="HoraEntrada" class="form-label"><i class="bi bi-clock"></i>
                                                    Hora de Entrada</label>
                                                <input type="time" class="form-control-modern" id="HoraEntrada"
                                                    name="HoraEntrada"
                                                    value="<%= asistencia.HoraEntrada ? asistencia.HoraEntrada.slice(0,5) : '' %>">
                                                <small class="form-text text-muted">Se autocompleta según la
                                                    jornada</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="HoraSalida" class="form-label"><i
                                                        class="bi bi-clock-history"></i> Hora de Salida</label>
                                                <input type="time" class="form-control-modern" id="HoraSalida"
                                                    name="HoraSalida"
                                                    value="<%= asistencia.HoraSalida ? asistencia.HoraSalida.slice(0,5) : '' %>">
                                                <small class="form-text text-muted">Se autocompleta según la
                                                    jornada</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="TipoAsistencia" class="form-label"><i class="bi bi-tag"></i>
                                                    Tipo de Asistencia</label>
                                                <select class="form-control-modern form-select-modern"
                                                    id="TipoAsistencia" name="TipoAsistencia" required>
                                                    <option value="REGULAR" <%=asistencia.TipoAsistencia==='REGULAR'
                                                        ? 'selected' : '' %>>Regular</option>
                                                    <option value="FERIADO" <%=asistencia.TipoAsistencia==='FERIADO'
                                                        ? 'selected' : '' %>>Feriado</option>
                                                    <option value="EXTRA" <%=asistencia.TipoAsistencia==='EXTRA'
                                                        ? 'selected' : '' %>>Extra</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Estado y Observaciones -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-flag"></i> Estado y Observaciones
                                    </h5>
                                    <div class="row g-3">
                                        <!-- Horas calculadas -->
                                        <div class="col-md-12">
                                            <div class="alert alert-info d-none" id="horasCalculadasInfo"
                                                style="border-radius: 0.75rem;">
                                                <h6><i class="bi bi-calculator me-2"></i>Horas Trabajadas Calculadas
                                                </h6>
                                                <div class="d-flex align-items-center gap-3">
                                                    <span>Total: <strong id="horasCalculadas">0.00</strong> horas</span>
                                                    <small class="text-muted">Se calcula automáticamente</small>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label"><i class="bi bi-flag"></i> Estado de
                                                    Asistencia</label>
                                                <div class="d-flex gap-4 align-items-center mt-2">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="Estado"
                                                            id="EstadoPresente" value="PRESENTE"
                                                            <%=asistencia.Estado==='PRESENTE' ? 'checked' : '' %>>
                                                        <label class="form-check-label text-success fw-semibold"
                                                            for="EstadoPresente">
                                                            <i class="bi bi-check-circle me-1"></i>Presente
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="Estado"
                                                            id="EstadoTardanza" value="TARDANZA"
                                                            <%=asistencia.Estado==='TARDANZA' ? 'checked' : '' %>>
                                                        <label class="form-check-label text-warning fw-semibold"
                                                            for="EstadoTardanza">
                                                            <i class="bi bi-clock me-1"></i>Tardanza
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="Estado"
                                                            id="EstadoAusente" value="AUSENTE"
                                                            <%=asistencia.Estado==='AUSENTE' ? 'checked' : '' %>>
                                                        <label class="form-check-label text-danger fw-semibold"
                                                            for="EstadoAusente">
                                                            <i class="bi bi-x-circle me-1"></i>Ausente
                                                        </label>
                                                    </div>
                                                </div>
                                                <div class="form-text mt-2">
                                                    <small id="estadoInfo">
                                                        <strong>Presente:</strong> Llegó a tiempo |
                                                        <strong>Tardanza:</strong> Llegó tarde |
                                                        <strong>Ausente:</strong> No asistió
                                                    </small>
                                                    <div id="jornadaInfo" class="mt-1 text-primary d-none">
                                                        <i class="bi bi-info-circle me-1"></i>
                                                        <span id="jornadaDetalles"></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label for="Observaciones" class="form-label">
                                                    <i class="bi bi-chat-left-text"></i> Observaciones
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <textarea class="form-control-modern" id="Observaciones"
                                                    name="Observaciones" rows="3"
                                                    placeholder="Ingrese observaciones adicionales..."><%= asistencia.Observaciones || '' %></textarea>
                                                <div class="form-text">
                                                    <span id="observacionesRequeridas" class="text-danger d-none">
                                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                                        Las observaciones son obligatorias cuando el empleado está
                                                        ausente
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-buttons">
                                    <a href="/asistencia" class="btn btn-form btn-form-cancel">
                                        <i class="bi bi-x-circle me-2"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-form-primary">
                                        <i class="bi bi-save me-2"></i> Guardar Cambios
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const jornadaSelect = document.getElementById('JornadaLaboral');
            const horaEntrada = document.getElementById('HoraEntrada');
            const horaSalida = document.getElementById('HoraSalida');
            const jornadaInfo = document.getElementById('jornadaInfo');
            const jornadaDetalles = document.getElementById('jornadaDetalles');
            const horasCalculadasInfo = document.getElementById('horasCalculadasInfo');
            const horasCalculadas = document.getElementById('horasCalculadas');

            const jornadas = {
                'COMPLETA': { entrada: '08:00', salida: '17:00', tolerancia: '08:30' },
                'MEDIO_MANANA': { entrada: '08:00', salida: '12:00', tolerancia: '08:30' },
                'MEDIO_TARDE': { entrada: '13:00', salida: '17:50', tolerancia: '13:30' },
                'NOCTURNO': { entrada: '22:00', salida: '06:00', tolerancia: '22:30' }
            };

            if (jornadaSelect) {
                jornadaSelect.addEventListener('change', function () {
                    const jornada = jornadas[this.value];
                    if (jornada) {
                        horaEntrada.value = jornada.entrada;
                        horaSalida.value = jornada.salida;
                        jornadaInfo.classList.remove('d-none');
                        jornadaDetalles.textContent = `Entrada: ${jornada.entrada}, Salida: ${jornada.salida}, Tolerancia hasta: ${jornada.tolerancia}`;
                        calcularHoras();
                    } else if (this.value === 'PERSONALIZADO') {
                        jornadaInfo.classList.add('d-none');
                        calcularHoras();
                    } else {
                        jornadaInfo.classList.add('d-none');
                        horasCalculadasInfo.classList.add('d-none');
                    }
                });
            }

            function calcularHoras() {
                const entrada = horaEntrada.value;
                const salida = horaSalida.value;
                if (entrada && salida) {
                    const [horaE, minE] = entrada.split(':').map(Number);
                    const [horaS, minS] = salida.split(':').map(Number);
                    let totalMinutos = 0;
                    if (horaS < horaE) {
                        totalMinutos = (24 - horaE) * 60 - minE + horaS * 60 + minS;
                    } else {
                        totalMinutos = (horaS - horaE) * 60 + (minS - minE);
                    }
                    const horas = (totalMinutos / 60).toFixed(2);
                    horasCalculadas.textContent = horas;
                    horasCalculadasInfo.classList.remove('d-none');
                } else {
                    horasCalculadasInfo.classList.add('d-none');
                }
            }

            horaEntrada.addEventListener('change', calcularHoras);
            horaSalida.addEventListener('change', calcularHoras);
            calcularHoras();

            // Show jornada info on load
            if (jornadaSelect.value && jornadas[jornadaSelect.value]) {
                const jornada = jornadas[jornadaSelect.value];
                jornadaInfo.classList.remove('d-none');
                jornadaDetalles.textContent = `Entrada: ${jornada.entrada}, Salida: ${jornada.salida}, Tolerancia hasta: ${jornada.tolerancia}`;
            }

            function validarAsistencia() {
                const jornada = jornadas[jornadaSelect.value];
                const entrada = horaEntrada.value;
                if (jornada && entrada) {
                    if (entrada <= jornada.tolerancia) {
                        document.getElementById('EstadoPresente').checked = true;
                    } else {
                        document.getElementById('EstadoTardanza').checked = true;
                    }
                }
            }

            horaEntrada.addEventListener('change', validarAsistencia);

            const form = document.querySelector('form');
            const estadoInputs = document.querySelectorAll('input[name="Estado"]');
            const observacionesInput = document.getElementById('Observaciones');
            const observacionesRequeridas = document.getElementById('observacionesRequeridas');

            function toggleObservacionesRequeridas() {
                const estadoAusente = document.getElementById('EstadoAusente').checked;
                if (estadoAusente) {
                    observacionesRequeridas.classList.remove('d-none');
                    observacionesInput.setAttribute('required', 'required');
                    horaEntrada.value = '';
                    horaSalida.value = '';
                    horasCalculadasInfo.classList.add('d-none');
                } else {
                    observacionesRequeridas.classList.add('d-none');
                    observacionesInput.removeAttribute('required');
                    if (jornadaSelect.value && jornadas[jornadaSelect.value]) {
                        const jornada = jornadas[jornadaSelect.value];
                        horaEntrada.value = jornada.entrada;
                        horaSalida.value = jornada.salida;
                        calcularHoras();
                    }
                }
            }

            estadoInputs.forEach(input => {
                input.addEventListener('change', toggleObservacionesRequeridas);
            });

            toggleObservacionesRequeridas();

            form.addEventListener('submit', function (e) {
                const estadoAusente = document.getElementById('EstadoAusente').checked;
                const observaciones = observacionesInput.value.trim();
                if (estadoAusente && !observaciones) {
                    e.preventDefault();
                    alert('Debe ingresar una observación cuando el estado es AUSENTE');
                    observacionesInput.focus();
                    return;
                }
                if (!jornadaSelect.value) {
                    e.preventDefault();
                    alert('Debe seleccionar un tipo de jornada laboral');
                    jornadaSelect.focus();
                    return;
                }
            });
        });
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>