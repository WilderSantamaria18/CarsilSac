                        <span>Facturas</span>
                    </a>
                    <% } %>

                        <% if (user && tienePermiso(user, 'clientes' )) { %>
                            <a href="/clientes" class="sidebar-item" data-page="clientes">
                                <i class="bi bi-people"></i>
                                <span>Clientes</span>
                            </a>
                            <% } %>

                                <% if (user && tienePermiso(user, 'productos' )) { %>
                                    <a href="/productos" class="sidebar-item" data-page="productos">
                                        <i class="bi bi-box"></i>
                                        <span>Productos</span>
                                    </a>
                                    <% } %>

                                        <div class="sidebar-section-label">RECURSOS HUMANOS</div>

                                        <% if (user && tienePermiso(user, 'empleados' )) { %>
                                            <a href="/empleados" class="sidebar-item" data-page="empleados">
                                                <i class="bi bi-person-badge"></i>
                                                <span>Empleados</span>
                                            </a>
                                            <% } %>

                                                <% if (user && tienePermiso(user, 'pagos' )) { %>
                                                    <a href="/pagos" class="sidebar-item" data-page="pagos">
                                                        <i class="bi bi-wallet2"></i>
                                                        <span>Pagos</span>
                                                    </a>
                                                    <% } %>

                                                        <% if (user && tienePermiso(user, 'asistencias' )) { %>
                                                            <a href="/asistencia" class="sidebar-item"
                                                                data-page="asistencias">
                                                                <i class="bi bi-calendar-check"></i>
                                                                <span>Asistencias</span>
                                                            </a>
                                                            <% } %>

                                                                <div class="sidebar-section-label">
                                                                    ADMINISTRACION</div>

                                                                <% if (user && tienePermiso(user, 'reportes' )) { %>
                                                                    <a href="/reportes" class="sidebar-item"
                                                                        data-page="reportes">
                                                                        <i class="bi bi-bar-chart-line"></i>
                                                                        <span>Reportes</span>
                                                                    </a>
                                                                    <% } %>

                                                                        <% if (user && tienePermiso(user, 'usuarios' ))
                                                                            { %>
                                                                            <a href="/usuarios" class="sidebar-item"
                                                                                data-page="usuarios">
                                                                                <i class="bi bi-shield-check"></i>
                                                                                <span>Usuarios</span>
                                                                            </a>
                                                                            <% } %>

                                                                                <% if (user &&
                                                                                    tienePermiso(user, 'empresa' )) { %>
                                                                                    <a href="/empresa"
                                                                                        class="sidebar-item"
                                                                                        data-page="empresa">
                                                                                        <i class="bi bi-gear"></i>
                                                                                        <span>Empresa</span>
                                                                                    </a>
                                                                                    <% } %>
    </div>

    <div class="sidebar-footer" style="padding: 1rem; border-top: 1px solid rgba(0,0,0,0.05); margin-top: auto;">

        <% if (user && user.IdRol !==2) { %>
            <div class="user-profile-mini"
                style="display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.5rem; padding: 0.5rem; border-radius: 0.5rem; background-color: #f8fafc; border: 1px solid #f1f5f9; position: relative;">

                <div style="display: flex; align-items: center; gap: 0.75rem; overflow: hidden; cursor: pointer; transition: opacity 0.2s;"
                    onclick="toggleUserModal()" onmouseover="this.style.opacity='0.8'"
                    onmouseout="this.style.opacity='1'" title="Ver perfil y tiempo de sesión">
                    <div class="avatar-mini"
                        style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem; flex-shrink: 0; box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.2);">
                        <%= user.Nombres ? user.Nombres.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <div class="user-info-mini"
                        style="overflow: hidden; display: flex; flex-direction: column; justify-content: center;">
                        <span
                            style="font-size: 0.85rem; font-weight: 700; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.2;">
                            <%= user.Nombres %>
                                <%= user.Apellidos %>
                        </span>
                    </div>
                </div>

                <!-- Botón de Notificaciones -->
                <a href="/notificaciones" class="notif-badge"
                    style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background-color: #f1f5f9; color: #64748b; transition: all 0.2s; position: relative;"
                    title="Notificaciones"
                    onmouseover="this.style.backgroundColor='#e2e8f0'; this.style.color='#0f172a'"
                    onmouseout="this.style.backgroundColor='#f1f5f9'; this.style.color='#64748b'">
                    <i class="bi bi-bell-fill" style="font-size: 0.9rem;"></i>
