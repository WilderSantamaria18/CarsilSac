</nav>

<!-- Modal de Perfil con Glassmorphism -->
<% if (user) { %>
    <div id="userProfileModal"
        style="display: none; position: fixed; inset: 0; z-index: 9999; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;">
        <!-- Fondo oscuro semitransparente -->
        <div style="position: absolute; inset: 0; background-color: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px);"
            onclick="toggleUserModal()"></div>

        <!-- Contenido del modal (Glassmorphism) -->
        <div
            style="position: relative; width: 100%; max-width: 24rem; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.4); border-radius: 1.5rem; padding: 2rem; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255,255,255,0.5) inset; transform: translateY(20px); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); text-align: center;">

            <!-- Botón cerrar -->
            <button onclick="toggleUserModal()"
                style="position: absolute; top: 1rem; right: 1rem; width: 32px; height: 32px; border-radius: 50%; border: none; background: rgba(0,0,0,0.05); color: #64748b; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s;"
                onmouseover="this.style.background='rgba(0,0,0,0.1)'; this.style.color='#0f172a'"
                onmouseout="this.style.background='rgba(0,0,0,0.05)'; this.style.color='#64748b'">
                <i class="bi bi-x-lg" style="font-size: 1rem;"></i>
            </button>

            <!-- Avatar Grande -->
            <div
                style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 2.25rem; margin: 0 auto 1.25rem; box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4), 0 8px 10px -6px rgba(59, 130, 246, 0.1); border: 4px solid white;">
                <%= user.Nombres ? user.Nombres.charAt(0).toUpperCase() : 'U' %>
            </div>

            <h3 style="margin: 0 0 0.25rem 0; font-size: 1.25rem; font-weight: 800; color: #0f172a; line-height: 1.2;">
                <%= user.Nombres %>
                    <%= user.Apellidos %>
            </h3>

            <p style="margin: 0 0 1rem 0; color: #64748b; font-size: 0.95rem; font-weight: 500;">
                <%= user.Correo %>
            </p>

            <div
                style="display: inline-flex; align-items: center; gap: 0.5rem; background: #f1f5f9; padding: 0.35rem 1rem; border-radius: 9999px; margin-bottom: 2rem;">
                <i class="bi bi-shield-check text-blue-600" style="color: #2563eb;"></i>
                <span
                    style="font-size: 0.8rem; font-weight: 700; color: #334155; text-transform: uppercase; letter-spacing: 0.05em;">
                    <%= user.RolNombre || (user.IdRol===1 ? 'Administrador' : (user.IdRol===3 ? 'Supervisor'
                        : 'Empleado' )) %>
                </span>
            </div>

            <!-- Tarjetas de Info -->
            <div style="display: grid; grid-template-columns: 1fr; gap: 0.75rem; text-align: left;">

                <!-- Tiempo Activo -->
                <div
                    style="background: rgba(255,255,255,0.6); border: 1px solid rgba(0,0,0,0.05); border-radius: 1rem; padding: 1rem; display: flex; align-items: center; gap: 1rem;">
                    <div
                        style="width: 40px; height: 40px; border-radius: 0.75rem; background: #ecfdf5; color: #10b981; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <p
                            style="margin: 0; font-size: 0.75rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.025em;">
                            Tiempo en el Sistema</p>
                        <p style="margin: 0; font-size: 1.125rem; font-weight: 800; color: #0f172a; font-variant-numeric: tabular-nums;"
                            id="sessionTimer">00:00:00</p>
                    </div>
                </div>

                <!-- Limite inactividad -->
                <div
                    style="background: rgba(255,255,255,0.6); border: 1px solid rgba(0,0,0,0.05); border-radius: 1rem; padding: 1rem; display: flex; align-items: center; gap: 1rem;">
                    <div
                        style="width: 40px; height: 40px; border-radius: 0.75rem; background: #fff7ed; color: #f97316; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div>
                        <p
                            style="margin: 0; font-size: 0.75rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.025em;">
                            Límite de Inactividad</p>
                        <p style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #0f172a;">20 minutos</p>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <script>
        // Variables de control del modal
        const modal = document.getElementById('userProfileModal');
        let modalOpen = false;

        // Variables del timer
        const loginTime = <%= user.LoginTime ? user.LoginTime : new Date().getTime() %>;
        const timerElement = document.getElementById('sessionTimer');
        let timerInterval;

        function toggleUserModal() {
            if (!modalOpen) {
                // Abrir
                modal.style.display = 'flex';
                // Pequeño timeout para permitir la transicion CSS
                setTimeout(() => {
                    modal.style.opacity = '1';
                    modal.children[1].style.transform = 'translateY(0)';
                }, 10);
                modalOpen = true;
            } else {
                // Cerrar
                modal.style.opacity = '0';
                modal.children[1].style.transform = 'translateY(20px)';
                setTimeout(() => {
                    modal.style.display = 'none';
                }, 300); // 300ms matches css transition
                modalOpen = false;
            }
        }

        function updateTimer() {
            const now = Date.now();
            const diffMs = now - loginTime;

            // Convertir MS a HH:MM:SS
            const hours = Math.floor(diffMs / 3600000);
            const minutes = Math.floor((diffMs % 3600000) / 60000);
            const seconds = Math.floor((diffMs % 60000) / 1000);

            const pad = (num) => num.toString().padStart(2, '0');

            if (hours > 0) {
                timerElement.textContent = `${pad(hours)}:${pad(minutes)}:${pad(seconds)}`;
            } else {
                timerElement.textContent = `${pad(minutes)}:${pad(seconds)}`;
            }
        }

        function startTimer() {
            updateTimer(); // actualiza de inmediato
            timerInterval = setInterval(updateTimer, 1000);
        }

        function stopTimer() {
            if (timerInterval) {
                clearInterval(timerInterval);
            }
        }

        // Iniciar el timer al cargar la página, no al abrir el modal
        document.addEventListener('DOMContentLoaded', function () {
            startTimer();
        });
    </script>
    <% } %>