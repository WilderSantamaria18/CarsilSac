<!-- Sidebar - Estilo Linear/Notion Minimalista - Fijo -->
<nav class="sidebar" id="sidebar">
    <!-- Logo centrado -->
    <div class="sidebar-brand">
        <img src="/img/Carsil.png" alt="CARSIL" class="sidebar-logo">

    </div>

    <div class="sidebar-section-label">MENU</div>

    <div class="sidebar-nav">
        <a href="/menu/principal" class="sidebar-item" data-page="inicio">
            <i class="bi bi-grid-1x2"></i>
            <span>Dashboard</span>
        </a>

        <% if (user && tienePermiso(user, 'proformas' )) { %>
            <a href="/proformas" class="sidebar-item" data-page="proformas">
                <i class="bi bi-file-earmark-text"></i>
                <span>Proformas</span>
            </a>
            <% } %>

                <% if (user && tienePermiso(user, 'facturas' )) { %>
                    <a href="/facturas" class="sidebar-item" data-page="facturas">
                        <i class="bi bi-receipt"></i>
                        <span>Facturas</span>
                    </a>
                    <% } %>

                        <% if (user && tienePermiso(user, 'clientes' )) { %>
                            <a href="/clientes" class="sidebar-item" data-page="clientes">
                                <i class="bi bi-people"></i>
                                <span>Clientes</span>
                            </a>
                            <% } %>

                                <% if (user && tienePermiso(user, 'productos' )) { %>
                                    <a href="/productos" class="sidebar-item" data-page="productos">
                                        <i class="bi bi-box"></i>
                                        <span>Productos</span>
                                    </a>
                                    <% } %>

                                        <div class="sidebar-section-label">RECURSOS HUMANOS</div>

                                        <% if (user && tienePermiso(user, 'empleados' )) { %>
                                            <a href="/empleados" class="sidebar-item" data-page="empleados">
                                                <i class="bi bi-person-badge"></i>
                                                <span>Empleados</span>
                                            </a>
                                            <% } %>

                                                <% if (user && tienePermiso(user, 'pagos' )) { %>
                                                    <a href="/pagos" class="sidebar-item" data-page="pagos">
                                                        <i class="bi bi-wallet2"></i>
                                                        <span>Pagos</span>
                                                    </a>
                                                    <% } %>

                                                        <% if (user && tienePermiso(user, 'asistencias' )) { %>
                                                            <a href="/asistencia" class="sidebar-item"
                                                                data-page="asistencias">
                                                                <i class="bi bi-calendar-check"></i>
                                                                <span>Asistencias</span>
                                                            </a>
                                                            <% } %>

                                                                <div class="sidebar-section-label">ADMINISTRACION</div>

                                                                <% if (user && tienePermiso(user, 'reportes' )) { %>
                                                                    <a href="/reportes" class="sidebar-item"
                                                                        data-page="reportes">
                                                                        <i class="bi bi-bar-chart-line"></i>
                                                                        <span>Reportes</span>
                                                                    </a>
                                                                    <% } %>

                                                                        <% if (user && tienePermiso(user, 'usuarios' ))
                                                                            { %>
                                                                            <a href="/usuarios" class="sidebar-item"
                                                                                data-page="usuarios">
                                                                                <i class="bi bi-shield-check"></i>
                                                                                <span>Usuarios</span>
                                                                            </a>
                                                                            <% } %>

                                                                                <% if (user &&
                                                                                    tienePermiso(user, 'empresa' )) { %>
                                                                                    <a href="/empresa"
                                                                                        class="sidebar-item"
                                                                                        data-page="empresa">
                                                                                        <i class="bi bi-gear"></i>
                                                                                        <span>Empresa</span>
                                                                                    </a>
                                                                                    <% } %>
    </div>

    <div class="sidebar-footer" style="padding: 1rem; border-top: 1px solid rgba(0,0,0,0.05); margin-top: auto;">
        <!-- Profile Section Tailwind (Adaptable en sistemas mixtos) -->
        <div class="flex flex-col gap-4" style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="p-3 rounded-2xl bg-slate-50 dark:bg-slate-900/50 flex items-center gap-3"
                style="padding: 0.75rem; border-radius: 1rem; background-color: #f8fafc; display: flex; align-items: center; gap: 0.75rem;">
                <div class="size-10 rounded-full flex items-center justify-center text-white font-bold"
                    style="width: 2.5rem; height: 2.5rem; border-radius: 9999px; background-color: #3b4bc9; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: white;">
                    <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                </div>
                <div class="flex flex-col overflow-hidden"
                    style="display: flex; flex-direction: column; overflow: hidden;">
                    <h1 class="text-slate-900 dark:text-white text-sm font-bold truncate"
                        style="font-size: 0.875rem; font-weight: 700; color: #0f172a; margin:0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                    </h1>
                    <p class="text-slate-500 text-[10px] font-semibold uppercase tracking-wider"
                        style="font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin:0;">
                        <%= user && user.IdRol===1 ? 'Administrador' : (user && user.IdRol===2 ? 'Vendedor' : 'Personal'
                            ) %>
                    </p>
                    <div class="flex items-center gap-1.5 mt-0.5"
                        style="display: flex; align-items: center; gap: 0.375rem; margin-top: 0.125rem;">
                        <span class="size-1.5 bg-green-500 rounded-full animate-pulse"
                            style="width: 0.375rem; height: 0.375rem; background-color: #22c55e; border-radius: 9999px;"></span>
                        <p class="text-slate-400 text-[10px] font-medium"
                            style="font-size: 0.625rem; font-weight: 500; color: #94a3b8; margin:0;">Activo Ahora</p>
                    </div>
                </div>
            </div>
            <a href="/login"
                class="w-full h-10 flex items-center justify-center bg-red-50 text-red-600 hover:bg-red-100 hover:text-red-700 rounded-xl font-bold text-sm tracking-wide transition-all"
                style="width: 100%; height: 2.5rem; display: flex; align-items: center; justify-content: center; background-color: #fef2f2; color: #dc2626; border-radius: 0.75rem; font-weight: 700; font-size: 0.875rem; text-decoration: none; transition: all 0.2s;">
                <i class="bi bi-box-arrow-left" style="margin-right: 0.5rem; font-size: 1.1rem;"></i>
                Cerrar Sesión
            </a>
        </div>
    </div>
</nav>