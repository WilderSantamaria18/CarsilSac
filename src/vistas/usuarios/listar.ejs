<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuarios - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290149">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-person-circle"></i>
                        Gestión de Usuarios
                    </h5>
                    <div class="user-profile ms-auto">
                        <span>Administrador</span>
                        <div class="user-avatar">A</div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Estadísticas -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                            <i class="bi bi-people text-white"></i>
                        </div>
                        <h6 class="text-muted">Total Usuarios</h6>
                        <h3 class="text-primary"><%= usuarios ? usuarios.length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #55efc4, #00b894);">
                            <i class="bi bi-person-check text-white"></i>
                        </div>
                        <h6 class="text-muted">Activos</h6>
                        <h3 class="text-success"><%= usuarios ? usuarios.filter(u => u.Estado).length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #fd79a8, #e84393);">
                            <i class="bi bi-person-x text-white"></i>
                        </div>
                        <h6 class="text-muted">Inactivos</h6>
                        <h3 class="text-danger"><%= usuarios ? usuarios.filter(u => !u.Estado).length : 0 %></h3>
                    </div>
                </div>

                <!-- Alertas -->
                <% if (success && success.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i><%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (error && error.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- Búsqueda y acciones -->
                <div class="search-container">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex gap-2 flex-grow-1 me-3">
                            <select id="campoFiltroUsuario" class="form-select" style="max-width: 180px;">
                                <option value="1">Nombres</option>
                                <option value="2">Apellidos</option>
                                <option value="3">Documento</option>
                                <option value="4">Correo</option>
                                <option value="5">Rol</option>
                                <option value="6">Estado</option>
                            </select>
                            <input type="text" id="valorFiltroUsuario" class="form-control" placeholder="Buscar usuarios...">
                        </div>
                        <a href="/usuarios/crear" class="btn btn-primary-modern btn-modern">
                            <i class="bi bi-plus-circle"></i>
                            Nuevo Usuario
                        </a>
                    </div>
                </div>

                <!-- Tabla de usuarios -->
                <div class="table-responsive">
                    <table class="table table-modern align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center"><i class="bi bi-hash"></i></th>
                                <th><i class="bi bi-person"></i> Nombres</th>
                                <th><i class="bi bi-person-vcard"></i> Apellidos</th>
                                <th><i class="bi bi-credit-card"></i> Documento</th>
                                <th><i class="bi bi-envelope"></i> Correo</th>
                                <th><i class="bi bi-person-badge"></i> Rol</th>
                                <th class="text-center"><i class="bi bi-toggle-on"></i> Estado</th>
                                <th class="text-center"><i class="bi bi-gear"></i> Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% usuarios.forEach((usuario, index) => { %>
                                <tr>
                                            <td><input class="form-check-input custom-checkbox row-checkbox" type="checkbox"></td>
                                            <td><%= index + 1 %></td>
                                    <td><%= usuario.Nombres %></td>
                                    <td><%= usuario.Apellidos %></td>
                                    <td><%= usuario.TipoDocumento %>: <%= usuario.NumeroDocumento %></td>
                                    <td><%= usuario.Correo %></td>
                                    <td><%= usuario.Rol %></td>
                                    <td class="text-center">
                                        <span class="badge <%= usuario.Estado ? 'bg-success' : 'bg-secondary' %> px-3 py-2">
                                            <i class="bi <%= usuario.Estado ? 'bi-toggle-on' : 'bi-toggle-off' %> me-1"></i>
                                            <%= usuario.Estado ? 'Activo' : 'Inactivo' %>
                                        </span>
                                    </td>
                                    <td class="text-center">
<div class="action-buttons justify-content-center">
<a href="/usuarios/editar/<%= usuario.IdUsuario %>" 
                                           class="btn-action-icon btn-action-edit" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="/usuarios/eliminar/<%= usuario.IdUsuario %>" 
                                           class="btn-action-icon btn-action-delete" title="Eliminar"
                                           onclick="return confirm('¿Está seguro de eliminar este usuario?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
</div>
</td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        const menuItems = document.querySelectorAll('.menu-item');
        const userAvatar = document.querySelector('.user-avatar');
        const userName = 'Administrador';
        userAvatar.textContent = userName.charAt(0);

        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            // Cambia el icono de dirección
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });
        
        // Menú activo// Filtro por campo seleccionable para usuarios
        const campoFiltroUsuario = document.getElementById('campoFiltroUsuario');
        const valorFiltroUsuario = document.getElementById('valorFiltroUsuario');
        if (campoFiltroUsuario && valorFiltroUsuario) {
            valorFiltroUsuario.addEventListener('input', filtrarTablaUsuarios);
            campoFiltroUsuario.addEventListener('change', filtrarTablaUsuarios);
            function filtrarTablaUsuarios() {
                const col = parseInt(campoFiltroUsuario.value);
                const searchTerm = valorFiltroUsuario.value.toLowerCase();
                const rows = document.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const cell = row.querySelectorAll('td')[col];
                    if (cell) {
                        if (cell.textContent.toLowerCase().includes(searchTerm)) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    }
                });
            }
        }
    });
    </script>
    <script src="/publico/js/layout.js?v=1772427290149"></script>
</body>
</html>
