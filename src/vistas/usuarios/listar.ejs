    <script>
        // Configuracion de visualizacion de contrasena global
        document.querySelectorAll('.btn-toggle-pwd').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault(); // Prevenir submit accidental
                const input = this.previousElementSibling;
                const icon = this.querySelector('.material-symbols-outlined');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.textContent = 'visibility_off';
                } else {
                    input.type = 'password';
                    icon.textContent = 'visibility';
                }
            });
        });

        // Filtro de tabla
        const campoFiltroUsuario = document.getElementById('campoFiltroUsuario');
        const valorFiltroUsuario = document.getElementById('valorFiltroUsuario');
        if (campoFiltroUsuario && valorFiltroUsuario) {
            [campoFiltroUsuario, valorFiltroUsuario].forEach(el =>
                el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', filtrarTablaUsuarios)
            );
            function filtrarTablaUsuarios() {
                // Mapeo:
                // 1: Nombres (col 1)
                // 2: Apellidos (col 1 - combinados en front)
                // 3: Documento (col 2)
                // 4: Correo (col 3)
                // 5: Rol (col 4)
                // 6: Estado (col 5)
                const mapCol = { '1': 1, '2': 1, '3': 2, '4': 3, '5': 4, '6': 5 };
                const col = mapCol[campoFiltroUsuario.value] || 1;
                const term = valorFiltroUsuario.value.toLowerCase();
                document.querySelectorAll('#tbodyUsuarios tr').forEach(row => {
                    const tds = row.querySelectorAll('td');
                    if (tds.length < 7) return;
                    const show = tds[col] && tds[col].textContent.toLowerCase().includes(term);
                    row.style.display = show ? '' : 'none';
                });
            }
        }

        // Funciones Modal
        function cerrarModal(id) {
            document.getElementById(id).classList.add('hidden');
            document.body.style.overflow = '';
        }
        function abrirModal(id) {
            document.getElementById(id).classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        function cerrarSiOverlay(e, id) {
            if (e.target.id === id) cerrarModal(id);
        }
        function abrirModalCrearUsuario() {
            abrirModal('modalCrearUsuario');
        }
        function abrirModalEditarUsuario(btn) {
            try {
                const d = btn.dataset;

                // Validar que los datos existan
                if (!d.id || !d.nombres || !d.apellidos) {
                    console.error('Datos incompletos en el botón:', d);
                    alert('Error: No se pudieron cargar todos los datos del usuario. Por favor recargue la página.');
                    return;
                }

                // Avatar y titulos dinamicos
                const iniciales = ((d.nombres || '').charAt(0) + (d.apellidos || '').charAt(0)).toUpperCase() || 'U';
                document.getElementById('u_edit_avatar').textContent = iniciales;
                document.getElementById('u_edit_title').textContent = `Actualice el perfil de ${d.nombres} ${d.apellidos}.`;

                // Asignar endpoint de formulario (POST a editar)
                document.getElementById('formEditarUsuario').action = `/usuarios/editar/${d.id}`;

                // Llenar campos - con validación
                document.getElementById('u_edit_nombres').value = d.nombres || '';
                document.getElementById('u_edit_apellidos').value = d.apellidos || '';
                document.getElementById('u_edit_tipodocumento').value = d.tipodocumento || 'DNI';
                document.getElementById('u_edit_numerodocumento').value = d.numerodocumento || '';
                document.getElementById('u_edit_correo').value = d.correo || '';
                document.getElementById('u_edit_telefono').value = d.telefono || '';
                document.getElementById('u_edit_direccion').value = d.direccion || '';
                document.getElementById('u_edit_idrol').value = d.idrol || '';
                document.getElementById('u_edit_estado').value = d.estado || '1';

                // Reset inputs de clave de ser necesario
                document.querySelectorAll('#formEditarUsuario input[type="password"]').forEach(i => i.value = '');

                abrirModal('modalEditarUsuario');
            } catch (error) {
                console.error('Error al abrir modal de edición:', error);
                alert('Error al abrir el formulario de edición. Verifica la consola para más detalles.');
            }
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                cerrarModal('modalCrearUsuario');
                cerrarModal('modalEditarUsuario');
            }
        });

        // Confirm form submit para edicion de contrasenas
        const formEditarUsuario = document.getElementById('formEditarUsuario');
        if (formEditarUsuario) {
            formEditarUsuario.addEventListener('submit', function (e) {
                const pwd = this.querySelector('input[name="Clave"]').value;
                const confirmPwd = this.querySelector('input[name="ConfirmarClave"]').value;
                if (pwd || confirmPwd) {
                    if (pwd !== confirmPwd) {
                        e.preventDefault();
                        alert("Las nuevas contrasenas no coinciden. Verifique y vuelva a intentarlo.");
                    }
                }
            });
        }

        // Confirm form submit para crear para validacion de contrasenas
        const formCrearUsuario = document.querySelector('#modalCrearUsuario form');
        if (formCrearUsuario) {
            formCrearUsuario.addEventListener('submit', function (e) {
                const pwd = this.querySelector('input[name="Clave"]').value;
                const confirmPwd = this.querySelector('input[name="ConfirmarClave"]').value;
                if (pwd !== confirmPwd) {
                    e.preventDefault();
                    alert("Las contrasenas no coinciden. Verifique y vuelva a intentarlo.");
                }
            });
        }

    </script>
    <script src="/publico/js/layout.js?v=1772427290149"></script>
