<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuarios - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290149">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .main-content {
            padding: 0 !important;
            background: #f6f6f8;
        }
    </style>
</head>

<body class="bg-[#f6f6f8] text-slate-900 font-display">
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <div class="p-8">

                    <!-- Page Title -->
                    <div class="mb-8">
                        <h2 class="text-2xl font-bold text-slate-900 mb-2">Gestión de Usuarios</h2>
                        <p class="text-slate-500">Administra las cuentas y roles del sistema CARSIL.</p>
                    </div>

                    <!-- Flash messages -->
                    <% const flashSuccess=success && success.length> 0 ? (Array.isArray(success) ? success[0] : success)
                        : null; %>
                        <% const flashError=error && error.length> 0 ? (Array.isArray(error) ? error[0] : error) : null;
                            %>
                            <% if (flashSuccess) { %>
                                <div
                                    class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                                    <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                                    <span>
                                        <%= flashSuccess %>
                                    </span>
                                </div>
                                <% } %>
                                    <% if (flashError) { %>
                                        <div
                                            class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                                            <span class="material-symbols-outlined text-rose-500">error</span>
                                            <span>
                                                <%= flashError %>
                                            </span>
                                        </div>
                                        <% } %>

                                            <!-- Stats Cards -->
                                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
                                                <div
                                                    class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-[#3b4bc9]">
                                                    <p
                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
                                                        Total Usuarios</p>
                                                    <p class="text-3xl font-bold text-[#3b4bc9]">
                                                        <%= usuarios ? usuarios.length : 0 %>
                                                    </p>
                                                </div>
                                                <div
                                                    class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-emerald-500">
                                                    <p
                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
                                                        Activos</p>
                                                    <p class="text-3xl font-bold text-emerald-600">
                                                        <%= usuarios ? usuarios.filter(u=> u.Estado).length : 0 %>
                                                    </p>
                                                </div>
                                                <div
                                                    class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-rose-500">
                                                    <p
                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
                                                        Inactivos</p>
                                                    <p class="text-3xl font-bold text-rose-600">
                                                        <%= usuarios ? usuarios.filter(u=> !u.Estado).length : 0 %>
                                                    </p>
                                                </div>
                                            </div>

                                            <!-- Filter Bar -->
                                            <div
                                                class="bg-white p-4 rounded-xl border border-slate-100 mb-6 flex flex-wrap gap-4 items-center shadow-sm">
                                                <div class="flex-1 min-w-[260px] relative group">
                                                    <span
                                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#3b4bc9] transition-colors">search</span>
                                                    <input id="valorFiltroUsuario"
                                                        class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] transition-all text-sm outline-none"
                                                        placeholder="Buscar usuarios..." type="text" />
                                                </div>
                                                <select id="campoFiltroUsuario"
                                                    class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                                                    <option value="1">Nombres</option>
                                                    <option value="2">Apellidos</option>
                                                    <option value="3">Documento</option>
                                                    <option value="4">Correo</option>
                                                    <option value="5">Rol</option>
                                                    <option value="6">Estado</option>
                                                </select>
                                                <button type="button" onclick="abrirModalCrearUsuario()"
                                                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 hover:shadow-lg transition-all text-sm">
                                                    <span class="material-symbols-outlined text-sm">person_add</span>
                                                    Nuevo Usuario
                                                </button>
                                            </div>

                                            <!-- Data Table -->
                                            <div
                                                class="bg-white rounded-xl border border-slate-100 shadow-md overflow-hidden">
                                                <div class="overflow-x-auto">
                                                    <table class="w-full text-left border-collapse" id="tablaUsuarios">
                                                        <thead>
                                                            <tr class="bg-slate-50 border-b border-slate-200">
                                                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center"
                                                                    style="width: 50px;">#</th>
                                                                <th
                                                                    class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                                    Usuario</th>
                                                                <th
                                                                    class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                                    Documento</th>
                                                                <th
                                                                    class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                                    Contacto</th>
                                                                <th
                                                                    class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                                    Rol</th>
                                                                <th
                                                                    class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center">
                                                                    Estado</th>
                                                                <th
                                                                    class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">
                                                                    Acciones</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody class="divide-y divide-slate-100" id="tbodyUsuarios">
                                                            <% if (usuarios && usuarios.length> 0) { %>
                                                                <% usuarios.forEach((usuario, index)=> { %>
                                                                    <tr class="hover:bg-slate-50/60 transition-colors">
                                                                        <td
                                                                            class="px-6 py-4 text-center text-sm text-slate-400 font-medium">
                                                                            <%= index + 1 %>
                                                                        </td>
                                                                        <!-- Usuario -->
                                                                        <td class="px-6 py-4 whitespace-nowrap">
                                                                            <div class="flex items-center gap-3">
                                                                                <div
                                                                                    class="w-10 h-10 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] font-bold text-sm flex-shrink-0 border border-[#3b4bc9]/20">
                                                                                    <%= usuario.Nombres ?
                                                                                        usuario.Nombres.charAt(0).toUpperCase()
                                                                                        : 'U' %>
                                                                                        <%= usuario.Apellidos ?
                                                                                            usuario.Apellidos.charAt(0).toUpperCase()
                                                                                            : '' %>
                                                                                </div>
                                                                                <div>
                                                                                    <p
                                                                                        class="text-sm font-bold text-slate-800 leading-tight">
                                                                                        <%= usuario.Nombres %>
                                                                                            <%= usuario.Apellidos %>
                                                                                    </p>
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                        <!-- Documento -->
                                                                        <td class="px-6 py-4 whitespace-nowrap">
                                                                            <div class="flex items-center gap-1.5">
                                                                                <span
                                                                                    class="text-xs font-semibold px-2 py-0.5 bg-slate-100 text-slate-600 rounded uppercase tracking-wider">
                                                                                    <%= usuario.TipoDocumento %>
                                                                                </span>
                                                                                <span
                                                                                    class="text-sm font-mono text-slate-700">
                                                                                    <%= usuario.NumeroDocumento %>
                                                                                </span>
                                                                            </div>
                                                                        </td>
                                                                        <!-- Contacto -->
                                                                        <td class="px-6 py-4 whitespace-nowrap">
                                                                            <div class="flex flex-col gap-1">
                                                                                <span
                                                                                    class="text-xs text-slate-600 flex items-center gap-1.5">
                                                                                    <span
                                                                                        class="material-symbols-outlined text-[15px] text-slate-400">mail</span>
                                                                                    <%= usuario.Correo %>
                                                                                </span>
                                                                                <% if (usuario.Telefono) { %>
                                                                                    <span
                                                                                        class="text-xs text-slate-600 flex items-center gap-1.5">
                                                                                        <span
                                                                                            class="material-symbols-outlined text-[15px] text-slate-400">phone</span>
                                                                                        <%= usuario.Telefono %>
                                                                                    </span>
                                                                                    <% } %>
                                                                            </div>
                                                                        </td>
                                                                        <!-- Rol -->
                                                                        <td class="px-6 py-4 whitespace-nowrap">
                                                                            <span
                                                                                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-[#3b4bc9]/5 border border-[#3b4bc9]/20 text-[#3b4bc9]">
                                                                                <span
                                                                                    class="material-symbols-outlined text-[14px]">shield_person</span>
                                                                                <%= usuario.Rol %>
                                                                            </span>
                                                                        </td>
                                                                        <!-- Estado -->
                                                                        <td
                                                                            class="px-6 py-4 whitespace-nowrap text-center">
                                                                            <span
                                                                                class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider <%= usuario.Estado ? 'bg-emerald-50 text-emerald-700 border border-emerald-200/50' : 'bg-slate-100 text-slate-500 border border-slate-200/50' %>">
                                                                                <span
                                                                                    class="material-symbols-outlined text-[13px] mr-1">
                                                                                    <%= usuario.Estado ? 'check_circle'
                                                                                        : 'cancel' %>
                                                                                </span>
                                                                                <%= usuario.Estado ? 'Activo'
                                                                                    : 'Inactivo' %>
                                                                            </span>
                                                                        </td>
                                                                        <!-- Acciones -->
                                                                        <td
                                                                            class="px-6 py-4 whitespace-nowrap text-right">
                                                                            <div
                                                                                class="flex items-center justify-end gap-1">
                                                                                <a href="/usuarios/editar/<%= usuario.IdUsuario %>"
                                                                                    class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                                                                    title="Editar">
                                                                                    <span
                                                                                        class="material-symbols-outlined text-lg leading-none">edit</span>
                                                                                </a>
                                                                                <form
                                                                                    action="/usuarios/eliminar/<%= usuario.IdUsuario %>"
                                                                                    method="POST" class="inline"
                                                                                    onsubmit="return confirm('¿Eliminar definitivamente a <%= usuario.Nombres %> <%= usuario.Apellidos %>?')">
                                                                                    <button type="submit"
                                                                                        class="p-1.5 hover:bg-rose-50 rounded-lg transition-colors text-slate-500 hover:text-rose-600"
                                                                                        title="Eliminar">
                                                                                        <span
                                                                                            class="material-symbols-outlined text-lg leading-none">delete</span>
                                                                                    </button>
                                                                                </form>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    <% }); %>
                                                                        <% } else { %>
                                                                            <tr>
                                                                                <td colspan="7"
                                                                                    class="text-center py-16">
                                                                                    <div
                                                                                        class="flex flex-col items-center justify-center">
                                                                                        <span
                                                                                            class="material-symbols-outlined text-5xl text-slate-300 block mb-3">group</span>
                                                                                        <p
                                                                                            class="text-slate-500 font-medium mb-1">
                                                                                            No hay usuarios registrados
                                                                                        </p>
                                                                                        <button
                                                                                            onclick="abrirModalCrearUsuario()"
                                                                                            class="mt-4 inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 transition-all text-sm">
                                                                                            <span
                                                                                                class="material-symbols-outlined text-sm">person_add</span>
                                                                                            Nuevo Usuario
                                                                                        </button>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                            <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>

                </div><!-- /p-8 -->
            </div><!-- /main-content -->
    </div><!-- /wrapper -->

    <!-- ==================== MODAL NUEVO USUARIO ==================== -->
    <div id="modalCrearUsuario"
        class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-[100] p-4 hidden"
        onclick="cerrarSiOverlay(event,'modalCrearUsuario')">
        <div class="bg-white w-full max-w-3xl rounded-xl shadow-2xl overflow-hidden border border-slate-200 flex flex-col max-h-[90vh]"
            onclick="event.stopPropagation()">
            <div
                class="px-8 py-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50 flex-shrink-0">
                <div>
                    <h2 class="text-xl font-bold text-slate-900 tracking-tight">Crear Nuevo Usuario</h2>
                    <p class="text-slate-500 text-sm mt-0.5">Registre un nuevo miembro en el sistema.</p>
                </div>
                <button type="button" onclick="cerrarModal('modalCrearUsuario')"
                    class="text-slate-400 hover:text-slate-600 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <form action="/usuarios/crear" method="POST" autocomplete="off"
                class="flex flex-col overflow-hidden flex-1">
                <div class="px-8 py-6 space-y-8 overflow-y-auto flex-1">

                    <!-- Sección 1: Información Personal -->
                    <section>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                <span class="material-symbols-outlined text-[#3b4bc9] text-[20px]">person</span>
                            </div>
                            <h3 class="font-semibold text-slate-800">Información Personal</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Nombres</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">badge</span>
                                    <input name="Nombres" required type="text" placeholder="Ej: Juan"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Apellidos</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">badge</span>
                                    <input name="Apellidos" required type="text" placeholder="Ej: Pérez"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Tipo
                                    de Documento</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">contact_page</span>
                                    <select name="TipoDocumento"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none transition-all text-sm">
                                        <option value="DNI">DNI</option>
                                        <option value="RUC">RUC</option>
                                        <option value="CE">Carné de Extranjería</option>
                                        <option value="PASAPORTE">Pasaporte</option>
                                    </select>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Número
                                    de Documento</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">fingerprint</span>
                                    <input name="NumeroDocumento" required type="text" placeholder="00000000"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Sección 2: Contacto -->
                    <section>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                <span
                                    class="material-symbols-outlined text-[#3b4bc9] text-[20px]">alternate_email</span>
                            </div>
                            <h3 class="font-semibold text-slate-800">Información de Contacto</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Correo
                                    Electrónico</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">mail</span>
                                    <input name="Correo" required type="email" placeholder="usuario@carsil.com"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Teléfono</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">phone</span>
                                    <input name="Telefono" type="tel" placeholder="+51 987 654 321"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="col-span-1 md:col-span-2 space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Dirección
                                    <span class="normal-case text-slate-400">(Opcional)</span></label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">location_on</span>
                                    <input name="Direccion" type="text" placeholder="Av. Principal 123, Lima"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Sección 3: Credenciales -->
                    <section>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                <span class="material-symbols-outlined text-[#3b4bc9] text-[20px]">lock</span>
                            </div>
                            <h3 class="font-semibold text-slate-800">Credenciales y Rol</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Contraseña</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">key</span>
                                    <input name="Clave" required type="password" placeholder="********" minlength="6"
                                        class="pwd-toggle w-full pl-10 pr-10 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    <button type="button"
                                        class="btn-toggle-pwd absolute right-3 top-2.5 text-slate-400 hover:text-slate-600">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </button>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Confirmar
                                    Contraseña</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">verified_user</span>
                                    <input name="ConfirmarClave" required type="password" placeholder="********"
                                        minlength="6"
                                        class="pwd-toggle w-full pl-10 pr-10 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    <button type="button"
                                        class="btn-toggle-pwd absolute right-3 top-2.5 text-slate-400 hover:text-slate-600">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </button>
                                </div>
