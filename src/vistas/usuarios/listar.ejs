                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">phone</span>
                                    <input id="u_edit_telefono" name="Telefono" type="tel"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="col-span-1 md:col-span-2 space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Direccion
