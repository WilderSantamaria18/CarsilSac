                    <section>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                <span class="material-symbols-outlined text-[#3b4bc9] text-[20px]">lock</span>
                            </div>
                            <h3 class="font-semibold text-slate-800">Credenciales y Rol</h3>
                        </div>

                        <!-- Box indicativo: Para no cambiar password dejar en blanco -->
                        <div
                            class="mb-5 flex items-center gap-3 bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl text-sm text-slate-600">
                            <span class="material-symbols-outlined text-slate-400">info</span>
                            <span>Si no desea cambiar la contrasena de este usuario, deje los siguientes campos en
                                blanco.</span>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Nueva
                                    Contrasena</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">key</span>
                                    <input name="Clave" type="password" placeholder="(Sin cambios)" minlength="6"
                                        class="pwd-toggle w-full pl-10 pr-10 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    <button type="button"
                                        class="btn-toggle-pwd absolute right-3 top-2.5 text-slate-400 hover:text-slate-600">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </button>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label
                                    class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Confirmar
                                    Nueva Contrasena</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">verified_user</span>
                                    <input name="ConfirmarClave" type="password" placeholder="(Sin cambios)"
                                        minlength="6"
                                        class="pwd-toggle w-full pl-10 pr-10 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    <button type="button"
                                        class="btn-toggle-pwd absolute right-3 top-2.5 text-slate-400 hover:text-slate-600">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </button>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Rol
                                    del Sistema</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">manage_accounts</span>
                                    <select id="u_edit_idrol" name="IdRol" required
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none transition-all text-sm">
                                        <option value="">Seleccionar rol...</option>
                                        <% if (typeof roles !=='undefined' && roles) { roles.forEach(rol=> { %>
                                            <option value="<%= rol.IdRol %>">
                                                <%= rol.Descripcion %>
                                            </option>
                                            <% }); } %>
                                    </select>
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1">Estado
                                    de Cuenta</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">toggle_on</span>
                                    <select id="u_edit_estado" name="Estado"
                                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none transition-all text-sm">
                                        <option value="1">Activo</option>
                                        <option value="0">Inactivo</option>
