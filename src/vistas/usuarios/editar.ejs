<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Usuario - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290149">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .main-content {
            padding: 0 !important;
            background: #f6f6f8;
        }
    </style>
</head>

<body class="bg-[#f6f6f8] text-slate-900 font-display">
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">

                <!-- Page Content -->
                <div class="flex items-start justify-center min-h-[calc(100vh-4rem)] p-8">
                    <div
                        class="bg-white w-full max-w-2xl rounded-xl shadow-xl flex flex-col border border-slate-200 overflow-hidden">

                        <!-- Modal Header -->
                        <div
                            class="px-8 py-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] font-bold text-lg border-2 border-[#3b4bc9]/20">
                                    <%= usuario.Nombres.charAt(0) %>
                                        <%= usuario.Apellidos.charAt(0) %>
                                </div>
                                <div>
                                    <h2 class="text-xl font-bold text-slate-900">
                                        <%= usuario.Nombres %>
                                            <%= usuario.Apellidos %>
                                    </h2>
                                    <p class="text-sm text-slate-500 mt-0.5">ID: <%= usuario.IdUsuario %> &mdash;
                                            Editando perfil de usuario</p>
                                </div>
                            </div>
                            <a href="/usuarios" class="text-slate-400 hover:text-slate-600 transition-colors"
                                title="Cancelar">
                                <span class="material-symbols-outlined">close</span>
                            </a>
                        </div>

                        <!-- Alerts -->
                        <% const flashSuccess=typeof success !=='undefined' && success !==null ? (Array.isArray(success)
                            ? success[0] : success) : null; %>
                            <% const flashError=typeof error !=='undefined' && error !==null ? (Array.isArray(error) ?
                                error[0] : error) : null; %>
                                <% if (flashSuccess && flashSuccess.length> 0) { %>
                                    <div
                                        class="mx-8 mt-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                                        <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                                        <span>
                                            <%= flashSuccess %>
                                        </span>
                                    </div>
                                    <% } %>
                                        <% if (flashError && flashError.length> 0) { %>
                                            <div
                                                class="mx-8 mt-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                                                <span class="material-symbols-outlined text-rose-500">error</span>
                                                <span>
                                                    <%= flashError %>
                                                </span>
                                            </div>
                                            <% } %>

                                                <form action="/usuarios/editar/<%= usuario.IdUsuario %>" method="POST">
                                                    <div class="flex-1 overflow-y-auto px-8 py-6 space-y-8">

                                                        <!-- Sección 1: Información Personal -->
                                                        <section>
                                                            <div class="flex items-center gap-2 mb-4">
                                                                <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                                                    <span
                                                                        class="material-symbols-outlined text-[#3b4bc9] text-[20px]">person</span>
                                                                </div>
                                                                <h3 class="font-semibold text-slate-800">Información
                                                                    Personal</h3>
                                                            </div>
                                                            <div class="grid grid-cols-2 gap-4">
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Nombres">Nombres</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="Nombres" name="Nombres"
                                                                            value="<%= usuario.Nombres %>" type="text"
                                                                            required>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">badge</span>
                                                                    </div>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Apellidos">Apellidos</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="Apellidos" name="Apellidos"
                                                                            value="<%= usuario.Apellidos %>" type="text"
                                                                            required>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">badge</span>
                                                                    </div>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="TipoDocumento">Tipo de Documento</label>
                                                                    <div class="relative">
                                                                        <select
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none transition-all text-sm"
                                                                            id="TipoDocumento" name="TipoDocumento">
                                                                            <option value="DNI"
                                                                                <%=usuario.TipoDocumento==='DNI'
                                                                                ? 'selected' : '' %>>DNI</option>
                                                                            <option value="RUC"
                                                                                <%=usuario.TipoDocumento==='RUC'
                                                                                ? 'selected' : '' %>>RUC</option>
                                                                            <option value="CE"
                                                                                <%=usuario.TipoDocumento==='CE'
                                                                                ? 'selected' : '' %>>Carné de
                                                                                Extranjería</option>
                                                                            <option value="PASAPORTE"
                                                                                <%=usuario.TipoDocumento==='PASAPORTE'
                                                                                ? 'selected' : '' %>>Pasaporte</option>
                                                                        </select>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">contact_page</span>
                                                                    </div>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="NumeroDocumento">Número de
                                                                        Documento</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="NumeroDocumento" name="NumeroDocumento"
                                                                            value="<%= usuario.NumeroDocumento %>"
                                                                            type="text" required>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">fingerprint</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </section>

                                                        <!-- Sección 2: Información de Contacto -->
                                                        <section>
                                                            <div class="flex items-center gap-2 mb-4">
                                                                <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                                                    <span
                                                                        class="material-symbols-outlined text-[#3b4bc9] text-[20px]">alternate_email</span>
                                                                </div>
                                                                <h3 class="font-semibold text-slate-800">Información de
                                                                    Contacto</h3>
                                                            </div>
                                                            <div class="grid grid-cols-2 gap-4">
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Correo">Correo Electrónico</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="Correo" name="Correo"
                                                                            value="<%= usuario.Correo %>" type="email"
                                                                            required>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">mail</span>
                                                                    </div>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Telefono">Teléfono</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="Telefono" name="Telefono"
                                                                            value="<%= usuario.Telefono || '' %>"
                                                                            type="tel">
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">phone</span>
                                                                    </div>
                                                                </div>
                                                                <div class="col-span-2 space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Direccion">Dirección</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="Direccion" name="Direccion"
                                                                            value="<%= usuario.Direccion || '' %>"
                                                                            type="text">
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">location_on</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </section>

                                                        <!-- Sección 3: Credenciales y Rol -->
                                                        <section>
                                                            <div class="flex items-center gap-2 mb-4">
                                                                <div class="p-1.5 bg-[#3b4bc9]/10 rounded-lg">
                                                                    <span
                                                                        class="material-symbols-outlined text-[#3b4bc9] text-[20px]">lock</span>
                                                                </div>
                                                                <h3 class="font-semibold text-slate-800">Credenciales y
                                                                    Rol</h3>
                                                            </div>
                                                            <div class="grid grid-cols-2 gap-4">
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Clave">Nueva Contraseña</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="Clave" name="Clave"
                                                                            placeholder="Mínimo 6 caracteres"
                                                                            type="password">
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">key</span>
                                                                        <button type="button"
                                                                            class="toggle-password absolute right-3 top-2.5 text-slate-400 hover:text-slate-600"
                                                                            data-target="Clave">
                                                                            <span
                                                                                class="material-symbols-outlined text-[18px]">visibility</span>
                                                                        </button>
                                                                    </div>
                                                                    <p class="text-xs text-slate-400 ml-1">Dejar en
                                                                        blanco para no cambiar la contraseña.</p>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="ConfirmarClave">Confirmar Nueva
                                                                        Contraseña</label>
                                                                    <div class="relative">
                                                                        <input
                                                                            class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm"
                                                                            id="ConfirmarClave" name="ConfirmarClave"
                                                                            placeholder="Repita la nueva contraseña"
                                                                            type="password">
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">verified_user</span>
                                                                        <button type="button"
                                                                            class="toggle-password absolute right-3 top-2.5 text-slate-400 hover:text-slate-600"
                                                                            data-target="ConfirmarClave">
                                                                            <span
                                                                                class="material-symbols-outlined text-[18px]">visibility</span>
                                                                        </button>
                                                                    </div>
                                                                    <p class="text-xs text-slate-400 ml-1">Debe
                                                                        coincidir con la nueva contraseña.</p>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="IdRol">Rol del Sistema</label>
                                                                    <div class="relative">
                                                                        <select
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none transition-all text-sm"
                                                                            id="IdRol" name="IdRol" required>
                                                                            <% roles.forEach(rol=> { %>
                                                                                <option value="<%= rol.IdRol %>"
                                                                                    <%=rol.IdRol==usuario.IdRol
                                                                                    ? 'selected' : '' %>><%=
                                                                                        rol.Descripcion %>
                                                                                </option>
                                                                                <% }); %>
                                                                        </select>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">manage_accounts</span>
                                                                    </div>
                                                                </div>
                                                                <div class="space-y-1.5">
                                                                    <label
                                                                        class="text-xs font-semibold text-slate-500 uppercase tracking-wider ml-1"
                                                                        for="Estado">Estado de Cuenta</label>
                                                                    <div class="relative">
                                                                        <select
                                                                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-200 bg-white focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none appearance-none transition-all text-sm"
                                                                            id="Estado" name="Estado">
                                                                            <option value="1" <%=usuario.Estado==1
                                                                                ? 'selected' : '' %>>Activo</option>
                                                                            <option value="0" <%=usuario.Estado==0
                                                                                ? 'selected' : '' %>>Inactivo</option>
                                                                        </select>
                                                                        <span
                                                                            class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-[18px]">toggle_on</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </section>

                                                    </div>

                                                    <!-- Modal Footer -->
                                                    <div
                                                        class="px-8 py-5 border-t border-slate-100 flex justify-end gap-3 bg-slate-50">
                                                        <a href="/usuarios"
                                                            class="px-5 py-2.5 rounded-lg font-semibold text-slate-600 hover:bg-slate-200 transition-colors border border-slate-200">
                                                            Cancelar
                                                        </a>
                                                        <button type="submit"
                                                            class="px-6 py-2.5 rounded-lg font-semibold text-white bg-[#3b4bc9] hover:bg-[#3b4bc9]/90 transition-all shadow-lg shadow-[#3b4bc9]/20 active:scale-[0.98]">
                                                            Guardar Cambios
                                                        </button>
                                                    </div>
                                                </form>

                    </div>
                </div>
            </div>
    </div>

    <script>
        document.querySelectorAll('.toggle-password').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const input = document.getElementById(btn.getAttribute('data-target'));
                const icon = btn.querySelector('.material-symbols-outlined');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.textContent = 'visibility_off';
                } else {
                    input.type = 'password';
                    icon.textContent = 'visibility';
                }
            });
        });

        // Validación de contraseña
        document.querySelector('form').addEventListener('submit', function (e) {
            const claveInput = document.getElementById('Clave');
            const confirmarClaveInput = document.getElementById('ConfirmarClave');
            const clave = claveInput.value.trim();
            const confirmarClave = confirmarClaveInput.value.trim();
            if (clave !== '' || confirmarClave !== '') {
                if (clave === '') { e.preventDefault(); alert('Si desea cambiar la contraseña, complete el campo "Nueva Contraseña"'); claveInput.focus(); return; }
                if (confirmarClave === '') { e.preventDefault(); alert('Debe confirmar la nueva contraseña'); confirmarClaveInput.focus(); return; }
                if (clave !== confirmarClave) { e.preventDefault(); alert('Las contraseñas no coinciden'); confirmarClaveInput.focus(); return; }
                if (clave.length < 6) { e.preventDefault(); alert('La contraseña debe tener al menos 6 caracteres'); claveInput.focus(); return; }
            } else {
                claveInput.removeAttribute('name');
                confirmarClaveInput.removeAttribute('name');
            }
        });
    </script>
    <script src="/publico/js/layout.js?v=1772427290149"></script>
</body>

</html>