<!-- PAGOS/EDIT.EJS - MODAL FORM - TAILWIND DESIGN -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Pago - CARSIL</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: {
                colors: { "primary": "#3b4bc9" },
                fontFamily: { "display": ["Inter", "sans-serif"] },
            }},
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; margin: 0; overflow: hidden; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        input[readonly] { cursor: not-allowed; }
    </style>
</head>

<body class="bg-white h-screen flex flex-col overflow-hidden text-slate-900 font-display">

<%
var fechaInicioVal = pago.FechaInicio ? (pago.FechaInicio.toISOString ? pago.FechaInicio.toISOString().substring(0,10) : String(pago.FechaInicio).substring(0,10)) : '';
var fechaFinVal    = pago.FechaFin    ? (pago.FechaFin.toISOString    ? pago.FechaFin.toISOString().substring(0,10)    : String(pago.FechaFin).substring(0,10))    : '';
var fechaPagoVal   = pago.FechaPago   ? (pago.FechaPago.toISOString   ? pago.FechaPago.toISOString().substring(0,10)   : String(pago.FechaPago).substring(0,10))   : '';
%>

<form action="/pagos/editar/<%= pago.IdPago %>" method="POST" class="flex flex-col h-full overflow-hidden">

    <!-- Modal Header -->
    <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center flex-shrink-0 bg-white">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] font-bold text-lg flex-shrink-0">
                <%= pago.NombreEmpleado ? pago.NombreEmpleado.charAt(0).toUpperCase() : 'E' %>
            </div>
            <div>
                <h2 class="text-xl font-bold text-slate-900">Editar Pago de Remuneración</h2>
                <p class="text-sm text-slate-500 mt-0.5">
                    <span class="font-medium text-slate-700"><%= pago.NombreEmpleado || 'Empleado' %></span>
                    &nbsp;A·&nbsp; Semana <span class="font-semibold"><%= pago.Semana %></span> / <%= pago.Año %>
                    &nbsp;A·&nbsp; ID: <span class="font-mono text-xs">#<%= pago.IdPago %></span>
                </p>
            </div>
        </div>
        <button type="button" class="text-slate-400 hover:text-slate-600 transition-colors"
            onclick="try { window.parent.cerrarModal(); } catch(e) { window.location.href='/pagos/listar'; }">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <% if (success && success.length > 0) { %>
    <div class="mx-8 mt-4 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm flex-shrink-0">
        <span class="material-symbols-outlined text-emerald-500">check_circle</span>
        <span><%= success %></span>
    </div>
    <% } %>
    <% if (error && error.length > 0) { %>
    <div class="mx-8 mt-4 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm flex-shrink-0">
        <span class="material-symbols-outlined text-rose-500">error</span>
        <span><%= error %></span>
    </div>
    <% } %>

    <!-- Modal Body (scrollable) -->
    <div class="flex-1 overflow-y-auto p-8 space-y-8">

        <!-- SecciÃ³n 1: Empleado y Periodo -->
        <section>
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-[#3b4bc9] text-xl">person_search</span>
                <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Empleado y Periodo</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Seleccionar Empleado</label>
                    <div class="relative">
                        <select id="IdEmpleado" name="IdEmpleado" required
                            class="w-full h-11 pl-10 pr-10 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] appearance-none text-sm outline-none">
                            <option value="">Seleccione un empleado...</option>
                            <% if (typeof empleados !== 'undefined' && empleados) { %>
                            <% empleados.forEach(function(empleado) { %>
                            <option value="<%= empleado.IdEmpleado %>"
                                data-sueldo="<%= empleado.SueldoBase %>"
                                data-horasbase="<%= empleado.HorasBase %>"
                                <%= empleado.IdEmpleado == pago.IdEmpleado ? 'selected' : '' %>>
                                <%= empleado.Nombres %> <%= empleado.Apellidos %> - S/ <%= empleado.SueldoBase %>
                            </option>
                            <% }); %>
                            <% } %>
                        </select>
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">person</span>
                        <span class="material-symbols-outlined absolute right-3 top-2.5 text-slate-400 pointer-events-none">expand_more</span>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Semana (Auto)</label>
                    <div class="relative">
                        <input type="number" id="Semana" name="Semana" min="1" max="53" readonly required
                            value="<%= pago.Semana %>"
                            class="w-full h-11 pl-10 pr-3 rounded-lg border border-slate-100 bg-slate-50 text-slate-500 text-sm outline-none cursor-not-allowed">
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">calendar_view_week</span>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">AÃ±o (Auto)</label>
                    <div class="relative">
                        <input type="number" id="Anio" name="Anio" min="2020" max="2030" readonly required
                            value="<%= pago.Anio %>"
                            class="w-full h-11 pl-10 pr-3 rounded-lg border border-slate-100 bg-slate-50 text-slate-500 text-sm outline-none cursor-not-allowed">
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">event</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- SecciÃ³n 2: Fechas del Periodo -->
        <section>
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-[#3b4bc9] text-xl">date_range</span>
                <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Fechas del Periodo</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Fecha Inicio</label>
                    <input type="date" id="FechaInicio" name="FechaInicio" required value="<%= fechaInicioVal %>"
                        class="w-full h-11 px-3 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Fecha Fin</label>
                    <input type="date" id="FechaFin" name="FechaFin" required value="<%= fechaFinVal %>"
                        class="w-full h-11 px-3 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">
                        Fecha Pago <span class="text-slate-400 font-normal">(Opcional)</span>
                    </label>
                    <input type="date" id="FechaPago" name="FechaPago" value="<%= fechaPagoVal %>"
                        class="w-full h-11 px-3 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                </div>
            </div>
        </section>

        <!-- Sección 3: Cálculo de Remuneración -->
        <section class="bg-[#3b4bc9]/5 p-6 rounded-xl border border-[#3b4bc9]/10">
            <div class="flex items-center gap-2 mb-5">
                <span class="material-symbols-outlined text-[#3b4bc9] text-xl">calculate</span>
                <h3 class="text-sm font-semibold uppercase tracking-wider text-[#3b4bc9]/70">Cálculo de Remuneración</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Horas Trabajadas</label>
                    <div class="flex items-center gap-3">
                        <div class="relative flex-1">
                            <input type="number" step="0.01" id="HorasTrabajadas" name="HorasTrabajadas" required
                                value="<%= pago.HorasTrabajadas %>"
                                class="w-full h-11 pl-10 pr-3 rounded-lg border border-slate-200 bg-white font-bold text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                            <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">schedule</span>
                        </div>
                        <span class="text-xs font-medium text-slate-500 bg-slate-200 px-2 py-1 rounded whitespace-nowrap">Puede editarse</span>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Sueldo Calculado</label>
                    <div class="relative">
                        <input type="number" step="0.01" id="SueldoSemanal" name="SueldoSemanal" required
                            value="<%= pago.SueldoSemanal %>"
                            class="w-full h-11 pl-10 pr-3 rounded-lg border border-[#3b4bc9]/30 bg-white text-[#3b4bc9] font-bold text-lg outline-none focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9]">
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-[#3b4bc9] text-xl pointer-events-none">payments</span>
                    </div>
                    <p class="text-[10px] text-slate-400 mt-1 uppercase tracking-tighter">Se recalcula o puede editarse</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Bonificaciones</label>
                    <div class="relative">
                        <input type="number" step="0.01" id="Bonificaciones" name="Bonificaciones"
                            value="<%= pago.Bonificaciones %>"
                            class="w-full h-11 pl-10 pr-3 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-emerald-400 text-xl pointer-events-none">redeem</span>
                    </div>
                    <p class="text-[10px] text-slate-400 mt-1">Bonos, incentivos, horas extras</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Descuentos</label>
                    <div class="relative">
                        <input type="number" step="0.01" id="Descuentos" name="Descuentos"
                            value="<%= pago.Descuentos %>"
                            class="w-full h-11 pl-10 pr-3 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-rose-400 text-xl pointer-events-none">remove_circle</span>
                    </div>
                    <p class="text-[10px] text-slate-400 mt-1">Tardanzas, faltas, anticipos</p>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Total a Pagar</label>
                    <div class="relative">
                        <input type="number" step="0.01" id="TotalPago" name="TotalPago" readonly required
                            value="<%= pago.TotalPago %>"
                            class="w-full h-12 pl-10 pr-3 rounded-lg border-2 border-emerald-400 bg-emerald-50 text-emerald-700 font-bold text-lg outline-none">
                        <span class="material-symbols-outlined absolute left-3 top-3 text-emerald-500 text-xl pointer-events-none">savings</span>
                    </div>
                    <p class="text-[10px] text-emerald-600 mt-1 font-semibold uppercase tracking-tighter">Sueldo Calculado + Bonificaciones + Descuentos</p>
                </div>
            </div>
        </section>

        <!-- Sección 4: Detalles Adicionales -->
        <section>
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-[#3b4bc9] text-xl">info</span>
                <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Detalles Adicionales</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Método de Pago</label>
                    <div class="relative">
                        <select id="MetodoPago" name="MetodoPago"
                            class="w-full h-11 pl-10 pr-10 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] appearance-none text-sm outline-none">
                            <option value="TRANSFERENCIA" <%= pago.MetodoPago === 'TRANSFERENCIA' ? 'selected' : '' %>>Transferencia Bancaria</option>
                            <option value="EFECTIVO"      <%= pago.MetodoPago === 'EFECTIVO'      ? 'selected' : '' %>>Efectivo</option>
                            <option value="CHEQUE"        <%= pago.MetodoPago === 'CHEQUE'        ? 'selected' : '' %>>Cheque</option>
                            <option value="DEPOSITO"      <%= pago.MetodoPago === 'DEPOSITO'      ? 'selected' : '' %>>Depósito Bancario</option>
                        </select>
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">account_balance</span>
                        <span class="material-symbols-outlined absolute right-2 top-2.5 text-slate-400 pointer-events-none">expand_more</span>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Estado del Pago</label>
                    <div class="relative">
                        <select id="Estado" name="Estado"
                            class="w-full h-11 pl-10 pr-10 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] appearance-none text-sm outline-none">
                            <option value="PENDIENTE" <%= pago.Estado === 'PENDIENTE' ? 'selected' : '' %>>Pendiente</option>
                            <option value="PAGADO"    <%= pago.Estado === 'PAGADO'    ? 'selected' : '' %>>Pagado</option>
                            <option value="PARCIAL"   <%= pago.Estado === 'PARCIAL'   ? 'selected' : '' %>>Pago Parcial</option>
                            <option value="CANCELADO" <%= pago.Estado === 'CANCELADO' ? 'selected' : '' %>>Cancelado</option>
                        </select>
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">pending_actions</span>
                        <span class="material-symbols-outlined absolute right-2 top-2.5 text-slate-400 pointer-events-none">expand_more</span>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Sueldo Base Semanal <span class="text-slate-400 font-normal">(Lectura)</span></label>
                    <div class="relative">
                        <input type="number" step="0.01" id="SueldoBaseInfo" readonly placeholder="â€”"
                            class="w-full h-11 pl-10 pr-3 rounded-lg border border-slate-100 bg-slate-50 text-slate-500 text-sm outline-none cursor-not-allowed">
                        <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-400 text-xl pointer-events-none">money_off</span>
                    </div>
                    <p class="text-[10px] text-slate-400 mt-1">Del empleado seleccionado</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">
                        Comentarios <span class="text-slate-400 font-normal">(Opcional)</span>
                    </label>
                    <textarea id="Comentarios" name="Comentarios"
                        placeholder="Observaciones adicionales sobre el pago..."
                        class="w-full p-3 rounded-lg border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none resize-none h-[88px]"><%= pago.Comentarios || '' %></textarea>
                </div>
            </div>
        </section>

    </div><!-- /body scroll -->

    <!-- Modal Footer -->
    <div class="px-8 py-5 border-t border-slate-100 flex justify-end gap-3 bg-slate-50/50 flex-shrink-0">
        <button type="button"
            onclick="try { window.parent.cerrarModal(); } catch(e) { window.location.href='/pagos/listar'; }"
            class="px-6 py-2.5 rounded-lg text-sm font-semibold text-slate-600 hover:bg-slate-200 transition-colors">
            Cancelar
        </button>
        <button type="submit"
            class="px-6 py-2.5 rounded-lg text-sm font-semibold bg-[#3b4bc9] text-white hover:bg-[#3b4bc9]/90 shadow-lg shadow-[#3b4bc9]/25 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">save</span>
            Guardar Cambios
        </button>
    </div>

</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const empleadoSelect  = document.getElementById('IdEmpleado');
        const fechaInicio     = document.getElementById('FechaInicio');
        const fechaFin        = document.getElementById('FechaFin');
        const horasTrabajadas = document.getElementById('HorasTrabajadas');
        const sueldoBaseInfo  = document.getElementById('SueldoBaseInfo');
        const sueldoSemanal   = document.getElementById('SueldoSemanal');
        const bonificaciones  = document.getElementById('Bonificaciones');
        const descuentos      = document.getElementById('Descuentos');
        const totalPago       = document.getElementById('TotalPago');

        function obtenerSueldoBaseEmpleado() {
            const opt = empleadoSelect.options[empleadoSelect.selectedIndex];
            if (opt && opt.value) {
                sueldoBaseInfo.value = (parseFloat(opt.getAttribute('data-sueldo')) || 0).toFixed(2);
                calcularSueldoProporcional();
            } else {
                sueldoBaseInfo.value = '';
            }
        }

        function calcularSueldoProporcional() {
            const opt = empleadoSelect.options[empleadoSelect.selectedIndex];
            const sb  = parseFloat(opt ? opt.getAttribute('data-sueldo') : 0) || 0;
            const hb  = parseFloat(opt ? opt.getAttribute('data-horasbase') : 43) || 43;
            const hr  = parseFloat(horasTrabajadas.value) || 0;
            if (sb > 0 && hr > 0 && hb > 0) {
                let sc = (sb / hb) * hr;
                if (sc > sb) sc = sb;
                sueldoSemanal.value = sc.toFixed(2);
            } else {
                sueldoSemanal.value = sueldoSemanal.value || '0.00';
            }
            calcularTotal();
        }

        function calcularTotal() {
            const s = parseFloat(sueldoSemanal.value) || 0;
            const b = parseFloat(bonificaciones.value) || 0;
            const d = parseFloat(descuentos.value) || 0;
            totalPago.value = (s + b - d).toFixed(2);
        }

        async function obtenerHorasDesdeAsistencias() {
            const id = empleadoSelect.value;
            const fi = fechaInicio.value;
            const ff = fechaFin.value;
            if (!id || !fi || !ff) return;
            try {
                horasTrabajadas.value = 'Calculando...';
                const resp = await fetch(`/pagos/calcular-horas?idEmpleado=${id}&fechaInicio=${fi}&fechaFin=${ff}`);
                const data = await resp.json();
                horasTrabajadas.value = (resp.ok && data.success) ? (data.horasTrabajadas || '0.00') : '0.00';
            } catch (e) {
                console.error(e);
                horasTrabajadas.value = '0.00';
            } finally {
                calcularSueldoProporcional();
            }
        }

        function validarNum(inp) {
            let v = parseFloat(inp.value) || 0;
            if (v < 0) v = 0;
            inp.value = v.toFixed(2);
            calcularTotal();
        }

        empleadoSelect.addEventListener('change', function() { obtenerSueldoBaseEmpleado(); obtenerHorasDesdeAsistencias(); });
        fechaInicio.addEventListener('change', obtenerHorasDesdeAsistencias);
        fechaFin.addEventListener('change', obtenerHorasDesdeAsistencias);
        horasTrabajadas.addEventListener('input', calcularSueldoProporcional);
        horasTrabajadas.addEventListener('blur', function() { let v = parseFloat(this.value)||0; if(v<0)v=0; this.value=v.toFixed(2); calcularSueldoProporcional(); });
        sueldoSemanal.addEventListener('input', calcularTotal);
        bonificaciones.addEventListener('input', calcularTotal);
        bonificaciones.addEventListener('blur', function() { validarNum(this); });
        descuentos.addEventListener('input', calcularTotal);
        descuentos.addEventListener('blur', function() { validarNum(this); });

        // Init: cargar sueldo base del empleado seleccionado
        obtenerSueldoBaseEmpleado();
        calcularTotal();
    });
</script>
</body>
</html>
