<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Remuneración - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=<%= Date.now() %>">
    <style>
        /* Estilos para campos calculados automáticamente */
        .campo-calculado {
            position: relative;
        }

        .campo-calculado::after {
            content: "🔄";
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            animation: rotation 1s infinite linear;
            opacity: 0;
            z-index: 10;
        }

        .campo-calculado.calculando::after {
            opacity: 1;
        }

        .campo-calculado.calculando {
            background: linear-gradient(90deg, #e3f2fd, #bbdefb, #e3f2fd);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }

        @keyframes rotation {
            from {
                transform: translateY(-50%) rotate(0deg);
            }

            to {
                transform: translateY(-50%) rotate(359deg);
            }
        }

        @keyframes shimmer {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        .total-highlight {
            border: 2px solid var(--success, #16a34a) !important;
            font-weight: 700;
            font-size: 1.05rem;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-cash-coin"></i>
                            Registrar Pago
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= typeof user !=='undefined' && user && user.Nombres ? user.Nombres : 'Administrador'
                                    %>
                            </span>
                            <div class="user-avatar">
                                <%= typeof user !=='undefined' && user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="form-container">
                    <div class="form-card" style="max-width: 960px;">
                        <div class="form-header-title">
                            <i class="bi bi-cash-coin"></i> Registrar Pago de Remuneración
                        </div>

                        <div class="form-body">
                            <form action="/pagos/crear" method="POST">
                                <!-- Empleado y Periodo -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-person"></i> Empleado y Periodo
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="IdEmpleado" class="form-label"><i class="bi bi-person"></i>
                                                    Empleado</label>
                                                <select class="form-control-modern form-select-modern" id="IdEmpleado"
                                                    name="IdEmpleado" required>
                                                    <option value="">Seleccione un empleado</option>
                                                    <% if (typeof empleados !=='undefined' && empleados) { %>
                                                        <% empleados.forEach(empleado=> { %>
                                                            <option value="<%= empleado.IdEmpleado %>"
                                                                data-sueldo="<%= empleado.SueldoBase %>"
                                                                data-horasbase="<%= empleado.HorasBase %>">
                                                                <%= empleado.Nombres %>
                                                                    <%= empleado.Apellidos %> - S/ <%=
                                                                            empleado.SueldoBase %>
                                                            </option>
                                                            <% }); %>
                                                                <% } %>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label for="Semana" class="form-label"><i
                                                        class="bi bi-calendar-week"></i> Semana</label>
                                                <input type="number" class="form-control-modern" id="Semana"
                                                    name="Semana" min="1" max="53" readonly required>
                                                <small class="form-text text-muted">Se calcula automáticamente</small>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label for="Anio" class="form-label"><i class="bi bi-calendar"></i>
                                                    Año</label>
                                                <input type="number" class="form-control-modern" id="Anio" name="Anio"
                                                    min="2020" max="2030" readonly required>
                                                <small class="form-text text-muted">Se calcula automáticamente</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fechas -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-calendar-range"></i> Fechas del Periodo
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="FechaInicio" class="form-label"><i
                                                        class="bi bi-calendar-event"></i> Fecha Inicio</label>
                                                <input type="date" class="form-control-modern" id="FechaInicio"
                                                    name="FechaInicio" required>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="FechaFin" class="form-label"><i
                                                        class="bi bi-calendar-event"></i> Fecha Fin</label>
                                                <input type="date" class="form-control-modern" id="FechaFin"
                                                    name="FechaFin" required>
                                                <small class="form-text text-muted">Se sugiere automáticamente</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="FechaPago" class="form-label">
                                                    <i class="bi bi-calendar-check"></i> Fecha de Pago
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <input type="date" class="form-control-modern" id="FechaPago"
                                                    name="FechaPago">
                                                <small class="form-text text-muted">Dejar vacío si aún no se ha
                                                    pagado</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cálculos -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-calculator"></i> Cálculo de Remuneración
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="HorasTrabajadas" class="form-label"><i
                                                        class="bi bi-clock-history"></i> Horas Trabajadas</label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="HorasTrabajadas" name="HorasTrabajadas" required>
                                                <small class="form-text text-muted"><i class="bi bi-magic me-1"></i>Se
                                                    calcula automáticamente desde asistencias</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="SueldoSemanal" class="form-label"><i
                                                        class="bi bi-calculator"></i> Sueldo Calculado</label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="SueldoSemanal" name="SueldoSemanal" readonly required>
                                                <small class="form-text text-muted">(SueldoBase ÷ HorasBase) × Horas
                                                    reales</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="Bonificaciones" class="form-label"><i
                                                        class="bi bi-gift"></i> Bonificaciones</label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="Bonificaciones" name="Bonificaciones" value="0.00">
                                                <small class="form-text text-muted">Bonos, incentivos, horas
                                                    extras</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="Descuentos" class="form-label"><i
                                                        class="bi bi-dash-circle"></i> Descuentos</label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="Descuentos" name="Descuentos" value="0.00">
                                                <small class="form-text text-muted">Tardanzas, faltas, anticipos</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="TotalPago" class="form-label"><i
                                                        class="bi bi-cash-stack"></i> Total a Pagar</label>
                                                <input type="number" step="0.01"
                                                    class="form-control-modern total-highlight" id="TotalPago"
                                                    name="TotalPago" readonly required>
                                                <small class="form-text"
                                                    style="color: var(--success, #16a34a); font-weight: 600;"><i
                                                        class="bi bi-calculator me-1"></i>Sueldo + Bonificaciones -
                                                    Descuentos</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Detalles Adicionales -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-sliders"></i> Detalles Adicionales
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="MetodoPago" class="form-label"><i
                                                        class="bi bi-credit-card"></i> Método de Pago</label>
                                                <select class="form-control-modern form-select-modern" id="MetodoPago"
                                                    name="MetodoPago">
                                                    <option value="TRANSFERENCIA">Transferencia Bancaria</option>
                                                    <option value="EFECTIVO">Efectivo</option>
                                                    <option value="CHEQUE">Cheque</option>
                                                    <option value="DEPOSITO">Depósito Bancario</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="Estado" class="form-label"><i class="bi bi-toggle-on"></i>
                                                    Estado del Pago</label>
                                                <select class="form-control-modern form-select-modern" id="Estado"
                                                    name="Estado">
                                                    <option value="PENDIENTE">Pendiente</option>
                                                    <option value="PAGADO">Pagado</option>
                                                    <option value="PARCIAL">Pago Parcial</option>
                                                    <option value="CANCELADO">Cancelado</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="SueldoBaseInfo" class="form-label"><i
                                                        class="bi bi-info-circle"></i> Sueldo Base Semanal</label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="SueldoBaseInfo" readonly>
                                                <small class="form-text text-muted">Sueldo base del empleado
                                                    seleccionado</small>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label for="Comentarios" class="form-label">
                                                    <i class="bi bi-chat-left-text"></i> Comentarios
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <textarea class="form-control-modern" id="Comentarios"
                                                    name="Comentarios" rows="3"
                                                    placeholder="Observaciones adicionales sobre el pago..."></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-buttons">
                                    <a href="/pagos/listar" class="btn btn-form btn-form-cancel">
                                        <i class="bi bi-x-circle me-2"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-form-primary">
                                        <i class="bi bi-save me-2"></i> Registrar Pago
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Campos del formulario
            const empleadoSelect = document.getElementById('IdEmpleado');
            const fechaInicio = document.getElementById('FechaInicio');
            const fechaFin = document.getElementById('FechaFin');
            const horasTrabajadas = document.getElementById('HorasTrabajadas');
            const sueldoBaseInfo = document.getElementById('SueldoBaseInfo');
            const sueldoSemanal = document.getElementById('SueldoSemanal');
            const bonificaciones = document.getElementById('Bonificaciones');
            const descuentos = document.getElementById('Descuentos');
            const totalPago = document.getElementById('TotalPago');
            const semana = document.getElementById('Semana');
            const anio = document.getElementById('Anio');

            // Función para obtener el sueldo base del empleado seleccionado
            function obtenerSueldoBaseEmpleado() {
                const selectedOption = empleadoSelect.options[empleadoSelect.selectedIndex];
                if (selectedOption && selectedOption.value) {
                    const sueldoBase = parseFloat(selectedOption.getAttribute('data-sueldo')) || 0;
                    sueldoBaseInfo.value = sueldoBase.toFixed(2);
                    calcularSueldoProporcional();
                    return sueldoBase;
                }
                sueldoBaseInfo.value = '';
                return 0;
            }

            // Función para calcular semana y año automáticamente
            function calcularSemanaAnio() {
                if (!fechaInicio.value) return;
                const fecha = new Date(fechaInicio.value);
                const fechaTemp = new Date(fecha);
                fechaTemp.setHours(0, 0, 0, 0);
                fechaTemp.setDate(fechaTemp.getDate() + 3 - (fechaTemp.getDay() + 6) % 7);
                const primerJueves = new Date(fechaTemp.getFullYear(), 0, 4);
                const numeroSemana = 1 + Math.round(((fechaTemp.getTime() - primerJueves.getTime()) / 86400000 - 3 + (primerJueves.getDay() + 6) % 7) / 7);
                semana.value = numeroSemana;
                anio.value = fecha.getFullYear();
            }

            // Función para sugerir fecha de fin
            function sugerirFechaFin() {
                if (!fechaInicio.value || fechaFin.value) return;
                const inicio = new Date(fechaInicio.value);
                const diaSemanaInicio = inicio.getDay();
                let diasASumar = 6;
                if (diaSemanaInicio === 1) diasASumar = 5;
                else if (diaSemanaInicio === 0) diasASumar = 6;
                else if (diaSemanaInicio >= 2 && diaSemanaInicio <= 6) {
                    diasASumar = 6 - diaSemanaInicio;
                    if (diasASumar === 0) diasASumar = 7;
                }
                const fechaFinSugerida = new Date(inicio);
                fechaFinSugerida.setDate(inicio.getDate() + diasASumar);
                const año = fechaFinSugerida.getFullYear();
                const mes = String(fechaFinSugerida.getMonth() + 1).padStart(2, '0');
                const dia = String(fechaFinSugerida.getDate()).padStart(2, '0');
                fechaFin.value = `${año}-${mes}-${dia}`;
            }

            // Función para calcular el sueldo proporcional
            function calcularSueldoProporcional() {
                const opcionSeleccionada = empleadoSelect.options[empleadoSelect.selectedIndex];
                const sueldoBase = parseFloat(opcionSeleccionada.getAttribute('data-sueldo')) || 0;
                const horasBase = parseFloat(opcionSeleccionada.getAttribute('data-horasbase')) || 43;
                const horasReales = parseFloat(horasTrabajadas.value) || 0;
                if (sueldoBase > 0 && horasReales > 0 && horasBase > 0) {
                    const valorPorHora = sueldoBase / horasBase;
                    let sueldoCalculado = valorPorHora * horasReales;
                    if (sueldoCalculado > sueldoBase) sueldoCalculado = sueldoBase;
                    sueldoSemanal.value = sueldoCalculado.toFixed(2);
                    calcularTotal();
                } else {
                    sueldoSemanal.value = '0.00';
                }
            }

            // Función para calcular el total a pagar
            function calcularTotal() {
                const sueldo = parseFloat(sueldoSemanal.value) || 0;
                const bonos = parseFloat(bonificaciones.value) || 0;
                const descuentosAplicados = parseFloat(descuentos.value) || 0;
                const total = sueldo + bonos - descuentosAplicados;
                totalPago.value = total.toFixed(2);
            }

            // Función para obtener horas trabajadas desde las asistencias
            async function obtenerHorasDesdeAsistencias() {
                const idEmpleado = empleadoSelect.value;
                const fechaInicioVal = fechaInicio.value;
                const fechaFinVal = fechaFin.value;
                if (!idEmpleado || !fechaInicioVal || !fechaFinVal) {
                    horasTrabajadas.value = '0.00';
                    horasTrabajadas.title = 'Seleccione empleado y fechas para calcular.';
                    calcularSueldoProporcional();
                    return;
                }
                const horasContainer = horasTrabajadas.closest('.form-group') || horasTrabajadas.closest('.col-md-6');
                if (horasContainer) horasContainer.querySelectorAll('.alert').forEach(a => a.remove());
                try {
                    horasTrabajadas.parentElement.classList.add('campo-calculado', 'calculando');
                    horasTrabajadas.value = 'Calculando...';
                    const response = await fetch(`/pagos/calcular-horas?idEmpleado=${idEmpleado}&fechaInicio=${fechaInicioVal}&fechaFin=${fechaFinVal}`);
                    const data = await response.json();
                    if (!response.ok) throw new Error(data.message || 'Error de conexión con el servidor.');
                    if (data.success) {
                        horasTrabajadas.value = data.horasTrabajadas;
                        if (data.desglose && data.desglose.length > 0) {
                            let tooltipText = 'Desglose de asistencias:\n';
                            data.desglose.forEach(asist => {
                                const fechaAsistencia = new Date(asist.Fecha).toLocaleDateString('es-ES', { year: 'numeric', month: '2-digit', day: '2-digit' });
                                tooltipText += `${fechaAsistencia}: ${asist.HorasTrabajadas}h (${asist.JornadaLaboral})\n`;
                            });
                            horasTrabajadas.title = tooltipText.trim();
                        } else {
                            horasTrabajadas.title = 'No se encontraron asistencias para este período.';
                        }
                    } else {
                        horasTrabajadas.value = '0.00';
                        horasTrabajadas.title = data.message || 'No se pudo calcular.';
                    }
                } catch (error) {
                    console.error('Error al calcular horas:', error);
                    horasTrabajadas.value = '0.00';
                    horasTrabajadas.title = 'Error al calcular. Puede ingresarlo manualmente.';
                } finally {
                    horasTrabajadas.parentElement.classList.remove('campo-calculado', 'calculando');
                    calcularSueldoProporcional();
                }
            }

            // Función para validar y formatear valores numéricos
            function validarYFormatearNumero(input) {
                let valor = parseFloat(input.value) || 0;
                if (valor < 0) valor = 0;
                input.value = valor.toFixed(2);
                calcularTotal();
            }

            // Eventos
            if (empleadoSelect) empleadoSelect.addEventListener('change', function () {
                obtenerSueldoBaseEmpleado();
                obtenerHorasDesdeAsistencias();
            });
            if (fechaInicio) fechaInicio.addEventListener('change', function () {
                calcularSemanaAnio();
                sugerirFechaFin();
                obtenerHorasDesdeAsistencias();
            });
            if (fechaFin) fechaFin.addEventListener('change', obtenerHorasDesdeAsistencias);
            if (horasTrabajadas) {
                horasTrabajadas.addEventListener('input', function () {
                    calcularSueldoProporcional();
                    this.title = 'Editado manualmente';
                });
                horasTrabajadas.addEventListener('blur', function () {
                    let valor = parseFloat(this.value) || 0;
                    if (valor < 0) valor = 0;
                    this.value = valor.toFixed(2);
                    calcularSueldoProporcional();
                });
            }
            if (bonificaciones) {
                bonificaciones.addEventListener('input', calcularTotal);
                bonificaciones.addEventListener('blur', function () { validarYFormatearNumero(this); });
            }
            if (descuentos) {
                descuentos.addEventListener('input', calcularTotal);
                descuentos.addEventListener('blur', function () { validarYFormatearNumero(this); });
            }
            calcularTotal();
        });
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>