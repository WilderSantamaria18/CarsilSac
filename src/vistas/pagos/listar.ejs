<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Pagos - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290144">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .main-content {
            padding: 0 !important;
            background: #f6f6f8;
        }

        /* ── Modal overlay ── */
        .pago-modal-overlay {
            display: none; position: fixed; inset: 0; z-index: 1080;
            background: rgba(10,12,20,0.72);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            align-items: center; justify-content: center;
        }
        .pago-modal-overlay.active { display: flex; }
        @keyframes pagoSheetIn {
            from { transform: translateY(40px) scale(0.97); opacity: 0; }
            to   { transform: translateY(0) scale(1); opacity: 1; }
        }
    </style>
</head>

<body class="bg-[#f6f6f8] text-slate-900 font-display">

    <% var totalPagos=pagos ? pagos.length : 0; var completados=0; var pendientes=0; var montoPendiente=0; if (pagos) {
        pagos.forEach(p=> {
        if (p.Estado === 'PAGADO') completados++;
        else if (p.Estado === 'PENDIENTE' || p.Estado === 'PARCIAL') {
        pendientes++;
        montoPendiente += parseFloat(p.TotalPago || 0);
        }
        });
        }
        %>

        <div class="wrapper">
            <%- include("../parciales/sidebar") %>

                <div class="main-content" id="main-content">

                    <!-- Top Nav -->
                    <header
                        class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-10 shadow-sm">
                        <div class="flex items-center gap-2">
                            <span class="text-slate-400 text-sm">Panel</span>
                            <span class="material-symbols-outlined text-sm text-slate-300">chevron_right</span>
                            <span class="font-semibold text-sm">Gestión de Pagos</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="relative">
                                <span
                                    class="material-symbols-outlined p-2 text-slate-500 hover:bg-slate-100 rounded-full cursor-pointer transition-colors">notifications</span>
                                <span
                                    class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                            </div>
                            <div class="h-8 w-px bg-slate-200"></div>
                            <div
                                class="w-8 h-8 rounded-full bg-[#3b4bc9] flex items-center justify-center text-white text-xs font-bold">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                            <span class="text-sm font-medium hidden sm:inline-block">
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                        </div>
                    </header>

                    <!-- Content Area -->
                    <div class="p-8">

                        <!-- Page Title -->
                        <div class="mb-8">
                            <h2 class="text-3xl font-black tracking-tight mb-2">Gestión de Pagos</h2>
                            <p class="text-slate-500">Administra y supervisa los pagos de nómina al personal.</p>
                        </div>

                        <!-- Stats Cards -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
                            <div
                                class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-[#3b4bc9]">
                                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total
                                    Registros</p>
                                <p class="text-3xl font-bold text-[#3b4bc9]">
                                    <%= totalPagos %>
                                </p>
                            </div>
                            <div
                                class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-emerald-500">
                                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pagos
                                    Completados</p>
                                <p class="text-3xl font-bold text-emerald-600">
                                    <%= completados %>
                                </p>
                            </div>
                            <div
                                class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-amber-500">
                                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pendientes
                                    de Pago</p>
                                <p class="text-3xl font-bold text-amber-600">
                                    <%= pendientes %>
                                </p>
                            </div>
                            <div
                                class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-violet-500">
                                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Monto
                                    Pendiente</p>
                                <p class="text-2xl font-bold text-violet-600">S/ <%=
                                        montoPendiente.toLocaleString('es-PE',{minimumFractionDigits:2}) %>
                                </p>
                            </div>
                        </div>

                        <!-- Filter Bar -->
                        <div
                            class="bg-white p-4 rounded-xl border border-slate-100 mb-6 flex flex-wrap gap-4 items-center shadow-sm">
                            <div class="flex-1 min-w-[260px] relative group">
                                <span
                                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#3b4bc9] transition-colors">search</span>
                                <input id="valorFiltro"
                                    class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] transition-all text-sm outline-none"
                                    placeholder="Buscar pagos..." type="text" />
                            </div>
                            <select id="campoFiltro"
                                class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                                <option value="1">Empleado</option>
                                <option value="2">Semana/Año</option>
                                <option value="3">Período</option>
                                <option value="4">Horas</option>
                                <option value="5">Total</option>
                                <option value="6">Estado</option>
                                <option value="7">Método</option>
                            </select>
                            <div class="flex items-center gap-2">
                                <button type="button" onclick="abrirModalCrear()"
                                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 hover:shadow-lg transition-all text-sm">
                                    <span class="material-symbols-outlined text-sm">add_circle</span>
                                    Nuevo Pago
                                </button>
                            </div>
                        </div>

                        <!-- Data Table -->
                        <div class="bg-white rounded-xl border border-slate-100 shadow-md overflow-hidden">
                            <div class="overflow-x-auto">
                                <table class="w-full text-left border-collapse" id="tablaPagos">
                                    <thead>
                                        <tr class="bg-slate-50 border-b border-slate-200">
                                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest"
                                                style="width: 40px;">
                                                <input type="checkbox" onchange="toggleAll(this)"
                                                    class="rounded text-[#3b4bc9] focus:ring-[#3b4bc9] border-slate-300">
                                            </th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                Empleado</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                Semana / Año</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                Período</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center">
                                                Horas</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">
                                                Total Pagar</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center">
                                                Estado</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center">
                                                Método</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center">
                                                Fecha Pago</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">
                                                Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100" id="tbodyPagos">
                                        <% if (pagos && pagos.length> 0) { %>
                                            <% pagos.forEach(pago=> { %>

                                                <tr class="hover:bg-slate-50/60 transition-colors">
                                                    <!-- Checkbox -->
                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                        <input type="checkbox"
                                                            class="row-checkbox rounded text-[#3b4bc9] focus:ring-[#3b4bc9] border-slate-300">
                                                    </td>

                                                    <!-- Empleado -->
                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                        <div class="flex items-center gap-3">
                                                            <div
                                                                class="w-9 h-9 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 font-bold text-sm flex-shrink-0">
                                                                <%= pago.NombreEmpleado ?
                                                                    pago.NombreEmpleado.charAt(0).toUpperCase() : 'E' %>
                                                            </div>
                                                            <div>
                                                                <p class="text-sm font-semibold leading-tight">
                                                                    <%= pago.NombreEmpleado || `Empleado
                                                                        ${pago.IdEmpleado}` %>
                                                                </p>
                                                                <p class="text-xs text-slate-400 font-mono mt-0.5">ID:
                                                                    <%= pago.IdEmpleado %>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </td>

                                                    <!-- Semana / Año -->
                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                        <div class="flex flex-col">
                                                            <span
                                                                class="inline-flex items-center px-2 py-0.5 rounded textxs font-bold bg-[#3b4bc9]/10 text-[#3b4bc9] w-max">
                                                                Semana <%= pago.Semana %>
                                                            </span>
                                                            <span class="text-xs text-slate-400 mt-1">
                                                                <%= pago.Anio %>
                                                            </span>
                                                        </div>
                                                    </td>

                                                    <!-- Período -->
                                                    <td class="px-6 py-4 whitespace-nowrap text-xs text-slate-500">
                                                        <div class="flex flex-col gap-0.5">
                                                            <div><strong class="text-slate-600">Inicia:</strong>
                                                                <%= pago.FechaInicio ? (pago.FechaInicio.toISOString ?
                                                                    pago.FechaInicio.toISOString().substring(0,10) :
                                                                    pago.FechaInicio.substring(0,10)) : 'N/A' %>
                                                            </div>
                                                            <div><strong class="text-slate-600">Termina:</strong>
                                                                <%= pago.FechaFin ? (pago.FechaFin.toISOString ?
                                                                    pago.FechaFin.toISOString().substring(0,10) :
                                                                    pago.FechaFin.substring(0,10)) : 'N/A' %>
                                                            </div>
                                                        </div>
                                                    </td>

                                                    <!-- Horas -->
                                                    <td
                                                        class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium text-slate-600">
                                                        <div
                                                            class="inline-flex items-center gap-1 bg-slate-100 px-2.5 py-1 rounded-md">
                                                            <span
                                                                class="material-symbols-outlined text-[14px]">schedule</span>
                                                            <%= parseFloat(pago.HorasTrabajadas || 0).toFixed(1) %>h
                                                        </div>
                                                    </td>

                                                    <!-- Total Pagar -->
                                                    <td class="px-6 py-4 whitespace-nowrap text-right">
                                                        <div class="flex flex-col items-end">
                                                            <span class="text-base font-bold text-[#3b4bc9]">S/ <%=
                                                                    parseFloat(pago.TotalPago || 0).toFixed(2) %></span>
                                                            <div
                                                                class="flex items-center gap-2 mt-0.5 text-[10px] font-medium text-slate-400 uppercase tracking-widest">
                                                                <% if (pago.Bonificaciones> 0 || pago.Descuentos > 0) {
                                                                    %>
                                                                    <span class="text-emerald-500"
                                                                        title="Bonificaciones">+S/<%=
                                                                            parseFloat(pago.Bonificaciones).toFixed(2)
                                                                            %></span>
                                                                    <span class="text-rose-500" title="Descuentos">-S/
                                                                        <%= parseFloat(pago.Descuentos).toFixed(2) %>
                                                                            </span>
                                                                    <% } else { %>
                                                                        <span>Base S/<%=
                                                                                parseFloat(pago.SueldoSemanal).toFixed(2)
                                                                                %></span>
                                                                        <% } %>
                                                            </div>
                                                        </div>
                                                    </td>

                                                    <!-- Estado -->
                                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                                        <% if (pago.Estado==='PAGADO' ) { %>
                                                            <span
                                                                class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-emerald-50 text-emerald-700 uppercase tracking-wider">
                                                                <span
                                                                    class="material-symbols-outlined text-[13px] mr-1">check_circle</span>
                                                                Pagado
                                                            </span>
                                                            <% } else if (pago.Estado==='PENDIENTE' ||
                                                                pago.Estado==='PARCIAL' ) { %>
                                                                <span
                                                                    class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-amber-50 text-amber-700 uppercase tracking-wider">
                                                                    <span
                                                                        class="material-symbols-outlined text-[13px] mr-1">schedule</span>
                                                                    <%= pago.Estado %>
                                                                </span>
                                                                <% } else { %>
                                                                    <span
                                                                        class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-rose-50 text-rose-700 uppercase tracking-wider">
                                                                        <span
                                                                            class="material-symbols-outlined text-[13px] mr-1">cancel</span>
                                                                        <%= pago.Estado %>
                                                                    </span>
                                                                    <% } %>
                                                    </td>

                                                    <!-- Método -->
                                                    <td
                                                        class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium text-slate-600">
                                                        <%= pago.MetodoPago || 'N/A' %>
                                                            <% if (pago.MetodoPago==='TRANSFERENCIA' ) { %>
                                                                <br><span
                                                                    class="material-symbols-outlined text-sm text-[#3b4bc9] mt-0.5">account_balance</span>
                                                                <% } else if (pago.MetodoPago==='EFECTIVO' ) { %>
                                                                    <br><span
                                                                        class="material-symbols-outlined text-sm text-emerald-600 mt-0.5">payments</span>
                                                                    <% } %>
                                                    </td>

                                                    <!-- Fecha Pago -->
                                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm">
                                                        <% if (pago.FechaPago) { %>
                                                            <span class="text-slate-600">
                                                                <%= pago.FechaPago.toISOString ?
                                                                    pago.FechaPago.toISOString().substring(0,10) :
                                                                    pago.FechaPago.substring(0,10) %>
                                                            </span>
                                                            <% } else { %>
                                                                <span class="text-slate-400">—</span>
                                                                <% } %>
                                                    </td>

                                                    <!-- Acciones -->
                                                    <td class="px-6 py-4 whitespace-nowrap text-right">
                                                        <div class="flex items-center justify-end gap-1">
                                                            <% if (pago.Estado !=='PAGADO' ) { %>
                                                                <button type="button" onclick="abrirModalEditar(<%= pago.IdPago %>)"
                                                                    class="p-1.5 hover:bg-emerald-50 rounded-lg transition-colors text-emerald-600"
                                                                    title="Marcar como pagado">
                                                                    <span
                                                                        class="material-symbols-outlined text-lg leading-none">check_circle</span>
                                                                </button>
                                                                <% } %>
                                                                    <button type="button" onclick="abrirModalEditar(<%= pago.IdPago %>)"
                                                                        class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                                                        title="Editar pago">
                                                                        <span
                                                                            class="material-symbols-outlined text-lg leading-none">edit</span>
                                                                    </button>
                                                                    <a href="/pagos/eliminar/<%= pago.IdPago %>"
                                                                        class="p-1.5 hover:bg-rose-50 rounded-lg transition-colors text-slate-500 hover:text-rose-600"
                                                                        title="Eliminar pago"
                                                                        onclick="return confirm('¿Está seguro de eliminar este pago?\nEmpleado: <%= pago.NombreEmpleado || pago.IdEmpleado %>\nTotal: S/ <%= parseFloat(pago.TotalPago || 0).toFixed(2) %>')">
                                                                        <span
                                                                            class="material-symbols-outlined text-lg leading-none">delete</span>
                                                                    </a>
                                                                    <% if (pago.Comentarios && pago.Comentarios.trim())
                                                                        { %>
                                                                        <button type="button"
                                                                            class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                                                            title="<%= pago.Comentarios %>"
                                                                            onclick="alert('<%= pago.Comentarios %>')">
                                                                            <span
                                                                                class="material-symbols-outlined text-lg leading-none">chat</span>
                                                                        </button>
                                                                        <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="10" class="text-center py-16">
                                                                <div class="flex flex-col items-center justify-center">
                                                                    <span
                                                                        class="material-symbols-outlined text-5xl text-slate-300 block mb-3">account_balance_wallet</span>
                                                                    <h5
                                                                        class="text-lg font-semibold text-slate-700 mb-1">
                                                                        No hay pagos registrados</h5>
                                                                    <p class="text-slate-400 text-sm mb-5">Comience
                                                                        registrando el primer pago de nómina.</p>
                                                                    <button type="button" onclick="abrirModalCrear()"
                                                                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 transition-all text-sm">
                                                                        <span
                                                                            class="material-symbols-outlined text-sm">add_circle</span>
                                                                        Registrar primer pago
                                                                    </button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                            <!-- Pagination footer -->
                            <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                                <p class="text-sm text-slate-500">
                                    Mostrando <span id="visibleCount">
                                        <%= totalPagos %>
                                    </span> de <strong>
                                        <%= totalPagos %>
                                    </strong> pagos
                                </p>
                            </div>
                        </div>

                    </div><!-- /p-8 -->
                </div><!-- /main-content -->
        </div><!-- /wrapper -->

        <!-- ── Modal Overlay ── -->
        <div class="pago-modal-overlay" id="pagoOverlay" onclick="cerrarSiOverlay(event)">
            <div id="pagoModalCard" style="width:96%;max-width:1100px;max-height:94vh;background:#fff;border-radius:1.25rem;overflow:hidden;display:flex;flex-direction:column;animation:pagoSheetIn 0.28s cubic-bezier(.22,1,.36,1) both;box-shadow:0 32px 80px rgba(0,0,0,0.28);">
                <div id="pagoSpinner" style="display:flex;align-items:center;justify-content:center;height:280px;">
                    <svg width="40" height="40" viewBox="0 0 50 50" style="animation:pagoSpin 0.9s linear infinite">
                        <circle cx="25" cy="25" r="20" fill="none" stroke="#3b4bc9" stroke-width="5" stroke-dasharray="80 20"/>
                    </svg>
                </div>
                <iframe id="pagoIframe" name="pagoIframe"
                    style="width:100%;flex:1;border:none;display:none;min-height:600px;"
                    src="about:blank"></iframe>
            </div>
        </div>
        <style>@keyframes pagoSpin { to { transform: rotate(360deg); } }</style>

        <script>
            // ── Modal functions ──
            var pagoOverlay = document.getElementById('pagoOverlay');
            var pagoIframe  = document.getElementById('pagoIframe');
            var pagoSpinner = document.getElementById('pagoSpinner');

            function abrirModal(url) {
                pagoSpinner.style.display = 'flex';
                pagoIframe.style.display  = 'none';
                pagoIframe.src = url;
                pagoOverlay.classList.add('active');
            }
            function abrirModalCrear()     { abrirModal('/pagos/crear'); }
            function abrirModalEditar(id)  { abrirModal('/pagos/editar/' + id); }

            function cerrarModal() {
                pagoOverlay.classList.remove('active');
                setTimeout(function() {
                    pagoIframe.src = 'about:blank';
                    pagoSpinner.style.display = 'flex';
                    pagoIframe.style.display  = 'none';
                }, 300);
            }
            function cerrarSiOverlay(e) {
                if (e.target === pagoOverlay) cerrarModal();
            }

            pagoIframe.addEventListener('load', function() {
                try {
                    var href = pagoIframe.contentWindow.location.href;
                    if (href && (href.indexOf('/pagos/listar') !== -1 || href.indexOf('/pagos/lista') !== -1)) {
                        cerrarModal();
                        window.location.reload();
                        return;
                    }
                } catch(e) {}
                pagoSpinner.style.display = 'none';
                pagoIframe.style.display  = 'block';
            });

            // Seleccionar/Deseleccionar todos
            function toggleAll(source) {
                var checkboxes = document.querySelectorAll('.row-checkbox');
                for (var i = 0; i < checkboxes.length; i++) {
                    checkboxes[i].checked = source.checked;
                }
            }

            // Filtro tabla simple
            const campoFiltro = document.getElementById('campoFiltro');
            const valorFiltro = document.getElementById('valorFiltro');
            if (campoFiltro && valorFiltro) {
                [campoFiltro, valorFiltro].forEach(el =>
                    el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', filtrarTabla)
                );
                function filtrarTabla() {
                    const col = parseInt(campoFiltro.value);
                    const term = valorFiltro.value.toLowerCase().replace(/s\/|\+|\-/g, '').trim();
                    let vis = 0;
                    document.querySelectorAll('#tbodyPagos tr').forEach(row => {
                        const tds = row.querySelectorAll('td');
                        if (tds.length < 10) return;
                        const cell = tds[col];
                        let cellText = cell ? cell.textContent.toLowerCase().replace(/s\/|\+|\-/g, '').trim() : '';
                        const show = cellText.includes(term);
                        row.style.display = show ? '' : 'none';
                        if (show) vis++;
                    });
                    const vc = document.getElementById('visibleCount');
                    if (vc) vc.textContent = vis;
                }
            }
        </script>
        <script src="/publico/js/layout.js?v=1772427290144"></script>
</body>

