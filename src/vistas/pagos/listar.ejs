<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Pagos - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290144">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-cash-coin"></i>
                        Gestión de Pagos
                    </h5>
                    <div class="user-profile ms-auto">
                        <span>Administrador</span>
                        <div class="user-avatar">A</div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Mensajes de éxito y error eliminados según solicitud del usuario -->
                
                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #28a745, #20c997);">
                            <i class="bi bi-list-check text-white"></i>
                        </div>                
                        <h6 class="text-muted">Total de Registros</h6>
                        <h3 class="text-primary"><%= pagos ? pagos.length : 0 %></h3>
                        <small class="text-muted">Pagos registrados en el sistema</small>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                            <i class="bi bi-check-circle text-white"></i>
                        </div>                
                        <h6 class="text-muted">Pagos Completados</h6>
                        <h3 class="text-success"><%= pagos ? pagos.filter(p => p.Estado === 'PAGADO').length : 0 %></h3>
                        <small class="text-muted">Ya fueron pagados</small>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ffeaa7, #fdcb6e);">
                            <i class="bi bi-clock text-white"></i>
                        </div>                
                        <h6 class="text-muted">Pendientes de Pago</h6>
                        <h3 class="text-warning"><%= pagos ? pagos.filter(p => p.Estado === 'PENDIENTE' || p.Estado === 'PARCIAL').length : 0 %></h3>
                        <small class="text-muted">Requieren atención</small>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                            <i class="bi bi-cash-stack text-white"></i>
                        </div>                
                        <h6 class="text-muted">Monto Total Pendiente</h6>
                        <h3 class="text-primary">S/ <%= pagos ? pagos.filter(p => p.Estado !== 'PAGADO').reduce((sum, p) => sum + parseFloat(p.TotalPago || 0), 0).toFixed(2) : '0.00' %></h3>
                        <small class="text-muted">Por pagar a empleados</small>
                    </div>
                </div>

                <!-- Search and Actions -->
                <div class="search-container">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="search-box flex-grow-1 me-3">
                            <div class="d-flex gap-2">
                                <select class="form-select" id="campoFiltro" style="max-width: 200px;">
                                    <option value="0">Empleado</option>
                                    <option value="1">Semana</option>
                                    <option value="2">Año</option>
                                    <option value="3">Período (Inicio-Fin)</option>
                                    <option value="4">Horas Trabajadas</option>
                                    <option value="5">Sueldo Base</option>
                                    <option value="6">Bonificaciones</option>
                                    <option value="7">Descuentos</option>
                                    <option value="8">Total a Pagar</option>
                                    <option value="9">Estado</option>
                                    <option value="10">Método de Pago</option>
                                    <option value="11">Fecha de Pago</option>
                                </select>
                                <input type="text" class="form-control" id="valorFiltro" placeholder="Buscar pagos...">
                            </div>
                        </div>
                        <a href="/pagos/crear" class="btn btn-primary-modern btn-modern">
                            <i class="bi bi-plus-circle"></i>
                            Nuevo Pago
                        </a>
                    </div>
                </div>

                <!-- Tabla de pagos modernizada -->
                <div class="card-modern">
                    <div class="table-responsive">
                        <table class="table table-modern mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"><input class="form-check-input custom-checkbox" type="checkbox"></th>
                                    <th>Empleado <i class="bi bi-arrow-down-up"></i> <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Semana / Año <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Período Laboral <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Horas <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Sueldo Base <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Bonificaciones <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Descuentos <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Total a Pagar <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Estado <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Método de Pago <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Fecha de Pago <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Observaciones <i class="bi bi-arrow-down-up"></i></th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (pagos && pagos.length > 0) { %>
                                    <% pagos.forEach(pago => { %>
                                        <tr>
                                            <td><input class="form-check-input custom-checkbox" type="checkbox"></td>
                                            <td>
                                                <div class="item-info">
                                                    <div class="item-avatar">
                                                        <%= pago.NombreEmpleado ? pago.NombreEmpleado.charAt(0).toUpperCase() : 'E' %>
                                                    </div>
                                                    <div>
                                                        <strong><%= pago.NombreEmpleado || `Empleado ${pago.IdEmpleado}` %></strong>
                                                        <small class="d-block text-muted">ID: <%= pago.IdEmpleado %></small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="text-center">
                                                    <span class="badge bg-primary">Semana <%= pago.Semana %></span>
                                                    <div class="text-muted small mt-1"><%= pago.Anio %></div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="small">
                                                    <div><strong>Inicio:</strong> <%= pago.FechaInicio ? (pago.FechaInicio.toISOString ? pago.FechaInicio.toISOString().substring(0,10) : pago.FechaInicio.substring(0,10)) : 'N/A' %></div>
                                                    <div><strong>Fin:</strong> <%= pago.FechaFin ? (pago.FechaFin.toISOString ? pago.FechaFin.toISOString().substring(0,10) : pago.FechaFin.substring(0,10)) : 'N/A' %></div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info text-dark">
                                                    <i class="bi bi-clock me-1"></i>
                                                    <%= parseFloat(pago.HorasTrabajadas || 0).toFixed(1) %>h
                                                </span>
                                            </td>
                                            <td class="amount-highlight text-end">
                                                <strong>S/ <%= parseFloat(pago.SueldoSemanal || 0).toFixed(2) %></strong>
                                            </td>
                                            <td class="text-end">
                                                <span class="text-success fw-bold">
                                                    + S/ <%= parseFloat(pago.Bonificaciones || 0).toFixed(2) %>
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <span class="text-danger fw-bold">
                                                    - S/ <%= parseFloat(pago.Descuentos || 0).toFixed(2) %>
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <div class="amount-highlight" style="font-size: 1.2rem; padding: 0.5rem; background: #f8f9fa; border-radius: 0.5rem; border-left: 4px solid #0056b3;">
                                                    <strong>S/ <%= parseFloat(pago.TotalPago || 0).toFixed(2) %></strong>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-modern <%= pago.Estado === 'PAGADO' ? 'badge-pagado' : pago.Estado === 'PENDIENTE' ? 'badge-pendiente' : pago.Estado === 'PARCIAL' ? 'badge-pendiente' : 'badge-vencido' %>">
                                                    <i class="bi <%= 
                                                        pago.Estado === 'PAGADO' ? 'bi-check-circle' : 
                                                        pago.Estado === 'PENDIENTE' ? 'bi-clock' : 
                                                        pago.Estado === 'PARCIAL' ? 'bi-clock-history' :
                                                        'bi-x-circle' 
                                                    %>"></i>
                                                    <%= pago.Estado %>
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="small">
                                                    <div class="fw-bold"><%= pago.MetodoPago || 'No especificado' %></div>
                                                    <% if (pago.MetodoPago === 'TRANSFERENCIA') { %>
                                                        <i class="bi bi-bank text-primary"></i>
                                                    <% } else if (pago.MetodoPago === 'EFECTIVO') { %>
                                                        <i class="bi bi-cash text-success"></i>
                                                    <% } else if (pago.MetodoPago === 'CHEQUE') { %>
                                                        <i class="bi bi-receipt text-info"></i>
                                                    <% } else if (pago.MetodoPago === 'DEPOSITO') { %>
                                                        <i class="bi bi-building text-warning"></i>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <% if (pago.FechaPago) { %>
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-calendar-check me-1"></i>
                                                        <%= pago.FechaPago.toISOString ? pago.FechaPago.toISOString().substring(0,10) : pago.FechaPago.substring(0,10) %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">
                                                        <i class="bi bi-calendar-x me-1"></i>
                                                        Sin pagar
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (pago.Comentarios && pago.Comentarios.trim()) { %>
                                                    <span class="small text-muted" title="<%= pago.Comentarios %>">
                                                        <i class="bi bi-chat-dots me-1"></i>
                                                        <%= pago.Comentarios.length > 30 ? pago.Comentarios.substring(0, 30) + '...' : pago.Comentarios %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-muted small">Sin observaciones</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <div class="action-buttons justify-content-center">
                                                    <a href="/pagos/editar/<%= pago.IdPago %>" class="btn-action-icon btn-action-edit" title="Editar pago">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <% if (pago.Estado !== 'PAGADO') { %>
                                                        <a href="/pagos/editar/<%= pago.IdPago %>" class="btn-action-icon btn-action-view text-success" title="Marcar como pagado">
                                                            <i class="bi bi-check-circle"></i>
                                                        </a>
                                                    <% } %>
                                                    <a href="/pagos/eliminar/<%= pago.IdPago %>" class="btn-action-icon btn-action-delete" title="Eliminar pago" onclick="return confirm('¿Está seguro de eliminar este pago?\\n\\nEmpleado: <%= pago.NombreEmpleado || pago.IdEmpleado %>\\nPeríodo: Semana <%= pago.Semana %> del <%= pago.Anio %>\\nTotal: S/ <%= parseFloat(pago.TotalPago || 0).toFixed(2) %>')">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="13" class="text-center py-5">
                                            <div class="d-flex flex-column align-items-center">
                                                <i class="bi bi-cash-coin text-muted" style="font-size: 4rem; opacity: 0.5;"></i>
                                                <h5 class="text-muted mt-3">No hay pagos registrados</h5>
                                                <p class="text-muted">Comience registrando el primer pago de nómina</p>
                                                <a href="/pagos/crear" class="btn btn-primary-modern btn-modern mt-2">
                                                    <i class="bi bi-plus-circle"></i>
                                                    Registrar primer pago
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>// Filtro único con combo box y campo de texto para pagos
        const campoFiltro = document.getElementById('campoFiltro');
        const valorFiltro = document.getElementById('valorFiltro');
        if (campoFiltro && valorFiltro) {
            valorFiltro.addEventListener('input', filtrarTablaPagos);
            campoFiltro.addEventListener('change', filtrarTablaPagos);
        }

        function filtrarTablaPagos() {
            const col = parseInt(campoFiltro.value);
            const searchTerm = valorFiltro.value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                if (row.querySelectorAll('td').length < 13) return;
                
                const cell = row.querySelectorAll('td')[col];
                let cellText = cell.textContent.toLowerCase();
                
                // Para campos de montos, eliminar el símbolo "s/" y signos
                if (col === 4 || col === 5 || col === 6 || col === 7) {
                    cellText = cellText.replace(/s\/|\+|\-/g, '').trim();
                }
                
                if (cell && cellText.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
    <script src="/publico/js/layout.js?v=1772427290144"></script>
</body>
</html>
