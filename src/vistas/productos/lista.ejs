<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Productos - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290145">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <!-- Botón para ocultar/mostrar barra -->

            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-box"></i>
                            Gestión de Productos
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid py-4">
                    <!-- Estadísticas -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon" style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                                <i class="bi bi-box text-white"></i>
                            </div>
                            <h6 class="text-muted">Total Productos</h6>
                            <h3 class="text-primary">
                                <%= productos ? productos.length : 0 %>
                            </h3>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon" style="background: linear-gradient(135deg, #55efc4, #00b894);">
                                <i class="bi bi-check-circle text-white"></i>
                            </div>
                            <h6 class="text-muted">Disponibles</h6>
                            <h3 class="text-success">
                                <%= productos ? productos.length : 0 %>
                            </h3>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon" style="background: linear-gradient(135deg, #ffeaa7, #fdcb6e);">
                                <i class="bi bi-exclamation-triangle text-white"></i>
                            </div>
                            <h6 class="text-muted">Stock Bajo</h6>
                            <h3 class="text-warning">0</h3>
                        </div>
                    </div>

                    <!-- Mensajes -->
                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>
                            <%= success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    <%= error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <!-- Búsqueda y acciones -->
                                    <div class="search-container">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2 flex-grow-1 me-3">
                                                <!-- Filtro por tipo de código -->
                                                <div class="d-flex gap-2 align-items-center">

                                                    <form action="/productos" method="GET" class="d-flex gap-2">

                                                        <% if (typeof codigo !=='undefined' && codigo) { %>
                                                            <a href="/productos" class="btn btn-outline-secondary">
                                                                <i class="bi bi-x-circle"></i> Limpiar
                                                            </a>
                                                            <% } %>
                                                    </form>
                                                </div>

                                                <!-- Búsqueda general -->
                                                <div class="ms-3 d-flex gap-2 flex-grow-1">
                                                    <select class="form-select" id="campoFiltro"
                                                        style="max-width: 180px;">
                                                        <option value="0">Código</option>
                                                        <option value="1">Nombre</option>
                                                        <option value="2">Descripción</option>
                                                        <option value="3">Marca</option>
                                                        <option value="4">Modelo</option>
                                                        <option value="5">Tipo</option>
                                                        <option value="6">Precio</option>
                                                    </select>
                                                    <input type="text" class="form-control" id="valorFiltro"
                                                        placeholder="Buscar productos...">
                                                </div>
                                            </div>
                                            <a href="/productos/crear" class="btn btn-primary-modern btn-modern">
                                                <i class="bi bi-plus-circle"></i>
                                                Nuevo Producto
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Tabla modernizada -->
                                    <div class="card-modern">
                                        <div class="table-responsive">
                                            <table class="table table-modern mb-0">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 40px;"><input
                                                                class="form-check-input custom-checkbox"
                                                                type="checkbox"></th>
                                                        <th>Código <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Nombre <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Descripción <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Marca <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Modelo <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Tipo <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Unidad <i class="bi bi-arrow-down-up"></i></th>
                                                        <th>Precio Unitario <i class="bi bi-arrow-down-up"></i></th>
                                                        <th class="text-center">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (productos && productos.length> 0) { %>
                                                        <% productos.forEach(producto=> { %>
                                                            <tr>
                                                                <td><input class="form-check-input custom-checkbox"
                                                                        type="checkbox"></td>
                                                                <td>
                                                                    <span class="fw-bold text-primary">
                                                                        <%= producto.Codigo %>
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <div class="item-info">
                                                                        <div class="item-avatar">
                                                                            <%= producto.Nombre ?
                                                                                producto.Nombre.charAt(0).toUpperCase()
                                                                                : 'P' %>
                                                                        </div>
                                                                        <div class="item-details">
                                                                            <strong>
                                                                                <%= producto.Nombre %>
                                                                            </strong>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <%= producto.Descripcion %>
                                                                </td>
                                                                <td>
                                                                    <%= producto.Marca %>
                                                                </td>
                                                                <td>
                                                                    <%= producto.Modelo %>
                                                                </td>
                                                                <td>
                                                                    <span class="badge bg-light text-dark">
                                                                        <%= producto.Tipo %>
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <%= producto.UnidadMedida %>
                                                                </td>
                                                                <td class="price-cell">S/ <%= producto.PrecioUnitario %>
                                                                </td>
                                                                <td class="text-center">
                                                                    <div class="action-buttons justify-content-center">
                                                                        <a href="/productos/editar/<%= producto.IdProducto %>"
                                                                            class="btn-action-icon btn-action-edit"
                                                                            title="Editar">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </a>
                                                                        <a href="/productos/eliminar/<%= producto.IdProducto %>"
                                                                            class="btn-action-icon btn-action-delete"
                                                                            title="Eliminar"
                                                                            onclick="return confirm('¿Está seguro de eliminar este producto?')">
                                                                            <i class="bi bi-trash"></i>
                                                                        </a>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            <% }); %>
                                                                <% } else { %>
                                                                    <tr>
                                                                        <td colspan="9" class="text-center py-5">
                                                                            <i class="bi bi-box text-muted"
                                                                                style="font-size: 3rem;"></i>
                                                                            <p class="text-muted mt-2">
                                                                                <% if (codigo && codigo.length> 0) { %>
                                                                                    No se encontraron productos con el
                                                                                    código "<%= codigo %>"
                                                                                        <% } else if (terminoBusqueda &&
                                                                                            terminoBusqueda.length> 0) {
                                                                                            %>
                                                                                            No se encontraron productos
                                                                                            que coincidan con "<%=
                                                                                                terminoBusqueda %>"
                                                                                                <% } else { %>
                                                                                                    No hay productos
                                                                                                    registrados.
                                                                                                    <% } %>
                                                                            </p>
                                                                            <a href="/productos/crear"
                                                                                class="btn btn-primary-modern btn-modern">
                                                                                <i class="bi bi-plus-circle"></i>
                                                                                Agregar producto
                                                                            </a>
                                                                        </td>
                                                                    </tr>
                                                                    <% } %>
                                                </tbody>
                                            </table>

                                            <!-- Paginación Modernizada -->
                                            <div class="pagination-modern">
                                                <div class="pagination-info">
                                                    Showing 1 - <%= productos ? productos.length : 0 %> of <%= productos
                                                            ? productos.length : 0 %>
                                                </div>
                                                <ul class="pagination-controls">
                                                    <li><button class="page-item-modern disabled"><i
                                                                class="bi bi-chevron-left"></i></button></li>
                                                    <li><button class="page-item-modern active">1</button></li>
                                                    <li><button class="page-item-modern disabled"><i
                                                                class="bi bi-chevron-right"></i></button></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');

            // Toggle sidebar
            toggleBtn.addEventListener('click', function () {
                sidebar.classList.toggle('hide');
                mainContent.classList.toggle('full');
                if (sidebar.classList.contains('hide')) {
                    toggleIcon.classList.remove('bi-chevron-left');
                    toggleIcon.classList.add('bi-chevron-right');
                } else {
                    toggleIcon.classList.remove('bi-chevron-right');
                    toggleIcon.classList.add('bi-chevron-left');
                }
            });

            // Filtro de tabla
            const campoFiltro = document.getElementById('campoFiltro');
            const valorFiltro = document.getElementById('valorFiltro');
            if (campoFiltro && valorFiltro) {
                valorFiltro.addEventListener('input', filtrarTablaProductos);
                campoFiltro.addEventListener('change', filtrarTablaProductos);
            }

            function filtrarTablaProductos() {
                const col = parseInt(campoFiltro.value);
                const searchTerm = valorFiltro.value.toLowerCase();
                const rows = document.querySelectorAll('tbody tr');

                rows.forEach(row => {
                    if (row.querySelectorAll('td').length < 9) return;

                    const cell = row.querySelectorAll('td')[col];
                    let cellText = cell.textContent.toLowerCase();

                    if (col === 7) {
                        cellText = cellText.replace('s/', '').trim();
                    }

                    if (cell && cellText.includes(searchTerm)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }
        });
    </script>
    <script src="/publico/js/layout.js?v=1772427290145"></script>
</body>

</html>