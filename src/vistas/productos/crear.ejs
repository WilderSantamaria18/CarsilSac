<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Producto - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290145">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290145">
    
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-box-seam me-2"></i>
                        Registro de Nuevo Producto
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Usuario' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %></div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Mensajes flash -->
                <% if (messages && messages.success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i><%= messages.success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (messages && messages.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i><%= messages.error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <div class="page-header">
                    <h4 class="text-primary mb-2"><i class="bi bi-box-seam me-2"></i>Agregar Nuevo Producto al Inventario</h4>
                    <p class="text-muted">Complete los siguientes campos para registrar un nuevo producto en el sistema.</p>
                </div>

                <!-- Formulario modernizado -->
                <div class="card-modern">
                    <div class="card-body p-4">
                        <form action="/productos/crear" method="POST">
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Código del Producto</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-modern">
                                                <i class="bi bi-upc-scan"></i>
                                            </span>
                                            <input type="text" name="Codigo" class="form-control-modern input-modern" placeholder="Ej: PROD-001" required>
                                        </div>
                                        <small class="text-muted">Código único que identifica al producto</small>
                                    </div>
                                </div>
                                
                                <div class="col-md-8">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Nombre del Producto</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-modern">
                                                <i class="bi bi-tag"></i>
                                            </span>
                                            <input type="text" name="Nombre" class="form-control-modern input-modern" placeholder="Ej: Bomba Hidráulica Industrial" required>
                                        </div>
                                        <small class="text-muted">Nombre comercial o descriptivo del producto</small>
                                    </div>
                                </div>
                                
                                <div class="col-md-12">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Descripción Detallada</label>
                                        <textarea name="Descripcion" class="form-control-modern input-modern" rows="3" placeholder="Detalles específicos, características, aplicaciones..."></textarea>
                                        <small class="text-muted">Incluya especificaciones técnicas y detalles relevantes</small>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Marca</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-modern">
                                                <i class="bi bi-building"></i>
                                            </span>
                                            <input type="text" name="Marca" class="form-control-modern input-modern" placeholder="Ej: Grundfos">
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Modelo</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-modern">
                                                <i class="bi bi-diagram-3"></i>
                                            </span>
                                            <input type="text" name="Modelo" class="form-control-modern input-modern" placeholder="Ej: CR 15-3">
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Tipo de Producto</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-modern">
                                                <i class="bi bi-grid"></i>
                                            </span>
                                            <input type="text" name="Tipo" class="form-control-modern input-modern" placeholder="Ej: Bomba Centrífuga">
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Unidad de Medida</label>
                                        <select name="UnidadMedida" class="form-control-modern form-select-modern input-modern">
                                            <option value="UNID" selected>Unidad (UNID)</option>
                                            <option value="KG">Kilogramo (KG)</option>
                                            <option value="MT">Metro (MT)</option>
                                            <option value="LT">Litro (LT)</option>
                                            <option value="JGO">Juego (JGO)</option>
                                            <option value="PAR">Par (PAR)</option>
                                            <option value="CAJA">Caja (CAJA)</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-group-modern">
                                        <label class="label-modern">Precio Unitario (S/)</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-modern">
                                                <i class="bi bi-currency-dollar"></i>
                                            </span>
                                            <input type="number" step="0.01" min="0" name="PrecioUnitario" class="form-control-modern input-modern" placeholder="0.00" required>
                                        </div>
                                        <small class="text-muted">Precio sin IGV</small>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top">
                                <a href="/productos" class="btn-form btn-form-cancel-modern btn-modern">
                                    <i class="bi bi-x-circle"></i>
                                    Cancelar
                                </a>
                                <button type="submit" class="btn-form btn-form-primary-modern btn-modern">
                                    <i class="bi bi-save"></i>
                                    Guardar Producto
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        
        // Toggle sidebar
        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });
    });
    </script>
    <script src="/publico/js/layout.js?v=1772427290145"></script>
</body>
</html>
