<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuevo Empleado - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=<%= Date.now() %>">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-person-plus"></i>
                            Nuevo Empleado
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="form-container">
                    <div class="form-card">
                        <div class="form-header-title">
                            <i class="bi bi-person-plus"></i> Registrar Nuevo Trabajador
                        </div>

                        <div class="form-body">
                            <form action="/empleados" method="POST">
                                <!-- Sección de Información Personal -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-person-lines-fill"></i> Información Personal
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="IdUsuario" class="form-label">
                                                    <i class="bi bi-person-badge"></i> Usuario Asociado
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="IdUsuario"
                                                    name="IdUsuario" required>
                                                    <option value="">Seleccionar usuario...</option>
                                                    <% usuarios.forEach(u=> { %>
                                                        <option value="<%= u.IdUsuario %>">
                                                            <%= u.Nombres %>
                                                                <%= u.Apellidos %> (<%= u.Correo %>)
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Cargo" class="form-label">
                                                    <i class="bi bi-briefcase"></i> Cargo
                                                </label>
                                                <input type="text" class="form-control-modern" id="Cargo" name="Cargo"
                                                    placeholder="Ej: Técnico, Ingeniero..." required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Area" class="form-label">
                                                    <i class="bi bi-building"></i> Área
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <input type="text" class="form-control-modern" id="Area" name="Area"
                                                    placeholder="Ej: Producción, Ventas...">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="FechaContratacion" class="form-label">
                                                    <i class="bi bi-calendar-event"></i> Fecha de Contratación
                                                </label>
                                                <input type="date" class="form-control-modern" id="FechaContratacion"
                                                    name="FechaContratacion" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="TipoContrato" class="form-label">
                                                    <i class="bi bi-file-earmark-text"></i> Tipo de Contrato
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="TipoContrato"
                                                    name="TipoContrato">
                                                    <option value="INDEFINIDO" selected>Indefinido</option>
                                                    <option value="TEMPORAL">Temporal</option>
                                                    <option value="PRACTICAS">Prácticas</option>
                                                    <option value="OBRA_DETERMINADA">Obra determinada</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="SueldoBase" class="form-label">
                                                    <i class="bi bi-cash-coin"></i> Sueldo Base (S/)
                                                </label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="SueldoBase" name="SueldoBase" placeholder="0.00" required>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Información Bancaria -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-bank"></i> Información Bancaria
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Banco" class="form-label">
                                                    <i class="bi bi-bank2"></i> Banco
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <input type="text" class="form-control-modern" id="Banco" name="Banco"
                                                    placeholder="Ej: BCP, Interbank...">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="NumeroCuenta" class="form-label">
                                                    <i class="bi bi-credit-card"></i> Número de Cuenta
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <input type="text" class="form-control-modern" id="NumeroCuenta"
                                                    name="NumeroCuenta" placeholder="Número de cuenta bancaria">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="TipoCuenta" class="form-label">
                                                    <i class="bi bi-wallet2"></i> Tipo de Cuenta
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="TipoCuenta"
                                                    name="TipoCuenta">
                                                    <option value="AHORROS" selected>Ahorros</option>
                                                    <option value="CORRIENTE">Corriente</option>
                                                    <option value="NOMINA">Nómina</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Estado -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-info-circle"></i> Estado del Empleado
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Estado" class="form-label">
                                                    <i class="bi bi-toggle-on"></i> Estado
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="Estado"
                                                    name="Estado">
                                                    <option value="ACTIVO" selected>Activo</option>
                                                    <option value="INACTIVO">Inactivo</option>
                                                    <option value="VACACIONES">Vacaciones</option>
                                                    <option value="LICENCIA">Licencia</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-buttons">
                                    <a href="/empleados" class="btn btn-form btn-form-cancel">
                                        <i class="bi bi-arrow-left me-2"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-form-primary">
                                        <i class="bi bi-save me-2"></i> Guardar Empleado
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Establecer fecha actual como predeterminada para contratación
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('FechaContratacion').value = today;
        });
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>