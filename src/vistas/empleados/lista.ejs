<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Empleados - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290135">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
    </style>
</head>
<body class="bg-[#f6f6f8] text-slate-900 font-display">
<div class="wrapper">
    <%- include("../parciales/sidebar") %>

    <div class="main-content" id="main-content">

        <!-- Content -->
        <div class="p-8">

            <!-- Page Title -->
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Gestión de Empleados</h2>
                <p class="text-slate-500">Administra el equipo de trabajo de CARSIL Equipos y Servicios SAC.</p>
            </div>

            <!-- Flash messages -->
            <% const flashSuccess = success && success.length > 0 ? (Array.isArray(success) ? success[0] : success) : null; %>
            <% const flashError = error && error.length > 0 ? (Array.isArray(error) ? error[0] : error) : null; %>
            <% if (flashSuccess) { %>
            <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                <span><%= flashSuccess %></span>
            </div>
            <% } %>
            <% if (flashError) { %>
            <div class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-rose-500">error</span>
                <span><%= flashError %></span>
            </div>
            <% } %>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-[#3b4bc9]">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total Empleados</p>
                    <p class="text-3xl font-bold text-[#3b4bc9]"><%= empleados ? empleados.length : 0 %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-emerald-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Activos</p>
                    <p class="text-3xl font-bold text-emerald-600"><%= empleados ? empleados.filter(e => e.Estado === 'ACTIVO').length : 0 %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-slate-400">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Inactivos</p>
                    <p class="text-3xl font-bold text-slate-500"><%= empleados ? empleados.filter(e => e.Estado !== 'ACTIVO').length : 0 %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-violet-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Nómina Total</p>
                    <p class="text-2xl font-bold text-violet-600">S/ <%= empleados ? empleados.reduce((s, e) => s + parseFloat(e.SueldoBase || 0), 0).toFixed(2) : '0.00' %></p>
                </div>
            </div>

            <!-- Filter Bar -->
            <div class="bg-white p-4 rounded-xl border border-slate-100 mb-6 flex flex-wrap gap-4 items-center shadow-sm">
                <div class="flex-1 min-w-[260px] relative group">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#3b4bc9] transition-colors">search</span>
                    <input id="valorFiltro"
                           class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] transition-all text-sm outline-none"
                           placeholder="Buscar empleados..." type="text" />
                </div>
                <select id="campoFiltro"
                        class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                    <option value="0">Empleado</option>
                    <option value="1">Cargo</option>
                    <option value="2">Área</option>
                    <option value="3">Estado</option>
                </select>
                <button onclick="abrirModalCrear()"
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 hover:shadow-lg transition-all text-sm">
                    <span class="material-symbols-outlined text-sm">person_add</span>
                    Nuevo Empleado
                </button>
            </div>

            <!-- Data Table -->
            <div class="bg-white rounded-xl border border-slate-100 shadow-md overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200">
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Empleado</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Contacto</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Cargo / Área</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Contrato</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Sueldo</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Banco</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Estado</th>
                                <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100" id="tbodyEmpleados">
                            <% if (empleados && empleados.length > 0) { %>
                            <% empleados.forEach(e => { %>
                            <tr class="hover:bg-slate-50/60 transition-colors">
                                <!-- Empleado -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] font-bold text-sm flex-shrink-0">
                                            <%= e.Nombres ? e.Nombres.charAt(0).toUpperCase() : 'E' %><%= e.Apellidos ? e.Apellidos.charAt(0).toUpperCase() : '' %>
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold leading-tight"><%= e.Apellidos %>, <%= e.Nombres %></p>
                                            <p class="text-xs text-slate-400 mt-0.5">ID: <%= e.IdEmpleado %></p>
                                        </div>
                                    </div>
                                </td>
                                <!-- Contacto -->
                                <td class="px-6 py-4">
                                    <div class="flex flex-col gap-0.5">
                                        <% if (e.Correo) { %>
                                        <span class="text-xs text-slate-600 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm text-slate-400">mail</span>
                                            <%= e.Correo %>
                                        </span>
                                        <% } %>
                                        <% if (e.Telefono) { %>
                                        <span class="text-xs text-slate-600 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm text-slate-400">phone</span>
                                            <%= e.Telefono %>
                                        </span>
                                        <% } %>
                                        <% if (!e.Correo && !e.Telefono) { %><span class="text-slate-300 text-sm">—</span><% } %>
                                    </div>
                                </td>
                                <!-- Cargo / Área -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <p class="text-sm font-medium text-slate-700"><%= e.Cargo %></p>
                                    <p class="text-xs text-slate-400 mt-0.5"><%= e.Area || 'Sin área' %></p>
                                </td>
                                <!-- Contrato -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <p class="text-xs text-slate-500 font-medium"><%= e.TipoContrato || 'Sin especificar' %></p>
                                    <p class="text-xs text-slate-400 mt-0.5">
                                        <%= e.FechaContratacion ? new Date(e.FechaContratacion).toLocaleDateString('es-PE', {day:'2-digit',month:'short',year:'numeric'}) : 'N/A' %>
                                    </p>
                                </td>
                                <!-- Sueldo -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm font-bold text-emerald-700">S/ <%= Number(e.SueldoBase || 0).toFixed(2) %></span>
                                </td>
                                <!-- Banco -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (e.Banco) { %>
                                    <p class="text-xs font-medium text-slate-700"><%= e.Banco %></p>
                                    <p class="text-xs text-slate-400 font-mono mt-0.5"><%= e.NumeroCuenta || '—' %></p>
                                    <% } else { %><span class="text-slate-300 text-sm">—</span><% } %>
                                </td>
                                <!-- Estado -->
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% const estadoClasses = {
                                        'ACTIVO':    'bg-emerald-50 text-emerald-700',
                                        'INACTIVO':  'bg-slate-100 text-slate-500',
                                        'VACACIONES':'bg-sky-50 text-sky-700',
                                        'LICENCIA':  'bg-amber-50 text-amber-700'
                                    }; %>
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider <%= estadoClasses[e.Estado] || 'bg-slate-100 text-slate-500' %>">
                                        <%= e.Estado %>
                                    </span>
                                </td>
                                <!-- Acciones -->
                                <td class="px-6 py-4 whitespace-nowrap text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <button
                                            onclick="abrirModalEditar(this)"
                                            data-id="<%= e.IdEmpleado %>"
                                            data-cargo="<%= (e.Cargo||'').replace(/\"/g,'&quot;') %>"
                                            data-area="<%= (e.Area||'').replace(/\"/g,'&quot;') %>"
                                            data-fechacontratacion="<%= e.FechaContratacion ? new Date(e.FechaContratacion).toISOString().split('T')[0] : '' %>"
                                            data-tipocontrato="<%= e.TipoContrato||'INDEFINIDO' %>"
                                            data-sueldobase="<%= e.SueldoBase||0 %>"
                                            data-banco="<%= (e.Banco||'').replace(/\"/g,'&quot;') %>"
                                            data-numerocuenta="<%= (e.NumeroCuenta||'').replace(/\"/g,'&quot;') %>"
                                            data-tipocuenta="<%= e.TipoCuenta||'AHORROS' %>"
                                            data-estado="<%= e.Estado||'ACTIVO' %>"
                                            data-nombre="<%= (e.Nombres+' '+e.Apellidos).replace(/\"/g,'&quot;') %>"
                                            class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                            title="Editar">
                                            <span class="material-symbols-outlined text-lg leading-none">edit</span>
                                        </button>
                                        <form action="/empleados/<%= e.IdEmpleado %>/delete" method="POST" class="inline"
                                              onsubmit="return confirm('¿Eliminar a <%= e.Nombres %> <%= e.Apellidos %>?')">
                                            <button type="submit" class="p-1.5 hover:bg-rose-50 rounded-lg transition-colors text-slate-500 hover:text-rose-600" title="Eliminar">
                                                <span class="material-symbols-outlined text-lg leading-none">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                            <% } else { %>
                            <tr>
                                <td colspan="8" class="text-center py-16">
                                    <span class="material-symbols-outlined text-5xl text-slate-300 block mb-3">badge</span>
                                    <p class="text-slate-500 font-medium mb-1">No hay empleados registrados</p>
                                    <p class="text-slate-400 text-sm mb-5">Comience agregando su primer empleado</p>
                                    <button onclick="abrirModalCrear()"
                                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 transition-all text-sm">
                                        <span class="material-symbols-outlined text-sm">person_add</span>
                                        Nuevo Empleado
                                    </button>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                    <p class="text-sm text-slate-500">
                        Mostrando <span id="visibleCount"><%= empleados ? empleados.length : 0 %></span>
                        de <strong><%= empleados ? empleados.length : 0 %></strong> empleados
                    </p>
                </div>
            </div>
        </div><!-- /p-8 -->
    </div><!-- /main-content -->
</div><!-- /wrapper -->


<!-- ==================== MODAL NUEVO EMPLEADO ==================== -->
<div id="modalCrear"
     class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4 hidden"
     onclick="cerrarSiOverlay(event,'modalCrear')">
    <div class="bg-white w-full max-w-2xl rounded-xl shadow-2xl overflow-hidden border border-slate-200 flex flex-col max-h-[90vh]"
         onclick="event.stopPropagation()">
        <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center flex-shrink-0">
            <div>
                <h2 class="text-xl font-bold text-slate-900 tracking-tight">Registrar Nuevo Empleado</h2>
                <p class="text-slate-500 text-sm mt-1">Complete los datos del nuevo trabajador.</p>
            </div>
            <button onclick="cerrarModal('modalCrear')" class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form action="/empleados" method="POST" autocomplete="off" class="flex flex-col overflow-hidden flex-1">
            <div class="px-8 py-6 space-y-6 overflow-y-auto flex-1">

                <!-- Info Laboral -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-[#3b4bc9] text-xl">work</span>
                        <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Información Laboral</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Usuario Asociado</label>
                            <select name="IdUsuario" required
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="">Seleccionar usuario...</option>
                                <% if (typeof usuarios !== 'undefined') { usuarios.forEach(u => { %>
                                <option value="<%= u.IdUsuario %>"><%= u.Nombres %> <%= u.Apellidos %> (<%= u.Correo %>)</option>
                                <% }); } %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Cargo</label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">badge</span>
                                </div>
                                <input name="Cargo" required placeholder="Ej: Técnico Mecánico" type="text"
                                       class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Área <span class="text-slate-400 font-normal text-xs">Opcional</span></label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">corporate_fare</span>
                                </div>
                                <input name="Area" placeholder="Ej: Producción, Ventas..." type="text"
                                       class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Fecha de Contratación</label>
                            <input name="FechaContratacion" required type="date"
                                   class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Tipo de Contrato</label>
                            <select name="TipoContrato"
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="INDEFINIDO">Indefinido</option>
                                <option value="TEMPORAL">Temporal</option>
                                <option value="PRACTICAS">Prácticas</option>
                                <option value="OBRA_DETERMINADA">Obra determinada</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Sueldo Base (S/)</label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">payments</span>
                                </div>
                                <input name="SueldoBase" required placeholder="0.00" type="number" step="0.01" min="0"
                                       class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Estado</label>
                            <select name="Estado"
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="ACTIVO">Activo</option>
                                <option value="INACTIVO">Inactivo</option>
                                <option value="VACACIONES">Vacaciones</option>
                                <option value="LICENCIA">Licencia</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Info Bancaria -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-[#3b4bc9] text-xl">account_balance</span>
                        <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Información Bancaria <span class="text-slate-400 font-normal normal-case">Opcional</span></h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Banco</label>
                            <input name="Banco" placeholder="Ej: BCP, Interbank..." type="text"
                                   class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Número de Cuenta</label>
                            <input name="NumeroCuenta" placeholder="Número de cuenta bancaria" type="text"
                                   class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none font-mono">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Tipo de Cuenta</label>
                            <select name="TipoCuenta"
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="AHORROS">Ahorros</option>
                                <option value="CORRIENTE">Corriente</option>
                                <option value="NOMINA">Nómina</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-8 py-5 bg-slate-50 border-t border-slate-100 flex justify-end gap-3 flex-shrink-0">
                <button type="button" onclick="cerrarModal('modalCrear')"
                        class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-lg transition-colors border border-slate-200">
                    Cancelar
                </button>
                <button type="submit"
                        class="px-6 py-2.5 text-sm font-bold text-white bg-[#3b4bc9] hover:bg-[#3b4bc9]/90 rounded-lg shadow-lg shadow-[#3b4bc9]/20 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Guardar Empleado
                </button>
            </div>
        </form>
    </div>
</div>


<!-- ==================== MODAL EDITAR EMPLEADO ==================== -->
<div id="modalEditar"
     class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4 hidden"
     onclick="cerrarSiOverlay(event,'modalEditar')">
    <div class="bg-white w-full max-w-2xl rounded-xl shadow-2xl overflow-hidden border border-slate-200 flex flex-col max-h-[90vh]"
         onclick="event.stopPropagation()">
        <!-- Header dinámico con avatar -->
        <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center flex-shrink-0">
            <div class="flex items-center gap-4">
                <div id="editAvatarBadge" class="w-12 h-12 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] font-bold text-lg flex-shrink-0"></div>
                <div>
                    <h2 id="editTitulo" class="text-xl font-bold text-slate-900 tracking-tight">Editar Empleado</h2>
                    <p class="text-slate-500 text-sm mt-0.5">Actualice los datos del empleado seleccionado.</p>
                </div>
            </div>
            <button onclick="cerrarModal('modalEditar')" class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form id="formEditar" method="POST" autocomplete="off" class="flex flex-col overflow-hidden flex-1">
            <input type="hidden" name="_method" value="PUT">
            <div class="px-8 py-6 space-y-6 overflow-y-auto flex-1">

                <!-- Info Laboral -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-[#3b4bc9] text-xl">work</span>
                        <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Información Laboral</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Cargo</label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">badge</span>
                                </div>
                                <input id="e_cargo" name="Cargo" required type="text"
                                       class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Área</label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">corporate_fare</span>
                                </div>
                                <input id="e_area" name="Area" type="text"
                                       class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Fecha de Contratación</label>
                            <input id="e_fechacontratacion" name="FechaContratacion" required type="date"
                                   class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Tipo de Contrato</label>
                            <select id="e_tipocontrato" name="TipoContrato"
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="INDEFINIDO">Indefinido</option>
                                <option value="TEMPORAL">Temporal</option>
                                <option value="PRACTICAS">Prácticas</option>
                                <option value="OBRA_DETERMINADA">Obra determinada</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Sueldo Base (S/)</label>
                            <div class="relative group">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-slate-400 text-sm group-focus-within:text-[#3b4bc9] transition-colors">payments</span>
                                </div>
                                <input id="e_sueldobase" name="SueldoBase" required type="number" step="0.01" min="0"
                                       class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Estado</label>
                            <select id="e_estado" name="Estado"
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="ACTIVO">Activo</option>
                                <option value="INACTIVO">Inactivo</option>
                                <option value="VACACIONES">Vacaciones</option>
                                <option value="LICENCIA">Licencia</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Info Bancaria -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-[#3b4bc9] text-xl">account_balance</span>
                        <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Información Bancaria</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Banco</label>
                            <input id="e_banco" name="Banco" placeholder="Ej: BCP, Interbank..." type="text"
                                   class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Número de Cuenta</label>
                            <input id="e_numerocuenta" name="NumeroCuenta" type="text"
                                   class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none font-mono">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1.5">Tipo de Cuenta</label>
                            <select id="e_tipocuenta" name="TipoCuenta"
                                    class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] text-sm outline-none">
                                <option value="AHORROS">Ahorros</option>
                                <option value="CORRIENTE">Corriente</option>
                                <option value="NOMINA">Nómina</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-8 py-5 bg-slate-50 border-t border-slate-100 flex justify-end gap-3 flex-shrink-0">
                <button type="button" onclick="cerrarModal('modalEditar')"
                        class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-lg transition-colors border border-slate-200">
                    Cancelar
                </button>
                <button type="submit"
                        class="px-6 py-2.5 text-sm font-bold text-white bg-[#3b4bc9] hover:bg-[#3b4bc9]/90 rounded-lg shadow-lg shadow-[#3b4bc9]/20 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>


<script>
    // ——— Filtro tabla ———
    const campoFiltro = document.getElementById('campoFiltro');
    const valorFiltro = document.getElementById('valorFiltro');
    const colMap = { '0': 0, '1': 2, '2': 2, '3': 6 };

    if (campoFiltro && valorFiltro) {
        const colReal = { '0': 0, '1': 2, '2': 2, '3': 6 };
        [campoFiltro, valorFiltro].forEach(el =>
            el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', filtrarTabla)
        );
        function filtrarTabla() {
            const col = parseInt(campoFiltro.value);
            const realCol = [0, 2, 2, 6][col] ?? 0;
            const term = valorFiltro.value.toLowerCase();
            let vis = 0;
            document.querySelectorAll('#tbodyEmpleados tr').forEach(row => {
                const cell = row.querySelectorAll('td')[realCol];
                const show = cell && cell.textContent.toLowerCase().includes(term);
                row.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            const vc = document.getElementById('visibleCount');
            if (vc) vc.textContent = vis;
        }
    }

    // ——— Modales ———
    function cerrarModal(id) {
        document.getElementById(id).classList.add('hidden');
        document.body.style.overflow = '';
    }
    function abrirModal(id) {
        document.getElementById(id).classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function cerrarSiOverlay(e, id) {
        if (e.target === document.getElementById(id)) cerrarModal(id);
    }

    function abrirModalCrear() { abrirModal('modalCrear'); }

    function abrirModalEditar(btn) {
        const d = btn.dataset;

        // Avatar y título
        const initials = d.nombre ? d.nombre.trim().split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase() : 'E';
        document.getElementById('editAvatarBadge').textContent = initials;
        document.getElementById('editTitulo').textContent = 'Editar: ' + (d.nombre || 'Empleado');

        document.getElementById('formEditar').action = `/empleados/${d.id}?_method=PUT`;

        document.getElementById('e_cargo').value             = d.cargo          || '';
        document.getElementById('e_area').value              = d.area           || '';
        document.getElementById('e_fechacontratacion').value = d.fechacontratacion || '';
        document.getElementById('e_sueldobase').value        = d.sueldobase     || '0';
        document.getElementById('e_banco').value             = d.banco          || '';
        document.getElementById('e_numerocuenta').value      = d.numerocuenta   || '';

        setSelect('e_tipocontrato', d.tipocontrato || 'INDEFINIDO');
        setSelect('e_tipocuenta',   d.tipocuenta   || 'AHORROS');
        setSelect('e_estado',       d.estado       || 'ACTIVO');

        abrirModal('modalEditar');
    }

    function setSelect(id, val) {
        const sel = document.getElementById(id);
        for (let opt of sel.options) opt.selected = opt.value === val;
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { cerrarModal('modalCrear'); cerrarModal('modalEditar'); }
    });
</script>
<script src="/publico/js/layout.js?v=1772427290135"></script>
</body>
</html>
