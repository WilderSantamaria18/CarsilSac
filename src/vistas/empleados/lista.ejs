<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Empleados - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290139">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-person-badge"></i>
                        Gestión de Empleados
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Mensajes flash eliminados según solicitud del usuario -->

                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #28a745, #20c997);">
                            <i class="bi bi-person-badge text-white"></i>
                        </div>
                        <h6 class="text-muted">Total Empleados</h6>
                        <h3 class="text-primary"><%= empleados ? empleados.length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                            <i class="bi bi-check-circle text-white"></i>
                        </div>
                        <h6 class="text-muted">Activos</h6>
                        <h3 class="text-success"><%= empleados ? empleados.filter(e => e.Estado === 'ACTIVO').length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6c757d, #495057);">
                            <i class="bi bi-pause-circle text-white"></i>
                        </div>
                        <h6 class="text-muted">Inactivos</h6>
                        <h3 class="text-muted"><%= empleados ? empleados.filter(e => e.Estado !== 'ACTIVO').length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6f42c1, #6610f2);">
                            <i class="bi bi-currency-dollar text-white"></i>
                        </div>
                        <h6 class="text-muted">Nómina Total</h6>
                        <h3 class="text-info">S/ <%= empleados ? empleados.reduce((sum, e) => sum + parseFloat(e.SueldoBase || 0), 0).toFixed(2) : '0.00' %></h3>
                    </div>
                </div>

                <!-- Search and Actions -->
                <div class="search-container">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="search-box flex-grow-1 me-3">
                            <div class="d-flex gap-2">
                                <select class="form-select" id="campoFiltroEmpleado" style="max-width: 180px;">
                                    <option value="0">Empleado</option>
                                    <option value="1">Contacto</option>
                                    <option value="2">Cargo</option>
                                    <option value="3">Área</option>
                                    <option value="4">Contratación</option>
                                    <option value="5">Sueldo</option>
                                    <option value="6">Banco</option>
                                    <option value="7">Estado</option>
                                </select>
                                <input type="text" class="form-control" id="valorFiltroEmpleado" placeholder="Buscar empleados...">
                            </div>
                        </div>
                        <a href="/empleados/create" class="btn btn-primary-modern btn-modern">
                            <i class="bi bi-plus-circle"></i>
                            Nuevo Empleado
                        </a>
                    </div>
                </div>

                <!-- Tabla de empleados modernizada -->
                <div class="card-modern">
                    <div class="table-responsive">
                        <table class="table table-modern mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"><input class="form-check-input custom-checkbox" type="checkbox"></th>
                                    <th>Empleado <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Contacto <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Cargo <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Área <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Contratación <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Sueldo <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Datos Bancarios <i class="bi bi-arrow-down-up"></i></th>
                                    <th>Estado <i class="bi bi-arrow-down-up"></i></th>
                                    <th class="text-center"><i class="bi bi-gear me-1"></i>Acciones <i class="bi bi-arrow-down-up"></i></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (empleados && empleados.length > 0) { %>
                                    <% empleados.forEach(e => { %>
                                        <tr>
                                            <td><input class="form-check-input custom-checkbox" type="checkbox"></td>
                                            <td>
                                                <div class="item-info">
                                                    <div class="item-avatar">
                                                        <%= e.Nombres ? e.Nombres.charAt(0).toUpperCase() : 'E' %>
                                                    </div>
                                                    <div>
                                                        <strong><%= e.Apellidos %>, <%= e.Nombres %></strong>
                                                        <div class="text-muted small">ID: <%= e.IdEmpleado %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <% if (e.Correo) { %>
                                                        <div class="contact-info">
                                                            <i class="bi bi-envelope"></i>
                                                            <span><%= e.Correo %></span>
                                                        </div>
                                                    <% } %>
                                                    <% if (e.Telefono) { %>
                                                        <div class="contact-info">
                                                            <i class="bi bi-telephone"></i>
                                                            <span><%= e.Telefono %></span>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark">
                                                    <i class="bi bi-briefcase me-1"></i>
                                                    <%= e.Cargo %>
                                                </span>
                                            </td>
                                            <td>
                                                <i class="bi bi-building text-muted me-1"></i>
                                                <%= e.Area || 'Sin área' %>
                                            </td>
                                            <td>
                                                <div>
                                                    <i class="bi bi-calendar-check text-muted me-1"></i>
                                                    <%= e.FechaContratacion ? new Date(e.FechaContratacion).toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
                                                </div>
                                                <small class="text-muted"><%= e.TipoContrato || 'Sin especificar' %></small>
                                            </td>
                                            <td>
                                                <strong class="salary-highlight">
                                                    S/ <%= Number(e.SueldoBase || 0).toFixed(2) %>
                                                </strong>
                                            </td>
                                            <td>
                                                <div>
                                                    <% if (e.Banco) { %>
                                                        <div class="contact-info">
                                                            <i class="bi bi-bank"></i>
                                                            <span><%= e.Banco %></span>
                                                        </div>
                                                    <% } %>
                                                    <% if (e.NumeroCuenta) { %>
                                                        <small class="text-muted"><%= e.NumeroCuenta %></small>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge badge-modern <%= e.Estado === 'ACTIVO' ? 'badge-activo' : 'badge-inactivo' %>">
                                                    <i class="bi <%= e.Estado === 'ACTIVO' ? 'bi-check-circle' : 'bi-pause-circle' %>"></i>
                                                    <%= e.Estado %>
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="action-buttons justify-content-center">
                                                    <a href="/empleados/<%= e.IdEmpleado %>/edit" 
                                                       class="btn-action-icon btn-action-edit" 
                                                       title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form action="/empleados/<%= e.IdEmpleado %>/delete" 
                                                          method="POST" 
                                                          class="d-inline"
                                                          onsubmit="return confirm('¿Está seguro de eliminar este empleado?');">
                                                        <button type="submit" 
                                                                class="btn-action-icon btn-action-delete" 
                                                                title="Eliminar">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="9" class="text-center py-5">
                                            <i class="bi bi-person-badge text-muted" style="font-size: 3rem;"></i>
                                            <p class="text-muted mt-2">No hay empleados registrados.</p>
                                            <a href="/empleados/create" class="btn btn-primary-modern btn-modern">
                                                <i class="bi bi-plus-circle"></i>
                                                Crear primer empleado
                                            </a>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>// Filtro único con combo box y campo de texto para empleados
        const campoFiltroEmpleado = document.getElementById('campoFiltroEmpleado');
        const valorFiltroEmpleado = document.getElementById('valorFiltroEmpleado');
        if (campoFiltroEmpleado && valorFiltroEmpleado) {
            valorFiltroEmpleado.addEventListener('input', filtrarTablaEmpleados);
            campoFiltroEmpleado.addEventListener('change', filtrarTablaEmpleados);
        }

        function filtrarTablaEmpleados() {
            const col = parseInt(campoFiltroEmpleado.value);
            const searchTerm = valorFiltroEmpleado.value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                if (row.querySelectorAll('td').length < 9) return;
                
                let cellText = '';
                const cells = row.querySelectorAll('td');
                
                // Ajustar según la columna seleccionada
                switch(col) {
                    case 0: // Empleado
                        cellText = cells[0].textContent.toLowerCase();
                        break;
                    case 1: // Contacto
                        cellText = cells[1].textContent.toLowerCase();
                        break;
                    case 2: // Cargo
                        cellText = cells[2].textContent.toLowerCase();
                        break;
                    case 3: // Área
                        cellText = cells[3].textContent.toLowerCase();
                        break;
                    case 4: // Contratación
                        cellText = cells[4].textContent.toLowerCase();
                        break;
                    case 5: // Sueldo
                        cellText = cells[5].textContent.toLowerCase();
                        break;
                    case 6: // Banco
                        cellText = cells[6].textContent.toLowerCase();
                        break;
                    case 7: // Estado
                        cellText = cells[7].textContent.toLowerCase();
                        break;
                }
                
                if (cellText.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
    <script src="/publico/js/layout.js?v=1772427290139"></script>
</body>
</html>
