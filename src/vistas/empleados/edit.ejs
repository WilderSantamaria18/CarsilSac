<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Empleado - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=<%= Date.now() %>">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-person-gear"></i>
                            Editar Empleado
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="form-container">
                    <div class="form-card">
                        <div class="form-header-title">
                            <i class="bi bi-person-gear"></i> Editar Información de Trabajador
                        </div>

                        <div class="form-body">
                            <!-- Employee Header -->
                            <div class="employee-header">
                                <div class="employee-avatar">
                                    <%= empleado.Nombres.charAt(0) %>
                                        <%= empleado.Apellidos.charAt(0) %>
                                </div>
                                <div class="employee-info">
                                    <h4>
                                        <%= empleado.Apellidos %>, <%= empleado.Nombres %>
                                    </h4>
                                    <small>ID: <%= empleado.IdEmpleado %> | Cargo: <%= empleado.Cargo %></small>
                                </div>
                            </div>

                            <form action="/empleados/<%= empleado.IdEmpleado %>?_method=PUT" method="POST">
                                <!-- Sección de Información Laboral -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-briefcase"></i> Información Laboral
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Cargo" class="form-label">
                                                    <i class="bi bi-briefcase"></i> Cargo
                                                </label>
                                                <input type="text" class="form-control-modern" id="Cargo" name="Cargo"
                                                    value="<%= empleado.Cargo %>" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Area" class="form-label">
                                                    <i class="bi bi-building"></i> Área
                                                </label>
                                                <input type="text" class="form-control-modern" id="Area" name="Area"
                                                    value="<%= empleado.Area || '' %>">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="FechaContratacion" class="form-label">
                                                    <i class="bi bi-calendar-event"></i> Fecha de Contratación
                                                </label>
                                                <input type="date" class="form-control-modern" id="FechaContratacion"
                                                    name="FechaContratacion"
                                                    value="<%= empleado.FechaContratacion ? new Date(empleado.FechaContratacion).toISOString().split('T')[0] : '' %>"
                                                    required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="TipoContrato" class="form-label">
                                                    <i class="bi bi-file-earmark-text"></i> Tipo de Contrato
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="TipoContrato"
                                                    name="TipoContrato">
                                                    <option value="INDEFINIDO" <%=empleado.TipoContrato==='INDEFINIDO'
                                                        ? 'selected' : '' %>>Indefinido</option>
                                                    <option value="TEMPORAL" <%=empleado.TipoContrato==='TEMPORAL'
                                                        ? 'selected' : '' %>>Temporal</option>
                                                    <option value="PRACTICAS" <%=empleado.TipoContrato==='PRACTICAS'
                                                        ? 'selected' : '' %>>Prácticas</option>
                                                    <option value="OBRA_DETERMINADA"
                                                        <%=empleado.TipoContrato==='OBRA_DETERMINADA' ? 'selected' : ''
                                                        %>>Obra determinada</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="SueldoBase" class="form-label">
                                                    <i class="bi bi-cash-coin"></i> Sueldo Base (S/)
                                                </label>
                                                <input type="number" step="0.01" class="form-control-modern"
                                                    id="SueldoBase" name="SueldoBase" value="<%= empleado.SueldoBase %>"
                                                    required>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Información Bancaria -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-bank"></i> Información Bancaria
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Banco" class="form-label">
                                                    <i class="bi bi-bank2"></i> Banco
                                                </label>
                                                <input type="text" class="form-control-modern" id="Banco" name="Banco"
                                                    value="<%= empleado.Banco || '' %>">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="NumeroCuenta" class="form-label">
                                                    <i class="bi bi-credit-card"></i> Número de Cuenta
                                                </label>
                                                <input type="text" class="form-control-modern" id="NumeroCuenta"
                                                    name="NumeroCuenta" value="<%= empleado.NumeroCuenta || '' %>">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="TipoCuenta" class="form-label">
                                                    <i class="bi bi-wallet2"></i> Tipo de Cuenta
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="TipoCuenta"
                                                    name="TipoCuenta">
                                                    <option value="AHORROS" <%=empleado.TipoCuenta==='AHORROS'
                                                        ? 'selected' : '' %>>Ahorros</option>
                                                    <option value="CORRIENTE" <%=empleado.TipoCuenta==='CORRIENTE'
                                                        ? 'selected' : '' %>>Corriente</option>
                                                    <option value="NOMINA" <%=empleado.TipoCuenta==='NOMINA'
                                                        ? 'selected' : '' %>>Nómina</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Estado -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-info-circle"></i> Estado del Empleado
                                    </h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="Estado" class="form-label">
                                                    <i class="bi bi-toggle-on"></i> Estado
                                                </label>
                                                <select class="form-control-modern form-select-modern" id="Estado"
                                                    name="Estado">
                                                    <option value="ACTIVO" <%=empleado.Estado==='ACTIVO' ? 'selected'
                                                        : '' %>>Activo</option>
                                                    <option value="INACTIVO" <%=empleado.Estado==='INACTIVO'
                                                        ? 'selected' : '' %>>Inactivo</option>
                                                    <option value="VACACIONES" <%=empleado.Estado==='VACACIONES'
                                                        ? 'selected' : '' %>>Vacaciones</option>
                                                    <option value="LICENCIA" <%=empleado.Estado==='LICENCIA'
                                                        ? 'selected' : '' %>>Licencia</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-buttons">
                                    <a href="/empleados" class="btn btn-form btn-form-cancel">
                                        <i class="bi bi-arrow-left me-2"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-form-primary">
                                        <i class="bi bi-save me-2"></i> Guardar Cambios
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Toggle sidebar handled by layout.js
        });
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>