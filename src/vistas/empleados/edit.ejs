<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Empleado - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290139">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290139">
    
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        <!-- Botón para ocultar/mostrar barra -->
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <!-- Navbar -->
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-person-badge"></i>
                        Editar de Empleados
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid py-4">
                <div class="card card-custom">
                    <div class="card-header bg-white border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-person-gear me-2"></i>Editar Información de Trabajador
                            </h5>
                            <a href="/empleados" class="btn btn-form btn-form-cancel">
                                <i class="bi bi-arrow-left me-2"></i>Volver
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- Mensajes de éxito y error eliminados según solicitud del usuario -->
                        
                        <div class="employee-header">
                            <div class="employee-avatar">
                                <%= empleado.Nombres.charAt(0) %><%= empleado.Apellidos.charAt(0) %>
                            </div>
                            <div class="employee-info">
                                <h4><%= empleado.Apellidos %>, <%= empleado.Nombres %></h4>
                                <small>ID: <%= empleado.IdEmpleado %> | Cargo: <%= empleado.Cargo %></small>
                            </div>
                        </div>

                        <form action="/empleados/<%= empleado.IdEmpleado %>?_method=PUT" method="POST">
                            <!-- Sección de Información Laboral -->
                            <div class="form-section">
                                <h6 class="form-section-title">
                                    <i class="bi bi-briefcase me-2"></i>Información Laboral
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="Cargo" class="form-label">Cargo</label>
                                        <input type="text" class="form-control-modern" id="Cargo" name="Cargo" value="<%= empleado.Cargo %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="Area" class="form-label">Área</label>
                                        <input type="text" class="form-control-modern" id="Area" name="Area" value="<%= empleado.Area || '' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="FechaContratacion" class="form-label">Fecha de Contratación</label>
                                        <input type="date" class="form-control-modern" id="FechaContratacion" name="FechaContratacion" 
                                               value="<%= empleado.FechaContratacion ? new Date(empleado.FechaContratacion).toISOString().split('T')[0] : '' %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="TipoContrato" class="form-label">Tipo de Contrato</label>
                                        <select class="form-control-modern form-select-modern" id="TipoContrato" name="TipoContrato">
                                            <option value="INDEFINIDO" <%= empleado.TipoContrato === 'INDEFINIDO' ? 'selected' : '' %>>Indefinido</option>
                                            <option value="TEMPORAL" <%= empleado.TipoContrato === 'TEMPORAL' ? 'selected' : '' %>>Temporal</option>
                                            <option value="PRACTICAS" <%= empleado.TipoContrato === 'PRACTICAS' ? 'selected' : '' %>>Prácticas</option>
                                            <option value="OBRA_DETERMINADA" <%= empleado.TipoContrato === 'OBRA_DETERMINADA' ? 'selected' : '' %>>Obra determinada</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="SueldoBase" class="form-label">Sueldo Base (S/)</label>
                                        <input type="number" step="0.01" class="form-control-modern" id="SueldoBase" name="SueldoBase" 
                                               value="<%= empleado.SueldoBase %>" required>
                                    </div>
                                </div>
                            </div>

                            <!-- Sección de Información Bancaria -->
                            <div class="form-section">
                                <h6 class="form-section-title">
                                    <i class="bi bi-bank me-2"></i>Información Bancaria
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="Banco" class="form-label">Banco</label>
                                        <input type="text" class="form-control-modern" id="Banco" name="Banco" value="<%= empleado.Banco || '' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="NumeroCuenta" class="form-label">Número de Cuenta</label>
                                        <input type="text" class="form-control-modern" id="NumeroCuenta" name="NumeroCuenta" value="<%= empleado.NumeroCuenta || '' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="TipoCuenta" class="form-label">Tipo de Cuenta</label>
                                        <select class="form-control-modern form-select-modern" id="TipoCuenta" name="TipoCuenta">
                                            <option value="AHORROS" <%= empleado.TipoCuenta === 'AHORROS' ? 'selected' : '' %>>Ahorros</option>
                                            <option value="CORRIENTE" <%= empleado.TipoCuenta === 'CORRIENTE' ? 'selected' : '' %>>Corriente</option>
                                            <option value="NOMINA" <%= empleado.TipoCuenta === 'NOMINA' ? 'selected' : '' %>>Nómina</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Sección de Estado -->
                            <div class="form-section">
                                <h6 class="form-section-title">
                                    <i class="bi bi-info-circle me-2"></i>Estado del Empleado
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="Estado" class="form-label">Estado</label>
                                        <select class="form-control-modern form-select-modern" id="Estado" name="Estado">
                                            <option value="ACTIVO" <%= empleado.Estado === 'ACTIVO' ? 'selected' : '' %>>Activo</option>
                                            <option value="INACTIVO" <%= empleado.Estado === 'INACTIVO' ? 'selected' : '' %>>Inactivo</option>
                                            <option value="VACACIONES" <%= empleado.Estado === 'VACACIONES' ? 'selected' : '' %>>Vacaciones</option>
                                            <option value="LICENCIA" <%= empleado.Estado === 'LICENCIA' ? 'selected' : '' %>>Licencia</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end mt-4 gap-2">
                                <a href="/empleados" class="btn btn-form btn-form-cancel">
                                    <i class="bi bi-x-circle me-2"></i>Cancelar
                                </a>
                                <button type="submit" class="btn-form btn-form-primary">
                                    <i class="bi bi-save me-2"></i>Guardar Cambios
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Toggle sidebar});
    </script>
    <script src="/publico/js/layout.js?v=1772427290139"></script>
</body>
</html>
