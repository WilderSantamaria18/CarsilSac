<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - CARSIL Gestión de Proformas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ========================================
           DASHBOARD STYLES
           ======================================== */

        /* Top Navbar */
        .dash-navbar {
            height: 64px;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .dash-nav-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .dash-nav-search {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-page);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 16px;
            width: 280px;
            margin-left: 60px;
        }

        .dash-nav-search i {
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .dash-nav-search input {
            border: none;
            background: transparent;
            outline: none;
            font-family: inherit;
            font-size: 0.8125rem;
            color: var(--text-primary);
            width: 100%;
        }

        .dash-nav-search input::placeholder {
            color: var(--text-muted);
        }

        .dash-nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dash-nav-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s ease;
        }

        .dash-nav-icon:hover {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        .dash-nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 4px 12px 4px 4px;
            border: 1px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
        }

        .dash-nav-avatar {
            width: 34px;
            height: 34px;
            background: var(--primary);
            color: #fff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.8125rem;
        }

        .dash-nav-user-info {
            line-height: 1.2;
        }

        .dash-nav-user-name {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .dash-nav-user-role {
            font-size: 0.625rem;
            color: var(--text-muted);
        }

        /* Page Content */
        .dash-content {
            padding: 28px 32px;
        }

        /* Page Header */
        .dash-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .dash-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }

        .dash-date-picker {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 16px;
            font-size: 0.8125rem;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .dash-date-picker i {
            color: var(--text-muted);
        }

        /* ========================================
           STAT CARDS ROW
           ======================================== */
        .stat-cards-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card-v2 {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 22px;
            transition: box-shadow 0.2s ease;
        }

        .stat-card-v2:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        }

        .stat-card-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .stat-card-label {
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        .stat-card-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--primary-light);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.125rem;
        }

        .stat-card-icon.green {
            background: var(--success-light);
            color: var(--success);
        }

        .stat-card-icon.purple {
            background: var(--purple-light);
            color: var(--purple);
        }

        .stat-card-icon.amber {
            background: var(--warning-light);
            color: var(--warning);
        }

        .stat-card-row {
            display: flex;
            align-items: baseline;
            gap: 10px;
            margin-bottom: 6px;
        }

        .stat-card-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
        }

        .stat-card-trend {
            font-size: 0.6875rem;
            font-weight: 600;
            padding: 2px 6px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 2px;
        }

        .stat-card-trend.up {
            background: var(--success-light);
            color: var(--success);
        }

        .stat-card-trend.down {
            background: var(--danger-light);
            color: var(--danger);
        }

        .stat-card-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ========================================
           CHARTS ROW
           ======================================== */
        .charts-row {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
        }

        .chart-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .chart-card-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .chart-card-subtitle {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .chart-filter-btn {
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .chart-container {
            position: relative;
            height: 280px;
        }

        .chart-legend-custom {
            display: flex;
            gap: 16px;
            margin-bottom: 12px;
        }

        .chart-legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        /* ========================================
           RECENT TABLE
           ======================================== */
        .table-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
        }

        .table-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .table-card-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .table-header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .table-search {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--bg-page);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            width: 200px;
        }

        .table-search i {
            color: var(--text-muted);
            font-size: 0.8125rem;
        }

        .table-search input {
            border: none;
            background: transparent;
            outline: none;
            font-family: inherit;
            font-size: 0.75rem;
            width: 100%;
            color: var(--text-primary);
        }

        .table-search input::placeholder {
            color: var(--text-muted);
        }

        .sort-btn {
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 0.75rem;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .dash-table {
            width: 100%;
            border-collapse: collapse;
        }

        .dash-table thead th {
            text-align: left;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            padding: 10px 12px;
            border-bottom: 1px solid var(--border);
        }

        .dash-table tbody td {
            padding: 12px;
            font-size: 0.8125rem;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
        }

        .dash-table tbody tr:last-child td {
            border-bottom: none;
        }

        .dash-table tbody tr:hover {
            background: var(--bg-page);
        }

        .table-id {
            font-weight: 600;
            color: var(--text-primary);
        }

        .table-badge {
            font-size: 0.6875rem;
            font-weight: 500;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .table-badge.pending {
            background: var(--warning-light);
            color: var(--warning);
        }

        .table-badge.completed {
            background: var(--success-light);
            color: var(--success);
        }

        .table-badge.cancelled {
            background: var(--danger-light);
            color: var(--danger);
        }

        .table-total {
            font-weight: 600;
            color: var(--text-primary);
        }

        /* ========================================
           RESPONSIVE
           ======================================== */
        @media (max-width: 1024px) {
            .stat-cards-row {
                grid-template-columns: repeat(2, 1fr);
            }

            .charts-row {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .dash-content {
                padding: 16px;
            }

            .stat-cards-row {
                grid-template-columns: 1fr;
            }

            .dash-navbar {
                padding: 0 16px;
            }

            .dash-nav-search {
                display: none;
            }

            .dash-nav-user-info {
                display: none;
            }

            .dash-header {
                flex-direction: column;
                gap: 12px;
                align-items: flex-start;
            }

            .table-header-actions {
                flex-direction: column;
                gap: 8px;
            }

            .table-search {
                width: 100%;
            }
        }

        /* ========================================
           NOTIFICATION BELL
           ======================================== */
        .notif-wrapper {
            position: relative;
        }

        .notif-bell {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s ease;
            position: relative;
        }

        .notif-bell:hover {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        .notif-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            width: 18px;
            height: 18px;
            background: var(--danger);
            color: #fff;
            border-radius: 50%;
            font-size: 0.5625rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--bg-card);
        }

        .notif-badge.hidden {
            display: none;
        }

        .notif-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 360px;
            max-height: 440px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
            z-index: 9999;
            display: none;
            overflow: hidden;
        }

        .notif-dropdown.show {
            display: block;
        }

        .notif-dropdown-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            border-bottom: 1px solid var(--border-light);
        }

        .notif-dropdown-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .notif-mark-read {
            font-size: 0.6875rem;
            color: var(--primary);
            cursor: pointer;
            font-weight: 500;
            background: none;
            border: none;
            font-family: inherit;
        }

        .notif-mark-read:hover {
            text-decoration: underline;
        }

        .notif-list {
            max-height: 360px;
            overflow-y: auto;
            padding: 4px 0;
        }

        .notif-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 10px 16px;
            transition: background 0.1s ease;
            cursor: pointer;
            border-left: 3px solid transparent;
        }

        .notif-item:hover {
            background: var(--bg-page);
        }

        .notif-item.unread {
            border-left-color: var(--primary);
            background: var(--primary-light);
        }

        .notif-item.unread:hover {
            background: #e4e7fc;
        }

        .notif-icon {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8125rem;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .notif-icon.crear {
            background: var(--success-light);
            color: var(--success);
        }

        .notif-icon.actualizar {
            background: var(--primary-light);
            color: var(--primary);
        }

        .notif-icon.eliminar {
            background: var(--danger-light);
            color: var(--danger);
        }

        .notif-info {
            flex: 1;
            min-width: 0;
        }

        .notif-msg {
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-primary);
            line-height: 1.3;
        }

        .notif-detail {
            font-size: 0.6875rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .notif-time {
            font-size: 0.625rem;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .notif-empty {
            padding: 30px 16px;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.8125rem;
        }

        .notif-empty i {
            font-size: 1.5rem;
            display: block;
            margin-bottom: 8px;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <!-- Top Navbar -->
                <div class="dash-navbar">
                    <div class="dash-nav-left">
                        <div class="dash-nav-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Buscar proformas, clientes...">
                        </div>
                    </div>
                    <div class="dash-nav-right">
                        <!-- Notification Bell -->
                        <div class="notif-wrapper" id="notifWrapper">
                            <button class="notif-bell" id="notifBell" title="Notificaciones">
                                <i class="bi bi-bell"></i>
                                <span class="notif-badge hidden" id="notifBadge">0</span>
                            </button>
                            <div class="notif-dropdown" id="notifDropdown">
                                <div class="notif-dropdown-header">
                                    <span class="notif-dropdown-title">Notificaciones</span>
                                    <button class="notif-mark-read" id="markAllRead">Marcar todas leidas</button>
                                </div>
                                <div class="notif-list" id="notifList">
                                    <div class="notif-empty">
                                        <i class="bi bi-bell-slash"></i>
                                        Sin notificaciones
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button class="dash-nav-icon" title="Ayuda" data-bs-toggle="modal" data-bs-target="#helpModal">
                            <i class="bi bi-question-circle"></i>
                        </button>

                        <!-- Help Modal -->
                        <div class="modal fade help-modal" id="helpModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">
                                            <i class="bi bi-journal-bookmark"></i> Manual de Usuario
                                        </h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                            aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <% if (user && user.IdRol===1) { %>
                                            <!-- Manual para Administrador -->
                                            <div class="help-callout">
                                                <i class="bi bi-shield-check"></i>
                                                <p>Hola <strong>
                                                        <%= user.Nombres || 'Administrador' %>
                                                    </strong>. Como Administrador tienes acceso total al sistema. Aquí
                                                    tienes una guía rápida de las funciones principales.</p>
                                            </div>

                                            <div class="help-section">
                                                <h3 class="help-h3"><i class="bi bi-graph-up-arrow"></i> Dashboard y
                                                    Reportes</h3>
                                                <ul class="help-list">
                                                    <li>El <strong>Dashboard</strong> muestra un resumen en tiempo real
                                                        de toda la actividad de la empresa.</li>
                                                    <li>Usa la barra de búsqueda de "Proformas Recientes" para encontrar
                                                        operaciones rápidas por cliente o estado.</li>
                                                    <li>La sección de <strong>Reportes</strong> (en el menú lateral) te
                                                        permite generar analíticas detalladas y exportarlas a PDF.</li>
                                                </ul>
                                            </div>

                                            <div class="help-section">
                                                <h3 class="help-h3"><i class="bi bi-people"></i> Gestión de Personal y
                                                    Roles</h3>
                                                <ul class="help-list">
                                                    <li>Desde <strong>Recursos Humanos > Empleados</strong> puedes dar
                                                        de alta nuevos trabajadores y gestionar su asistencia.</li>
                                                    <li>En <strong>Administración > Usuarios</strong> puedes crear
                                                        credenciales de acceso para los empleados.</li>
                                                    <li>En <strong>Administración > Roles</strong> puedes limitar o dar
                                                        permisos (ej. crear rol "Cajero").</li>
                                                </ul>
                                            </div>

                                            <div class="help-section">
                                                <h3 class="help-h3"><i class="bi bi-cart"></i> Ventas y Proformas</h3>
                                                <ul class="help-list">
                                                    <li>Puedes supervisar todas las proformas de los vendedores.</li>
                                                    <li>Las proformas pueden pasar de estado <strong>Pendiente</strong>
                                                        a <strong>Aprobada</strong> y finalmente a
                                                        <strong>Vendida</strong> (Facturada).
                                                    </li>
                                                    <li>Todo cambio en el sistema genera una notificación automática
                                                        (campana en la parte superior).</li>
                                                </ul>
                                            </div>
                                            <% } else { %>
                                                <!-- Manual para Vendedor/Otros roles -->
                                                <div class="help-callout">
                                                    <i class="bi bi-star"></i>
                                                    <p>Hola <strong>
                                                            <%= user ? user.Nombres : 'Usuario' %>
                                                        </strong>. Aquí tienes una guía rápida para operar el módulo de
                                                        ventas y proformas.</p>
                                                </div>

                                                <div class="help-section">
                                                    <h3 class="help-h3"><i class="bi bi-person-badge"></i> 1. Registrar
                                                        Clientes</h3>
                                                    <ul class="help-list">
                                                        <li>Antes de crear una proforma, asegúrate de que el cliente
                                                            exista en <strong>Menú > Clientes</strong>.</li>
                                                        <li>Puedes buscar usando su DNI/RUC en la nueva proforma, y el
                                                            sistema autocompletará sus datos si ya está registrado.</li>
                                                    </ul>
                                                </div>

                                                <div class="help-section">
                                                    <h3 class="help-h3"><i class="bi bi-file-earmark-text"></i> 2. Crear
                                                        una Proforma</h3>
                                                    <ul class="help-list">
                                                        <li>Ve a <strong>Menú > Proformas</strong> y haz clic en "Nueva
                                                            Proforma".</li>
                                                        <li>Busca los productos a cotizar en la barra de búsqueda (el
                                                            catálogo mostrará stock y precios).</li>
                                                        <li>Ajusta las cantidades y el IGV. El sistema calculará el
                                                            Subtotal y Total automáticamente.</li>
                                                        <li>La proforma se creará en estado <strong>Pendiente</strong>.
                                                        </li>
                                                    </ul>
                                                </div>

                                                <div class="help-section">
                                                    <h3 class="help-h3"><i class="bi bi-receipt"></i> 3. Generar Factura
                                                        (Venta real)</h3>
                                                    <ul class="help-list">
                                                        <li>Cuando el cliente acepte la cotización, ve al detalle de la
                                                            proforma y cambia su estado a <strong>Vendida</strong>.</li>
                                                        <li>Ir a <strong>Menú > Facturas</strong> y asociar esa proforma
                                                            para generar el comprobante final.</li>
                                                        <li>Esto descontará el stock de los productos automáticamente.
                                                        </li>
                                                    </ul>
                                                </div>
                                                <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="dash-nav-user">
                            <div class="dash-nav-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                            <div class="dash-nav-user-info">
                                <div class="dash-nav-user-name">
                                    <%= user && user.Nombres ? user.Nombres : 'Admin' %>
                                </div>
                                <div class="dash-nav-user-role">Administrador</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dashboard Content -->
                <div class="dash-content">
                    <!-- Page Header -->
                    <div class="dash-header">
                        <h1 class="dash-title">Resumen General</h1>
                        <div class="dash-date-picker" id="dateDisplay">
                            <i class="bi bi-calendar3"></i>
                            <span id="dateRangeText"></span>
                            <i class="bi bi-chevron-down" style="font-size:0.625rem"></i>
                        </div>
                    </div>

                    <!-- Stat Cards -->
                    <div class="stat-cards-row">
                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Total Clientes</span>
                                <div class="stat-card-icon">
                                    <i class="bi bi-people"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.clientes ? estadisticas.clientes : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.clientes ?
                                        estadisticas.clientes : 0 %>
                                </span>
                                <span class="stat-card-trend up"><i class="bi bi-arrow-up-short"></i>4.9%</span>
                            </div>
                            <span class="stat-card-sub">Registrados en el sistema</span>
                        </div>

                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Proformas</span>
                                <div class="stat-card-icon green">
                                    <i class="bi bi-file-earmark-text"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.proformas ? estadisticas.proformas : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.proformas ?
                                        estadisticas.proformas : 0 %>
                                </span>
                                <span class="stat-card-trend up"><i class="bi bi-arrow-up-short"></i>7.5%</span>
                            </div>
                            <span class="stat-card-sub">Total generadas</span>
                        </div>

                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Productos</span>
                                <div class="stat-card-icon purple">
                                    <i class="bi bi-box-seam"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.productos ? estadisticas.productos : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.productos ?
                                        estadisticas.productos : 0 %>
                                </span>
                                <span class="stat-card-trend down"><i class="bi bi-arrow-down-short"></i>6.0%</span>
                            </div>
                            <span class="stat-card-sub">En catalogo activo</span>
                        </div>

                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Empleados Activos</span>
                                <div class="stat-card-icon amber">
                                    <i class="bi bi-person-badge"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.empleados ? estadisticas.empleados : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.empleados ?
                                        estadisticas.empleados : 0 %>
                                </span>
                                <span class="stat-card-trend up"><i class="bi bi-arrow-up-short"></i>2.1%</span>
                            </div>
                            <span class="stat-card-sub">Nomina del personal</span>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="charts-row">
                        <!-- Revenue / Proformas Analytics -->
                        <div class="chart-card">
                            <div class="chart-card-header">
                                <div>
                                    <div class="chart-card-title">Actividad de Proformas</div>
                                </div>
                                <select class="chart-filter-btn" id="proformasChartFilter"
                                    style="border:none; cursor:pointer; font-family:inherit; font-size:0.8125rem; background:transparent; font-weight:500; color:var(--text-secondary);">
                                    <option value="semana">Esta Semana</option>
                                    <option value="mes">Ultimo Mes</option>
                                </select>
                            </div>
                            <div class="chart-container">
                                <canvas id="barChart"></canvas>
                            </div>
                        </div>

                        <!-- Income Chart -->
                        <div class="chart-card">
                            <div class="chart-card-header">
                                <div>
                                    <div class="chart-card-title">Distribucion por Modulo</div>
                                    <div class="chart-card-subtitle">Registros activos en cada seccion</div>
                                </div>
                            </div>
                            <div class="chart-legend-custom">
                                <div class="chart-legend-item">
                                    <span class="legend-dot" style="background: var(--primary)"></span>
                                    Registros actuales
                                </div>
                            </div>
                            <div class="chart-container">
                                <canvas id="barChartIncome"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Orders / Proformas Table -->
                    <div class="table-card">
                        <div class="table-card-header">
                            <span class="table-card-title">Proformas Recientes</span>
                            <div class="table-header-actions">
                                <div class="table-search">
                                    <i class="bi bi-search"></i>
                                    <input type="text" placeholder="Buscar" id="tableSearchInput">
                                </div>
                                <button class="sort-btn">
                                    <i class="bi bi-filter"></i>
                                    Ordenar
                                    <i class="bi bi-chevron-down" style="font-size:0.625rem"></i>
                                </button>
                            </div>
                        </div>
                        <table class="dash-table" id="proformasTable">
                            <thead>
                                <tr>
                                    <th>Codigo</th>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th>Estado</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof proformasRecientes !=='undefined' && proformasRecientes.length> 0) { %>
                                    <% proformasRecientes.forEach(function(p) { %>
                                        <tr>
                                            <td><span class="table-id">
                                                    <%= p.Codigo || '#' + p.IdProforma %>
                                                </span></td>
                                            <td>
                                                <%= p.FechaEmision ? new
                                                    Date(p.FechaEmision).toLocaleDateString('es-PE', { day: '2-digit' ,
                                                    month: 'short' , year: 'numeric' }) : '-' %>
                                            </td>
                                            <td>
                                                <%= p.ClienteNombre %>
                                            </td>
                                            <td>
                                                <% if (p.Estado==='PENDIENTE' ) { %>
                                                    <span class="table-badge pending">Pendiente</span>
                                                    <% } else if (p.Estado==='APROBADA' ) { %>
                                                        <span class="table-badge completed">Aprobada</span>
                                                        <% } else if (p.Estado==='VENDIDA' ) { %>
                                                            <span class="table-badge completed">Vendida</span>
                                                            <% } else if (p.Estado==='VENCIDA' ) { %>
                                                                <span class="table-badge cancelled">Vencida</span>
                                                                <% } else if (p.Estado==='ANULADA' ) { %>
                                                                    <span class="table-badge cancelled">Anulada</span>
                                                                    <% } else { %>
                                                                        <span class="table-badge pending">
                                                                            <%= p.Estado %>
                                                                        </span>
                                                                        <% } %>
                                            </td>
                                            <td><span class="table-total">S/ <%= p.Total ?
                                                        Number(p.Total).toLocaleString('es-PE', { minimumFractionDigits:
                                                        2 }) : '0.00' %></span></td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5"
                                                        style="text-align: center; color: var(--text-muted); padding: 24px;">
                                                        No hay proformas registradas</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
    </div>

    <script src="/publico/js/layout.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Date display
            const now = new Date();
            const dateStart = new Date(now);
            dateStart.setDate(dateStart.getDate() - 30);
            const fmt = { month: 'short', day: 'numeric', year: 'numeric' };
            document.getElementById('dateRangeText').textContent =
                dateStart.toLocaleDateString('es-PE', fmt) + ' - ' + now.toLocaleDateString('es-PE', fmt);

            // Counter animation
            document.querySelectorAll('.stat-card-value').forEach(el => {
                const target = parseInt(el.dataset.count) || 0;
                if (target === 0) return;
                let current = 0;
                const step = Math.max(Math.ceil(target / 40), 1);
                el.textContent = '0';
                const timer = setInterval(() => {
                    current += step;
                    if (current >= target) { current = target; clearInterval(timer); }
                    el.textContent = current;
                }, 30);
            });

            // ========================================
            // BAR CHART - Proformas Activity (Real Data)
            // ========================================
            const primary = '#3B49DF';
            const primaryLight = '#eef0fd';
            let actividadSemanalData = JSON.parse('<%= typeof actividadSemanal !== "undefined" ? actividadSemanal : "[0,0,0,0,0,0,0]" %>');

            // Generate labels for the last 7 days
            const dayNames = ['Dom', 'Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab'];
            const today = new Date().getDay();
            const last7DaysLabels = [];
            for (let i = 6; i >= 0; i--) {
                const d = new Date();
                d.setDate(d.getDate() - i);
                last7DaysLabels.push(dayNames[d.getDay()]);
            }

            const barCtx = document.getElementById('barChart').getContext('2d');
            const proformasChart = new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: last7DaysLabels,
                    datasets: [{
                        label: 'Proformas creadas',
                        data: actividadSemanalData,
                        backgroundColor: function (context) {
                            const chart = context.chart;
                            const { ctx, chartArea } = chart;
                            if (!chartArea) return primary;
                            const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
                            gradient.addColorStop(0, primary);
                            gradient.addColorStop(1, '#5b67e8');
                            return gradient;
                        },
                        borderRadius: 6,
                        borderSkipped: false,
                        barPercentage: 0.6,
                        categoryPercentage: 0.7,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1A1A2E',
                            titleFont: { family: 'Inter', size: 12 },
                            bodyFont: { family: 'Inter', size: 11 },
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: false,
                            callbacks: {
                                label: function (context) {
                                    return context.raw + ' proformas';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                font: { family: 'Inter', size: 11 },
                                color: '#9CA3AF',
                                stepSize: 1
                            },
                            grid: { color: '#F0F0F0', drawBorder: false },
                            border: { display: false }
                        },
                        x: {
                            ticks: {
                                font: { family: 'Inter', size: 11, weight: 500 },
                                color: '#6B7280'
                            },
                            grid: { display: false },
                            border: { display: false }
                        }
                    }
                }
            });

            // Filter logic for Proformas Activity chart
            const chartFilter = document.getElementById('proformasChartFilter');
            if (chartFilter) {
                chartFilter.addEventListener('change', async function () {
                    const val = this.value;
                    if (val === 'semana') {
                        // Revert to week data (the original data passed from server)
                        proformasChart.data.labels = last7DaysLabels;
                        proformasChart.data.datasets[0].data = actividadSemanalData;
                        proformasChart.update();
                    } else if (val === 'mes') {
                        // Fetch month data (last 30 days, grouped by week for simplicity, or just fetch the API)
                        try {
                            const isWeeklyChart = false;

                            // Let's use the reportes API we already have
                            const res = await fetch('/reportes/api/proformas-por-mes');
                            const json = await res.json();
                            if (json.success && json.data.length > 0) {
                                // Extract last 6 months
                                const last6 = json.data.slice(-6);
                                const labels = last6.map(d => {
                                    const [y, m] = d.mes.split('-');
                                    return new Date(y, m - 1).toLocaleDateString('es-PE', { month: 'short' });
                                });
                                const data = last6.map(d => d.cantidad);

                                proformasChart.data.labels = labels;
                                proformasChart.data.datasets[0].data = data;
                                proformasChart.update();
                            }
                        } catch (err) {
                            console.error('Error fetching chart data:', err);
                        }
                    }
                });
            }

            // ========================================
            // BAR CHART - Distribution by Module (Real Data)
            // ========================================
            const clientesVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.clientes ? estadisticas.clientes : 0 %>') || 0;
            const proformasVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.proformas ? estadisticas.proformas : 0 %>') || 0;
            const productosVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.productos ? estadisticas.productos : 0 %>') || 0;
            const empleadosVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.empleados ? estadisticas.empleados : 0 %>') || 0;
            const facturasVal = parseInt('<%= typeof totalFacturas !== "undefined" ? totalFacturas : 0 %>') || 0;

            const incomeCtx = document.getElementById('barChartIncome').getContext('2d');
            new Chart(incomeCtx, {
                type: 'bar',
                data: {
                    labels: ['Clientes', 'Proformas', 'Facturas', 'Productos', 'Empleados'],
                    datasets: [
                        {
                            label: 'Registros actuales',
                            data: [clientesVal, proformasVal, facturasVal, productosVal, empleadosVal],
                            backgroundColor: primary,
                            borderRadius: 4,
                            barPercentage: 0.6,
                            categoryPercentage: 0.7,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1A1A2E',
                            titleFont: { family: 'Inter', size: 12 },
                            bodyFont: { family: 'Inter', size: 11 },
                            padding: 10,
                            cornerRadius: 8,
                            callbacks: {
                                label: function (context) {
                                    return context.raw + ' registros';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                font: { family: 'Inter', size: 11 },
                                color: '#9CA3AF',
                                stepSize: 5
                            },
                            grid: { color: '#F0F0F0', drawBorder: false },
                            border: { display: false }
                        },
                        x: {
                            ticks: {
                                font: { family: 'Inter', size: 11, weight: 500 },
                                color: '#6B7280'
                            },
                            grid: { display: false },
                            border: { display: false }
                        }
                    }
                }
            });

            // Table search
            const searchInput = document.getElementById('tableSearchInput');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    const val = this.value.toLowerCase();
                    document.querySelectorAll('#proformasTable tbody tr').forEach(row => {
                        row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
                    });
                });
            }

            // ========================================
            // NOTIFICATIONS SYSTEM
            // ========================================
            const notifBell = document.getElementById('notifBell');
            const notifDropdown = document.getElementById('notifDropdown');
            const notifBadge = document.getElementById('notifBadge');
            const notifList = document.getElementById('notifList');
            const markAllRead = document.getElementById('markAllRead');

            // Toggle dropdown
            notifBell.addEventListener('click', function (e) {
                e.stopPropagation();
                notifDropdown.classList.toggle('show');
                if (notifDropdown.classList.contains('show')) {
                    fetchNotificaciones();
                }
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function (e) {
                if (!document.getElementById('notifWrapper').contains(e.target)) {
                    notifDropdown.classList.remove('show');
                }
            });

            // Mark all as read
            markAllRead.addEventListener('click', async function () {
                await fetch('/api/notificaciones/leer-todas', { method: 'POST' });
                notifBadge.classList.add('hidden');
                notifBadge.textContent = '0';
                document.querySelectorAll('.notif-item.unread').forEach(item => {
                    item.classList.remove('unread');
                });
            });

            // Time ago helper
            function timeAgo(dateStr) {
                const now = new Date();
                const date = new Date(dateStr);
                const diff = Math.floor((now - date) / 1000);
                if (diff < 60) return 'Ahora';
                if (diff < 3600) return Math.floor(diff / 60) + ' min';
                if (diff < 86400) return Math.floor(diff / 3600) + ' h';
                return Math.floor(diff / 86400) + ' d';
            }

            // Icon by type
            function getNotifIcon(tipo) {
                switch (tipo) {
                    case 'CREAR': return { cls: 'crear', icon: 'bi-plus-circle' };
                    case 'ACTUALIZAR': return { cls: 'actualizar', icon: 'bi-pencil' };
                    case 'ELIMINAR': return { cls: 'eliminar', icon: 'bi-trash' };
                    default: return { cls: 'actualizar', icon: 'bi-info-circle' };
                }
            }

            // Fetch and render
            async function fetchNotificaciones() {
                try {
                    const res = await fetch('/api/notificaciones');
                    const data = await res.json();

                    // Update badge
                    if (data.noLeidas > 0) {
                        notifBadge.textContent = data.noLeidas > 99 ? '99+' : data.noLeidas;
                        notifBadge.classList.remove('hidden');
                    } else {
                        notifBadge.classList.add('hidden');
                    }

                    // Render list
                    if (data.notificaciones.length === 0) {
                        notifList.innerHTML = '<div class="notif-empty"><i class="bi bi-bell-slash"></i>Sin notificaciones</div>';
                        return;
                    }

                    notifList.innerHTML = data.notificaciones.map(n => {
                        const { cls, icon } = getNotifIcon(n.Tipo);
                        const unread = n.Leida === 0 ? 'unread' : '';
                        return `
                            <div class="notif-item ${unread}" data-id="${n.IdNotificacion}" onclick="markRead(${n.IdNotificacion}, this)">
                                <div class="notif-icon ${cls}">
                                    <i class="bi ${icon}"></i>
                                </div>
                                <div class="notif-info">
                                    <div class="notif-msg">${n.Mensaje}</div>
                                    ${n.Detalle ? `<div class="notif-detail">${n.Detalle}</div>` : ''}
                                    <div class="notif-time">${n.Usuario ? n.Usuario + ' - ' : ''}${timeAgo(n.FechaCreacion)}</div>
                                </div>
                            </div>
                        `;
                    }).join('');
                } catch (err) {
                    console.error('Error al cargar notificaciones:', err);
                }
            }

            // Mark individual notification as read
            window.markRead = async function (id, el) {
                if (el.classList.contains('unread')) {
                    el.classList.remove('unread');
                    await fetch('/api/notificaciones/leer/' + id, { method: 'POST' });
                    const current = parseInt(notifBadge.textContent) || 0;
                    if (current <= 1) {
                        notifBadge.classList.add('hidden');
                    } else {
                        notifBadge.textContent = current - 1;
                    }
                }
            };

            // Initial load + polling every 15 seconds
            fetchNotificaciones();
            setInterval(fetchNotificaciones, 15000);
        });
    </script>
</body>

</html>