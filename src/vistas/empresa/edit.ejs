<!-- src/vistas/empresa/edit.ejs -->
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Empresa - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290140">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290140">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-gear"></i>
                            Editar Configuración de Empresa
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>
                <div class="container-fluid py-4">
                    <div class="form-card">
                        <h2 class="form-header-title">Editar Información</h2>

                        <form action="/empresa/editar/<%= empresa.IdEmpresa %>" method="POST"
                            enctype="multipart/form-data">
                            <div class="form-avatar-section">
                                <div class="form-avatar-wrapper">
                                    <% if (empresa.Logo) { %>
                                        <img src="/empresa/logo/<%= empresa.IdEmpresa %>" alt="Logo">
                                        <% } else { %>
                                            <i class="bi bi-image form-avatar-icon"></i>
                                            <% } %>
                                                <div class="avatar-edit-btn"
                                                    onclick="document.getElementById('Logo').click()">
                                                    <i class="bi bi-camera"></i>
                                                </div>
                                </div>
                                <div style="flex-grow: 1;">
                                    <label for="Logo" class="form-label">Actualizar Logo</label>
                                    <input type="file" class="form-control-modern" id="Logo" name="Logo"
                                        accept="image/*" style="padding: 0.6rem 1rem;">
                                    <small class="text-muted d-block mt-1">Formatos soportados: JPG, PNG, GIF. Tamaño
                                        máximo: 2MB</small>
                                </div>
                            </div>

                            <div class="form-grid">
                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Razón Social <span
                                                class="text-danger">*</span></label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="Nombre" name="Nombre"
                                            value="<%= empresa.Nombre || '' %>" required placeholder="Ej: CARSIL SAC">
                                        <i class="bi bi-building input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">RUC <span class="text-danger">*</span></label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="RUC" name="RUC"
                                            value="<%= empresa.RUC || '' %>" required maxlength="11"
                                            placeholder="Ej: 20123456789">
                                        <i class="bi bi-upc-scan input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Estado</label>
                                        <span class="form-action-text success"><i class="bi bi-check2"></i>
                                            Seleccione</span>
                                    </div>
                                    <div class="input-wrapper">
                                        <select class="form-control-modern form-select-modern" id="Estado"
                                            name="Estado">
                                            <option value="1" <%=empresa.Estado==1 ? 'selected' : '' %>>Activo</option>
                                            <option value="0" <%=empresa.Estado==0 ? 'selected' : '' %>>Inactivo
                                            </option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Dirección <span class="text-danger">*</span></label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="Direccion" name="Direccion"
                                            value="<%= empresa.Direccion || '' %>" required
                                            placeholder="Ej: Av. Principal 123">
                                        <i class="bi bi-geo-alt input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Teléfono</label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="Telefono" name="Telefono"
                                            value="<%= empresa.Telefono || '' %>" maxlength="20"
                                            placeholder="Ej: 012345678">
                                        <i class="bi bi-telephone input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Celular</label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="Celular" name="Celular"
                                            value="<%= empresa.Celular || '' %>" maxlength="20"
                                            placeholder="Ej: 987654321">
                                        <i class="bi bi-phone input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group full-width">
                                    <div class="form-group-header">
                                        <label class="form-label">Email</label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="email" class="form-control-modern" id="Email" name="Email"
                                            value="<%= empresa.Email || '' %>" maxlength="100"
                                            placeholder="Ej: contacto@carsil.com">
                                        <i class="bi bi-envelope input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Cuenta Bancaria</label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="CuentaBancaria"
                                            name="CuentaBancaria" value="<%= empresa.CuentaBancaria || '' %>"
                                            maxlength="100">
                                        <i class="bi bi-credit-card input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="form-group-header">
                                        <label class="form-label">Nombre de la Cuenta</label>
                                    </div>
                                    <div class="input-wrapper has-icon">
                                        <input type="text" class="form-control-modern" id="NombreCuentaBancaria"
                                            name="NombreCuentaBancaria"
                                            value="<%= empresa.NombreCuentaBancaria || '' %>" maxlength="100">
                                        <i class="bi bi-bank2 input-icon"></i>
                                    </div>
                                </div>

                                <div class="form-group full-width">
                                    <div class="form-group-header">
                                        <label class="form-label">Texto de Presentación en Proformas</label>
                                    </div>
                                    <textarea class="form-control-modern" id="TextoPresentacion"
                                        name="TextoPresentacion" rows="3"
                                        maxlength="500"><%= empresa.TextoPresentacion || 'En atención a vuestra solicitud, tenemos el agrado de cotizarles lo siguiente:' %></textarea>
                                </div>
                            </div>

                            <div class="form-buttons">
                                <a href="/empresa" class="btn-form btn-form-cancel">Cancelar</a>
                                <button type="submit" class="btn-form btn-form-primary"><i class="bi bi-check2"></i>
                                    Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/publico/js/layout.js?v=1772427290140"></script>
</body>

</html>