<!-- src/vistas/empresa/lista.ejs -->
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración de Empresa - CARSIL</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290140">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .main-content {
            padding: 0 !important;
            background: #f6f6f8;
        }
    </style>
</head>

<body class="bg-[#f6f6f8] text-slate-900 font-display">
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">

                <!-- Page Content -->
                <div class="max-w-5xl mx-auto p-8">

                    <% if (empresas && empresas.length> 0) { %>
                        <% const empresa=empresas[0]; %>

                            <div class="flex items-center justify-between mb-8">
                                <div>
                                    <h3 class="text-2xl font-black text-slate-900 tracking-tight">Información de la
                                        Empresa</h3>
                                    <p class="text-slate-500 mt-1">Detalles de la identidad corporativa, datos de
                                        contacto y financieros.</p>
                                </div>
                                <!-- Action Button inside Header -->
                                <a href="/empresa/editar/<%= empresa.IdEmpresa %>"
                                    class="px-5 py-2.5 bg-[#3b4bc9] hover:bg-[#3b4bc9]/90 text-white rounded-lg text-sm font-bold shadow-lg shadow-[#3b4bc9]/30 transition-all flex items-center gap-2">
                                    <span class="material-symbols-outlined text-sm">edit</span>
                                    Editar Información
                                </a>
                            </div>

                            <!-- Flash messages -->
                            <% if (typeof success !=='undefined' && success) { %>
                                <div
                                    class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                                    <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                                    <span>
                                        <%= success %>
                                    </span>
                                </div>
                                <% } %>

                                    <div class="space-y-8">

                                        <!-- Sección: Identidad Corporativa -->
                                        <section
                                            class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                                            <div
                                                class="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                                                <div class="flex items-center gap-2">
                                                    <span
                                                        class="material-symbols-outlined text-[#3b4bc9]">branding_watermark</span>
                                                    <h4 class="text-base font-bold text-slate-900">Identidad Corporativa
                                                    </h4>
                                                </div>
                                            </div>
                                            <div class="p-6 grid grid-cols-1 md:grid-cols-12 gap-6">

                                                <!-- Logo Display -->
                                                <div
                                                    class="md:col-span-4 flex flex-col items-center justify-center p-6 border border-slate-100 rounded-xl bg-slate-50">
                                                    <div
                                                        class="w-full aspect-video bg-white rounded-lg flex items-center justify-center overflow-hidden shadow-inner border border-slate-100">
                                                        <% if (empresa.Logo) { %>
                                                            <img src="/empresa/logo/<%= empresa.IdEmpresa %>"
                                                                alt="Logo de la empresa"
                                                                class="w-full h-full object-contain p-2">
                                                            <% } else { %>
                                                                <span
                                                                    class="material-symbols-outlined text-5xl text-slate-300">image</span>
                                                                <% } %>
                                                    </div>
                                                </div>

                                                <!-- Identity Info -->
                                                <div class="md:col-span-8 space-y-4">
                                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                                        <div>
                                                            <p
                                                                class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                                Razón Social</p>
                                                            <div class="flex items-center gap-2 text-slate-900">
                                                                <span
                                                                    class="material-symbols-outlined text-slate-400 text-lg">business</span>
                                                                <span class="font-semibold">
                                                                    <%= empresa.Nombre || 'No configurado' %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div>
                                                            <p
                                                                class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                                RUC</p>
                                                            <div class="flex items-center gap-2 text-slate-900">
                                                                <span
                                                                    class="material-symbols-outlined text-slate-400 text-lg">badge</span>
                                                                <span class="font-mono font-medium">
                                                                    <%= empresa.RUC || 'No configurado' %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-4">
                                                        <div>
                                                            <p
                                                                class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                                Nombre Comercial</p>
                                                            <div class="flex items-center gap-2 text-slate-900">
                                                                <span
                                                                    class="material-symbols-outlined text-slate-400 text-lg">store</span>
                                                                <span class="font-medium">
                                                                    <%= empresa.NombreComercial || 'No configurado' %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div>
                                                            <p
                                                                class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                                Estado</p>
                                                            <div class="flex items-center gap-2">
                                                                <span
                                                                    class="material-symbols-outlined text-lg <%= empresa.Estado == 1 ? 'text-emerald-500' : 'text-slate-400' %>">toggle_on</span>
                                                                <span
                                                                    class="font-semibold <%= empresa.Estado == 1 ? 'text-emerald-600' : 'text-slate-500' %>">
                                                                    <%= empresa.Estado==1 ? 'Activo' : 'Inactivo' %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <!-- Sección: Ubicación y Contacto -->
                                        <section
                                            class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                                            <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                                                <div class="flex items-center gap-2">
                                                    <span
                                                        class="material-symbols-outlined text-[#3b4bc9]">location_on</span>
                                                    <h4 class="text-base font-bold text-slate-900">Ubicación y Contacto
                                                    </h4>
                                                </div>
                                            </div>
                                            <div class="p-6">
                                                <div class="mb-6">
                                                    <p
                                                        class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                        Dirección Fiscal</p>
                                                    <div
                                                        class="flex items-center gap-2 text-slate-900 border border-slate-100 p-3 bg-slate-50 rounded-lg">
                                                        <span
                                                            class="material-symbols-outlined text-slate-400 text-lg">map</span>
                                                        <span>
                                                            <%= empresa.Direccion || 'No configurado' %>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                                                    <div>
                                                        <p
                                                            class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                            Teléfono</p>
                                                        <div class="flex items-center gap-2 text-slate-900">
                                                            <span
                                                                class="material-symbols-outlined text-slate-400 text-lg">call</span>
                                                            <span>
                                                                <%= empresa.Telefono || 'No configurado' %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <p
                                                            class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                            Celular</p>
                                                        <div class="flex items-center gap-2 text-slate-900">
                                                            <span
                                                                class="material-symbols-outlined text-slate-400 text-lg">phone_iphone</span>
                                                            <span>
                                                                <%= empresa.Celular || 'No configurado' %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <p
                                                            class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                                                            Correo Electrónico</p>
                                                        <div class="flex items-center gap-2 text-slate-900">
                                                            <span
                                                                class="material-symbols-outlined text-slate-400 text-lg">mail</span>
                                                            <span class="break-all">
                                                                <%= empresa.Email || 'No configurado' %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <!-- Sección: Información Financiera -->
                                        <section
                                            class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                                            <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                                                <div class="flex items-center gap-2">
                                                    <span
                                                        class="material-symbols-outlined text-[#3b4bc9]">account_balance</span>
                                                    <h4 class="text-base font-bold text-slate-900">Información
                                                        Financiera</h4>
                                                </div>
                                            </div>
                                            <div class="p-6">
                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                                    <div class="p-4 rounded-xl border border-slate-200 bg-white">
                                                        <div class="flex justify-between items-center mb-4">
                                                            <span
                                                                class="text-xs font-bold uppercase text-slate-400 tracking-wider">Cuenta
                                                                Bancaria Principal</span>
                                                            <span
                                                                class="bg-emerald-50 border border-emerald-100 text-emerald-700 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase">Activo</span>
                                                        </div>
                                                        <div class="space-y-4 border-t border-slate-100 pt-4">
                                                            <div>
                                                                <p class="text-xs font-semibold text-slate-400 mb-1">
                                                                    Titular de la Cuenta</p>
                                                                <p class="font-medium text-slate-900 truncate">
                                                                    <%= empresa.NombreCuentaBancaria || 'No configurado'
                                                                        %>
                                                                </p>
                                                            </div>
                                                            <div>
                                                                <p class="text-xs font-semibold text-slate-400 mb-1">
                                                                    Banco y Número de Cuenta</p>
                                                                <p class="font-mono font-medium text-slate-900">
                                                                    <%= empresa.CuentaBancaria || 'No configurado' %>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <!-- Sección: Preferencias -->
                                        <section
                                            class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                                            <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                                                <div class="flex items-center gap-2">
                                                    <span
                                                        class="material-symbols-outlined text-[#3b4bc9]">description</span>
                                                    <h4 class="text-base font-bold text-slate-900">Preferencias
                                                        (Proformas)</h4>
                                                </div>
                                            </div>
                                            <div class="p-6">
                                                <p
                                                    class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                                                    Texto de Presentación Inicial</p>
                                                <div
                                                    class="p-4 bg-slate-50 text-slate-700 border border-slate-100 rounded-lg text-sm italic whitespace-pre-line leading-relaxed">
                                                    "<%= empresa.TextoPresentacion || 'Sin texto de presentación...' %>"
                                                </div>
                                            </div>
                                        </section>

                                    </div>

                                    <% } else { %>
                                        <!-- Empty State -->
                                        <div
                                            class="text-center py-16 bg-white rounded-xl border border-slate-200 shadow-sm mt-8">
                                            <span
                                                class="material-symbols-outlined text-6xl text-slate-300 block mb-4">corporate_fare</span>
                                            <h2 class="text-xl font-bold text-slate-900 mb-2">Configurar Empresa</h2>
                                            <p class="text-slate-500 mb-6 max-w-md mx-auto">No hay información de la
                                                empresa configurada en el sistema. Debe registrar los datos para poder
                                                emitir proformas y facturas correctamente.</p>
                                            <a href="/empresa/crear"
                                                class="inline-flex items-center gap-2 px-6 py-3 bg-[#3b4bc9] hover:bg-[#3b4bc9]/90 text-white rounded-lg text-sm font-bold shadow-lg shadow-[#3b4bc9]/30 transition-all">
                                                <span class="material-symbols-outlined text-base">add_circle</span>
                                                Nueva Configuración
                                            </a>
                                        </div>
                                        <% } %>

                </div>
            </div>
    </div>
    <script src="/publico/js/layout.js?v=1772427290140"></script>
</body>

</html>