<!-- src/vistas/empresa/lista.ejs -->
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración de Empresa - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290140">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290140">
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-gear"></i>
                            Configuración de Empresa
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Administrador' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                        </div>
                    </div>
                </nav>
                <div class="container-fluid py-4">
                    <% if (empresas && empresas.length> 0) { %>
                        <% const empresa=empresas[0]; %>
                            <div class="form-card">
                                <h2 class="form-header-title">Información de la Empresa</h2>

                                <div class="form-avatar-section">
                                    <div class="form-avatar-wrapper">
                                        <% if (empresa.Logo) { %>
                                            <img src="/empresa/logo/<%= empresa.IdEmpresa %>" alt="Logo">
                                            <% } else { %>
                                                <i class="bi bi-building form-avatar-icon"></i>
                                                <% } %>
                                    </div>
                                </div>

                                <div class="form-grid">
                                    <!-- Basic info -->
                                    <div class="form-group">
                                        <div class="form-group-header">
                                            <label class="form-label">Razón Social</label>
                                            <a href="/empresa/editar/<%= empresa.IdEmpresa %>"
                                                class="form-action-text"><i class="bi bi-pencil"></i> Editar</a>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.Nombre || 'No configurado' %>" readonly>
                                            <i class="bi bi-building input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-group-header">
                                            <label class="form-label">RUC</label>
                                            <span class="form-action-text success"><i
                                                    class="bi bi-check-circle-fill"></i> Registrado</span>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.RUC || 'No configurado' %>" readonly>
                                            <i class="bi bi-upc-scan input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group full-width">
                                        <div class="form-group-header">
                                            <label class="form-label">Dirección</label>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.Direccion || 'No configurado' %>" readonly>
                                            <i class="bi bi-geo-alt input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-group-header">
                                            <label class="form-label">Teléfono</label>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.Telefono || 'No configurado' %>" readonly>
                                            <i class="bi bi-telephone input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-group-header">
                                            <label class="form-label">Celular</label>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.Celular || 'No configurado' %>" readonly>
                                            <i class="bi bi-phone input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group full-width">
                                        <div class="form-group-header">
                                            <label class="form-label">Email</label>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="email" class="form-control-modern"
                                                value="<%= empresa.Email || 'No configurado' %>" readonly>
                                            <i class="bi bi-envelope input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-group-header">
                                            <label class="form-label">Cuenta Bancaria</label>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.CuentaBancaria || 'No configurado' %>" readonly>
                                            <i class="bi bi-credit-card input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-group-header">
                                            <label class="form-label">Nombre de Cuenta</label>
                                        </div>
                                        <div class="input-wrapper has-icon">
                                            <input type="text" class="form-control-modern"
                                                value="<%= empresa.NombreCuentaBancaria || 'No configurado' %>"
                                                readonly>
                                            <i class="bi bi-bank2 input-icon"></i>
                                        </div>
                                    </div>

                                    <div class="form-group full-width">
                                        <div class="form-group-header">
                                            <label class="form-label">Texto de Presentación en Proformas</label>
                                            <a href="/empresa/editar/<%= empresa.IdEmpresa %>"
                                                class="form-action-text"><i class="bi bi-pencil"></i> Editar</a>
                                        </div>
                                        <textarea class="form-control-modern"
                                            readonly><%= empresa.TextoPresentacion || 'En atención a vuestra solicitud, tenemos el agrado de cotizarles lo siguiente:' %></textarea>
                                    </div>
                                </div>
                            </div>
                            <% } else { %>
                                <!-- Empty State -->
                                <div class="form-card text-center py-5">
                                    <h2 class="form-header-title">Configurar Empresa</h2>
                                    <p class="text-muted mb-4">No hay información de empresa configurada en el sistema.
                                    </p>
                                    <a href="/empresa/crear" class="btn-form btn-form-primary">
                                        <i class="bi bi-plus-circle"></i> Nueva Configuración
                                    </a>
                                </div>
                                <% } %>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/publico/js/layout.js?v=1772427290140"></script>
</body>

</html>