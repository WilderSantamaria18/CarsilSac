<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Empresa - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css">
    <style>
        @media (max-width: 768px) {}

        .sidebar-heading {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.3rem;
        }

        .sidebar .logo {
            width: 54px;
            height: 54px;
            object-fit: contain;
            margin-bottom: 0.2rem;
            border-radius: 12px;
            background: #fff;
            padding: 6px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        .dashboard-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 2rem 0 1.5rem 0;
            justify-content: center;
        }

        .dashboard-header .logo {
            width: 60px;
            height: 60px;
            object-fit: contain;
            border-radius: 14px;
            background: #fff;
            padding: 7px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.10);
        }

        .dashboard-header .title {
            font-size: 2.1rem;
            font-weight: 700;
            color: #003366;
            letter-spacing: 1px;
        }

        .dashboard-header .subtitle {
            font-size: 1.1rem;
            color: #0056b3;
            font-weight: 500;
        }

        .modern-card {
            max-width: 600px;
            margin: 0 auto;
            border-radius: 1.2rem;
            box-shadow: 0 6px 32px rgba(0, 0, 0, 0.10);
            border: 1.5px solid #e3e8f0;
            background: #fff;
        }

        .modern-card .card-header {
            background: linear-gradient(90deg, #003366 60%, #0056b3 100%);
            color: #fff;
            border-radius: 1.2rem 1.2rem 0 0;
            padding: 1.2rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .modern-card .card-header h5 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 0;
        }

        .modern-card .card-body {
            padding: 2rem 2.5rem 2rem 2.5rem;
        }

        .form-section-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #003366;
            margin-bottom: 1.2rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid #eee;
        }

        .form-label {
            font-weight: 500;
            color: #003366;
        }

        .input-group-text {
            background: #e3e8f0;
            color: #003366;
            border: none;
            font-size: 1.1rem;
        }

        .form-control:focus {
            border-color: #0056b3;
            box-shadow: 0 0 0 0.15rem rgba(0, 86, 179, 0.10);
        }

        .btn-primary-custom {
            background-color: #0056b3;
            border-color: #0056b3;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 0.6rem 2.2rem;
            border-radius: 0.6rem;
        }

        .btn-primary-custom:hover {
            background-color: #004494;
            border-color: #004494;
        }

        .btn-outline-secondary {
            border-radius: 0.6rem;
            font-size: 1.1rem;
            padding: 0.6rem 2.2rem;
        }

        @media (max-width: 991px) {
            .modern-card {
                padding: 0;
            }

            .modern-card .card-body {
                padding: 1.2rem;
            }
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
            }

            .dashboard-header {
                flex-direction: column;
                gap: 0.5rem;
                padding: 1.2rem 0;
            }

            .modern-card {
                max-width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
            <!-- Botón para ocultar/mostrar barra -->
            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
                    <div class="container-fluid">
                        <span class="navbar-brand ms-3">Panel de Control</span>
                        <div class="user-profile ms-auto">
                            <span>Administrador</span>
                            <div class="user-avatar">A</div>
                        </div>
                    </div>
                </nav>
                <div class="dashboard-header">

                    <div>

                        <div class="subtitle">CARSIL Equipos y Servicios SAC</div>
                    </div>
                </div>
                <div class="container-fluid py-4">
                    <div class="card card-custom">
                        <div class="card-header bg-white border-bottom">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">
                                    <i class="bi bi-building me-2"></i>Registrar Empresa
                                </h5>
                                <a href="/empresa" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>Volver
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <form action="/empresa/crear" method="POST" enctype="multipart/form-data"
                                autocomplete="off">
                                <!-- Sección de Información de la Empresa -->
                                <div class="form-section mb-4">
                                    <h6 class="form-section-title mb-3">
                                        <i class="bi bi-info-circle me-2"></i>Información de la Empresa
                                    </h6>
                                    <div class="row g-4 align-items-center">
                                        <div class="col-md-6">
                                            <label for="Nombre" class="form-label">Nombre (Razón Social) <span
                                                    class="text-danger">*</span></label>
                                            <input type="text" class="form-control" id="Nombre" name="Nombre" required
                                                placeholder="Ej: CARSIL Equipos y Servicios SAC">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="RUC" class="form-label">RUC <span
                                                    class="text-danger">*</span></label>
                                            <input type="text" class="form-control" id="RUC" name="RUC" required
                                                placeholder="Ej: 20123456789" maxlength="11">
                                        </div>
                                        <div class="col-md-12">
                                            <label for="Direccion" class="form-label">Dirección <span
                                                    class="text-danger">*</span></label>
                                            <input type="text" class="form-control" id="Direccion" name="Direccion"
                                                required placeholder="Ej: Av. Principal 123, Lima">
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Información de Contacto -->
                                <div class="form-section mb-4">
                                    <h6 class="form-section-title mb-3">
                                        <i class="bi bi-phone me-2"></i>Información de Contacto
                                    </h6>
                                    <div class="row g-4 align-items-center">
                                        <div class="col-md-6">
                                            <label for="Telefono" class="form-label">Teléfono</label>
                                            <input type="text" class="form-control" id="Telefono" name="Telefono"
                                                placeholder="Ej: 012345678">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="Celular" class="form-label">Celular</label>
                                            <input type="text" class="form-control" id="Celular" name="Celular"
                                                placeholder="Ej: 987654321">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="Email" class="form-label">Email</label>
                                            <input type="email" class="form-control" id="Email" name="Email"
                                                placeholder="Ej: contacto@carsil.com">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="Representante" class="form-label">Representante Legal</label>
                                            <input type="text" class="form-control" id="Representante"
                                                name="Representante" placeholder="Ej: Juan Pérez">
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Información Bancaria -->
                                <div class="form-section mb-4">
                                    <h6 class="form-section-title mb-3">
                                        <i class="bi bi-bank me-2"></i>Información Bancaria
                                    </h6>
                                    <div class="row g-4 align-items-center">
                                        <div class="col-md-6">
                                            <label for="CuentaBancaria" class="form-label">Cuenta Bancaria</label>
                                            <input type="text" class="form-control" id="CuentaBancaria"
                                                name="CuentaBancaria" placeholder="Ej: 1234567890123456">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="NombreCuentaBancaria" class="form-label">Nombre de la Cuenta
                                                Bancaria</label>
                                            <input type="text" class="form-control" id="NombreCuentaBancaria"
                                                name="NombreCuentaBancaria" placeholder="Ej: CARSIL SAC">
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección de Otros Detalles -->
                                <div class="form-section mb-4">
                                    <h6 class="form-section-title mb-3">
                                        <i class="bi bi-info-circle me-2"></i>Otros Detalles
                                    </h6>
                                    <div class="row g-4 align-items-center">
                                        <div class="col-md-12">
                                            <label for="Logo" class="form-label">Logo</label>
                                            <input type="file" class="form-control" id="Logo" name="Logo"
                                                accept="image/*">
                                        </div>
                                        <div class="col-md-12">
                                            <label for="TextoPresentacion" class="form-label">Texto de
                                                Presentación</label>
                                            <textarea class="form-control" id="TextoPresentacion"
                                                name="TextoPresentacion" rows="3"
                                                placeholder="Ej: En atención a vuestra solicitud, tenemos el agrado de cotizarles lo siguiente:"></textarea>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end mt-4 gap-2">
                                    <a href="/empresa" class="btn btn-outline-secondary">
                                        <i class="bi bi-x-circle me-2"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-save me-2"></i>Registrar Empresa
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');
            const menuItems = document.querySelectorAll('.menu-item');
            const userAvatar = document.querySelector('.user-avatar');
            const userName = 'Administrador';
            userAvatar.textContent = userName.charAt(0);

            toggleBtn.addEventListener('click', function () {
                sidebar.classList.toggle('hide');
                mainContent.classList.toggle('full');
                // Cambia el icono de dirección
                if (sidebar.classList.contains('hide')) {
                    toggleIcon.classList.remove('bi-chevron-left');
                    toggleIcon.classList.add('bi-chevron-right');
                } else {
                    toggleIcon.classList.remove('bi-chevron-right');
                    toggleIcon.classList.add('bi-chevron-left');
                }
            });
            // Menú activo
        });
    </script>
    <script src="/publico/js/layout.js"></script>
</body>

</html>