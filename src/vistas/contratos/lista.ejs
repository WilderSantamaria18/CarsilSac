<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Contratos - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290138">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>
<body>

    <div class="wrapper">
        <!-- Sidebar -->
        <%- include("../parciales/sidebar") %>

        <!-- Botón para ocultar/mostrar barra -->

        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="navbar-brand ms-3 mb-0">
                        <i class="bi bi-file-earmark-check me-2"></i>
                        Gestión de Contratos
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>

<div id="main-content" class="main-content">
    <div class="container-fluid py-4">
            <div class="container-fluid py-4">
                <!-- Header modernizado -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h1 class="page-title">
                                <i class="bi bi-file-earmark-check me-2"></i>
                                Gestión de Contratos
                            </h1>
                        </div>
                        <div>
                            <a href="/contratos/crear" class="btn btn-primary-modern btn-modern">
                                <i class="bi bi-plus-circle"></i>
                                Nuevo Contrato
                            </a>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="page-title">
                                <i class="bi bi-file-earmark-check me-3 text-primary"></i>
                                Gestión de Contratos
                            </h1>
                            <p class="page-subtitle">Administre los contratos entre clientes y facturas</p>
                        </div>
                        <div>
                            <a href="/contratos/crear" class="btn btn-primary-modern btn-modern">
                                <i class="bi bi-plus-circle"></i>
                                Nuevo Contrato
                            </a>
                        </div>
                    </div>
                </div>

        <!-- Mensajes flash -->
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>
                <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

                <!-- Estadísticas modernizadas -->
                <% if (estadisticas) { %>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #0056b3, #0d6efd);">
                            <i class="bi bi-file-earmark-check text-white"></i>
                        </div>
                        <h6 class="text-muted">Total Contratos</h6>
                        <h3 class="text-primary"><%= estadisticas.TotalContratos || 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #28a745, #20c997);">
                            <i class="bi bi-check-circle text-white"></i>
                        </div>
                        <h6 class="text-muted">Contratos Activos</h6>
                        <h3 class="text-success"><%= estadisticas.ContratosActivos || 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6f42c1, #e83e8c);">
                            <i class="bi bi-flag text-white"></i>
                        </div>
                        <h6 class="text-muted">Finalizados</h6>
                        <h3 class="text-info"><%= estadisticas.ContratosFinalizados || 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ffc107, #fd7e14);">
                            <i class="bi bi-currency-dollar text-white"></i>
                        </div>
                        <h6 class="text-muted">Prom. Semanal</h6>
                        <h3 class="text-warning">S/ <%= parseFloat(estadisticas.PromedioPageSemanal || 0).toFixed(2) %></h3>
                    </div>
                </div>
                <% } %>

        <div class="search-container">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="search-box flex-grow-1 me-3">
                            <div class="d-flex gap-2 align-items-center">
                        <select class="form-select form-select-sm me-2" id="filtroEstado" style="width: auto;">
                            <option value="">Todos los estados</option>
                            <option value="ACTIVO">Activos</option>
                            <option value="FINALIZADO">Finalizados</option>
                            <option value="SUSPENDIDO">Suspendidos</option>
                            <option value="CANCELADO">Cancelados</option>
                        </select>
                        <input type="text" class="form-control form-control-sm" id="buscarContrato" 
                               placeholder="Buscar contrato..." style="width: 200px;">
                    </div>
                        </div>
                    </div>
                </div>
                
                <div class="card-modern">
                <% if (contratos && contratos.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-modern mb-0" id="tablaContratos">
                        <thead>
                            <tr>
                                <th style="width: 40px;"><input class="form-check-input custom-checkbox" type="checkbox"></th>
                                <th>Código <i class="bi bi-arrow-down-up"></i></th>
                                <th>Cliente <i class="bi bi-arrow-down-up"></i></th>
                                <th>Factura <i class="bi bi-arrow-down-up"></i></th>
                                <th>Fecha Inicio <i class="bi bi-arrow-down-up"></i></th>
                                <th>Fecha Fin <i class="bi bi-arrow-down-up"></i></th>
                                <th>Pago Semanal <i class="bi bi-arrow-down-up"></i></th>
                                <th>Estado <i class="bi bi-arrow-down-up"></i></th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% contratos.forEach(function(contrato) { %>
                            <tr data-estado="<%= contrato.Estado %>">
                                <td><input class="form-check-input custom-checkbox" type="checkbox"></td>
                                <td>
                                    <span class="fw-bold text-primary"><%= contrato.Codigo %></span>
                                </td>
                                <td>
                                    <div class="item-info">
                                        <div class="item-avatar">
                                            <%= contrato.ClienteNombre ? contrato.ClienteNombre.charAt(0).toUpperCase() : 'C' %>
                                        </div>
                                        <div class="item-details">
                                            <strong><%= contrato.ClienteNombre %></strong>
                                            <div class="text-muted"><i class="bi bi-card-text me-1"></i><%= contrato.ClienteDocumento %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <% if (contrato.FacturaCodigo) { %>
                                        <div>
                                            <strong><%= contrato.FacturaCodigo %></strong>
                                            <br>
                                            <small class="text-muted">
                                                S/ <%= parseFloat(contrato.FacturaTotal || 0).toFixed(2) %>
                                            </small>
                                        </div>
                                    <% } else { %>
                                        <span class="text-muted">Sin factura</span>
                                    <% } %>
                                </td>
                                <td>
                                    <%= new Date(contrato.FechaInicio).toLocaleDateString('es-PE') %>
                                </td>
                                <td>
                                    <% if (contrato.FechaFin) { %>
                                        <%= new Date(contrato.FechaFin).toLocaleDateString('es-PE') %>
                                    <% } else { %>
                                        <span class="text-muted">Indefinido</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (contrato.PagoSemanal) { %>
                                        <strong>S/ <%= parseFloat(contrato.PagoSemanal).toFixed(2) %></strong>
                                    <% } else { %>
                                        <span class="text-muted">No definido</span>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="badge badge-modern <%= contrato.Estado === 'ACTIVO' ? 'badge-activo' : (contrato.Estado === 'FINALIZADO' ? 'badge-inactivo' : (contrato.Estado === 'SUSPENDIDO' ? 'badge-warning' : 'badge-danger')) %>">
                                        <%= contrato.Estado %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="action-buttons justify-content-center">
                                        <a href="/contratos/<%= contrato.IdContrato %>" 
                                           class="btn-action-icon btn-action-view" 
                                           title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/contratos/<%= contrato.IdContrato %>/editar" 
                                           class="btn-action-icon btn-action-edit" 
                                           title="Editar contrato">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <% if (contrato.Estado === 'ACTIVO') { %>
                                        <button type="button" 
                                                class="btn-action-icon btn-action-delete text-secondary btn-cambiar-estado" 
                                                data-id="<%= contrato.IdContrato %>"
                                                data-estado="SUSPENDIDO"
                                                title="Suspender contrato">
                                            <i class="bi bi-pause"></i>
                                        </button>
                                        <% } else if (contrato.Estado === 'SUSPENDIDO') { %>
                                        <button type="button" 
                                                class="btn-action-icon btn-action-view text-success btn-cambiar-estado" 
                                                data-id="<%= contrato.IdContrato %>"
                                                data-estado="ACTIVO"
                                                title="Reactivar contrato">
                                            <i class="bi bi-play"></i>
                                        </button>
                                        <% } %>
                                        <button type="button" 
                                                class="btn-action-icon btn-action-delete btn-eliminar" 
                                                data-id="<%= contrato.IdContrato %>"
                                                data-codigo="<%= contrato.Codigo %>"
                                                title="Eliminar contrato">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div class="empty-state">
                    <i class="bi bi-file-earmark-check display-1 mb-3"></i>
                    <h5>No hay contratos registrados</h5>
                    <p>Comience creando su primer contrato para gestionar las relaciones entre clientes y facturas</p>
                    <a href="/contratos/crear" class="btn btn-primary-modern btn-modern">
                        <i class="bi bi-plus-circle"></i>
                        Crear Primer Contrato
                    </a>
                </div>
                <% } %>
            </div>
        </div>
                </div>
            </div>
        </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Sidebar functionality
    const toggleBtn = document.getElementById('toggleSidebarBtn');
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('main-content');
    const toggleIcon = document.getElementById('toggleIcon');
    const userAvatar = document.querySelector('.user-avatar');
    const userName = '<%= user && user.Nombres ? user.Nombres : "Administrador" %>';
    
    if (userAvatar) {
        userAvatar.textContent = userName.charAt(0);
    }

    // Toggle sidebar
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });
    }

    // Filtro por estado
    const filtroEstado = document.getElementById('filtroEstado');
    const buscarContrato = document.getElementById('buscarContrato');
    const tabla = document.getElementById('tablaContratos');
    
    if (filtroEstado && tabla) {
        filtroEstado.addEventListener('change', filtrarTabla);
        buscarContrato.addEventListener('input', filtrarTabla);
    }
    
    function filtrarTabla() {
        const estadoSeleccionado = filtroEstado.value.toLowerCase();
        const textoBusqueda = buscarContrato.value.toLowerCase();
        const filas = tabla.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
        
        Array.from(filas).forEach(fila => {
            const estado = fila.dataset.estado.toLowerCase();
            const textoFila = fila.textContent.toLowerCase();
            
            const coincideEstado = !estadoSeleccionado || estado === estadoSeleccionado;
            const coincideTexto = !textoBusqueda || textoFila.includes(textoBusqueda);
            
            fila.style.display = (coincideEstado && coincideTexto) ? '' : 'none';
        });
    }
    
    // Cambiar estado
    document.querySelectorAll('.btn-cambiar-estado').forEach(btn => {
        btn.addEventListener('click', async function() {
            const id = this.dataset.id;
            const nuevoEstado = this.dataset.estado;
            const accion = nuevoEstado === 'ACTIVO' ? 'reactivar' : 'suspender';
            
            if (await liquidGlassConfirm(`¿Está seguro de que desea ${accion} este contrato?`)) {
                cambiarEstadoContrato(id, nuevoEstado);
            }
        });
    });
    
    // Eliminar contrato
    document.querySelectorAll('.btn-eliminar').forEach(btn => {
        btn.addEventListener('click', async function() {
            const id = this.dataset.id;
            const codigo = this.dataset.codigo;
            
            if (await liquidGlassConfirm(`¿Está seguro de que desea eliminar el contrato ${codigo}?\nEsta acción no se puede deshacer.`)) {
                eliminarContrato(id);
            }
        });
    });
    
    async function cambiarEstadoContrato(id, estado) {
        try {
            const response = await fetch(`/contratos/${id}/estado`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ estado: estado })
            });
            
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error al cambiar el estado del contrato');
        }
    }
    
    async function eliminarContrato(id) {
        try {
            const response = await fetch(`/contratos/${id}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                }
            });
            
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error al eliminar el contrato');
        }
    }

    // Animación de contadores en las estadísticas
    function animateCounters() {
        const counters = document.querySelectorAll('.card-stats h3');
        counters.forEach(counter => {
            const text = counter.textContent;
            const isMonetary = text.includes('S/');
            const numberMatch = text.match(/[\d,]+\.?\d*/);
            
            if (numberMatch) {
                const target = parseFloat(numberMatch[0].replace(',', '')) || 0;
                const increment = target > 0 ? Math.max(Math.ceil(target / 50), 1) : 0;
                let current = 0;
                
                // Establecer valor inicial como 0
                if (isMonetary) {
                    counter.textContent = 'S/ 0.00';
                } else {
                    counter.textContent = '0';
                }
                
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        current = target;
                        clearInterval(timer);
                    }
                    
                    if (isMonetary) {
                        counter.textContent = `S/ ${Math.floor(current).toFixed(2)}`;
                    } else {
                        counter.textContent = Math.floor(current);
                    }
                }, 30);
            }
        });
    }

    // Ejecutar animación de contadores después de un breve delay
    setTimeout(animateCounters, 500);
});
</script>

    <script src="/publico/js/layout.js?v=1772427290138"></script>
</body>
</html>
