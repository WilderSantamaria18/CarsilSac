<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Contrato - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290137">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290137">
    
</head>
<body>

    <div class="wrapper">
        <!-- Sidebar -->
        <%- include("../parciales/sidebar") %>

        <!-- Botón para ocultar/mostrar barra -->

        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="navbar-brand ms-3 mb-0">
                        <i class="bi bi-pencil-square me-2"></i>
                        Editar Contrato
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>

<div id="main-content" class="main-content">
    <div class="container-fluid py-4">
            <div class="container-fluid py-4">
                <!-- Header modernizado -->
                <div class="page-header">
                    <div class="floating-shapes">
                        <i class="bi bi-pencil-square shape" style="font-size: 3rem;"></i>
                        <i class="bi bi-file-earmark-check shape" style="font-size: 2.5rem;"></i>
                        <i class="bi bi-gear shape" style="font-size: 2rem;"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="page-title">
                                <i class="bi bi-pencil me-3 text-warning"></i>
                                Editar Contrato <%= contrato.Codigo %>
                            </h1>
                            <p class="page-subtitle">Modifique la información del contrato</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span class="estado-badge estado-<%= contrato.Estado.toLowerCase() %>">
                                <%= contrato.Estado %>
                            </span>
                            <a href="/contratos/<%= contrato.IdContrato %>" class="btn-form btn-form-cancel-modern btn-modern">
                                <i class="bi bi-arrow-left"></i>
                                Volver al Detalle
                            </a>
                        </div>
                    </div>
                </div>

        <!-- Mensajes flash -->
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="row">
            <!-- Formulario -->
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-text me-2"></i>
                            Información del Contrato
                        </h5>
                    </div>
                    <div class="card-body">
                        <form action="/contratos/<%= contrato.IdContrato %>/editar" method="POST" id="formContrato">
                            <div class="row">
                                <!-- Código del Contrato -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="text" class="form-control-modern" id="Codigo" name="Codigo" 
                                               value="<%= contrato.Codigo %>" required>
                                        <label for="Codigo">Código del Contrato <span class="required">*</span></label>
                                    </div>
                                </div>

                                <!-- Cliente -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <select class="form-control-modern form-select-modern" id="IdCliente" name="IdCliente" required>
                                            <option value="">Seleccionar cliente...</option>
                                            <% clientes.forEach(function(cliente) { %>
                                                <option value="<%= cliente.IdCliente %>" 
                                                        <%= cliente.IdCliente == contrato.IdCliente ? 'selected' : '' %>>
                                                    <%= cliente.RazonSocial %> - <%= cliente.Documento %>
                                                </option>
                                            <% }); %>
                                        </select>
                                        <label for="IdCliente">Cliente <span class="required">*</span></label>
                                    </div>
                                </div>

                                <!-- Factura -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <select class="form-control-modern form-select-modern" id="IdFactura" name="IdFactura">
                                            <option value="">Seleccionar factura (opcional)...</option>
                                            <% facturas.forEach(function(factura) { %>
                                                <option value="<%= factura.IdFactura %>" 
                                                        data-cliente="<%= factura.IdCliente %>"
                                                        data-total="<%= factura.Total %>"
                                                        <%= factura.IdFactura == contrato.IdFactura ? 'selected' : '' %>>
                                                    <%= factura.Codigo %> - S/ <%= parseFloat(factura.Total).toFixed(2) %>
                                                </option>
                                            <% }); %>
                                        </select>
                                        <label for="IdFactura">Factura Asociada</label>
                                    </div>
                                </div>

                                <!-- Número de Cuenta Bancaria -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="text" class="form-control-modern" id="NumeroCuentaBanco" 
                                               name="NumeroCuentaBanco" value="<%= contrato.NumeroCuentaBanco || '' %>"
                                               placeholder="Número de cuenta">
                                        <label for="NumeroCuentaBanco">Número de Cuenta Bancaria</label>
                                    </div>
                                </div>

                                <!-- Fecha de Inicio -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="date" class="form-control-modern" id="FechaInicio" 
                                               name="FechaInicio" value="<%= contrato.FechaInicio.toISOString().split('T')[0] %>" required>
                                        <label for="FechaInicio">Fecha de Inicio <span class="required">*</span></label>
                                    </div>
                                </div>

                                <!-- Fecha de Fin -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="date" class="form-control-modern" id="FechaFin" name="FechaFin"
                                               value="<%= contrato.FechaFin ? contrato.FechaFin.toISOString().split('T')[0] : '' %>">
                                        <label for="FechaFin">Fecha de Fin (Opcional)</label>
                                    </div>
                                </div>

                                <!-- Pago Semanal -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="number" class="form-control-modern" id="PagoSemanal" 
                                               name="PagoSemanal" step="0.01" min="0" 
                                               value="<%= contrato.PagoSemanal || '' %>" placeholder="0.00">
                                        <label for="PagoSemanal">Pago Semanal (S/)</label>
                                    </div>
                                </div>

                                <!-- Estado -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <select class="form-control-modern form-select-modern" id="Estado" name="Estado">
                                            <option value="ACTIVO" <%= contrato.Estado === 'ACTIVO' ? 'selected' : '' %>>Activo</option>
                                            <option value="SUSPENDIDO" <%= contrato.Estado === 'SUSPENDIDO' ? 'selected' : '' %>>Suspendido</option>
                                            <option value="FINALIZADO" <%= contrato.Estado === 'FINALIZADO' ? 'selected' : '' %>>Finalizado</option>
                                            <option value="CANCELADO" <%= contrato.Estado === 'CANCELADO' ? 'selected' : '' %>>Cancelado</option>
                                        </select>
                                        <label for="Estado">Estado del Contrato</label>
                                    </div>
                                </div>

                                <!-- Términos y Condiciones -->
                                <div class="col-12 mb-3">
                                    <div class="form-floating">
                                        <textarea class="form-control-modern" id="Terminos" name="Terminos" 
                                                  style="height: 120px;" placeholder="Términos y condiciones del contrato..."><%= contrato.Terminos || '' %></textarea>
                                        <label for="Terminos">Términos y Condiciones</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <button type="submit" class="btn btn-warning-modern btn-modern me-3">
                                        <i class="bi bi-check-circle"></i>
                                        Actualizar Contrato
                                    </button>
                                    <a href="/contratos/<%= contrato.IdContrato %>" class="btn-form btn-form-cancel-modern btn-modern">
                                        <i class="bi bi-x-circle"></i>
                                        Cancelar
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Panel de información -->
            <div class="col-lg-4">
                <div class="card info-panel mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Información del Contrato Actual
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <h6 class="text-primary">
                                <i class="bi bi-calendar me-2"></i>
                                Fechas Importantes
                            </h6>
                            <ul class="list-unstyled small">
                                <li class="mb-2">
                                    <strong>Registrado:</strong> 
                                    <%= new Date(contrato.FechaRegistro).toLocaleDateString('es-PE') %>
                                </li>
                                <li class="mb-2">
                                    <strong>Inicio:</strong> 
                                    <%= new Date(contrato.FechaInicio).toLocaleDateString('es-PE') %>
                                </li>
                                <% if (contrato.FechaFin) { %>
                                <li class="mb-2">
                                    <strong>Fin:</strong> 
                                    <%= new Date(contrato.FechaFin).toLocaleDateString('es-PE') %>
                                </li>
                                <% } %>
                            </ul>
                        </div>

                        <div class="mb-3">
                            <h6 class="text-success">
                                <i class="bi bi-person-badge me-2"></i>
                                Cliente Actual
                            </h6>
                            <div class="small">
                                <p class="mb-1"><strong><%= contrato.ClienteNombre %></strong></p>
                                <p class="mb-1">Doc: <%= contrato.ClienteDocumento %></p>
                                <% if (contrato.ClienteEmail) { %>
                                <p class="mb-0">Email: <%= contrato.ClienteEmail %></p>
                                <% } %>
                            </div>
                        </div>

                        <% if (contrato.FacturaCodigo) { %>
                        <div class="mb-3">
                            <h6 class="text-info">
                                <i class="bi bi-receipt me-2"></i>
                                Factura Asociada
                            </h6>
                            <div class="small">
                                <p class="mb-1"><strong><%= contrato.FacturaCodigo %></strong></p>
                                <p class="mb-0">Total: S/ <%= parseFloat(contrato.FacturaTotal).toFixed(2) %></p>
                            </div>
                        </div>
                        <% } %>

                        <div id="infoFactura" class="d-none">
                            <h6 class="text-info">
                                <i class="bi bi-receipt me-2"></i>
                                Nueva Factura Seleccionada
                            </h6>
                            <div class="small">
                                <p class="mb-1"><strong>Total:</strong> <span id="facturaTotal"></span></p>
                                <p class="mb-0"><strong>Cliente:</strong> <span id="facturaCliente"></span></p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Consideraciones
                        </h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled small">
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                Puede cambiar el cliente del contrato
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                La factura se filtra por cliente
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check text-success me-2"></i>
                                Puede quitar la factura asociada
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-exclamation text-warning me-2"></i>
                                Los cambios son permanentes
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
                </div>
            </div>
        </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Sidebar functionality
    const toggleBtn = document.getElementById('toggleSidebarBtn');
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('main-content');
    const toggleIcon = document.getElementById('toggleIcon');
    const userAvatar = document.querySelector('.user-avatar');
    const userName = '<%= user && user.Nombres ? user.Nombres : "Administrador" %>';
    
    if (userAvatar) {
        userAvatar.textContent = userName.charAt(0);
    }

    // Toggle sidebar
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });
    }

    // Form functionality
    const clienteSelect = document.getElementById('IdCliente');
    const facturaSelect = document.getElementById('IdFactura');
    const fechaInicioInput = document.getElementById('FechaInicio');
    const fechaFinInput = document.getElementById('FechaFin');
    const infoFactura = document.getElementById('infoFactura');
    const facturaTotal = document.getElementById('facturaTotal');
    const facturaCliente = document.getElementById('facturaCliente');
    const estadoSelect = document.getElementById('Estado');

    // Filtrar facturas por cliente seleccionado
    clienteSelect.addEventListener('change', function() {
        const clienteId = this.value;
        const opciones = facturaSelect.querySelectorAll('option');
        
        // Resetear facturas
        facturaSelect.value = '';
        if (infoFactura) infoFactura.classList.add('d-none');
        
        opciones.forEach(opcion => {
            if (opcion.value === '') {
                opcion.style.display = 'block';
            } else {
                const facturaClienteId = opcion.dataset.cliente;
                opcion.style.display = (clienteId === '' || facturaClienteId === clienteId) ? 'block' : 'none';
            }
        });

        // Si hay cliente seleccionado, cargar sus facturas via AJAX
        if (clienteId) {
            cargarFacturasCliente(clienteId);
        }
    });

    // Mostrar información de factura seleccionada
    facturaSelect.addEventListener('change', function() {
        const opcionSeleccionada = this.options[this.selectedIndex];
        
        if (this.value && opcionSeleccionada.dataset.total && infoFactura) {
            const total = parseFloat(opcionSeleccionada.dataset.total).toFixed(2);
            const clienteNombre = clienteSelect.options[clienteSelect.selectedIndex].text;
            
            facturaTotal.textContent = 'S/ ' + total;
            facturaCliente.textContent = clienteNombre;
            infoFactura.classList.remove('d-none');
        } else if (infoFactura) {
            infoFactura.classList.add('d-none');
        }
    });

    // Validar fechas
    fechaInicioInput.addEventListener('change', async function() {
        fechaFinInput.min = this.value;
        if (fechaFinInput.value && fechaFinInput.value <= this.value) {
            const mantener = await liquidGlassConfirm('La fecha de fin es anterior o igual a la fecha de inicio.\n¿Desea mantenerla?');
            if (!mantener) {
                fechaFinInput.value = '';
            }
        }
    });

    // Actualizar badge de estado en tiempo real
    estadoSelect.addEventListener('change', function() {
        // Aquí podrías actualizar visualmente el badge si quisieras
        console.log('Estado cambiado a:', this.value);
    });

    // Cargar facturas del cliente via AJAX
    async function cargarFacturasCliente(clienteId) {
        try {
            const response = await fetch(`/contratos/api/facturas-cliente/${clienteId}`);
            const data = await response.json();
            
            if (data.success && data.facturas) {
                // Mantener la primera opción y facturas existentes que coincidan
                const facturaActual = facturaSelect.value;
                const primeraOpcion = facturaSelect.querySelector('option[value=""]');
                
                // Limpiar opciones (excepto la primera y posiblemente la actual)
                Array.from(facturaSelect.options).forEach(option => {
                    if (option.value !== '' && option.value !== facturaActual) {
                        option.remove();
                    }
                });
                
                // Agregar facturas disponibles
                data.facturas.forEach(factura => {
                    // No agregar si ya existe
                    if (!facturaSelect.querySelector(`option[value="${factura.IdFactura}"]`)) {
                        const opcion = document.createElement('option');
                        opcion.value = factura.IdFactura;
                        opcion.textContent = `${factura.Codigo} - S/ ${parseFloat(factura.Total).toFixed(2)}`;
                        opcion.dataset.cliente = clienteId;
                        opcion.dataset.total = factura.Total;
                        facturaSelect.appendChild(opcion);
                    }
                });
            }
        } catch (error) {
            console.error('Error al cargar facturas:', error);
        }
    }

    // Validación del formulario
    document.getElementById('formContrato').addEventListener('submit', async function(e) {
        const codigo = document.getElementById('Codigo').value.trim();
        const cliente = document.getElementById('IdCliente').value;
        const fechaInicio = document.getElementById('FechaInicio').value;
        const pagoSemanal = document.getElementById('PagoSemanal').value;

        if (!codigo || !cliente || !fechaInicio) {
            e.preventDefault();
            alert('Por favor complete todos los campos obligatorios.');
            return false;
        }

        if (pagoSemanal && (isNaN(pagoSemanal) || parseFloat(pagoSemanal) < 0)) {
            e.preventDefault();
            alert('El pago semanal debe ser un número positivo.');
            return false;
        }

        // Confirmar actualización
        const confirmado = await liquidGlassConfirm('¿Está seguro de que desea actualizar este contrato?');
        if (!confirmado) {
            e.preventDefault();
            return false;
        }
    });

    // Inicializar filtros si hay cliente seleccionado
    if (clienteSelect.value) {
        clienteSelect.dispatchEvent(new Event('change'));
    }
});
</script>

    <script src="/publico/js/layout.js?v=1772427290137"></script>
</body>
</html>
