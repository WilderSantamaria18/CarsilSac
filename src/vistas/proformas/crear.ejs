<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nueva Proforma - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290146">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290146">
    
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <!-- Botón para ocultar/mostrar barra -->

            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg top-navbar">
                    <div class="container-fluid">
                        <span class="navbar-brand">Nueva Proforma</span>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Usuario' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid py-4">
                    <!-- Alertas -->
                    <% if (messages && messages.success) { %>
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <%= messages.success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"
                                    aria-label="Close"></button>
                        </div>
                        <% } %>
                            <% if (messages && messages.error) { %>
                                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <%= messages.error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"
                                            aria-label="Close"></button>
                                </div>
                                <% } %>

                                    <form action="/proformas/nueva" method="POST">
                                        <!-- Información General -->
                                        <div class="form-section">
                                            <h4 class="section-title">
                                                <i class="bi bi-file-earmark-text"></i>
                                                Información General
                                            </h4>
                                            <div class="row g-4">
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-hash"></i>
                                                        Código
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-hash"></i>
                                                        <input type="text" name="Codigo" class="form-control-modern"
                                                            placeholder="PRO-001" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-people"></i>
                                                        Cliente
                                                    </label>
                                                    <select name="IdCliente" class="form-control-modern form-select-modern" required>
                                                        <option value="">Seleccionar Cliente</option>
                                                        <% if (typeof clientes !=='undefined' && clientes &&
                                                            clientes.length> 0) { %>
                                                            <% clientes.forEach(cliente=> { %>
                                                                <option value="<%= cliente.IdCliente %>">
                                                                    <%= cliente.RazonSocial %> - <%= cliente.Documento
                                                                            %>
                                                                </option>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <option value="" disabled>No hay clientes
                                                                            disponibles</option>
                                                                        <% } %>
                                                    </select>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-person-circle"></i>
                                                        Usuario
                                                    </label>
                                                    <select name="IdUsuario" class="form-control-modern form-select-modern" required>
                                                        <option value="">Seleccionar Usuario</option>
                                                        <% if (typeof usuarios !=='undefined' && usuarios &&
                                                            usuarios.length> 0) { %>
                                                            <% usuarios.forEach(usuario=> { %>
                                                                <option value="<%= usuario.IdUsuario %>" <%=user &&
                                                                    user.IdUsuario==usuario.IdUsuario ? 'selected' : ''
                                                                    %>>
                                                                    <%= usuario.Nombres %>
                                                                        <%= usuario.Apellidos %>
                                                                </option>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <option value="" disabled>No hay usuarios
                                                                            disponibles</option>
                                                                        <% } %>
                                                    </select>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-building"></i>
                                                        Empresa
                                                    </label>
                                                    <select name="IdEmpresa" class="form-control-modern form-select-modern" required>
                                                        <option value="">Seleccionar Empresa</option>
                                                        <% if (typeof empresas !=='undefined' && empresas &&
                                                            empresas.length> 0) { %>
                                                            <% empresas.forEach(empresa=> { %>
                                                                <option value="<%= empresa.IdEmpresa %>">
                                                                    <%= empresa.Nombre %> - <%= empresa.RUC %>
                                                                </option>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <option value="" disabled>No hay empresas
                                                                            disponibles</option>
                                                                        <% } %>
                                                    </select>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-calendar"></i>
                                                        Fecha Emisión
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-calendar"></i>
                                                        <input type="date" name="FechaEmision" class="form-control-modern"
                                                            required>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-tag"></i>
                                                        Referencia
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-tag"></i>
                                                        <input type="text" name="Referencia" class="form-control-modern"
                                                            placeholder="REF-001">
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-clock"></i>
                                                        Validez (días)
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-clock"></i>
                                                        <input type="number" name="ValidezOferta" class="form-control-modern"
                                                            value="10" min="1" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-check-circle"></i>
                                                        Estado
                                                    </label>
                                                    <select name="Estado" class="form-control-modern form-select-modern">
                                                        <option value="PENDIENTE" selected>PENDIENTE</option>
                                                        <option value="APROBADA">APROBADA</option>
                                                        <option value="RECHAZADA">RECHAZADA</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Condiciones Comerciales -->
                                        <div class="form-section">
                                            <h4 class="section-title">
                                                <i class="bi bi-clipboard-check"></i>
                                                Condiciones Comerciales
                                            </h4>
                                            <div class="row g-4">
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-truck"></i>
                                                        Tiempo Entrega
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-truck"></i>
                                                        <input type="text" name="TiempoEntrega" class="form-control-modern"
                                                            placeholder="15 días hábiles">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-geo-alt"></i>
                                                        Lugar Entrega
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-geo-alt"></i>
                                                        <input type="text" name="LugarEntrega" class="form-control-modern"
                                                            placeholder="Lima, Perú">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-shield-check"></i>
                                                        Garantía
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-shield-check"></i>
                                                        <input type="text" name="Garantia" class="form-control-modern"
                                                            placeholder="12 meses">
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">
                                                        <i class="bi bi-credit-card"></i>
                                                        Forma de Pago
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-credit-card"></i>
                                                        <input type="text" name="FormaPago" class="form-control-modern"
                                                            placeholder="50% adelanto, 50% contra entrega">
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">
                                                        <i class="bi bi-chat-left-text"></i>
                                                        Observaciones
                                                    </label>
                                                    <textarea name="Observaciones" class="form-control-modern" rows="2"
                                                        placeholder="Notas adicionales..."></textarea>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Totales -->
                                        <div class="form-section">
                                            <h4 class="section-title">
                                                <i class="bi bi-calculator"></i>
                                                Resumen de Costos
                                            </h4>
                                            <div class="row g-4">
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-percent"></i>
                                                        IGV (%)
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-percent"></i>
                                                        <input type="number" step="0.01" name="PorcentajeIGV"
                                                            class="form-control-modern" value="18.00" min="0" max="100"
                                                            required>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        SubTotal
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        <input type="number" step="0.01" name="SubTotal"
                                                            class="form-control-modern total-field" readonly>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        Total IGV
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        <input type="number" step="0.01" name="TotalIGV"
                                                            class="form-control-modern total-field" readonly>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        Total Final
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        <input type="number" step="0.01" name="Total"
                                                            class="form-control-modern total-field" readonly>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Detalle de Productos -->
                                        <div class="form-section">
                                            <div class="d-flex justify-content-between align-items-center mb-4">
                                                <h4 class="section-title mb-0">
                                                    <i class="bi bi-box-seam"></i>
                                                    Detalle de Productos
                                                </h4>
                                                <button type="button" class="btn btn-success" id="addRowBtn">
                                                    <i class="bi bi-plus-circle me-1"></i>Agregar Producto
                                                </button>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="table table-hover align-middle" id="detalleProformaTable">
                                                    <thead>
                                                        <tr>
                                                            <th width="25%">Producto</th>
                                                            <th width="10%">Cantidad</th>
                                                            <th width="10%">Unidad</th>
                                                            <th width="15%">Precio Unit.</th>
                                                            <th width="15%">Total</th>
                                                            <th width="20%">Descripción</th>
                                                            <th width="5%">Acción</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="detalleProformaBody">
                                                        <tr>
                                                            <td>
                                                                <select name="detalle[0][IdProducto]"
                                                                    class="form-control-modern form-select-modern form-control-modern form-select-modern-sm producto-select"
                                                                    required>
                                                                    <option value="">Seleccionar Producto</option>
                                                                    <% if (typeof productos !=='undefined' && productos
                                                                        && productos.length> 0) { %>
                                                                        <% productos.forEach(producto=> { %>
                                                                            <option value="<%= producto.IdProducto %>"
                                                                                data-precio="<%= producto.PrecioUnitario %>"
                                                                                data-unidad="<%= producto.UnidadMedida %>">
                                                                                <%= producto.Codigo %> - <%=
                                                                                        producto.Nombre %>
                                                                            </option>
                                                                            <% }); %>
                                                                                <% } else { %>
                                                                                    <option value="" disabled>No hay
                                                                                        productos disponibles</option>
                                                                                    <% } %>
                                                                </select>
                                                            </td>
                                                            <td><input type="number" step="0.01"
                                                                    name="detalle[0][Cantidad]"
                                                                    class="form-control-modern form-control-modern-sm" placeholder="1"
                                                                    min="0.01" step="0.01" required></td>
                                                            <td><input type="text" name="detalle[0][UnidadMedida]"
                                                                    class="form-control-modern form-control-modern-sm" value="UNID"
                                                                    required readonly></td>
                                                            <td><input type="number" step="0.01"
                                                                    name="detalle[0][PrecioUnitario]"
                                                                    class="form-control-modern form-control-modern-sm"
                                                                    placeholder="0.00" min="0" step="0.01" required>
                                                            </td>
                                                            <td><input type="number" step="0.01"
                                                                    name="detalle[0][Total]"
                                                                    class="form-control-modern form-control-modern-sm total-field"
                                                                    placeholder="0.00" readonly></td>
                                                            <td><input type="text"
                                                                    name="detalle[0][DescripcionAdicional]"
                                                                    class="form-control-modern form-control-modern-sm"
                                                                    placeholder="Descripción adicional"></td>
                                                            <td class="text-center"><button type="button"
                                                                    class="btn-form btn-form-cancel btn-sm btn-remove-row"><i
                                                                        class="bi bi-trash"></i></button></td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

                                        <!-- Botones de Acción -->
                                        <div class="d-flex justify-content-between align-items-center mt-4">
                                            <a href="/proformas" class="btn btn-form btn-form-cancel">
                                                <i class="bi bi-arrow-left me-2"></i>Volver
                                            </a>
                                            <div class="action-buttons">

                                                <button type="submit" class="btn-form btn-form-primary">
                                                    <i class="bi bi-save me-2"></i>Registrar Proforma
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Variables globales
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');
            const userAvatar = document.querySelector('.user-avatar');
            const userName = '<%= user && user.Nombres ? user.Nombres : "Usuario" %>';
            const detalleBody = document.getElementById('detalleProformaBody');
            const addRowBtn = document.getElementById('addRowBtn');
            let rowIdx = 1;

            // Configurar avatar de usuario
            if (userAvatar) {
                userAvatar.textContent = userName.charAt(0).toUpperCase();
            }

            // Toggle sidebar (solo si el botón existe)
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    if (sidebar) sidebar.classList.toggle('hide');
                    if (mainContent) mainContent.classList.toggle('full');
                });
            }

            // Función para recalcular totales generales de la proforma
            function recalcularTotalesGenerales() {
                let subtotal = 0;
                const filas = detalleBody.querySelectorAll('tr');

                filas.forEach(fila => {
                    const totalFila = parseFloat(fila.querySelector('input[name*="[Total]"]').value) || 0;
                    subtotal += totalFila;
                });

                const porcentajeIGV = parseFloat(document.querySelector('input[name="PorcentajeIGV"]').value) || 18;
                const totalIGV = subtotal * (porcentajeIGV / 100);
                const total = subtotal + totalIGV;

                document.querySelector('input[name="SubTotal"]').value = subtotal.toFixed(2);
                document.querySelector('input[name="TotalIGV"]').value = totalIGV.toFixed(2);
                document.querySelector('input[name="Total"]').value = total.toFixed(2);
            }

            // Función para autocompletar precio y unidad al seleccionar producto
            function autocompletarProducto(selectElement) {
                const selectedOption = selectElement.options[selectElement.selectedIndex];
                const row = selectElement.closest('tr');

                if (selectedOption.value && selectedOption.dataset.precio !== undefined) {
                    // Autocompletar precio unitario
                    const precioInput = row.querySelector('input[name*="[PrecioUnitario]"]');
                    precioInput.value = parseFloat(selectedOption.dataset.precio || 0).toFixed(2);

                    // Autocompletar unidad de medida
                    const unidadInput = row.querySelector('input[name*="[UnidadMedida]"]');
                    unidadInput.value = selectedOption.dataset.unidad || 'UNID';

                    // Calcular total de la fila si ya hay cantidad
                    const cantidadInput = row.querySelector('input[name*="[Cantidad]"]');
                    if (cantidadInput.value) {
                        calcularTotalFila(row);
                    }
                } else {
                    // Limpiar campos si no hay selección
                    row.querySelector('input[name*="[PrecioUnitario]"]').value = '';
                    row.querySelector('input[name*="[UnidadMedida]"]').value = 'UNID';
                    row.querySelector('input[name*="[Total]"]').value = '';
                    recalcularTotalesGenerales();
                }
            }

            // Función para calcular el total de una fila específica
            function calcularTotalFila(row) {
                const cantidad = parseFloat(row.querySelector('input[name*="[Cantidad]"]').value) || 0;
                const precio = parseFloat(row.querySelector('input[name*="[PrecioUnitario]"]').value) || 0;
                const total = cantidad * precio;
                row.querySelector('input[name*="[Total]"]').value = total.toFixed(2);

                // Recalcular totales generales
                recalcularTotalesGenerales();
            }

            // Agregar nueva fila de producto
            addRowBtn.addEventListener('click', function () {
                const row = document.createElement('tr');
                row.innerHTML = `
                <td>
                    <select name="detalle[${rowIdx}][IdProducto]" class="form-control-modern form-select-modern form-control-modern form-select-modern-sm producto-select" required>
                        <option value="">Seleccionar Producto</option>
                        <% if (typeof productos !== 'undefined' && productos.length > 0) { %>
                            <% productos.forEach(producto => { %>
                                <option value="<%= producto.IdProducto %>" data-precio="<%= producto.PrecioUnitario %>" data-unidad="<%= producto.UnidadMedida %>">
                                    <%= producto.Codigo %> - <%= producto.Nombre %>
                                </option>
                            <% }); %>
                        <% } %>
                    </select>
                </td>
                <td><input type="number" step="0.01" name="detalle[${rowIdx}][Cantidad]" class="form-control-modern form-control-modern-sm" placeholder="1" min="0.01" required></td>
                <td><input type="text" name="detalle[${rowIdx}][UnidadMedida]" class="form-control-modern form-control-modern-sm" value="UNID" required readonly></td>
                <td><input type="number" step="0.01" name="detalle[${rowIdx}][PrecioUnitario]" class="form-control-modern form-control-modern-sm" placeholder="0.00" min="0" required></td>
                <td><input type="number" step="0.01" name="detalle[${rowIdx}][Total]" class="form-control-modern form-control-modern-sm total-field" placeholder="0.00" readonly></td>
                <td><input type="text" name="detalle[${rowIdx}][DescripcionAdicional]" class="form-control-modern form-control-modern-sm" placeholder="Descripción adicional"></td>
                <td class="text-center"><button type="button" class="btn-form btn-form-cancel btn-sm btn-remove-row"><i class="bi bi-trash"></i></button></td>
            `;
                detalleBody.appendChild(row);
                rowIdx++;

                // Animación para la nueva fila
                row.style.opacity = '0';
                setTimeout(() => {
                    row.style.transition = 'opacity 0.3s ease';
                    row.style.opacity = '1';
                }, 10);
            });

            // Event delegation para eliminar filas
            detalleBody.addEventListener('click', function (e) {
                if (e.target.closest('.btn-remove-row')) {
                    const rows = detalleBody.querySelectorAll('tr');
                    if (rows.length > 1) {
                        const rowToRemove = e.target.closest('tr');
                        rowToRemove.style.transition = 'all 0.3s ease';
                        rowToRemove.style.opacity = '0';
                        rowToRemove.style.height = rowToRemove.offsetHeight + 'px';

                        setTimeout(() => {
                            rowToRemove.remove();
                            recalcularTotalesGenerales();
                        }, 300);
                    } else {
                        // Mostrar alerta si es la última fila
                        alert('Debe haber al menos un producto en la proforma');
                    }
                }
            });

            // Event delegation para cambios en los selects de productos
            detalleBody.addEventListener('change', function (e) {
                if (e.target.name && e.target.name.includes('[IdProducto]')) {
                    autocompletarProducto(e.target);
                }
            });

            // Event delegation para calcular totales cuando cambien cantidad o precio
            detalleBody.addEventListener('input', function (e) {
                if (e.target.name && (e.target.name.includes('[Cantidad]') || e.target.name.includes('[PrecioUnitario]'))) {
                    const row = e.target.closest('tr');
                    calcularTotalFila(row);
                }
            });

            // Recalcular cuando cambie el porcentaje de IGV
            document.querySelector('input[name="PorcentajeIGV"]').addEventListener('input', function () {
                recalcularTotalesGenerales();
            });

            // Establecer fecha actual por defecto
            const today = new Date();
            document.querySelector('input[name="FechaEmision"]').valueAsDate = today;

            // Inicializar totales al cargar la página
            recalcularTotalesGenerales();

            // Validación del formulario antes del envío
            document.querySelector('form').addEventListener('submit', function (e) {
                let isValid = true;
                const errorMessages = [];

                // Validar cliente
                const clienteSelect = document.querySelector('select[name="IdCliente"]');
                if (!clienteSelect.value) {
                    errorMessages.push('Debe seleccionar un cliente válido');
                    isValid = false;
                    clienteSelect.classList.add('is-invalid');
                } else {
                    clienteSelect.classList.remove('is-invalid');
                }

                // Validar usuario
                const usuarioSelect = document.querySelector('select[name="IdUsuario"]');
                if (!usuarioSelect.value) {
                    errorMessages.push('Debe seleccionar un usuario válido');
                    isValid = false;
                    usuarioSelect.classList.add('is-invalid');
                } else {
                    usuarioSelect.classList.remove('is-invalid');
                }

                // Validar empresa
                const empresaSelect = document.querySelector('select[name="IdEmpresa"]');
                if (!empresaSelect.value) {
                    errorMessages.push('Debe seleccionar una empresa válida');
                    isValid = false;
                    empresaSelect.classList.add('is-invalid');
                } else {
                    empresaSelect.classList.remove('is-invalid');
                }

                // Validar productos
                const productosSelect = document.querySelectorAll('.producto-select');
                productosSelect.forEach((select, index) => {
                    if (!select.value) {
                        errorMessages.push(`Debe seleccionar un producto válido en la fila ${index + 1}`);
                        isValid = false;
                        select.classList.add('is-invalid');
                    } else {
                        select.classList.remove('is-invalid');
                    }
                });

                if (!isValid) {
                    e.preventDefault();

                    // Mostrar alerta de Bootstrap
                    const alertDiv = document.createElement('div');
                    alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                    alertDiv.role = 'alert';
                    alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Error en el formulario:</strong> ${errorMessages.join('<br>')}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;

                    // Insertar al principio del contenedor
                    const container = document.querySelector('.container-fluid');
                    container.insertBefore(alertDiv, container.firstChild);

                    // Desplazarse al primer error
                    const firstInvalid = document.querySelector('.is-invalid');
                    if (firstInvalid) {
                        firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            });

            // Mejorar experiencia en móviles
            if (window.innerWidth <= 992 && sidebar && mainContent) {
                sidebar.classList.add('hide');
                mainContent.classList.add('full');
            }

            // Actualizar al cambiar tamaño de ventana
            window.addEventListener('resize', function () {
                if (!sidebar || !mainContent) return;
                if (window.innerWidth <= 992) {
                    sidebar.classList.add('hide');
                    mainContent.classList.add('full');
                } else {
                    sidebar.classList.remove('hide');
                    mainContent.classList.remove('full');
                }
            });
        });
    </script>
    <script src="/publico/js/layout.js?v=1772427290146"></script>
</body>

</html>