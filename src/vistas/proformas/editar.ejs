<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Proforma - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290146">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290146">
    
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <!-- Botón para ocultar/mostrar barra -->

            <!-- Main Content -->
            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg top-navbar">
                    <div class="container-fluid">
                        <span class="navbar-brand">Editar Proforma</span>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Usuario' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid py-4">
                    <!-- Alertas -->
                    <% if (messages && messages.success) { %>
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <%= messages.success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"
                                    aria-label="Close"></button>
                        </div>
                        <% } %>
                            <% if (messages && messages.error) { %>
                                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <%= messages.error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"
                                            aria-label="Close"></button>
                                </div>
                                <% } %>

                                    <div class="main-card">
                                        <h2 class="card-title">
                                            <i class="bi bi-pencil-square"></i>
                                            Editar Proforma: <%= proforma.Codigo %>
                                        </h2>

                                        <form action="/proformas/<%= proforma.IdProforma %>/editar" method="POST">
                                            <!-- Información General -->
                                            <div class="row g-4">
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-hash"></i>
                                                        Código
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-hash"></i>
                                                        <input type="text" name="Codigo" class="form-control-modern"
                                                            value="<%= proforma.Codigo %>" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-people"></i>
                                                        Cliente
                                                    </label>
                                                    <select name="IdCliente" class="form-control-modern form-select-modern" required>
                                                        <option value="">Seleccionar Cliente</option>
                                                        <% if (typeof clientes !=='undefined' && clientes &&
                                                            clientes.length> 0) { %>
                                                            <% clientes.forEach(function(cliente) { %>
                                                                <option value="<%= cliente.IdCliente %>"
                                                                    <%=proforma.IdCliente==cliente.IdCliente
                                                                    ? 'selected' : '' %>>
                                                                    <%= cliente.RazonSocial %> - <%= cliente.Ruc %>
                                                                </option>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <option value="" disabled>No hay clientes
                                                                            disponibles</option>
                                                                        <% } %>
                                                    </select>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-person-circle"></i>
                                                        Usuario
                                                    </label>
                                                    <select name="IdUsuario" class="form-control-modern form-select-modern" required>
                                                        <option value="">Seleccionar Usuario</option>
                                                        <% if (typeof usuarios !=='undefined' && usuarios &&
                                                            usuarios.length> 0) { %>
                                                            <% usuarios.forEach(function(usuario) { %>
                                                                <option value="<%= usuario.IdUsuario %>"
                                                                    <%=proforma.IdUsuario==usuario.IdUsuario
                                                                    ? 'selected' : '' %>>
                                                                    <%= usuario.Nombres %>
                                                                        <%= usuario.Apellidos %>
                                                                </option>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <option value="" disabled>No hay usuarios
                                                                            disponibles</option>
                                                                        <% } %>
                                                    </select>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-building"></i>
                                                        Empresa
                                                    </label>
                                                    <select name="IdEmpresa" class="form-control-modern form-select-modern" required>
                                                        <option value="">Seleccionar Empresa</option>
                                                        <% if (typeof empresas !=='undefined' && empresas &&
                                                            empresas.length> 0) { %>
                                                            <% let empresaSeleccionada=false; %>
                                                                <% empresas.forEach(empresa=> { %>
                                                                    <option value="<%= empresa.IdEmpresa %>"
                                                                        <%=String(proforma.IdEmpresa)===String(empresa.IdEmpresa)
                                                                        ? 'selected' : '' %>>
                                                                        <%= empresa.Nombre ? empresa.Nombre :
                                                                            (empresa.RazonSocial || '' ) %> - <%=
                                                                                empresa.RUC ? empresa.RUC : (empresa.Ruc
                                                                                || '' ) %>
                                                                    </option>
                                                                    <% if
                                                                        (String(proforma.IdEmpresa)===String(empresa.IdEmpresa))
                                                                        empresaSeleccionada=true; %>
                                                                        <% }); %>
                                                                            <% if (!empresaSeleccionada &&
                                                                                proforma.Empresa) { %>
                                                                                <option
                                                                                    value="<%= proforma.IdEmpresa %>"
                                                                                    selected>
                                                                                    <%= proforma.Empresa.Nombre ?
                                                                                        proforma.Empresa.Nombre :
                                                                                        (proforma.Empresa.RazonSocial
                                                                                        || '' ) %> - <%=
                                                                                            proforma.Empresa.RUC ?
                                                                                            proforma.Empresa.RUC :
                                                                                            (proforma.Empresa.Ruc || ''
                                                                                            ) %> (No disponible)
                                                                                </option>
                                                                                <% } %>
                                                                                    <% } else if (proforma.Empresa) { %>
                                                                                        <option
                                                                                            value="<%= proforma.IdEmpresa %>"
                                                                                            selected>
                                                                                            <%= proforma.Empresa.Nombre
                                                                                                ?
                                                                                                proforma.Empresa.Nombre
                                                                                                :
                                                                                                (proforma.Empresa.RazonSocial
                                                                                                || '' ) %> - <%=
                                                                                                    proforma.Empresa.RUC
                                                                                                    ?
                                                                                                    proforma.Empresa.RUC
                                                                                                    :
                                                                                                    (proforma.Empresa.Ruc
                                                                                                    || '' ) %>
                                                                                        </option>
                                                                                        <% } else { %>
                                                                                            <option value="" disabled>No
                                                                                                hay empresas disponibles
                                                                                            </option>
                                                                                            <% } %>
                                                    </select>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-calendar"></i>
                                                        Fecha Emisión
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-calendar"></i>
                                                        <input type="date" name="FechaEmision" class="form-control-modern"
                                                            value="<%= proforma.FechaEmision ? (typeof proforma.FechaEmision.toISOString === 'function' ? proforma.FechaEmision.toISOString().split('T')[0] : proforma.FechaEmision) : '' %>"
                                                            required>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-tag"></i>
                                                        Referencia
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-tag"></i>
                                                        <input type="text" name="Referencia" class="form-control-modern"
                                                            value="<%= proforma.Referencia || '' %>">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-clock"></i>
                                                        Validez Oferta (días)
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-clock"></i>
                                                        <input type="number" name="ValidezOferta" class="form-control-modern"
                                                            value="<%= proforma.ValidezOferta %>" min="1" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-truck"></i>
                                                        Tiempo Entrega
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-truck"></i>
                                                        <input type="text" name="TiempoEntrega" class="form-control-modern"
                                                            value="<%= proforma.TiempoEntrega || '' %>">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-geo-alt"></i>
                                                        Lugar Entrega
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-geo-alt"></i>
                                                        <input type="text" name="LugarEntrega" class="form-control-modern"
                                                            value="<%= proforma.LugarEntrega || '' %>">
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="section-divider">
                                                <span class="section-divider-title">Condiciones Comerciales</span>
                                            </div>

                                            <div class="row g-4">
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-shield-check"></i>
                                                        Garantía
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-shield-check"></i>
                                                        <input type="text" name="Garantia" class="form-control-modern"
                                                            value="<%= proforma.Garantia || '' %>">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-credit-card"></i>
                                                        Forma de Pago
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-credit-card"></i>
                                                        <input type="text" name="FormaPago" class="form-control-modern"
                                                            value="<%= proforma.FormaPago || '' %>">
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-percent"></i>
                                                        IGV (%)
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-percent"></i>
                                                        <input type="number" step="0.01" name="PorcentajeIGV"
                                                            class="form-control-modern" value="<%= proforma.PorcentajeIGV %>"
                                                            min="0" max="100" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-12">
                                                    <label class="form-label">
                                                        <i class="bi bi-chat-left-text"></i>
                                                        Observaciones
                                                    </label>
                                                    <textarea name="Observaciones" class="form-control-modern"
                                                        rows="2"><%= proforma.Observaciones || '' %></textarea>
                                                </div>
                                            </div>

                                            <div class="section-divider">
                                                <span class="section-divider-title">Totales</span>
                                            </div>

                                            <div class="row g-4">
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        SubTotal
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        <input type="number" step="0.01" name="SubTotal"
                                                            class="form-control-modern total-field"
                                                            value="<%= proforma.SubTotal %>" required readonly>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        Total IGV
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        <input type="number" step="0.01" name="TotalIGV"
                                                            class="form-control-modern total-field"
                                                            value="<%= proforma.TotalIGV %>" required readonly>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        Total
                                                    </label>
                                                    <div class="input-icon">
                                                        <i class="bi bi-currency-dollar"></i>
                                                        <input type="number" step="0.01" name="Total"
                                                            class="form-control-modern total-field"
                                                            value="<%= proforma.Total %>" required readonly>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">
                                                        <i class="bi bi-check-circle"></i>
                                                        Estado
                                                    </label>
                                                    <select name="Estado" class="form-control-modern form-select-modern">
                                                        <option value="PENDIENTE" <%=proforma.Estado==='PENDIENTE'
                                                            ? 'selected' : '' %>>PENDIENTE</option>
                                                        <option value="APROBADA" <%=proforma.Estado==='APROBADA'
                                                            ? 'selected' : '' %>>APROBADA</option>
                                                        <option value="RECHAZADA" <%=proforma.Estado==='RECHAZADA'
                                                            ? 'selected' : '' %>>RECHAZADA</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="section-divider">
                                                <span class="section-divider-title">Detalle de Productos</span>
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h5 class="fw-bold text-primary mb-0">
                                                    <i class="bi bi-box-seam"></i>
                                                    Productos incluidos
                                                </h5>
                                                <button type="button" class="btn btn-success" id="addRowBtn">
                                                    <i class="bi bi-plus-circle me-1"></i>Agregar Producto
                                                </button>
                                            </div>

                                            <div class="table-responsive">
                                                <table class="table table-hover align-middle" id="detalleProformaTable">
                                                    <thead>
                                                        <tr>
                                                            <th width="25%">Producto</th>
                                                            <th width="10%">Cantidad</th>
                                                            <th width="10%">Unidad</th>
                                                            <th width="15%">Precio Unit.</th>
                                                            <th width="15%">Total</th>
                                                            <th width="20%">Descripción</th>
                                                            <th width="5%">Acción</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="detalleProformaBody">
                                                        <% if (proforma.detalle && proforma.detalle.length> 0) { %>
                                                            <% proforma.detalle.forEach(function(item, idx) { %>
                                                                <tr>
                                                                    <td>
                                                                        <select name="detalle[<%= idx %>][IdProducto]"
                                                                            class="form-control-modern form-select-modern form-control-modern form-select-modern-sm producto-select"
                                                                            required>
                                                                            <option value="">Seleccionar Producto
                                                                            </option>
                                                                            <% if (typeof productos !=='undefined' &&
                                                                                productos && productos.length> 0) { %>
                                                                                <% productos.forEach(function(producto)
                                                                                    { %>
                                                                                    <option
                                                                                        value="<%= producto.IdProducto %>"
                                                                                        data-precio="<%= producto.PrecioUnitario %>"
                                                                                        data-unidad="<%= producto.UnidadMedida %>"
                                                                                        <%=item.IdProducto==producto.IdProducto
                                                                                        ? 'selected' : '' %>>
                                                                                        <%= producto.Codigo %> - <%=
                                                                                                producto.Nombre %>
                                                                                    </option>
                                                                                    <% }); %>
                                                                                        <% } else { %>
                                                                                            <option value="" disabled>No
                                                                                                hay productos
                                                                                                disponibles</option>
                                                                                            <% } %>
                                                                        </select>
                                                                    </td>
                                                                    <td><input type="number" step="0.01"
                                                                            name="detalle[<%= idx %>][Cantidad]"
                                                                            class="form-control-modern form-control-modern-sm"
                                                                            value="<%= item.Cantidad %>" min="0.01"
                                                                            required></td>
                                                                    <td><input type="text"
                                                                            name="detalle[<%= idx %>][UnidadMedida]"
                                                                            class="form-control-modern form-control-modern-sm"
                                                                            value="<%= item.UnidadMedida %>" required
                                                                            readonly></td>
                                                                    <td><input type="number" step="0.01"
                                                                            name="detalle[<%= idx %>][PrecioUnitario]"
                                                                            class="form-control-modern form-control-modern-sm"
                                                                            value="<%= item.PrecioUnitario %>" min="0"
                                                                            required></td>
                                                                    <td><input type="number" step="0.01"
                                                                            name="detalle[<%= idx %>][Total]"
                                                                            class="form-control-modern form-control-modern-sm total-field"
                                                                            value="<%= item.Total %>" readonly></td>
                                                                    <td><input type="text"
                                                                            name="detalle[<%= idx %>][DescripcionAdicional]"
                                                                            class="form-control-modern form-control-modern-sm"
                                                                            value="<%= item.DescripcionAdicional || '' %>">
                                                                    </td>
                                                                    <td class="text-center"><button type="button"
                                                                            class="btn-form btn-form-cancel btn-sm btn-remove-row"><i
                                                                                class="bi bi-trash"></i></button></td>
                                                                </tr>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td>
                                                                                <select name="detalle[0][IdProducto]"
                                                                                    class="form-control-modern form-select-modern form-control-modern form-select-modern-sm producto-select"
                                                                                    required>
                                                                                    <option value="">Seleccionar
                                                                                        Producto</option>
                                                                                    <% if (typeof productos
                                                                                        !=='undefined' && productos &&
                                                                                        productos.length> 0) { %>
                                                                                        <% productos.forEach(function(producto)
                                                                                            { %>
                                                                                            <option
                                                                                                value="<%= producto.IdProducto %>"
                                                                                                data-precio="<%= producto.PrecioUnitario %>"
                                                                                                data-unidad="<%= producto.UnidadMedida %>">
                                                                                                <%= producto.Codigo %> -
                                                                                                    <%= producto.Nombre
                                                                                                        %>
                                                                                            </option>
                                                                                            <% }); %>
                                                                                                <% } else { %>
                                                                                                    <option value=""
                                                                                                        disabled>No hay
                                                                                                        productos
                                                                                                        disponibles
                                                                                                    </option>
                                                                                                    <% } %>
                                                                                </select>
                                                                            </td>
                                                                            <td><input type="number" step="0.01"
                                                                                    name="detalle[0][Cantidad]"
                                                                                    class="form-control-modern form-control-modern-sm"
                                                                                    min="0.01" required></td>
                                                                            <td><input type="text"
                                                                                    name="detalle[0][UnidadMedida]"
                                                                                    class="form-control-modern form-control-modern-sm"
                                                                                    value="UNID" required readonly></td>
                                                                            <td><input type="number" step="0.01"
                                                                                    name="detalle[0][PrecioUnitario]"
                                                                                    class="form-control-modern form-control-modern-sm"
                                                                                    min="0" required></td>
                                                                            <td><input type="number" step="0.01"
                                                                                    name="detalle[0][Total]"
                                                                                    class="form-control-modern form-control-modern-sm total-field"
                                                                                    readonly></td>
                                                                            <td><input type="text"
                                                                                    name="detalle[0][DescripcionAdicional]"
                                                                                    class="form-control-modern form-control-modern-sm">
                                                                            </td>
                                                                            <td class="text-center"><button
                                                                                    type="button"
                                                                                    class="btn-form btn-form-cancel btn-sm btn-remove-row"><i
                                                                                        class="bi bi-trash"></i></button>
                                                                            </td>
                                                                        </tr>
                                                                        <% } %>
                                                    </tbody>
                                                </table>
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center mt-4">
                                                <a href="/proformas" class="btn btn-form btn-form-cancel">
                                                    <i class="bi bi-arrow-left me-2"></i>Cancelar
                                                </a>
                                                <div class="action-buttons">
                                                    <button type="button" class="btn btn-outline-primary">
                                                        <i class="bi bi-eye me-2"></i>Vista Previa
                                                    </button>
                                                    <button type="submit" class="btn-form btn-form-primary">
                                                        <i class="bi bi-save me-2"></i>Guardar Cambios
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Variables globales
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');
            const userAvatar = document.querySelector('.user-avatar');
            const userName = '<%= user && user.Nombres ? user.Nombres : "Usuario" %>';
            const detalleBody = document.getElementById('detalleProformaBody');
            const addRowBtn = document.getElementById('addRowBtn');
            let rowIdx = detalleBody ? detalleBody.querySelectorAll('tr').length : 0;

            // Quitar borde rojo de select empresa si hay valor seleccionado
            const empresaSelect = document.querySelector('select[name="IdEmpresa"]');
            if (empresaSelect) {
                function validarEmpresaSelect() {
                    if (empresaSelect.value && empresaSelect.value !== "") {
                        empresaSelect.classList.remove('is-invalid');
                    } else {
                        empresaSelect.classList.add('is-invalid');
                    }
                }
                empresaSelect.addEventListener('change', validarEmpresaSelect);
                validarEmpresaSelect();
            }

            // Configurar avatar de usuario
            if (userAvatar) {
                userAvatar.textContent = userName.charAt(0).toUpperCase();
            }

            // Toggle sidebar (solo si el botón existe)
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    if (sidebar) sidebar.classList.toggle('hide');
                    if (mainContent) mainContent.classList.toggle('full');
                });
            }

            // Función para recalcular totales generales de la proforma
            function recalcularTotalesGenerales() {
                let subtotal = 0;
                const filas = detalleBody.querySelectorAll('tr');
                filas.forEach(fila => {
                    const totalFila = parseFloat(fila.querySelector('input[name*="[Total]"]').value) || 0;
                    subtotal += totalFila;
                });
                const porcentajeIGV = parseFloat(document.querySelector('input[name="PorcentajeIGV"]').value) || 0;
                const totalIGV = subtotal * (porcentajeIGV / 100);
                const total = subtotal + totalIGV;
                document.querySelector('input[name="SubTotal"]').value = subtotal.toFixed(2);
                document.querySelector('input[name="TotalIGV"]').value = totalIGV.toFixed(2);
                document.querySelector('input[name="Total"]').value = total.toFixed(2);
            }

            // Función para autocompletar precio y unidad al seleccionar producto
            function autocompletarProducto(selectElement) {
                const selectedOption = selectElement.options[selectElement.selectedIndex];
                const row = selectElement.closest('tr');
                if (selectedOption.value && selectedOption.dataset.precio !== undefined) {
                    // Autocompletar precio unitario
                    const precioInput = row.querySelector('input[name*="[PrecioUnitario]"]');
                    if (precioInput) precioInput.value = parseFloat(selectedOption.dataset.precio || 0).toFixed(2);

                    // Autocompletar unidad de medida
                    const unidadInput = row.querySelector('input[name*="[UnidadMedida]"]');
                    if (unidadInput) unidadInput.value = selectedOption.dataset.unidad || 'UNID';

                    // Calcular total de la fila si ya hay cantidad
                    const cantidadInput = row.querySelector('input[name*="[Cantidad]"]');
                    if (cantidadInput && cantidadInput.value) {
                        calcularTotalFila(row);
                    }
                }
            }

            // Función para calcular el total de una fila específica
            function calcularTotalFila(row) {
                const cantidad = parseFloat(row.querySelector('input[name*="[Cantidad]"]').value) || 0;
                const precio = parseFloat(row.querySelector('input[name*="[PrecioUnitario]"]').value) || 0;
                const total = cantidad * precio;
                row.querySelector('input[name*="[Total]"]').value = total.toFixed(2);
                // Recalcular totales generales
                recalcularTotalesGenerales();
            }

            // Agregar nueva fila de producto
            addRowBtn.addEventListener('click', function () {
                const row = document.createElement('tr');
                row.innerHTML = `
                <td>
                    <select name="detalle[${rowIdx}][IdProducto]" class="form-control-modern form-select-modern form-control-modern form-select-modern-sm producto-select" required>
                        <option value="">Seleccionar Producto</option>
                        <% if (typeof productos !== 'undefined' && productos && productos.length > 0) { %>
                            <% productos.forEach(function(producto) { %>
                                <option value="<%= producto.IdProducto %>" 
                                        data-precio="<%= producto.PrecioUnitario %>" 
                                        data-unidad="<%= producto.UnidadMedida %>">
                                    <%= producto.Codigo %> - <%= producto.Nombre %>
                                </option>
                            <% }); %>
                        <% } else { %>
                            <option value="" disabled>No hay productos disponibles</option>
                        <% } %>
                    </select>
                </td>
                <td><input type="number" step="0.01" name="detalle[${rowIdx}][Cantidad]" class="form-control-modern form-control-modern-sm" min="0.01" required></td>
                <td><input type="text" name="detalle[${rowIdx}][UnidadMedida]" class="form-control-modern form-control-modern-sm" value="UNID" required readonly></td>
                <td><input type="number" step="0.01" name="detalle[${rowIdx}][PrecioUnitario]" class="form-control-modern form-control-modern-sm" min="0" required></td>
                <td><input type="number" step="0.01" name="detalle[${rowIdx}][Total]" class="form-control-modern form-control-modern-sm total-field" readonly></td>
                <td><input type="text" name="detalle[${rowIdx}][DescripcionAdicional]" class="form-control-modern form-control-modern-sm"></td>
                <td class="text-center"><button type="button" class="btn-form btn-form-cancel btn-sm btn-remove-row"><i class="bi bi-trash"></i></button></td>
            `;
                detalleBody.appendChild(row);
                rowIdx++;
                // Animación para la nueva fila
                row.style.opacity = '0';
                setTimeout(() => {
                    row.style.transition = 'opacity 0.3s ease';
                    row.style.opacity = '1';
                }, 10);
            });

            // Event delegation para eliminar filas
            detalleBody.addEventListener('click', function (e) {
                if (e.target.closest('.btn-remove-row')) {
                    const rows = detalleBody.querySelectorAll('tr');
                    if (rows.length > 1) {
                        const rowToRemove = e.target.closest('tr');
                        rowToRemove.style.transition = 'all 0.3s ease';
                        rowToRemove.style.opacity = '0';
                        rowToRemove.style.height = rowToRemove.offsetHeight + 'px';
                        setTimeout(() => {
                            rowToRemove.remove();
                            recalcularTotalesGenerales();
                        }, 300);
                    } else {
                        // Mostrar alerta si es la última fila
                        alert('Debe haber al menos un producto en la proforma');
                    }
                }
            });

            // Event delegation para cambios en los selects de productos
            detalleBody.addEventListener('change', function (e) {
                if (e.target.name && e.target.name.includes('[IdProducto]')) {
                    autocompletarProducto(e.target);
                }
            });

            // Event delegation para calcular totales cuando cambien cantidad o precio
            detalleBody.addEventListener('input', function (e) {
                if (e.target.name && (e.target.name.includes('[Cantidad]') || e.target.name.includes('[PrecioUnitario]'))) {
                    const row = e.target.closest('tr');
                    calcularTotalFila(row);
                }
            });

            // Recalcular cuando cambie el porcentaje de IGV
            document.querySelector('input[name="PorcentajeIGV"]').addEventListener('input', function () {
                recalcularTotalesGenerales();
            });

            // Inicializar eventos para las filas existentes
            document.querySelectorAll('.producto-select').forEach(select => {
                select.addEventListener('change', function () {
                    autocompletarProducto(this);
                });
            });

            document.querySelectorAll('input[name*="[Cantidad]"], input[name*="[PrecioUnitario]"]').forEach(input => {
                input.addEventListener('input', function () {
                    const row = this.closest('tr');
                    calcularTotalFila(row);
                });
            });

            // Inicializar totales al cargar la página
            recalcularTotalesGenerales();

            // Mejorar experiencia en móviles
            if (window.innerWidth <= 992 && sidebar && mainContent) {
                sidebar.classList.add('hide');
                mainContent.classList.add('full');
            }

            // Actualizar al cambiar tamaño de ventana
            window.addEventListener('resize', function () {
                if (!sidebar || !mainContent) return;
                if (window.innerWidth <= 992) {
                    sidebar.classList.add('hide');
                    mainContent.classList.add('full');
                } else {
                    sidebar.classList.remove('hide');
                    mainContent.classList.remove('full');
                }
            });
        });
    </script>
    <script src="/publico/js/layout.js?v=1772427290146"></script>
</body>

</html>