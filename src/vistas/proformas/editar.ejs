<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <!-- ── Navbar ── -->
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid px-4">
                        <div class="flex-grow-1">
                            <div class="pf-breadcrumb">
                                <a href="/dashboard"><i class="bi bi-house"></i> Inicio</a>
                                <i class="bi bi-chevron-right" style="font-size:0.6rem;"></i>
                                <a href="/proformas">Proformas</a>
                                <i class="bi bi-chevron-right" style="font-size:0.6rem;"></i>
                                <span>Editar / <%= proforma.Codigo %></span>
                            </div>
                            <div class="d-flex align-items-center gap-2 mt-1">
                                <span class="pf-header-title">Editar Proforma</span>
                                <% const estadoClase=proforma.Estado==='APROBADA' ? 'aprobada' :
                                    proforma.Estado==='RECHAZADA' ? 'rechazada' : 'pendiente' ; const
                                    estadoIcono=proforma.Estado==='APROBADA' ? 'bi-check-circle-fill' :
                                    proforma.Estado==='RECHAZADA' ? 'bi-x-circle-fill' : 'bi-clock-fill' ; %>
                                    <span class="pf-status-badge pf-status-<%= estadoClase %>">
                                        <i class="bi <%= estadoIcono %>"></i>
                                        <%= proforma.Estado %>
                                    </span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <a href="/proformas" class="pf-btn-cancel">Cancelar</a>
                            <button type="submit" form="proformaForm" class="pf-btn-save">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>
                        </div>
                    </div>
                </nav>

                <!-- ── Body ── -->
                <div class="pf-body">

                    <!-- Alertas -->
                    <% if (messages && messages.success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <%= messages.success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (messages && messages.error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                                    <%= messages.error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <!-- ── Meta-bar del documento ── -->
                                    <div class="pf-meta-bar">
                                        <div class="pf-meta-item">
                                            <i class="bi bi-file-earmark-text"></i>
                                            <div class="pf-meta-item-text">
                                                <span class="pf-meta-label">Código</span>
                                                <span class="pf-meta-value">
                                                    <%= proforma.Codigo %>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="pf-meta-item">
                                            <i class="bi bi-calendar3"></i>
                                            <div class="pf-meta-item-text">
                                                <span class="pf-meta-label">Fecha Emisión</span>
                                                <span class="pf-meta-value">
                                                    <%= proforma.FechaEmision ? (typeof
                                                        proforma.FechaEmision.toISOString==='function' ?
                                                        proforma.FechaEmision.toISOString().split('T')[0] :
                                                        proforma.FechaEmision) : '—' %>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="pf-meta-item">
                                            <i class="bi bi-cash-coin"></i>
                                            <div class="pf-meta-item-text">
                                                <span class="pf-meta-label">Total Actual</span>
                                                <span class="pf-meta-value" style="color:var(--primary);">S/ <%=
                                                        proforma.Total ? Number(proforma.Total).toFixed(2) : '0.00' %>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="pf-meta-item">
                                            <i class="bi bi-person"></i>
                                            <div class="pf-meta-item-text">
                                                <span class="pf-meta-label">ID Proforma</span>
                                                <span class="pf-meta-value">#<%= proforma.IdProforma %></span>
                                            </div>
                                        </div>
                                    </div>

                                    <form id="proformaForm" action="/proformas/<%= proforma.IdProforma %>/editar"
                                        method="POST">

                                        <!-- ══ Tarjeta 1: Información General ══ -->
                                        <div class="pf-card">
                                            <div class="pf-card-header">
                                                <div class="pf-card-header-left">
                                                    <i class="bi bi-info-circle"></i>
                                                    <h3>Información General</h3>
                                                </div>
                                            </div>
                                            <div class="pf-card-body">
                                                <div class="row g-4">
                                                    <div class="col-md-3">
                                                        <label class="pf-label">Código de Proforma</label>
                                                        <input type="text" name="Codigo" class="pf-input"
                                                            value="<%= proforma.Codigo %>" required>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="pf-label">Fecha de Emisión</label>
                                                        <input type="date" name="FechaEmision" class="pf-input"
                                                            value="<%= proforma.FechaEmision ? (typeof proforma.FechaEmision.toISOString === 'function' ? proforma.FechaEmision.toISOString().split('T')[0] : proforma.FechaEmision) : '' %>"
                                                            required>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="pf-label">Validez (días)</label>
                                                        <input type="number" name="ValidezOferta" class="pf-input"
                                                            value="<%= proforma.ValidezOferta %>" min="1" required>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="pf-label">Estado</label>
                                                        <select name="Estado" class="pf-input pf-select">
                                                            <option value="PENDIENTE" <%=proforma.Estado==='PENDIENTE'
                                                                ? 'selected' : '' %>>Pendiente</option>
                                                            <option value="APROBADA" <%=proforma.Estado==='APROBADA'
                                                                ? 'selected' : '' %>>Aprobada</option>
                                                            <option value="RECHAZADA" <%=proforma.Estado==='RECHAZADA'
                                                                ? 'selected' : '' %>>Rechazada</option>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <label class="pf-label">Cliente</label>
                                                        <select name="IdCliente" class="pf-input pf-select" required>
                                                            <option value="">Seleccionar cliente...</option>
                                                            <% if (typeof clientes !=='undefined' && clientes &&
                                                                clientes.length> 0) { %>
                                                                <% clientes.forEach(function(c) { %>
                                                                    <option value="<%= c.IdCliente %>"
                                                                        <%=proforma.IdCliente==c.IdCliente ? 'selected'
                                                                        : '' %>><%= c.RazonSocial %> — <%= c.Ruc %>
                                                                    </option>
                                                                    <% }); %>
                                                                        <% } %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="pf-label">Responsable</label>
                                                        <select name="IdUsuario" class="pf-input pf-select" required>
                                                            <option value="">Seleccionar responsable...</option>
                                                            <% if (typeof usuarios !=='undefined' && usuarios &&
                                                                usuarios.length> 0) { %>
                                                                <% usuarios.forEach(function(u) { %>
                                                                    <option value="<%= u.IdUsuario %>"
                                                                        <%=proforma.IdUsuario==u.IdUsuario ? 'selected'
                                                                        : '' %>><%= u.Nombres %>
                                                                            <%= u.Apellidos %>
                                                                    </option>
                                                                    <% }); %>
                                                                        <% } %>
                                                        </select>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="pf-label">Empresa Emisora</label>
                                                        <select name="IdEmpresa" class="pf-input pf-select" required>
                                                            <option value="">Seleccionar empresa...</option>
                                                            <% if (typeof empresas !=='undefined' && empresas &&
                                                                empresas.length> 0) { %>
                                                                <% let empresaSel=false; %>
                                                                    <% empresas.forEach(function(e) { %>
                                                                        <% const
                                                                            sel=String(proforma.IdEmpresa)===String(e.IdEmpresa);
                                                                            %>
                                                                            <% if (sel) empresaSel=true; %>
                                                                                <option value="<%= e.IdEmpresa %>"
                                                                                    <%=sel ? 'selected' : '' %>><%=
                                                                                        e.Nombre || e.RazonSocial || ''
                                                                                        %> — <%= e.RUC || e.Ruc || '' %>
                                                                                </option>
                                                                                <% }); %>
                                                                                    <% if (!empresaSel &&
                                                                                        proforma.Empresa) { %>
                                                                                        <option
                                                                                            value="<%= proforma.IdEmpresa %>"
                                                                                            selected>
                                                                                            <%= proforma.Empresa.Nombre
                                                                                                ||
                                                                                                proforma.Empresa.RazonSocial
                                                                                                || '' %> (actual)
                                                                                        </option>
                                                                                        <% } %>
                                                                                            <% } else if
                                                                                                (proforma.Empresa) { %>
                                                                                                <option
                                                                                                    value="<%= proforma.IdEmpresa %>"
                                                                                                    selected>
                                                                                                    <%= proforma.Empresa.Nombre
                                                                                                        ||
                                                                                                        proforma.Empresa.RazonSocial
                                                                                                        || '' %>
                                                                                                </option>
                                                                                                <% } %>
                                                        </select>
                                                    </div>
                                                    <div class="col-12">
                                                        <label class="pf-label">Referencia / Proyecto <span
                                                                style="font-weight:500;text-transform:none;letter-spacing:0;font-size:0.7rem;">(opcional)</span></label>
                                                        <textarea name="Referencia" class="pf-input" rows="2"
                                                            placeholder="Ej: Mantenimiento preventivo de compresores de aire..."><%= proforma.Referencia || '' %></textarea>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- ══ Tarjeta 2: Detalle de Productos ══ -->
                                        <div class="pf-card">
                                            <div class="pf-card-header">
                                                <div class="pf-card-header-left">
                                                    <i class="bi bi-list-ul"></i>
                                                    <h3>Detalle de Productos y Servicios</h3>
                                                </div>
                                                <button type="button" class="pf-btn-add-row" id="addRowBtn">
                                                    <i class="bi bi-plus-lg"></i> Agregar Producto
                                                </button>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="pf-table" id="detalleProformaTable">
                                                    <thead>
                                                        <tr>
                                                            <th style="width:32%;padding-left:1.5rem;">Producto /
                                                                Servicio</th>
                                                            <th style="width:9%;">Cantidad</th>
                                                            <th style="width:9%;text-align:center;">Unidad</th>
                                                            <th style="width:13%;">P. Unit (S/)</th>
                                                            <th style="width:11%;">Total (S/)</th>
                                                            <th style="width:20%;">Descripción adicional</th>
                                                            <th style="width:6%;text-align:center;">Acción</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="detalleProformaBody">
                                                        <% if (proforma.detalle && proforma.detalle.length> 0) { %>
                                                            <% proforma.detalle.forEach(function(item, idx) { %>
                                                                <tr>
                                                                    <td style="padding-left:1.5rem;">
                                                                        <select name="detalle[<%= idx %>][IdProducto]"
                                                                            class="pf-table-input pf-select producto-select"
                                                                            required>
                                                                            <option value="">Buscar o seleccionar...
                                                                            </option>
                                                                            <% if (typeof productos !=='undefined' &&
                                                                                productos && productos.length> 0) { %>
                                                                                <% productos.forEach(function(p) { %>
                                                                                    <option value="<%= p.IdProducto %>"
                                                                                        data-precio="<%= p.PrecioUnitario %>"
                                                                                        data-unidad="<%= p.UnidadMedida %>"
                                                                                        <%=item.IdProducto==p.IdProducto
                                                                                        ? 'selected' : '' %>><%=
                                                                                            p.Codigo %> — <%= p.Nombre
                                                                                                %>
                                                                                    </option>
                                                                                    <% }); %>
                                                                                        <% } %>
                                                                        </select>
                                                                    </td>
                                                                    <td><input type="number" step="0.01"
                                                                            name="detalle[<%= idx %>][Cantidad]"
                                                                            class="pf-table-input text-end"
                                                                            value="<%= item.Cantidad %>" min="0.01"
                                                                            required></td>
                                                                    <td style="text-align:center;"><span
                                                                            class="pf-unit-badge unidad-label">
                                                                            <%= item.UnidadMedida || 'UNID' %>
                                                                        </span><input type="hidden"
                                                                            name="detalle[<%= idx %>][UnidadMedida]"
                                                                            value="<%= item.UnidadMedida || 'UNID' %>">
                                                                    </td>
                                                                    <td><input type="number" step="0.01"
                                                                            name="detalle[<%= idx %>][PrecioUnitario]"
                                                                            class="pf-table-input text-end"
                                                                            value="<%= item.PrecioUnitario %>" min="0"
                                                                            required></td>
                                                                    <td><input type="number" step="0.01"
                                                                            name="detalle[<%= idx %>][Total]"
                                                                            class="pf-table-input total-field text-end"
                                                                            value="<%= item.Total %>" readonly></td>
                                                                    <td><input type="text"
                                                                            name="detalle[<%= idx %>][DescripcionAdicional]"
                                                                            class="pf-table-input"
                                                                            value="<%= item.DescripcionAdicional || '' %>"
                                                                            placeholder="Descripción opcional..."></td>
                                                                    <td style="text-align:center;"><button type="button"
                                                                            class="pf-btn-del" title="Eliminar"><i
                                                                                class="bi bi-trash3"></i></button></td>
                                                                </tr>
                                                                <% }); %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td style="padding-left:1.5rem;">
                                                                                <select name="detalle[0][IdProducto]"
                                                                                    class="pf-table-input pf-select producto-select"
                                                                                    required>
                                                                                    <option value="">Buscar o
                                                                                        seleccionar...</option>
                                                                                    <% if (typeof productos
                                                                                        !=='undefined' && productos &&
                                                                                        productos.length> 0) { %>
                                                                                        <% productos.forEach(function(p)
                                                                                            { %>
                                                                                            <option
                                                                                                value="<%= p.IdProducto %>"
                                                                                                data-precio="<%= p.PrecioUnitario %>"
                                                                                                data-unidad="<%= p.UnidadMedida %>">
                                                                                                <%= p.Codigo %> — <%=
                                                                                                        p.Nombre %>
                                                                                            </option>
                                                                                            <% }); %>
                                                                                                <% } %>
                                                                                </select>
                                                                            </td>
                                                                            <td><input type="number" step="0.01"
                                                                                    name="detalle[0][Cantidad]"
                                                                                    class="pf-table-input text-end"
                                                                                    placeholder="0" min="0.01" required>
                                                                            </td>
                                                                            <td style="text-align:center;"><span
                                                                                    class="pf-unit-badge unidad-label">UNID</span><input
                                                                                    type="hidden"
                                                                                    name="detalle[0][UnidadMedida]"
                                                                                    value="UNID"></td>
                                                                            <td><input type="number" step="0.01"
                                                                                    name="detalle[0][PrecioUnitario]"
                                                                                    class="pf-table-input text-end"
                                                                                    placeholder="0.00" min="0" required>
                                                                            </td>
                                                                            <td><input type="number" step="0.01"
                                                                                    name="detalle[0][Total]"
                                                                                    class="pf-table-input total-field text-end"
                                                                                    placeholder="0.00" readonly></td>
                                                                            <td><input type="text"
                                                                                    name="detalle[0][DescripcionAdicional]"
                                                                                    class="pf-table-input"
                                                                                    placeholder="Descripción opcional...">
                                                                            </td>
                                                                            <td style="text-align:center;"><button
                                                                                    type="button" class="pf-btn-del"
                                                                                    title="Eliminar"><i
                                                                                        class="bi bi-trash3"></i></button>
                                                                            </td>
                                                                        </tr>
                                                                        <% } %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

                                        <!-- ══ Grid: Condiciones + Totales ══ -->
                                        <div class="row g-4">
                                            <!-- Condiciones -->
                                            <div class="col-lg-6">
                                                <div class="pf-card h-100 d-flex flex-column">
                                                    <div class="pf-card-header">
                                                        <div class="pf-card-header-left">
                                                            <i class="bi bi-file-earmark-check"></i>
                                                            <h3>Condiciones y Observaciones</h3>
                                                        </div>
                                                    </div>
                                                    <div class="pf-card-body flex-grow-1 d-flex flex-column gap-3">
                                                        <div>
                                                            <label class="pf-label">Tiempo de Entrega</label>
                                                            <input type="text" name="TiempoEntrega" class="pf-input"
                                                                value="<%= proforma.TiempoEntrega || '' %>"
                                                                placeholder="Ej: 15 días hábiles">
                                                        </div>
                                                        <div>
                                                            <label class="pf-label">Lugar de Entrega</label>
                                                            <input type="text" name="LugarEntrega" class="pf-input"
                                                                value="<%= proforma.LugarEntrega || '' %>"
                                                                placeholder="Ej: Lima, Perú">
                                                        </div>
                                                        <div>
                                                            <label class="pf-label">Garantía</label>
                                                            <input type="text" name="Garantia" class="pf-input"
                                                                value="<%= proforma.Garantia || '' %>"
                                                                placeholder="Ej: 12 meses">
                                                        </div>
                                                        <div>
                                                            <label class="pf-label">Condiciones Comerciales / Forma de
                                                                Pago</label>
                                                            <textarea name="FormaPago" class="pf-input" rows="2"
                                                                placeholder="Ej: 50% adelanto, 50% contra entrega..."><%= proforma.FormaPago || '' %></textarea>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <label class="pf-label">Observaciones</label>
                                                            <textarea name="Observaciones" class="pf-input" rows="2"
                                                                placeholder="Notas adicionales internas..."><%= proforma.Observaciones || '' %></textarea>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Totales -->
                                            <div class="col-lg-6">
                                                <div class="pf-card h-100 d-flex flex-column">
                                                    <div class="pf-card-header">
                                                        <div class="pf-card-header-left">
                                                            <i class="bi bi-cash-coin"></i>
                                                            <h3>Resumen de Totales</h3>
                                                        </div>
                                                    </div>
                                                    <!-- Mini-stats visibles cuando totales = 0 -->
                                                    <div id="pfStatsPanel" class="pf-stats-panel">
                                                        <div class="pf-stat-item">
                                                            <div class="pf-stat-icon blue"><i
                                                                    class="bi bi-graph-up-arrow"></i></div>
                                                            <div>
                                                                <p class="pf-stat-text-title">Servicios especializados
                                                                </p>
                                                                <p class="pf-stat-text-val">Equipos industriales y
                                                                    soluciones técnicas</p>
                                                            </div>
                                                        </div>
                                                        <div class="pf-stat-item">
                                                            <div class="pf-stat-icon green"><i
                                                                    class="bi bi-shield-check"></i></div>
                                                            <div>
                                                                <p class="pf-stat-text-title">Garantía incluida</p>
                                                                <p class="pf-stat-text-val">Respaldo técnico certificado
                                                                </p>
                                                            </div>
                                                        </div>
                                                        <div class="pf-stat-item">
                                                            <div class="pf-stat-icon amber"><i
                                                                    class="bi bi-clock-history"></i></div>
                                                            <div>
                                                                <p class="pf-stat-text-title">Entrega a tiempo</p>
                                                                <p class="pf-stat-text-val">Cumplimiento en plazos
                                                                    acordados</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div id="pfQuoteBox" class="pf-quote-box">
                                                        <p class="pf-quote-text">"Actualizar con precisión garantiza que
                                                            cada cifra refleje la realidad del trabajo realizado."</p>
                                                        <p class="pf-quote-author">— CARSIL Equipos y Servicios SAC</p>
                                                    </div>

                                                    <div
                                                        class="pf-card-body flex-grow-1 d-flex flex-column justify-content-end">
                                                        <div class="mb-3">
                                                            <label class="pf-label">Tasa IGV (%)</label>
                                                            <input type="number" step="0.01" name="PorcentajeIGV"
                                                                class="pf-input" value="<%= proforma.PorcentajeIGV %>"
                                                                min="0" max="100" style="max-width:120px;" required>
                                                        </div>
                                                        <div class="pf-totals-list">
                                                            <div class="pf-total-row">
                                                                <span>Subtotal</span>
                                                                <strong id="subtotalDisplay">S/ 0.00</strong>
                                                                <input type="number" step="0.01" name="SubTotal"
                                                                    class="d-none" value="<%= proforma.SubTotal || 0 %>"
                                                                    readonly>
                                                            </div>
                                                            <div class="pf-total-row">
                                                                <span>IGV (<span id="igvPctLabel">
                                                                        <%= proforma.PorcentajeIGV || 18 %>
                                                                    </span>%)</span>
                                                                <strong id="igvDisplay">S/ 0.00</strong>
                                                                <input type="number" step="0.01" name="TotalIGV"
                                                                    class="d-none" value="<%= proforma.TotalIGV || 0 %>"
                                                                    readonly>
                                                            </div>
                                                            <div class="pf-total-final">
                                                                <span class="pf-total-final-label">Total a Pagar</span>
                                                                <span class="pf-total-final-value" id="totalDisplay">S/
                                                                    0.00</span>
                                                                <input type="number" step="0.01" name="Total"
                                                                    class="d-none" value="<%= proforma.Total || 0 %>"
                                                                    readonly>
                                                            </div>
                                                        </div>
                                                        <div class="pf-totals-note mt-3">
                                                            Los precios están expresados en Soles (S/) e incluyen IGV
                                                            según la tasa configurada.
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </form>
                </div>

                <!-- Mobile footer -->
                <div class="pf-mobile-footer d-none">
                    <a href="/proformas" class="pf-btn-cancel"
                        style="border:1px solid var(--border);border-radius:0.625rem;">Cancelar</a>
                    <button type="submit" form="proformaForm" class="pf-btn-save">Guardar</button>
                </div>

            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const detalleBody = document.getElementById('detalleProformaBody');
            const addRowBtn = document.getElementById('addRowBtn');
            let rowIdx = detalleBody ? detalleBody.querySelectorAll('tr').length : 0;

            function recalcularTotales() {
                let subtotal = 0;
                detalleBody.querySelectorAll('tr').forEach(fila => {
                    subtotal += parseFloat(fila.querySelector('input[name*="[Total]"]').value) || 0;
                });
                const pct = parseFloat(document.querySelector('input[name="PorcentajeIGV"]').value) || 0;
                const igv = subtotal * (pct / 100);
                const total = subtotal + igv;

                document.querySelector('input[name="SubTotal"]').value = subtotal.toFixed(2);
                document.querySelector('input[name="TotalIGV"]').value = igv.toFixed(2);
                document.querySelector('input[name="Total"]').value = total.toFixed(2);

                document.getElementById('subtotalDisplay').textContent = 'S/ ' + subtotal.toFixed(2);
                document.getElementById('igvDisplay').textContent = 'S/ ' + igv.toFixed(2);
                document.getElementById('totalDisplay').textContent = 'S/ ' + total.toFixed(2);
                document.getElementById('igvPctLabel').textContent = pct;

                // Ocultar stats panel cuando hay datos reales
                const statsPanel = document.getElementById('pfStatsPanel');
                const quoteBox = document.getElementById('pfQuoteBox');
                if (statsPanel) statsPanel.style.display = subtotal > 0 ? 'none' : '';
                if (quoteBox) quoteBox.style.display = subtotal > 0 ? 'none' : '';
            }

            function calcularFila(row) {
                const cant = parseFloat(row.querySelector('input[name*="[Cantidad]"]').value) || 0;
                const precio = parseFloat(row.querySelector('input[name*="[PrecioUnitario]"]').value) || 0;
                row.querySelector('input[name*="[Total]"]').value = (cant * precio).toFixed(2);
                recalcularTotales();
            }

            function autocompletar(select) {
                const opt = select.options[select.selectedIndex];
                const row = select.closest('tr');
                if (opt.value && opt.dataset.precio !== undefined) {
                    row.querySelector('input[name*="[PrecioUnitario]"]').value = parseFloat(opt.dataset.precio || 0).toFixed(2);
                    const unidad = opt.dataset.unidad || 'UNID';
                    row.querySelector('input[name*="[UnidadMedida]"]').value = unidad;
                    row.querySelector('.unidad-label').textContent = unidad;
                    if (parseFloat(row.querySelector('input[name*="[Cantidad]"]').value) > 0) calcularFila(row);
                }
            }

            const opcionesProductos = `<% if (typeof productos !== 'undefined' && productos && productos.length > 0) { %><% productos.forEach(function(p) { %><option value="<%= p.IdProducto %>" data-precio="<%= p.PrecioUnitario %>" data-unidad="<%= p.UnidadMedida %>"><%= p.Codigo %> — <%= p.Nombre %></option><% }); %><% } %>`;

            addRowBtn.addEventListener('click', () => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td style="padding-left:1.5rem;"><select name="detalle[${rowIdx}][IdProducto]" class="pf-table-input pf-select producto-select" required><option value="">Buscar o seleccionar...</option>${opcionesProductos}</select></td>
                    <td><input type="number" step="0.01" name="detalle[${rowIdx}][Cantidad]" class="pf-table-input text-end" placeholder="0" min="0.01" required></td>
                    <td style="text-align:center;"><span class="pf-unit-badge unidad-label">UNID</span><input type="hidden" name="detalle[${rowIdx}][UnidadMedida]" value="UNID"></td>
                    <td><input type="number" step="0.01" name="detalle[${rowIdx}][PrecioUnitario]" class="pf-table-input text-end" placeholder="0.00" min="0" required></td>
                    <td><input type="number" step="0.01" name="detalle[${rowIdx}][Total]" class="pf-table-input total-field text-end" placeholder="0.00" readonly></td>
                    <td><input type="text" name="detalle[${rowIdx}][DescripcionAdicional]" class="pf-table-input" placeholder="Descripción opcional..."></td>
                    <td style="text-align:center;"><button type="button" class="pf-btn-del" title="Eliminar"><i class="bi bi-trash3"></i></button></td>
                `;
                detalleBody.appendChild(row);
                rowIdx++;
                row.style.opacity = '0';
                requestAnimationFrame(() => { row.style.transition = 'opacity 0.2s'; row.style.opacity = '1'; });
            });

            detalleBody.addEventListener('click', e => {
                const btn = e.target.closest('.pf-btn-del');
                if (!btn) return;
                if (detalleBody.querySelectorAll('tr').length <= 1) {
                    alert('La proforma debe tener al menos un producto.');
                    return;
                }
                const row = btn.closest('tr');
                row.style.transition = 'opacity 0.2s'; row.style.opacity = '0';
                setTimeout(() => { row.remove(); recalcularTotales(); }, 220);
            });

            detalleBody.addEventListener('change', e => {
                if (e.target.classList.contains('producto-select')) autocompletar(e.target);
            });

            detalleBody.addEventListener('input', e => {
                const n = e.target.name || '';
                if (n.includes('[Cantidad]') || n.includes('[PrecioUnitario]')) calcularFila(e.target.closest('tr'));
            });

            document.querySelectorAll('.producto-select').forEach(s => s.addEventListener('change', () => autocompletar(s)));

            const igvInput = document.querySelector('input[name="PorcentajeIGV"]');
            if (igvInput) igvInput.addEventListener('input', recalcularTotales);

            recalcularTotales();
        });
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>