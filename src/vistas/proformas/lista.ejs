<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Proformas - CARSIL Equipos y Servicios SAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290135">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
        /* Modal */
        .pf-modal-overlay { display: none; position: fixed; inset: 0; z-index: 1080; background: rgba(10,12,20,0.72); backdrop-filter: blur(8px); align-items: center; justify-content: center; }
        .pf-modal-overlay.active { display: flex; }
        @keyframes sheetIn { from { transform: translateY(40px) scale(0.97); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
    </style>
</head>

<body class="bg-[#f6f6f8] text-slate-900 font-display">

<% var totalProformas = proformas ? proformas.length : 0;
   var pendienteCount = 0; var aprobadaCount = 0;
   if (proformas) { for (var i = 0; i < proformas.length; i++) {
       if (proformas[i].Estado === 'PENDIENTE') pendienteCount++;
       if (proformas[i].Estado === 'APROBADA' || proformas[i].Estado === 'FACTURADA') aprobadaCount++;
   }} %>

<div class="wrapper">
    <%- include("../parciales/sidebar") %>

    <div class="main-content" id="main-content">

        <!-- Content -->
        <div class="p-8">

            <!-- Page Title -->
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Gestión de Proformas</h2>
                <p class="text-slate-500">Administra y monitorea las proformas emitidas por CARSIL.</p>
            </div>

            <!-- Flash messages -->
            <% if (messages && messages.success) { %>
            <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                <span><%= messages.success %></span>
            </div>
            <% } %>
            <% if (messages && messages.error) { %>
            <div class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-rose-500">error</span>
                <span><%= messages.error %></span>
            </div>
            <% } %>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-[#3b4bc9]">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total Proformas</p>
                    <p class="text-3xl font-bold text-[#3b4bc9]"><%= totalProformas %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-amber-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pendientes</p>
                    <p class="text-3xl font-bold text-amber-600"><%= pendienteCount %></p>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm border-t-4 border-t-emerald-500">
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Aprobadas / Facturadas</p>
                    <p class="text-3xl font-bold text-emerald-600"><%= aprobadaCount %></p>
                </div>
            </div>

            <!-- Filter Bar -->
            <div class="bg-white p-4 rounded-xl border border-slate-100 mb-6 flex flex-wrap gap-4 items-center shadow-sm">
                <div class="flex-1 min-w-[220px] relative group">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#3b4bc9] transition-colors">search</span>
                    <input id="valorFiltro"
                           class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] transition-all text-sm outline-none"
                           placeholder="Buscar proformas..." type="text" />
                </div>
                <select id="campoFiltro"
                        class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                    <option value="0">Código</option>
                    <option value="1">Cliente</option>
                    <option value="2">Usuario</option>
                    <option value="3">Fecha</option>
                    <option value="8">Estado</option>
                    <option value="7">Total</option>
                </select>
                <button type="button" onclick="abrirModalCrear()"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 hover:shadow-lg transition-all text-sm">
                    <span class="material-symbols-outlined text-sm">add_circle</span>
                    Nueva Proforma
                </button>
            </div>

            <!-- Data Table -->
            <div class="bg-white rounded-xl border border-slate-100 shadow-md overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200">
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">
                                    <input class="rounded border-slate-300 text-[#3b4bc9] focus:ring-[#3b4bc9]" type="checkbox" onchange="toggleAll(this)">
                                </th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Código</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Cliente</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Usuario</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Empresa</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Fecha</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Validez</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">SubTotal</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">IGV</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Total</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Estado</th>
                                <th class="px-4 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100" id="tbodyProformas">
                        <% if (proformas && proformas.length > 0) { %>
                        <% proformas.forEach(function(pf) {
                            var estado = pf.EstadoVisual || pf.Estado || '';
                            var clienteOk = pf.ClienteNombre && pf.ClienteNombre.indexOf('no encontrado') === -1;
                            var usuarioOk = pf.UsuarioNombre && pf.UsuarioNombre.indexOf('no encontrado') === -1;
                            var empresaOk = pf.EmpresaNombre && pf.EmpresaNombre.indexOf('no encontrada') === -1;
                            var fechaStr = pf.FechaEmision ? (pf.FechaEmision.toISOString ? pf.FechaEmision.toISOString().split('T')[0] : pf.FechaEmision) : '';
                            var subtotal = !isNaN(parseFloat(pf.SubTotal)) ? parseFloat(pf.SubTotal).toFixed(2) : '0.00';
                            var igv = !isNaN(parseFloat(pf.TotalIGV)) ? parseFloat(pf.TotalIGV).toFixed(2) : '0.00';
                            var total = !isNaN(parseFloat(pf.Total)) ? parseFloat(pf.Total).toFixed(2) : '0.00';
                        %>
                        <tr class="hover:bg-slate-50/60 transition-colors">
                            <!-- Checkbox -->
                            <td class="px-4 py-4">
                                <input class="row-checkbox rounded border-slate-300 text-[#3b4bc9] focus:ring-[#3b4bc9]" type="checkbox">
                            </td>
                            <!-- Código -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[#3b4bc9] text-lg">description</span>
                                    <span class="font-mono font-bold text-[#3b4bc9] text-sm"><%= pf.Codigo %></span>
                                </div>
                            </td>
                            <!-- Cliente -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 font-bold text-sm flex-shrink-0">
                                        <%= clienteOk ? pf.ClienteNombre.charAt(0).toUpperCase() : 'C' %>
                                    </div>
                                    <div>
                                        <% if (clienteOk) { %>
                                        <p class="text-sm font-semibold leading-tight"><%= pf.ClienteNombre %></p>
                                        <% if (pf.ClienteDocumento) { %>
                                        <p class="text-xs text-slate-400 font-mono mt-0.5">RUC: <%= pf.ClienteDocumento %></p>
                                        <% } %>
                                        <% } else { %>
                                        <p class="text-sm text-amber-600 font-medium">ID: <%= pf.IdCliente %></p>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                            <!-- Usuario -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center text-amber-700 font-bold text-sm flex-shrink-0">
                                        <%= usuarioOk ? pf.UsuarioNombre.charAt(0).toUpperCase() : 'U' %>
                                    </div>
                                    <div>
                                        <% if (usuarioOk) { %>
                                        <p class="text-sm font-semibold leading-tight"><%= pf.UsuarioNombre %></p>
                                        <p class="text-xs text-slate-400 mt-0.5">Responsable</p>
                                        <% } else { %>
                                        <p class="text-sm text-amber-600 font-medium">ID: <%= pf.IdUsuario %></p>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                            <!-- Empresa -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-pink-100 flex items-center justify-center text-pink-700 font-bold text-sm flex-shrink-0">
                                        <%= empresaOk ? pf.EmpresaNombre.charAt(0).toUpperCase() : 'E' %>
                                    </div>
                                    <div>
                                        <% if (empresaOk) { %>
                                        <p class="text-sm font-semibold leading-tight"><%= pf.EmpresaNombre %></p>
                                        <% if (pf.EmpresaRUC) { %>
                                        <p class="text-xs text-slate-400 font-mono mt-0.5">RUC: <%= pf.EmpresaRUC %></p>
                                        <% } %>
                                        <% } else { %>
                                        <p class="text-sm text-amber-600 font-medium">ID: <%= pf.IdEmpresa %></p>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                            <!-- Fecha -->
                            <td class="px-4 py-4 whitespace-nowrap text-sm text-slate-500">
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-sm text-slate-400">calendar_today</span>
                                    <%= fechaStr || '—' %>
                                </div>
                            </td>
                            <!-- Validez -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold bg-slate-100 text-slate-600">
                                    <span class="material-symbols-outlined text-[13px]">schedule</span>
                                    <%= pf.ValidezOferta %> días
                                </span>
                            </td>
                            <!-- SubTotal -->
                            <td class="px-4 py-4 whitespace-nowrap text-sm font-semibold text-slate-700">
                                S/ <%= subtotal %>
                            </td>
                            <!-- IGV -->
                            <td class="px-4 py-4 whitespace-nowrap text-sm font-semibold text-slate-700">
                                S/ <%= igv %>
                            </td>
                            <!-- Total -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <span class="text-base font-bold text-emerald-700">S/ <%= total %></span>
                            </td>
                            <!-- Estado -->
                            <td class="px-4 py-4 whitespace-nowrap">
                                <%
                                var estadoBadge = {
                                    'PENDIENTE':  'bg-amber-50 text-amber-700',
                                    'APROBADA':   'bg-emerald-50 text-emerald-700',
                                    'FACTURADA':  'bg-sky-50 text-sky-700',
                                    'RECHAZADA':  'bg-rose-50 text-rose-700'
                                };
                                var estadoIcon = {
                                    'PENDIENTE':  'schedule',
                                    'APROBADA':   'check_circle',
                                    'FACTURADA':  'receipt',
                                    'RECHAZADA':  'cancel'
                                };
                                %>
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider <%= estadoBadge[estado] || 'bg-slate-100 text-slate-500' %>">
                                    <span class="material-symbols-outlined text-[13px]"><%= estadoIcon[estado] || 'help' %></span>
                                    <%= estado || 'SIN ESTADO' %>
                                </span>
                            </td>
                            <!-- Acciones -->
                            <td class="px-4 py-4 whitespace-nowrap text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <button type="button"
                                        class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                        title="Editar"
                                        onclick="abrirModalEditar(<%= pf.IdProforma %>, '<%= pf.Codigo %>')">
                                        <span class="material-symbols-outlined text-lg leading-none">edit</span>
                                    </button>
                                    <a href="/proformas/<%= pf.IdProforma %>/detalle" target="_blank"
                                       class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors text-slate-500 hover:text-[#3b4bc9]"
                                       title="Ver detalle">
                                        <span class="material-symbols-outlined text-lg leading-none">visibility</span>
                                    </a>
                                    <form action="/proformas/<%= pf.IdProforma %>/eliminar" method="POST" class="inline"
                                          onsubmit="return confirm('¿Seguro de eliminar esta proforma?')">
                                        <button type="submit"
                                            class="p-1.5 hover:bg-rose-50 rounded-lg transition-colors text-slate-500 hover:text-rose-600"
                                            title="Eliminar">
                                            <span class="material-symbols-outlined text-lg leading-none">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                        <% } else { %>
                        <tr>
                            <td colspan="12" class="text-center py-16">
                                <span class="material-symbols-outlined text-5xl text-slate-300 block mb-3">description</span>
                                <p class="text-slate-500 font-medium mb-1">No hay proformas registradas</p>
                                <p class="text-slate-400 text-sm mb-5">Crea tu primera proforma para comenzar.</p>
                                <button type="button" onclick="abrirModalCrear()"
                                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#3b4bc9] text-white font-semibold rounded-lg hover:bg-[#3b4bc9]/90 transition-all text-sm">
                                    <span class="material-symbols-outlined text-sm">add_circle</span>
                                    Nueva Proforma
                                </button>
                            </td>
                        </tr>
                        <% } %>
                        </tbody>
                    </table>
                </div>
                <!-- Footer -->
                <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                    <p class="text-sm text-slate-500">
                        Mostrando <span id="visibleCount"><%= totalProformas %></span>
                        de <strong><%= totalProformas %></strong> proformas
                    </p>
                </div>
            </div>

        </div><!-- /p-8 -->
    </div><!-- /main-content -->
</div><!-- /wrapper -->

<!-- MODAL FLOTANTE -->
<div class="pf-modal-overlay" id="pfOverlay" onclick="cerrarSiOverlay(event)">
    <div style="width:96%;max-width:1550px;max-height:94vh;background:#f6f6f8;border-radius:1.25rem;box-shadow:0 32px 80px rgba(0,0,0,0.45);display:flex;flex-direction:column;overflow:hidden;animation:sheetIn 0.35s cubic-bezier(0.16,1,0.3,1) both;">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 bg-white flex-shrink-0">
            <div class="flex items-center gap-2 font-bold text-slate-900">
                <span class="material-symbols-outlined text-[#3b4bc9]" id="pfIcon">description</span>
                <span id="pfTitle">Nueva Proforma</span>
            </div>
            <button onclick="cerrarModal()" title="Cerrar (Esc)"
                class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-500 hover:bg-slate-100 hover:text-slate-900 transition-colors">
                <span class="material-symbols-outlined text-xl">close</span>
            </button>
        </div>
        <div class="flex-1 overflow-hidden relative">
            <div id="pfSpinner" class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-[#f6f6f8] z-10">
                <div class="w-10 h-10 rounded-full border-4 border-slate-200 border-t-[#3b4bc9] animate-spin"></div>
                <span class="text-sm text-slate-500">Cargando formulario...</span>
            </div>
            <iframe id="pfIframe" name="pfIframe" style="width:100%;height:100%;min-height:82vh;border:none;display:block;"></iframe>
        </div>
    </div>
</div>

<script>
    var overlay = document.getElementById('pfOverlay');
    var iframe  = document.getElementById('pfIframe');
    var spinner = document.getElementById('pfSpinner');
    var titleEl = document.getElementById('pfTitle');
    var iconEl  = document.getElementById('pfIcon');

    function abrirModal(url, titulo, icono) {
        titleEl.textContent = titulo;
        iconEl.textContent = icono;
        iframe.style.visibility = 'hidden';
        spinner.style.display = 'flex';
        iframe.src = url;
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    function abrirModalCrear() { abrirModal('/proformas/nueva', 'Nueva Proforma', 'add_circle'); }
    function abrirModalEditar(id, codigo) { abrirModal('/proformas/' + id + '/editar', 'Editar Proforma - ' + codigo, 'edit'); }

    iframe.addEventListener('load', function () {
        try {
            var path = iframe.contentWindow.location.pathname;
            if (path === '/proformas' || path === '/proformas/') {
                cerrarModal();
                setTimeout(function () { location.reload(); }, 100);
                return;
            }
        } catch (e) {}
        spinner.style.display = 'none';
        iframe.style.visibility = 'visible';
    });
    function cerrarModal() {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(function () { iframe.src = 'about:blank'; }, 300);
    }
    function cerrarSiOverlay(e) { if (e.target === overlay) cerrarModal(); }
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') cerrarModal(); });

    function toggleAll(source) {
        document.querySelectorAll('.row-checkbox').forEach(function(cb) { cb.checked = source.checked; });
    }

    // Filtro de tabla
    const campoFiltro = document.getElementById('campoFiltro');
    const valorFiltro = document.getElementById('valorFiltro');
    if (campoFiltro && valorFiltro) {
        [campoFiltro, valorFiltro].forEach(function(el) {
            el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', filtrar);
        });
        function filtrar() {
            var col = parseInt(campoFiltro.value) + 1; // +1 por la columna checkbox
            var q = valorFiltro.value.toLowerCase();
            var vis = 0;
            document.querySelectorAll('#tbodyProformas tr').forEach(function(row) {
                var cell = row.querySelectorAll('td')[col];
                var show = cell && cell.textContent.toLowerCase().includes(q);
                row.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            var vc = document.getElementById('visibleCount');
            if (vc) vc.textContent = vis;
        }
    }
</script>
<script src="/publico/js/layout.js?v=1772427290135"></script>
</body>

</html>