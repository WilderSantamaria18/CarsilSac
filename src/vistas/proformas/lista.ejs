<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Proformas - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290147">
    <link rel="stylesheet" href="/publico/css/list-views.css">
</head>
<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-file-earmark-text"></i>
                        Gestión de Proformas
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= user && user.Nombres ? user.Nombres : 'Usuario' %></span>
                        <div class="user-avatar"><%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %></div>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid py-4">
                <!-- Mensajes flash -->
                <% if (messages && messages.success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i><%= messages.success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (messages && messages.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i><%= messages.error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- Debug section (temporary) -->
                <% if (proformas && proformas.length > 0 && (!proformas[0].ClienteNombre || !proformas[0].UsuarioNombre)) { %>
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Advertencia:</strong> Los datos de clientes o usuarios no se están cargando correctamente. 
                        Verificar que las tablas CLIENTE, USUARIO y EMPRESA tengan datos y estén relacionadas correctamente con las proformas.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                            <i class="bi bi-file-earmark-text text-white"></i>
                        </div>
                        <h6 class="text-muted">Total Proformas</h6>
                        <h3 class="text-primary"><%= proformas ? proformas.length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ffeaa7, #fdcb6e);">
                            <i class="bi bi-clock text-warning"></i>
                        </div>
                        <h6 class="text-muted">Pendientes</h6>
                        <h3 class="text-warning"><%= proformas ? proformas.filter(p => p.Estado === 'PENDIENTE').length : 0 %></h3>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #55efc4, #00b894);">
                            <i class="bi bi-check-circle text-success"></i>
                        </div>
                        <h6 class="text-muted">Aprobadas</h6>
                        <h3 class="text-success"><%= proformas ? proformas.filter(p => p.Estado === 'APROBADA').length : 0 %></h3>
                    </div>
                </div>

                <!-- Search and Actions -->
                <div class="search-container">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="search-box flex-grow-1 me-3">
                            <i class="bi bi-search search-icon"></i>
                            <div class="d-flex gap-2">
                                <select class="form-select" id="campoFiltro" style="max-width: 180px;">
                                    <option value="0">Código</option>
                                    <option value="1">Cliente</option>
                                    <option value="2">Usuario</option>
                                    <option value="3">Fecha</option>
                                    <option value="8">Estado</option>
                                    <option value="7">Total</option>
                                </select>
                                <input type="text" class="form-control" id="valorFiltro" placeholder="Buscar proformas...">
                            </div>
                        </div>
                        <a href="/proformas/nueva" class="btn btn-primary-modern btn-modern">
                            <i class="bi bi-plus-circle"></i>
                            Nueva Proforma
                        </a>
                    </div>
                </div>

                <!-- Tabla de proformas modernizada -->
                <div class="card-modern">
                    <div class="table-responsive">
                        <table class="table table-modern mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"><input class="form-check-input custom-checkbox" type="checkbox" onchange="toggleAll(this)"></th>
                                    <th>Código</th>
                                    <th>Cliente</th>
                                    <th>Usuario</th>
                                    <th>Empresa</th>
                                    <th>Fecha</th>
                                    <th>Validez</th>
                                    <th>SubTotal</th>
                                    <th>IGV</th>
                                    <th>Total</th>
                                    <th>Estado</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                            <% if (proformas && proformas.length > 0) { %>
                                <% proformas.forEach(function(proforma) { %>
                                    <tr>
                                            <td><input class="form-check-input custom-checkbox row-checkbox" type="checkbox"></td>
                                            <td>
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-file-earmark-text text-primary me-2"></i>
                                                <strong><%= proforma.Codigo %></strong>
                                            </div>
                                        </td>                        <td>
                            <div class="d-flex align-items-center">
                                <div class="item-avatar me-2">
                                    <%= (proforma.ClienteNombre && proforma.ClienteNombre.length > 0 && !proforma.ClienteNombre.includes('Cliente no encontrado')) ? 
                                        proforma.ClienteNombre.charAt(0).toUpperCase() : 'C' %>
                                </div>
                                <div>
                                    <% if (proforma.ClienteNombre && proforma.ClienteNombre.trim() !== '' && !proforma.ClienteNombre.includes('Cliente no encontrado')) { %>
                                        <div class="fw-bold"><%= proforma.ClienteNombre %></div>
                                        <% if (proforma.ClienteDocumento && proforma.ClienteDocumento.trim() !== '') { %>
                                            <small class="text-muted">RUC: <%= proforma.ClienteDocumento %></small>
                                        <% } %>
                                    <% } else { %>
                                        <span class="text-warning">Cliente ID: <%= proforma.IdCliente %></span>
                                    <% } %>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="item-avatar me-2" style="background: linear-gradient(135deg, #ffeaa7, #fdcb6e);">
                                    <%= (proforma.UsuarioNombre && proforma.UsuarioNombre.length > 0 && !proforma.UsuarioNombre.includes('Usuario no encontrado')) ? 
                                        proforma.UsuarioNombre.charAt(0).toUpperCase() : 'U' %>
                                </div>
                                <div>
                                    <% if (proforma.UsuarioNombre && proforma.UsuarioNombre.trim() !== '' && !proforma.UsuarioNombre.includes('Usuario no encontrado')) { %>
                                        <div class="fw-bold"><%= proforma.UsuarioNombre %></div>
                                        <small class="text-muted">Responsable</small>
                                    <% } else { %>
                                        <span class="text-warning">Usuario ID: <%= proforma.IdUsuario %></span>
                                    <% } %>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="item-avatar me-2" style="background: linear-gradient(135deg, #d63384, #e83e8c);">
                                    <%= (proforma.EmpresaNombre && proforma.EmpresaNombre.length > 0 && !proforma.EmpresaNombre.includes('Empresa no encontrada')) ? 
                                        proforma.EmpresaNombre.charAt(0).toUpperCase() : 'E' %>
                                </div>
                                <div>
                                    <% if (proforma.EmpresaNombre && proforma.EmpresaNombre.trim() !== '' && !proforma.EmpresaNombre.includes('Empresa no encontrada')) { %>
                                        <div class="fw-bold"><%= proforma.EmpresaNombre %></div>
                                        <% if (proforma.EmpresaRUC && proforma.EmpresaRUC.trim() !== '') { %>
                                            <small class="text-muted">RUC: <%= proforma.EmpresaRUC %></small>
                                        <% } %>
                                    <% } else { %>
                                        <span class="text-warning">Empresa ID: <%= proforma.IdEmpresa %></span>
                                    <% } %>
                                </div>
                            </div>
                        </td>
                                        <td>
                                            <i class="bi bi-calendar3 text-muted me-1"></i>
                                            <%= proforma.FechaEmision ? proforma.FechaEmision.toISOString ? proforma.FechaEmision.toISOString().split('T')[0] : proforma.FechaEmision : '' %>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark">
                                                <i class="bi bi-clock me-1"></i>
                                                <%= proforma.ValidezOferta %> días
                                            </span>
                                        </td>
                                        <td class="amount-highlight">S/ <%= !isNaN(parseFloat(proforma.SubTotal)) ? parseFloat(proforma.SubTotal).toFixed(2) : '0.00' %></td>
                                        <td class="amount-highlight">S/ <%= !isNaN(parseFloat(proforma.TotalIGV)) ? parseFloat(proforma.TotalIGV).toFixed(2) : '0.00' %></td>
                                        <td>
                                            <strong class="amount-highlight" style="font-size: 1.1rem;">
                                                S/ <%= !isNaN(parseFloat(proforma.Total)) ? parseFloat(proforma.Total).toFixed(2) : '0.00' %>
                                            </strong>
                                        </td>
                                        <td>
                                            <% let estado = proforma.EstadoVisual || proforma.Estado; %>
                                            <span class="badge badge-modern
                                                <%= estado === 'PENDIENTE' ? 'badge-pendiente'
                                                    : estado === 'APROBADA' ? 'badge-aprobado'
                                                    : estado === 'FACTURADA' ? 'badge-aprobado'
                                                    : estado === 'VENCIDA' ? 'badge-rechazado'
                                                    : 'badge-rechazado' %>">
                                                <i class="bi
                                                    <%= estado === 'PENDIENTE' ? 'bi-clock'
                                                        : estado === 'APROBADA' ? 'bi-check-circle'
                                                        : estado === 'FACTURADA' ? 'bi-receipt'
                                                        : estado === 'VENCIDA' ? 'bi-x-circle'
                                                        : 'bi-x-circle' %>"></i>
                                                <%= estado %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="action-buttons justify-content-center">

                                                <a href="/proformas/<%= proforma.IdProforma %>/editar" 
                                                   class="btn-action-icon btn-action-edit" 
                                                   title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a href="/proformas/<%= proforma.IdProforma %>/detalle" 
                                                   class="btn-action-icon btn-action-view" 
                                                   target="_blank"
                                                   title="Ver detalle en nueva pestaña">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                
                                                
                                                
                                                
                                                
                                                <form action="/proformas/<%= proforma.IdProforma %>/eliminar" 
                                                      method="POST" 
                                                      class="d-inline" 
                                                      onsubmit="return confirm('¿Seguro de eliminar esta proforma?');">
                                                    <button type="submit" 
                                                            class="btn-action-icon btn-action-delete" 
                                                            title="Eliminar">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        
</div></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="11" class="text-center py-5">
                                        <i class="bi bi-file-earmark-text text-muted" style="font-size: 3rem;"></i>
                                        <p class="text-muted mt-2">No hay proformas registradas.</p>
                                        <a href="/proformas/nueva" class="btn btn-primary-modern btn-modern">
                                            <i class="bi bi-plus-circle"></i>
                                            Crear primera proforma
                                        </a>
                                    </td>
                                </tr>
                            <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');
            
            // Toggle sidebar (solo si el botón existe)
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function() {
                    if (sidebar) sidebar.classList.toggle('hide');
                    if (mainContent) mainContent.classList.toggle('full');
                });
            }
            
            // Filtro de tabla
            const campoFiltro = document.getElementById('campoFiltro');
            const valorFiltro = document.getElementById('valorFiltro');
            if (campoFiltro && valorFiltro) {
                valorFiltro.addEventListener('input', filtrarTabla);
                campoFiltro.addEventListener('change', filtrarTabla);
            }
            
            function filtrarTabla() {
                const col = parseInt(campoFiltro.value);
                const searchTerm = valorFiltro.value.toLowerCase();
                const rows = document.querySelectorAll('tbody tr');
                
                rows.forEach(row => {
                    // Skip si es la fila de "no hay proformas"
                    if (row.querySelectorAll('td').length < 10) return;
                    
                    const cell = row.querySelectorAll('td')[col];
                    let cellText = cell.textContent.toLowerCase();
                    
                    // Para campos de moneda (SubTotal, IGV, Total)
                    if (col === 5 || col === 6 || col === 7) {
                        cellText = cellText.replace('s/', '').trim();
                    }
                    
                    if (cell && cellText.includes(searchTerm)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }
        });

        // Función para aprobar proforma
        async function aprobarProforma(idProforma) {
            if (await liquidGlassConfirm('¿Está seguro de que desea APROBAR esta proforma? Una vez aprobada podrá generar factura.')) {
                fetch(`/proformas/${idProforma}/aprobar`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ estado: 'APROBADA' })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Proforma aprobada exitosamente');
                        location.reload();
                    } else {
                        alert('Error al aprobar proforma: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error al aprobar proforma');
                });
            }
        }

        // Función para generar factura desde proforma
        async function generarFactura(idProforma) {
            if (await liquidGlassConfirm('¿Desea generar una factura basada en esta proforma aprobada?')) {
                // Mostrar indicador de carga
                const btn = event.target.closest('button');
                const originalContent = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
                btn.disabled = true;

                fetch(`/facturas/desde-proforma/${idProforma}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Factura generada exitosamente');
                        // Redirigir a la factura creada
                        window.open(`/facturas/${data.idFactura}`, '_blank');
                        location.reload();
                    } else {
                        alert('Error al generar factura: ' + data.message);
                        btn.innerHTML = originalContent;
                        btn.disabled = false;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error al generar factura');
                    btn.innerHTML = originalContent;
                    btn.disabled = false;
                });
            }
        }
    </script>
    <script src="/publico/js/layout.js?v=1772427290147"></script>
</body>
</html>
