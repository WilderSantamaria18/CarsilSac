<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Proformas - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/publico/css/list-views.css">
    <style>
        /* ══════════════════════════════════════════
           MODAL FLOTANTE CON FONDO DIFUMINADO
           ══════════════════════════════════════════ */
        .pf-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 1080;
            background: rgba(10, 12, 20, 0.72);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            align-items: center;
            justify-content: center;
            animation: overlayFadeIn 0.2s ease both;
        }

        .pf-modal-overlay.active {
            display: flex;
        }

        @keyframes overlayFadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .pf-modal-sheet {
            width: 90%;
            max-width: 1100px;
            max-height: 92vh;
            background: #f6f6f8;
            border-radius: 1.25rem;
            box-shadow: 0 32px 80px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(255, 255, 255, 0.08);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: sheetSlideIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        @keyframes sheetSlideIn {
            from {
                transform: translateY(40px) scale(0.97);
                opacity: 0;
            }

            to {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }

        .pf-modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.07);
            background: #fff;
            flex-shrink: 0;
        }

        .pf-modal-header-title {
            font-size: 1rem;
            font-weight: 700;
            color: #0f1117;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .pf-modal-header-title i {
            color: #3b4bc9;
            font-size: 1.1rem;
        }

        .pf-modal-close {
            width: 32px;
            height: 32px;
            border: none;
            background: none;
            cursor: pointer;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6b7280;
            font-size: 1.1rem;
            transition: background 0.15s, color 0.15s;
        }

        .pf-modal-close:hover {
            background: #f3f4f6;
            color: #0f1117;
        }

        .pf-modal-body {
            flex: 1;
            overflow: hidden;
            position: relative;
        }

        .pf-modal-loading {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            color: #6b7280;
            font-size: 0.875rem;
            background: #f6f6f8;
            z-index: 2;
        }

        .pf-modal-loading .spinner-border {
            width: 2.5rem;
            height: 2.5rem;
            color: #3b4bc9;
        }

        #pfModalIframe {
            width: 100%;
            height: 100%;
            min-height: 80vh;
            border: none;
            display: block;
        }

        @media (max-width: 768px) {
            .pf-modal-sheet {
                width: 100%;
                max-width: 100%;
                max-height: 100vh;
                border-radius: 0;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                    <div class="container-fluid">
                        <h5 class="page-title mb-0">
                            <i class="bi bi-file-earmark-text"></i>
                            Gestión de Proformas
                        </h5>
                        <div class="user-profile ms-auto">
                            <span>
                                <%= user && user.Nombres ? user.Nombres : 'Usuario' %>
                            </span>
                            <div class="user-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid py-4">
                    <!-- Mensajes flash -->
                    <% if (messages && messages.success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>
                            <%= messages.success %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% if (messages && messages.error) { %>
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    <%= messages.error %>
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <!-- Stats Cards -->
                                    <div class="stats-grid">
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #74b9ff, #0984e3);">
                                                <i class="bi bi-file-earmark-text text-white"></i>
                                            </div>
                                            <h6 class="text-muted">Total Proformas</h6>
                                            <h3 class="text-primary">
                                                <%= proformas ? proformas.length : 0 %>
                                            </h3>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #ffeaa7, #fdcb6e);">
                                                <i class="bi bi-clock text-warning"></i>
                                            </div>
                                            <h6 class="text-muted">Pendientes</h6>
                                            <h3 class="text-warning">
                                                <%= proformas ? proformas.filter(p=> p.Estado === 'PENDIENTE').length :
                                                    0 %>
                                            </h3>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon"
                                                style="background: linear-gradient(135deg, #55efc4, #00b894);">
                                                <i class="bi bi-check-circle text-success"></i>
                                            </div>
                                            <h6 class="text-muted">Aprobadas</h6>
                                            <h3 class="text-success">
                                                <%= proformas ? proformas.filter(p=> p.Estado === 'APROBADA').length : 0
                                                    %>
                                            </h3>
                                        </div>
                                    </div>

                                    <!-- Search and Actions -->
                                    <div class="search-container">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="search-box flex-grow-1 me-3">
                                                <i class="bi bi-search search-icon"></i>
                                                <div class="d-flex gap-2">
                                                    <select class="form-select" id="campoFiltro"
                                                        style="max-width: 180px;">
                                                        <option value="0">Código</option>
                                                        <option value="1">Cliente</option>
                                                        <option value="2">Usuario</option>
                                                        <option value="3">Fecha</option>
                                                        <option value="8">Estado</option>
                                                        <option value="7">Total</option>
                                                    </select>
                                                    <input type="text" class="form-control" id="valorFiltro"
                                                        placeholder="Buscar proformas...">
                                                </div>
                                            </div>
                                            <button type="button" class="btn btn-primary-modern btn-modern"
                                                onclick="abrirModalCrear()">
                                                <i class="bi bi-plus-circle"></i>
                                                Nueva Proforma
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Tabla -->
                                    <div class="card-modern">
                                        <div class="table-responsive">
                                            <table class="table table-modern mb-0">
                                                <thead>
                                                    <tr>
                                                        <th style="width:40px;"><input
                                                                class="form-check-input custom-checkbox" type="checkbox"
                                                                onchange="toggleAll(this)"></th>
                                                        <th>Código</th>
                                                        <th>Cliente</th>
                                                        <th>Usuario</th>
                                                        <th>Empresa</th>
                                                        <th>Fecha</th>
                                                        <th>Validez</th>
                                                        <th>SubTotal</th>
                                                        <th>IGV</th>
                                                        <th>Total</th>
                                                        <th>Estado</th>
                                                        <th class="text-center">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (proformas && proformas.length> 0) { %>
                                                        <% proformas.forEach(function(proforma) { %>
                                                            <tr>
                                                                <td><input
                                                                        class="form-check-input custom-checkbox row-checkbox"
                                                                        type="checkbox"></td>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <i
                                                                            class="bi bi-file-earmark-text text-primary me-2"></i>
                                                                        <strong>
                                                                            <%= proforma.Codigo %>
                                                                        </strong>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <div class="item-avatar me-2">
                                                                            <%= (proforma.ClienteNombre &&
                                                                                !proforma.ClienteNombre.includes('no
                                                                                encontrado')) ?
                                                                                proforma.ClienteNombre.charAt(0).toUpperCase()
                                                                                : 'C' %>
                                                                        </div>
                                                                        <div>
                                                                            <% if (proforma.ClienteNombre &&
                                                                                !proforma.ClienteNombre.includes('no
                                                                                encontrado')) { %>
                                                                                <div class="fw-bold">
                                                                                    <%= proforma.ClienteNombre %>
                                                                                </div>
                                                                                <% if (proforma.ClienteDocumento) { %>
                                                                                    <small class="text-muted">RUC: <%=
                                                                                            proforma.ClienteDocumento %>
                                                                                            </small>
                                                                                    <% } %>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="text-warning">ID:
                                                                                                <%= proforma.IdCliente
                                                                                                    %></span>
                                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <div class="item-avatar me-2"
                                                                            style="background:linear-gradient(135deg,#ffeaa7,#fdcb6e);">
                                                                            <%= (proforma.UsuarioNombre &&
                                                                                !proforma.UsuarioNombre.includes('no
                                                                                encontrado')) ?
                                                                                proforma.UsuarioNombre.charAt(0).toUpperCase()
                                                                                : 'U' %>
                                                                        </div>
                                                                        <div>
                                                                            <% if (proforma.UsuarioNombre &&
                                                                                !proforma.UsuarioNombre.includes('no
                                                                                encontrado')) { %>
                                                                                <div class="fw-bold">
                                                                                    <%= proforma.UsuarioNombre %>
                                                                                </div>
                                                                                <small
                                                                                    class="text-muted">Responsable</small>
                                                                                <% } else { %>
                                                                                    <span class="text-warning">ID: <%=
                                                                                            proforma.IdUsuario %></span>
                                                                                    <% } %>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <div class="item-avatar me-2"
                                                                            style="background:linear-gradient(135deg,#d63384,#e83e8c);">
                                                                            <%= (proforma.EmpresaNombre &&
                                                                                !proforma.EmpresaNombre.includes('no
                                                                                encontrada')) ?
                                                                                proforma.EmpresaNombre.charAt(0).toUpperCase()
                                                                                : 'E' %>
                                                                        </div>
                                                                        <div>
                                                                            <% if (proforma.EmpresaNombre &&
                                                                                !proforma.EmpresaNombre.includes('no
                                                                                encontrada')) { %>
                                                                                <div class="fw-bold">
                                                                                    <%= proforma.EmpresaNombre %>
                                                                                </div>
                                                                                <% if (proforma.EmpresaRUC) { %><small
                                                                                        class="text-muted">RUC: <%=
                                                                                            proforma.EmpresaRUC %>
                                                                                            </small>
                                                                                    <% } %>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="text-warning">ID:
                                                                                                <%= proforma.IdEmpresa
                                                                                                    %></span>
                                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <i class="bi bi-calendar3 text-muted me-1"></i>
                                                                    <%= proforma.FechaEmision ?
                                                                        (proforma.FechaEmision.toISOString ?
                                                                        proforma.FechaEmision.toISOString().split('T')[0]
                                                                        : proforma.FechaEmision) : '' %>
                                                                </td>
                                                                <td>
                                                                    <span class="badge bg-light text-dark">
                                                                        <i class="bi bi-clock me-1"></i>
                                                                        <%= proforma.ValidezOferta %> días
                                                                    </span>
                                                                </td>
                                                                <td class="amount-highlight">S/ <%=
                                                                        !isNaN(parseFloat(proforma.SubTotal)) ?
                                                                        parseFloat(proforma.SubTotal).toFixed(2)
                                                                        : '0.00' %>
                                                                </td>
                                                                <td class="amount-highlight">S/ <%=
                                                                        !isNaN(parseFloat(proforma.TotalIGV)) ?
                                                                        parseFloat(proforma.TotalIGV).toFixed(2)
                                                                        : '0.00' %>
                                                                </td>
                                                                <td><strong class="amount-highlight"
                                                                        style="font-size:1.1rem;">S/ <%=
                                                                            !isNaN(parseFloat(proforma.Total)) ?
                                                                            parseFloat(proforma.Total).toFixed(2)
                                                                            : '0.00' %></strong></td>
                                                                <td>
                                                                    <% let estado=proforma.EstadoVisual ||
                                                                        proforma.Estado; %>
                                                                        <span
                                                                            class="badge badge-modern <%= estado==='PENDIENTE'?'badge-pendiente':estado==='APROBADA'||estado==='FACTURADA'?'badge-aprobado':'badge-rechazado' %>">
                                                                            <i
                                                                                class="bi <%= estado==='PENDIENTE'?'bi-clock':estado==='APROBADA'?'bi-check-circle':estado==='FACTURADA'?'bi-receipt':'bi-x-circle' %>"></i>
                                                                            <%= estado %>
                                                                        </span>
                                                                </td>
                                                                <td class="text-center">
                                                                    <div class="action-buttons justify-content-center">
                                                                        <button type="button"
                                                                            class="btn-action-icon btn-action-edit"
                                                                            title="Editar"
                                                                            onclick="abrirModalEditar(<%= proforma.IdProforma %>, '<%= proforma.Codigo %>')">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </button>
                                                                        <a href="/proformas/<%= proforma.IdProforma %>/detalle"
                                                                            class="btn-action-icon btn-action-view"
                                                                            target="_blank" title="Ver detalle">
                                                                            <i class="bi bi-eye"></i>
                                                                        </a>
                                                                        <form
                                                                            action="/proformas/<%= proforma.IdProforma %>/eliminar"
                                                                            method="POST" class="d-inline"
                                                                            onsubmit="return confirm('¿Seguro de eliminar esta proforma?');">
                                                                            <button type="submit"
                                                                                class="btn-action-icon btn-action-delete"
                                                                                title="Eliminar">
                                                                                <i class="bi bi-trash"></i>
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            <% }); %>
                                                                <% } else { %>
                                                                    <tr>
                                                                        <td colspan="12" class="text-center py-5">
                                                                            <i class="bi bi-file-earmark-text text-muted"
                                                                                style="font-size:3rem;"></i>
                                                                            <p class="text-muted mt-2">No hay proformas
                                                                                registradas.</p>
                                                                            <button type="button"
                                                                                class="btn btn-primary-modern btn-modern"
                                                                                onclick="abrirModalCrear()">
                                                                                <i class="bi bi-plus-circle"></i> Crear
                                                                                primera proforma
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                </div>
            </div>
    </div>

    <!-- ══════════════════════════════════════════
         MODAL FLOTANTE CREAR / EDITAR PROFORMA
         ══════════════════════════════════════════ -->
    <div class="pf-modal-overlay" id="pfModalOverlay" onclick="cerrarModalSiOverlay(event)">
        <div class="pf-modal-sheet" id="pfModalSheet">
            <div class="pf-modal-header">
                <div class="pf-modal-header-title">
                    <i class="bi bi-file-earmark-plus" id="pfModalIcon"></i>
                    <span id="pfModalTitle">Nueva Proforma</span>
                </div>
                <button type="button" class="pf-modal-close" onclick="cerrarModal()" title="Cerrar (Esc)">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="pf-modal-body">
                <div class="pf-modal-loading" id="pfModalLoading">
                    <div class="spinner-border" role="status"><span class="visually-hidden">Cargando...</span></div>
                    <span>Cargando formulario...</span>
                </div>
                <iframe id="pfModalIframe" name="pfModalIframe"
                    style="width:100%;height:100%;min-height:82vh;border:none;"></iframe>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const overlay = document.getElementById('pfModalOverlay');
        const iframeEl = document.getElementById('pfModalIframe');
        const loadingEl = document.getElementById('pfModalLoading');
        const titleEl = document.getElementById('pfModalTitle');
        const iconEl = document.getElementById('pfModalIcon');

        function abrirModal(url, titulo, icono) {
            titleEl.textContent = titulo;
            iconEl.className = 'bi ' + icono;
            loadingEl.style.display = 'flex';
            iframeEl.style.visibility = 'hidden';
            iframeEl.src = url;
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function abrirModalCrear() {
            abrirModal('/proformas/nueva', 'Nueva Proforma', 'bi-file-earmark-plus');
        }

        function abrirModalEditar(id, codigo) {
            abrirModal('/proformas/' + id + '/editar', 'Editar — ' + codigo, 'bi-pencil-square');
        }

        iframeEl.addEventListener('load', function () {
            try {
                const path = iframeEl.contentWindow.location.pathname;
                // Si el iframe redirigió a /proformas (form enviado), cerrar y recargar
                if (path === '/proformas' || path === '/proformas/') {
                    cerrarModal();
                    location.reload();
                    return;
                }
            } catch (e) { }
            // Ocultar spinner, mostrar iframe
            loadingEl.style.display = 'none';
            iframeEl.style.visibility = 'visible';
        });

        function cerrarModal() {
            overlay.classList.remove('active');
            document.body.style.overflow = '';
            setTimeout(() => { iframeEl.src = 'about:blank'; }, 300);
        }

        function cerrarModalSiOverlay(e) {
            if (e.target === overlay) cerrarModal();
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') cerrarModal();
        });

        // Filtro de tabla
        document.addEventListener('DOMContentLoaded', function () {
            const campoFiltro = document.getElementById('campoFiltro');
            const valorFiltro = document.getElementById('valorFiltro');
            if (campoFiltro && valorFiltro) {
                function filtrarTabla() {
                    const col = parseInt(campoFiltro.value);
                    const q = valorFiltro.value.toLowerCase();
                    document.querySelectorAll('tbody tr').forEach(row => {
                        if (row.querySelectorAll('td').length < 10) return;
                        const cell = row.querySelectorAll('td')[col];
                        if (!cell) return;
                        row.style.display = cell.textContent.toLowerCase().includes(q) ? '' : 'none';
                    });
                }
                valorFiltro.addEventListener('input', filtrarTabla);
                campoFiltro.addEventListener('change', filtrarTabla);
            }
        });

        function toggleAll(source) {
            document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = source.checked);
        }
    </script>
    <script src="/publico/js/layout.js?v=<%= Date.now() %>"></script>
</body>

</html>