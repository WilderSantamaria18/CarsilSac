<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Cliente - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290135">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290135">
    
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar (sin cambios) -->
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-top border-bottom">
                <div class="container-fluid">
                    <h5 class="page-title mb-0">
                        <i class="bi bi-person-gear"></i>
                        Editar Cliente
                    </h5>
                    <div class="user-profile ms-auto">
                        <span><%= typeof user !== 'undefined' && user && user.Nombres ? user.Nombres : 'Administrador' %></span>
                        <div class="user-avatar"><%= typeof user !== 'undefined' && user && user.Nombres ? user.Nombres.charAt(0) : 'A' %></div>
                    </div>
                </div>
            </nav>
            
            <div class="form-container">
                <div class="form-card">
                    <div class="form-header-title"><i class="bi bi-person-gear"></i> Editar Información del Cliente</div>
                    
                    <div class="form-body">
                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger mb-4"><i class="bi bi-exclamation-triangle me-2"></i><%= error %></div>
                        <% } %>
                        
                        <form method="POST" action="/clientes/editar/<%= cliente.IdCliente %>">
                            <!-- Sección de Información Básica -->
                            <div class="form-section">
                                <h5 class="section-title">
                                    <i class="bi bi-info-circle"></i> Información Básica
                                </h5>
                                
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="razonSocial" class="form-label">
                                                <i class="bi bi-building"></i> Razón Social
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                                <input type="text" class="form-control-modern" id="razonSocial" name="RazonSocial" value="<%= cliente.RazonSocial %>" required>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="documento" class="form-label">
                                                <i class="bi bi-credit-card-2-front"></i> Documento
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-credit-card-2-front"></i></span>
                                                <input type="text" class="form-control-modern" id="documento" name="Documento" value="<%= cliente.Documento %>" required>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label for="direccion" class="form-label">
                                                <i class="bi bi-geo-alt"></i> Dirección
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                                <input type="text" class="form-control-modern" id="direccion" name="Direccion" value="<%= cliente.Direccion %>">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Sección de Contacto -->
                            <div class="form-section">
                                <h5 class="section-title">
                                    <i class="bi bi-telephone"></i> Información de Contacto
                                </h5>
                                
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="telefono" class="form-label">
                                                <i class="bi bi-telephone-outbound"></i> Teléfono
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                                <input type="text" class="form-control-modern" id="telefono" name="Telefono" value="<%= cliente.Telefono %>">
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="celular" class="form-label">
                                                <i class="bi bi-phone"></i> Celular
                                                <span class="optional-badge">Opcional</span>
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                                <input type="text" class="form-control-modern" id="celular" name="Celular" value="<%= cliente.Celular %>">
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="email" class="form-label">
                                                <i class="bi bi-envelope-at"></i> Email
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                                <input type="email" class="form-control-modern" id="email" name="Email" value="<%= cliente.Email %>">
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="contacto" class="form-label">
                                                <i class="bi bi-person-lines-fill"></i> Contacto
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                                <input type="text" class="form-control-modern" id="contacto" name="Contacto" value="<%= cliente.Contacto %>">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Acciones del formulario -->
                            <div class="form-buttons">
                                <a href="/clientes" class="btn btn-form btn-form-cancel">
                                    <i class="bi bi-arrow-left me-2"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-form-primary">
                                    <i class="bi bi-save me-2"></i> Guardar Cambios
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            
            <div class="footer">
                &copy; <%= new Date().getFullYear() %> CARSIL Equipos y Servicios SAC. Todos los derechos reservados.
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const toggleIcon = document.getElementById('toggleIcon');
            
            // Toggle sidebar
            toggleBtn.addEventListener('click', function() {
                sidebar.classList.toggle('hide');
                mainContent.classList.toggle('full');
                // Cambia el icono de dirección
                if (sidebar.classList.contains('hide')) {
                    toggleIcon.classList.remove('bi-chevron-left');
                    toggleIcon.classList.add('bi-chevron-right');
                } else {
                    toggleIcon.classList.remove('bi-chevron-right');
                    toggleIcon.classList.add('bi-chevron-left');
                }
            });
            
            // Cerrar sesión
            document.querySelector('.logout-item').addEventListener('click', async function(e) {
                e.preventDefault();
                if (await liquidGlassConfirm('¿Desea cerrar sesión?')) {
                    window.location.href = this.closest('a') ? this.closest('a').href : '/logout';
                }
            });
            
            // Activar elemento de menú actual
            const currentPath = window.location.pathname;
            document.querySelectorAll('.menu-item').forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
            
            // Efecto de hover para los campos del formulario
            const formGroups = document.querySelectorAll('.form-group');
            formGroups.forEach(group => {
                const input = group.querySelector('input, select, textarea');
                if(input) {
                    group.addEventListener('mouseenter', () => {
                        input.focus({preventScroll: true});
                    });
                }
            });
        });
    </script>
    <script src="/publico/js/layout.js?v=1772427290135"></script>
</body>
</html>
