</div>


<script>
    // ——— Filtro tabla ———
    const campoFiltro = document.getElementById('campoFiltro');
    const valorFiltro = document.getElementById('valorFiltro');
    const colMap = { '0': 0, '1': 1, '2': 2, '3': 3, '4': 4 };

    if (campoFiltro && valorFiltro) {
        [campoFiltro, valorFiltro].forEach(el =>
            el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', filtrarTabla)
        );
        function filtrarTabla() {
            const col = colMap[campoFiltro.value] ?? 0;
            const term = valorFiltro.value.toLowerCase();
            let vis = 0;
            document.querySelectorAll('#tbodyClientes tr').forEach(row => {
                const cell = row.querySelectorAll('td')[col];
                const show = cell && cell.textContent.toLowerCase().includes(term);
                row.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            const vc = document.getElementById('visibleCount');
            if (vc) vc.textContent = vis;
        }
    }

    // ——— Modales ———
    function cerrarModal(id) {
        document.getElementById(id).classList.add('hidden');
        document.body.style.overflow = '';
    }

    function abrirModal(id) {
        document.getElementById(id).classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    // Modal Crear
    function abrirModalCrear() { abrirModal('modalCrear'); }
    function cerrarModalCrear(e) { if (e.target === document.getElementById('modalCrear')) cerrarModal('modalCrear'); }

    // Modal Editar
    function abrirModalEditar(btn) {
        const d = btn.dataset;
        document.getElementById('formEditar').action = `/clientes/editar/${d.id}`;
        document.getElementById('e_documento').value    = d.documento    || '';
        document.getElementById('e_razonsocial').value  = d.razonsocial  || '';
        document.getElementById('e_direccion').value    = d.direccion    || '';
        document.getElementById('e_telefono').value     = d.telefono     || '';
        document.getElementById('e_celular').value      = d.celular      || '';
        document.getElementById('e_email').value        = d.email        || '';
        document.getElementById('e_contacto').value     = d.contacto     || '';
        abrirModal('modalEditar');
    }
    function cerrarModalEditar(e) { if (e.target === document.getElementById('modalEditar')) cerrarModal('modalEditar'); }

    // Cerrar con Escape
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            cerrarModal('modalCrear');
            cerrarModal('modalEditar');
        }
    });
</script>
