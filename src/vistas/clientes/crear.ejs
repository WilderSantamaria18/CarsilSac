<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Cliente - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290134">
    <link rel="stylesheet" href="/publico/css/form-views.css?v=1772427290134">
    
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar (sin cambios) -->
        <%- include("../parciales/sidebar") %>
        
        <!-- Botón para ocultar/mostrar barra -->
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom navbar-top">
                <div class="container-fluid">
                    <span class="navbar-brand ms-3 fw-semibold">Crear Nuevo Cliente</span>
                    <div class="user-profile ms-auto">
                        <span class="fw-medium">Administrador</span>
                        <div class="user-avatar">A</div>
                    </div>
                </div>
            </nav>
            
            <div class="container py-4">
                <div class="form-container">
                    <div class="form-card">
                        <div class="form-header-title" style="padding: 2rem 2rem 0; border-bottom: 1px solid var(--border-light); margin-bottom: 1.5rem;"><i class="bi bi-person-plus"></i> Registrar Nuevo Cliente</div>
                        
                        <div class="form-body">
                            <form action="/clientes/crear" method="POST" autocomplete="off">
                                <!-- Sección de Información Básica -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-info-circle"></i> Información Básica
                                    </h5>
                                    
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <div class="form-group-header">
                                                <label for="documento" class="form-label">Documento de Identidad</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <input type="text" class="form-control-modern" id="documento" name="Documento" required placeholder="Ingrese RUC o DNI">
                                                    <i class="input-icon bi bi-credit-card-2-front"></i>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <div class="form-group-header">
                                                <label for="razonSocial" class="form-label">Razón Social / Nombre</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <input type="text" class="form-control-modern" id="razonSocial" name="RazonSocial" required placeholder="Nombre completo o razón social">
                                                    <i class="input-icon bi bi-building"></i>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-12">
                                            <div class="form-group">
                                                <div class="form-group-header">
                                                <label for="direccion" class="form-label">Dirección Fiscal</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <input type="text" class="form-control-modern" id="direccion" name="Direccion" placeholder="Dirección completa">
                                                    <i class="input-icon bi bi-geo-alt"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Sección de Contacto -->
                                <div class="form-section">
                                    <h5 class="section-title">
                                        <i class="bi bi-telephone"></i> Información de Contacto
                                    </h5>
                                    
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <div class="form-group-header">
                                                <label for="telefono" class="form-label">Teléfono Principal</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <input type="text" class="form-control-modern" id="telefono" name="Telefono" required placeholder="Número de teléfono">
                                                    <i class="input-icon bi bi-telephone-outbound"></i>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="celular" class="form-label">
                                                    Celular Secundario 
                                                    <span class="optional-badge">Opcional</span>
                                                </label>
                                                <div class="input-wrapper has-icon">
                                                    <input type="text" class="form-control-modern" id="celular" name="Celular" placeholder="Número de celular alternativo">
                                                    <i class="input-icon bi bi-phone"></i>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <div class="form-group-header">
                                                <label for="email" class="form-label">Correo Electrónico</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <input type="email" class="form-control-modern" id="email" name="Email" placeholder="correo@empresa.com">
                                                    <i class="input-icon bi bi-envelope-at"></i>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <div class="form-group-header">
                                                <label for="contacto" class="form-label">Persona de Contacto</label>
                                            </div>
                                            <div class="input-wrapper has-icon">
                                                    <input type="text" class="form-control-modern" id="contacto" name="Contacto" placeholder="Nombre del contacto principal">
                                                    <i class="input-icon bi bi-person-lines-fill"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Sección de acciones -->
                                <div class="form-buttons">
                                    <a href="/clientes" class="btn btn-form btn-form-cancel btn-lg">
                                        <i class="bi bi-x-circle me-2"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-form-primary btn-lg">
                                        <i class="bi bi-save me-2"></i> Guardar Cliente
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        const menuItems = document.querySelectorAll('.menu-item');
        const userAvatar = document.querySelector('.user-avatar');
        const userName = 'Administrador';
        if(userAvatar) userAvatar.textContent = userName.charAt(0);

        if(toggleBtn) toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });
        
        // Marcar como activo el ítem de Clientes
        menuItems.forEach(item => {
            if(item.getAttribute('href') === '/clientes') {
                item.classList.add('active');
            } else {
                item.classList.remove('active');
            }
        });
        
        // Efecto de hover para los campos del formulario
        const formGroups = document.querySelectorAll('.form-group');
        formGroups.forEach(group => {
            const input = group.querySelector('input, select, textarea');
            if(input) {
                group.addEventListener('mouseenter', () => {
                    input.focus({preventScroll: true});
                });
            }
        });
    });
    </script>
    <script src="/publico/js/layout.js?v=1772427290134"></script>
</body>
</html>
