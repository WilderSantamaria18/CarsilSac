<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingreso | CARSIL Equipos y Servicios</title>
    <meta name="description" content="Accede al sistema de gestión empresarial CARSIL con IA integrada.">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary: #3B49DF;
            --primary-dark: #2d38b0;
            --primary-light: #eef0fd;
            --accent: #7C3AED;
            --accent2: #06b6d4;
            --navy: #0f172a;
            --panel-bg: #1e2a4a;
            --panel-bg2: #162040;
            --white: #ffffff;
            --gray-100: #f8fafc;
            --gray-200: #e2e8f0;
            --gray-400: #94a3b8;
            --gray-600: #475569;
            --gray-800: #1e293b;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: var(--gray-200);
            background-image:
                radial-gradient(ellipse at 0% 0%, rgba(59, 73, 223, 0.12) 0px, transparent 50%),
                radial-gradient(ellipse at 100% 0%, rgba(139, 92, 246, 0.10) 0px, transparent 50%),
                radial-gradient(ellipse at 100% 100%, rgba(16, 185, 129, 0.08) 0px, transparent 50%),
                radial-gradient(ellipse at 0% 100%, rgba(245, 158, 11, 0.08) 0px, transparent 50%);
            background-attachment: fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* ===================== MAIN CARD ===================== */
        .login-card {
            width: min(960px, 98vw);
            min-height: 600px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(15, 23, 42, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.08);
            background: var(--white);
        }

        /* ===================== LEFT PANEL ===================== */
        .left-panel {
            padding: 3rem 3rem 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            background: var(--white);
            position: relative;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 2.5rem;
        }

        .brand-logo {
            height: 44px;
            width: auto;
            object-fit: contain;
        }

        .brand-name {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--navy);
            letter-spacing: -0.3px;
        }

        .form-area h1 {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--gray-800);
            margin-bottom: 0.4rem;
            letter-spacing: -0.5px;
        }

        .form-area .subtitle {
            font-size: 0.9rem;
            color: var(--gray-400);
            margin-bottom: 2rem;
        }

        .field-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--gray-600);
            margin-bottom: 0.45rem;
            display: block;
        }

        .field-group {
            margin-bottom: 1.25rem;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-400);
            font-size: 0.9rem;
            pointer-events: none;
        }

        .form-input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.75rem;
            border: 1.5px solid var(--gray-200);
            border-radius: 10px;
            font-size: 0.92rem;
            font-family: 'Inter', sans-serif;
            color: var(--gray-800);
            background: var(--white);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .form-input::placeholder {
            color: #cbd5e1;
        }

        .form-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 73, 223, 0.12);
        }

        .eye-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--gray-400);
            font-size: 0.9rem;
            padding: 4px;
            transition: color 0.2s;
        }

        .eye-toggle:hover {
            color: var(--primary);
        }

        .row-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
            margin-top: -0.25rem;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.82rem;
            color: var(--gray-600);
            cursor: pointer;
            user-select: none;
        }

        .remember-me input[type="checkbox"] {
            accent-color: var(--primary);
            width: 14px;
            height: 14px;
            cursor: pointer;
        }

        .forgot-link {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--primary);
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-link:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        .btn-login {
            width: 100%;
            padding: 0.85rem;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border: none;
            border-radius: 10px;
            color: var(--white);
            font-size: 0.95rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            letter-spacing: 0.3px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
            pointer-events: none;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(59, 73, 223, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login i {
            margin-right: 0.5rem;
        }

        .footer-left {
            text-align: center;
            font-size: 0.78rem;
            color: var(--gray-400);
            margin-top: 1.5rem;
        }

        /* Alert */
        .alert-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.85rem;
            color: #b91c1c;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* ===================== RIGHT PANEL ===================== */
        .right-panel {
            background: linear-gradient(150deg, var(--panel-bg) 0%, var(--panel-bg2) 100%);
            padding: 2.5rem 2.25rem 2rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        /* decorative blobs */
        .right-panel::before {
            content: '';
            position: absolute;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.35) 0%, transparent 70%);
            top: -80px;
            right: -80px;
            border-radius: 50%;
            pointer-events: none;
        }

        .right-panel::after {
            content: '';
            position: absolute;
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(6, 182, 212, 0.2) 0%, transparent 70%);
            bottom: 60px;
            left: -60px;
            border-radius: 50%;
            pointer-events: none;
        }

        .right-panel-text h2 {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--white);
            line-height: 1.3;
            margin-bottom: 0.6rem;
            letter-spacing: -0.4px;
        }

        .right-panel-text p {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.55);
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }

        /* ===== MINI DASHBOARD ===== */
        .dash-container {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            padding: 1rem;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            backdrop-filter: blur(4px);
            position: relative;
            z-index: 1;
        }

        /* KPI row */
        .kpi-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.5rem;
        }

        .kpi-card {
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 0.65rem 0.7rem;
        }

        .kpi-label {
            font-size: 0.62rem;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.2rem;
        }

        .kpi-value {
            font-size: 1rem;
            font-weight: 800;
            color: var(--white);
            line-height: 1;
            margin-bottom: 0.2rem;
        }

        .kpi-badge {
            font-size: 0.6rem;
            font-weight: 600;
            padding: 1px 5px;
            border-radius: 20px;
            display: inline-block;
        }

        .kpi-badge.up {
            background: rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
        }

        .kpi-badge.down {
            background: rgba(239, 68, 68, 0.2);
            color: #fca5a5;
        }

        /* Chart row */
        .chart-row {
            display: grid;
            grid-template-columns: 1fr 85px;
            gap: 0.5rem;
        }

        .chart-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 0.65rem 0.75rem;
        }

        .chart-title {
            font-size: 0.62rem;
            color: rgba(255, 255, 255, 0.45);
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 0.5rem;
        }

        /* SVG line chart */
        .line-chart-svg {
            width: 100%;
            height: 70px;
            display: block;
        }

        /* Donut */
        .donut-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }

        .donut-svg {
            width: 60px;
            height: 60px;
        }

        .donut-legend {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .dl-item {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 0.55rem;
            color: rgba(255, 255, 255, 0.5);
        }

        .dl-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* Table */
        .mini-table {
            width: 100%;
            border-collapse: collapse;
        }

        .mini-table thead th {
            font-size: 0.58rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: rgba(255, 255, 255, 0.35);
            padding: 0.2rem 0.4rem;
            text-align: left;
        }

        .mini-table tbody tr {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .mini-table tbody td {
            padding: 0.28rem 0.4rem;
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.72);
        }

        .status-badge {
            font-size: 0.55rem;
            padding: 2px 7px;
            border-radius: 20px;
            font-weight: 600;
        }

        .status-badge.active {
            background: rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
        }

        .status-badge.pending {
            background: rgba(245, 158, 11, 0.2);
            color: #fcd34d;
        }

        .status-badge.closed {
            background: rgba(148, 163, 184, 0.15);
            color: #94a3b8;
        }

        /* AI badge */
        .ai-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.3), rgba(59, 73, 223, 0.3));
            border: 1px solid rgba(124, 58, 237, 0.4);
            border-radius: 20px;
            padding: 0.3rem 0.75rem;
            font-size: 0.7rem;
            font-weight: 600;
            color: #c4b5fd;
            margin-bottom: 0.75rem;
            width: fit-content;
        }

        .ai-badge i {
            font-size: 0.75rem;
        }

        /* ===================== RESPONSIVE ===================== */
        @media (max-width: 730px) {
            body {
                overflow-y: auto;
                align-items: flex-start;
            }

            .login-card {
                grid-template-columns: 1fr;
                border-radius: 0;
                min-height: 100vh;
                width: 100%;
            }

            .right-panel {
                display: none;
            }

            .left-panel {
                padding: 2.5rem 1.75rem;
                min-height: 100vh;
            }
        }

        @media (max-width: 900px) and (min-width: 731px) {
            .login-card {
                grid-template-columns: 1.1fr 0.9fr;
            }

            .left-panel {
                padding: 2.5rem 2rem;
            }

            .right-panel {
                padding: 2rem 1.5rem;
            }

            .right-panel-text h2 {
                font-size: 1.2rem;
            }
        }

        /* ===================== ANIMATION ===================== */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .left-panel {
            animation: fadeUp 0.55s ease both;
        }

        .right-panel {
            animation: fadeUp 0.65s ease both 0.1s;
        }

        .dash-container {
            animation: fadeUp 0.7s ease both 0.25s;
        }

        /* floating dot animation on right panel */
        @keyframes floatDot {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-8px);
            }
        }

        .float-dot {
            position: absolute;
            border-radius: 50%;
            opacity: 0.18;
            pointer-events: none;
        }

        .fd1 {
            width: 10px;
            height: 10px;
            background: #a78bfa;
            top: 20%;
            left: 15%;
            animation: floatDot 3.5s ease-in-out infinite;
        }

        .fd2 {
            width: 6px;
            height: 6px;
            background: #67e8f9;
            top: 60%;
            right: 12%;
            animation: floatDot 4s ease-in-out infinite 0.8s;
        }

        .fd3 {
            width: 14px;
            height: 14px;
            background: var(--primary);
            bottom: 20%;
            left: 30%;
            animation: floatDot 5s ease-in-out infinite 1.5s;
        }

        /* line pulse on chart */
        @keyframes dashPulse {
            from {
                stroke-dashoffset: 300;
            }

            to {
                stroke-dashoffset: 0;
            }
        }

        .chart-line-path {
            stroke-dasharray: 300;
            animation: dashPulse 2s ease forwards 0.9s;
        }
    </style>
</head>

<body>

    <div class="login-card">

        <!-- ==================== LEFT PANEL ==================== -->
        <div class="left-panel">
            <!-- Brand -->
            <div>
                <div class="brand">
                    <img src="/img/Carsil.png" alt="Logo CARSIL" class="brand-logo" id="brand-logo">
                </div>

                <!-- Form section -->
                <div class="form-area">
                    <h1>Bienvenido de vuelta</h1>
                    <p class="subtitle">Ingresa tus credenciales para acceder al sistema.</p>

                    <!-- Alert de error -->
                    <% if (error) { %>
                        <div class="alert-error" role="alert">
                            <i class="fas fa-exclamation-circle"></i>
                            <%= error %>
                        </div>
                        <% } %>

                            <form method="POST" action="/login" autocomplete="off">
                                <!-- Email -->
                                <div class="field-group">
                                    <label class="field-label" for="correo">Correo electrónico</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-envelope field-icon"></i>
                                        <input type="email" class="form-input" id="correo" name="correo" required
                                            autofocus placeholder="usuario@carsil.com">
                                    </div>
                                </div>

                                <!-- Password -->
                                <div class="field-group">
                                    <label class="field-label" for="clave">Contraseña</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-lock field-icon"></i>
                                        <input type="password" class="form-input" id="clave" name="clave" required
                                            placeholder="••••••••" style="padding-right: 2.75rem;">
                                        <button type="button" class="eye-toggle" id="togglePassword"
                                            title="Mostrar/ocultar contraseña">
                                            <i class="far fa-eye" id="eyeIcon"></i>
                                        </button>
                                    </div>
                                </div>

                                <!-- Remember me / Forgot -->
                                <div class="row-options">
                                    <label class="remember-me">
                                        <input type="checkbox" id="rememberMe" name="rememberMe">
                                        Recuérdame
                                    </label>
                                    <a href="/recuperar" class="forgot-link">¿Olvidaste tu contraseña?</a>
                                </div>

                                <!-- Login button -->
                                <button type="submit" class="btn-login" id="btn-login">
                                    <i class="fas fa-sign-in-alt"></i> Ingresar al sistema
                                </button>
                            </form>
                </div>
            </div>

            <!-- Footer -->
            <div class="footer-left">
                &copy; <%= new Date().getFullYear() %> CARSIL Equipos y Servicios. Todos los derechos reservados.
            </div>
        </div>

        <!-- ==================== RIGHT PANEL ==================== -->
        <div class="right-panel">
            <!-- Floating decorative dots -->
            <div class="float-dot fd1"></div>
            <div class="float-dot fd2"></div>
            <div class="float-dot fd3"></div>

            <!-- Text header -->
            <div class="right-panel-text">
                <div class="ai-badge">
                    <i class="fas fa-robot"></i> Potenciado con Inteligencia Artificial
                </div>
                <h2>Gestiona tu empresa de forma inteligente.</h2>
                <p>Accede al dashboard para administrar clientes, ventas, proyectos y más — con análisis en tiempo real
                    impulsado por IA.</p>
            </div>

            <!-- Mini Dashboard Preview -->
            <div class="dash-container">

                <!-- KPI Row -->
                <div class="kpi-row">
                    <div class="kpi-card">
                        <div class="kpi-label">Clientes</div>
                        <div class="kpi-value">1,284</div>
                        <span class="kpi-badge up">▲ 12%</span>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Ventas</div>
                        <div class="kpi-value">$48.2K</div>
                        <span class="kpi-badge up">▲ 8%</span>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Proyectos</div>
                        <div class="kpi-value">38</div>
                        <span class="kpi-badge down">▼ 2</span>
                    </div>
                </div>

                <!-- Chart row: Line + Donut -->
                <div class="chart-row">
                    <!-- Line chart -->
                    <div class="chart-card">
                        <div class="chart-title">Ingresos mensuales</div>
                        <svg class="line-chart-svg" viewBox="0 0 200 70" preserveAspectRatio="none">
                            <defs>
                                <linearGradient id="lineGrad" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#7C3AED" stop-opacity="0.4" />
                                    <stop offset="100%" stop-color="#3B49DF" stop-opacity="0.02" />
                                </linearGradient>
                            </defs>
                            <!-- Area fill -->
                            <path d="M0,55 C20,45 35,30 60,28 S90,40 110,22 S145,12 170,18 L200,14 L200,70 L0,70 Z"
                                fill="url(#lineGrad)" />
                            <!-- Line -->
                            <path class="chart-line-path"
                                d="M0,55 C20,45 35,30 60,28 S90,40 110,22 S145,12 170,18 L200,14" fill="none"
                                stroke="#a78bfa" stroke-width="2" stroke-linecap="round" />
                            <!-- Dots -->
                            <circle cx="60" cy="28" r="2.5" fill="#7C3AED" />
                            <circle cx="110" cy="22" r="2.5" fill="#7C3AED" />
                            <circle cx="170" cy="18" r="2.5" fill="#a78bfa" />
                            <circle cx="200" cy="14" r="3" fill="#fff" stroke="#7C3AED" stroke-width="1.5" />
                        </svg>
                    </div>
                    <!-- Donut -->
                    <div class="chart-card donut-wrap">
                        <div class="chart-title" style="text-align:center;">Categorías</div>
                        <svg class="donut-svg" viewBox="0 0 60 60">
                            <!-- bg ring -->
                            <circle cx="30" cy="30" r="22" fill="none" stroke="rgba(255,255,255,0.06)"
                                stroke-width="8" />
                            <!-- Ventas: stroke-dasharray = fraction of circumference (138.2) -->
                            <circle cx="30" cy="30" r="22" fill="none" stroke="#7C3AED" stroke-width="8"
                                stroke-dasharray="62 76" stroke-dashoffset="0" stroke-linecap="round"
                                transform="rotate(-90 30 30)" />
                            <circle cx="30" cy="30" r="22" fill="none" stroke="#06b6d4" stroke-width="8"
                                stroke-dasharray="41 97" stroke-dashoffset="-62" stroke-linecap="round"
                                transform="rotate(-90 30 30)" />
                            <circle cx="30" cy="30" r="22" fill="none" stroke="#10b981" stroke-width="8"
                                stroke-dasharray="35 103" stroke-dashoffset="-103" stroke-linecap="round"
                                transform="rotate(-90 30 30)" />
                            <text x="30" y="34" text-anchor="middle" fill="white" font-size="8" font-weight="700"
                                font-family="Inter,sans-serif">Ventas</text>
                        </svg>
                        <div class="donut-legend">
                            <div class="dl-item">
                                <div class="dl-dot" style="background:#7C3AED"></div>Equipos
                            </div>
                            <div class="dl-item">
                                <div class="dl-dot" style="background:#06b6d4"></div>Servicios
                            </div>
                            <div class="dl-item">
                                <div class="dl-dot" style="background:#10b981"></div>Proyectos
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Mini Table -->
                <div class="chart-card" style="padding: 0.55rem 0.75rem;">
                    <div class="chart-title" style="margin-bottom:0.4rem;">Últimos contratos</div>
                    <table class="mini-table">
                        <thead>
