<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportes - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ========== REPORT DASHBOARD ========== */
        .report-page {
            padding: 28px 32px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ---- Page Header ---- */
        .report-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 28px;
        }

        .report-header-left h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 4px 0;
        }

        .report-header-left p {
            font-size: 0.8125rem;
            color: var(--text-secondary);
            margin: 0;
        }

        .report-header-actions {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .report-header-actions .period-select {
            padding: 7px 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.8125rem;
            font-family: 'Inter', sans-serif;
            color: var(--text-primary);
            background: var(--bg-card);
            cursor: pointer;
        }

        .report-header-actions .period-select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .btn-export-rp {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 0.8125rem;
            font-weight: 500;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-primary);
            cursor: pointer;
            transition: all 0.15s ease;
        }

        .btn-export-rp:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }

        .btn-export-rp.primary {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

        .btn-export-rp.primary:hover {
            background: var(--primary-dark);
        }

        /* ---- Big KPI Cards Row ---- */
        .kpi-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .kpi-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 22px 24px;
            transition: box-shadow 0.2s ease;
        }

        .kpi-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        }

        .kpi-card.featured {
            position: relative;
            overflow: hidden;
        }

        .kpi-card .kpi-label {
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 8px;
        }

        .kpi-card .kpi-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.1;
            margin-bottom: 4px;
        }

        .kpi-card .kpi-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .kpi-card .kpi-sub .trend-up {
            color: var(--success);
            font-weight: 600;
        }

        .kpi-card .kpi-sub .trend-down {
            color: #EF4444;
            font-weight: 600;
        }

        /* Mini chart inside featured KPI */
        .kpi-mini-chart {
            height: 80px;
            margin-top: 12px;
        }

        /* ---- Charts Grid ---- */
        .charts-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .rp-chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            transition: box-shadow 0.2s ease;
        }

        .rp-chart-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        }

        .rp-chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .rp-chart-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .rp-chart-subtitle {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        .rp-chart-container {
            position: relative;
            height: 280px;
        }

        /* ---- Stats breakdown ---- */
        .stats-breakdown {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .breakdown-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
        }

        .breakdown-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        }

        .breakdown-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .breakdown-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 12px;
        }

        .breakdown-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .breakdown-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border-light);
            font-size: 0.8125rem;
        }

        .breakdown-list li:last-child {
            border-bottom: none;
        }

        .breakdown-list .bl-label {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
        }

        .breakdown-list .bl-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .breakdown-list .bl-value {
            font-weight: 600;
            color: var(--text-primary);
        }

        .breakdown-list .bl-pct {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-left: 6px;
        }

        /* Doughnut center */
        .doughnut-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .doughnut-center {
            position: absolute;
            text-align: center;
        }

        .doughnut-center .dc-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
        }

        .doughnut-center .dc-label {
            font-size: 0.6875rem;
            color: var(--text-muted);
        }

        /* ---- Recent Transactions Table ---- */
        .rp-table-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px 12px;
            margin-bottom: 24px;
        }

        .rp-table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .rp-table-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .rp-table {
            width: 100%;
            border-collapse: collapse;
        }

        .rp-table thead th {
            font-size: 0.6875rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            padding: 8px 12px;
            border-bottom: 1px solid var(--border);
        }

        .rp-table tbody td {
            font-size: 0.8125rem;
            color: var(--text-primary);
            padding: 12px;
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
        }

        .rp-table tbody tr:last-child td {
            border-bottom: none;
        }

        .rp-table tbody tr:hover {
            background: var(--primary-light);
        }

        .rp-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.6875rem;
            font-weight: 600;
        }

        .rp-badge.green {
            background: #ECFDF5;
            color: #059669;
        }

        .rp-badge.amber {
            background: #FFFBEB;
            color: #D97706;
        }

        .rp-badge.red {
            background: #FEF2F2;
            color: #DC2626;
        }

        .rp-badge.blue {
            background: var(--primary-light);
            color: var(--primary);
        }

        .rp-amount {
            font-weight: 600;
        }

        /* ---- Responsive ---- */
        @media (max-width: 1024px) {
            .kpi-row {
                grid-template-columns: 1fr 1fr;
            }

            .charts-grid {
                grid-template-columns: 1fr;
            }

            .stats-breakdown {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .report-page {
                padding: 16px;
            }

            .kpi-row {
                grid-template-columns: 1fr;
            }

            .report-header {
                flex-direction: column;
                gap: 12px;
            }

            .rp-chart-container {
                height: 220px;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <div class="report-page" id="reportContent">
                    <!-- Page Header -->
                    <div class="report-header">
                        <div class="report-header-left">
                            <h1>Reportes Analiticos</h1>
                            <p>Metricas de negocio: Proformas, Facturas y Clientes</p>
                        </div>
                        <div class="report-header-actions">
                            <select class="period-select" id="periodoFiltro">
                                <option value="mes">Este Mes</option>
                                <option value="trimestre">Ultimo Trimestre</option>
                                <option value="semestre">Ultimo Semestre</option>
                                <option value="anio">Este Ano</option>
                                <option value="todo" selected>Todo</option>
                            </select>
                            <button class="btn-export-rp" onclick="window.print()">
                                <i class="bi bi-printer"></i> Imprimir
                            </button>
                            <button class="btn-export-rp primary" onclick="actualizarDatos()">
                                <i class="bi bi-arrow-repeat"></i> Actualizar
                            </button>
                        </div>
                    </div>

                    <!-- KPI Cards -->
                    <div class="kpi-row">
                        <!-- Big KPI: Total Ingresos -->
                        <div class="kpi-card featured">
                            <div class="kpi-label">Ingresos totales en proformas</div>
                            <div class="kpi-value" id="kpiTotalIngresos">S/ 0</div>
                            <div class="kpi-sub">
                                <span class="trend-up" id="kpiIngresosTrend"></span>
                                Total acumulado
                            </div>
                            <div class="kpi-mini-chart">
                                <canvas id="miniChartIngresos"></canvas>
                            </div>
                        </div>
                        <!-- Total Proformas -->
                        <div class="kpi-card">
                            <div class="kpi-label">Total Proformas</div>
                            <div class="kpi-value" id="kpiTotalProformas">0</div>
                            <div class="kpi-sub">
                                <span id="kpiProformasPendientes">0</span> pendientes
                            </div>
                        </div>
                        <!-- Total Facturas -->
                        <div class="kpi-card">
                            <div class="kpi-label">Total Facturas</div>
                            <div class="kpi-value" id="kpiTotalFacturas">0</div>
                            <div class="kpi-sub">
                                <span id="kpiFacturasMsg">Generadas del sistema</span>
                            </div>
                        </div>
                        <!-- Tasa Conversion -->
                        <div class="kpi-card">
                            <div class="kpi-label">Tasa de Conversion</div>
                            <div class="kpi-value" id="kpiTasaConversion">0%</div>
                            <div class="kpi-sub">
                                Proformas convertidas a ventas
                            </div>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="charts-grid">
                        <!-- Proformas por Mes (Bar + Line) -->
                        <div class="rp-chart-card">
                            <div class="rp-chart-header">
                                <div>
                                    <div class="rp-chart-title">Actividad Mensual</div>
                                    <div class="rp-chart-subtitle">Proformas y facturas por mes (ultimos 12 meses)</div>
                                </div>
                            </div>
                            <div class="rp-chart-container">
                                <canvas id="chartMensual"></canvas>
                            </div>
                        </div>
                        <!-- Proformas por Estado (Doughnut) -->
                        <div class="rp-chart-card">
                            <div class="rp-chart-header">
                                <div>
                                    <div class="rp-chart-title">Estados de Proformas</div>
                                    <div class="rp-chart-subtitle">Distribucion porcentual</div>
                                </div>
                            </div>
                            <div class="rp-chart-container doughnut-wrapper">
                                <canvas id="chartEstados"></canvas>
                                <div class="doughnut-center">
                                    <div class="dc-value" id="doughnutTotal">0</div>
                                    <div class="dc-label">Total</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Stats Breakdown Row -->
                    <div class="stats-breakdown">
                        <!-- Cost Analysis / Top Clientes -->
                        <div class="breakdown-card">
                            <div class="breakdown-title">Top Clientes por Proformas</div>
                            <div class="breakdown-value" id="topClientesTotal">S/ 0</div>
                            <ul class="breakdown-list" id="topClientesList">
                                <li><span class="bl-label">Cargando...</span></li>
                            </ul>
                        </div>
                        <!-- Financial Health / Resumen Facturas -->
                        <div class="breakdown-card">
                            <div class="breakdown-title">Resumen de Facturas</div>
                            <div class="breakdown-value" id="resumenFacturasTotal">S/ 0</div>
                            <div style="height: 180px;">
                                <canvas id="chartFacturas"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Transactions Table -->
                    <div class="rp-table-card">
                        <div class="rp-table-header">
                            <span class="rp-table-title">Ultimas Proformas</span>
                            <button class="btn-export-rp" onclick="window.location.href='/proformas'">
                                <i class="bi bi-arrow-right"></i> Ver todas
                            </button>
                        </div>
                        <table class="rp-table">
                            <thead>
                                <tr>
                                    <th>Codigo</th>
                                    <th>Cliente</th>
                                    <th>Fecha</th>
                                    <th>Estado</th>
                                    <th style="text-align:right">Total</th>
                                </tr>
                            </thead>
                            <tbody id="recentProformasTable">
                                <tr>
                                    <td colspan="5" style="text-align:center; color: var(--text-muted); padding: 24px;">
                                        Cargando datos...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
    </div>

    <script src="/publico/js/layout.js"></script>
    <script>
        const PRIMARY = '#3B49DF';
        const PRIMARY_LIGHT = '#eef0fd';
        const COLORS = {
            pendiente: '#F59E0B',
            aprobada: '#3B49DF',
            vendida: '#10B981',
            vencida: '#EF4444',
            anulada: '#9CA3AF',
            facturas: '#8B5CF6'
        };

        // On load
        document.addEventListener('DOMContentLoaded', function () {
            actualizarDatos();
        });

        async function actualizarDatos() {
            await Promise.all([
                cargarKPIs(),
                cargarProformasMes(),
                cargarEstados(),
                cargarTopClientes(),
                cargarFacturas(),
                cargarRecentProformas()
            ]);
        }

        // ===== KPIs =====
        async function cargarKPIs() {
            try {
                const res = await fetch('/reportes/api/kpis');
                const json = await res.json();
                if (!json.success) return;
                const d = json.data;

                document.getElementById('kpiTotalProformas').textContent = d.totalProformas || 0;
                document.getElementById('kpiProformasPendientes').textContent = d.proformasPendientes || 0;
                document.getElementById('kpiTasaConversion').textContent = (d.tasaConversion || 0) + '%';

                // Facturas
                const totalFacturas = d.totalVentas || 0;
                document.getElementById('kpiTotalFacturas').textContent = totalFacturas;
                document.getElementById('kpiFacturasMsg').textContent =
                    (d.ventasCompletadas || 0) + ' completadas, ' + (d.ventasPendientes || 0) + ' pendientes';

                // Total ingresos from proformas
                const ingresos = d.totalVentasCompletadas || 0;
                document.getElementById('kpiTotalIngresos').textContent = 'S/ ' + Number(ingresos).toLocaleString('es-PE', { minimumFractionDigits: 2 });

                if (d.ventasMes > 0) {
                    document.getElementById('kpiIngresosTrend').innerHTML =
                        '<i class="bi bi-arrow-up-short"></i> S/ ' + Number(d.ventasMes).toLocaleString('es-PE', { minimumFractionDigits: 2 }) + ' este mes';
                }

            } catch (err) {
                console.error('Error KPIs:', err);
            }
        }

        // ===== Proformas por Mes =====
        let chartMensualInstance = null;
        async function cargarProformasMes() {
            try {
                const res = await fetch('/reportes/api/proformas-por-mes');
                const json = await res.json();
                if (!json.success) return;

                const labels = json.data.map(d => {
                    const [y, m] = d.mes.split('-');
                    return new Date(y, m - 1).toLocaleDateString('es-PE', { month: 'short' });
                });
                const cantidades = json.data.map(d => d.cantidad);
                const montos = json.data.map(d => parseFloat(d.total_ventas) || 0);

                // Mini chart
                const miniCtx = document.getElementById('miniChartIngresos').getContext('2d');
                new Chart(miniCtx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: montos,
                            borderColor: PRIMARY,
                            backgroundColor: PRIMARY_LIGHT,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 0,
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { enabled: false } },
                        scales: { x: { display: false }, y: { display: false } }
                    }
                });

                // Main monthly chart
                const ctx = document.getElementById('chartMensual').getContext('2d');
                if (chartMensualInstance) chartMensualInstance.destroy();
                chartMensualInstance = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Proformas',
                                data: cantidades,
                                backgroundColor: PRIMARY,
                                borderRadius: 6,
                                barPercentage: 0.5,
                                categoryPercentage: 0.7,
                                order: 2
                            },
                            {
                                label: 'Ingresos (S/)',
                                data: montos,
                                type: 'line',
                                borderColor: '#10B981',
                                backgroundColor: 'rgba(16,185,129,0.08)',
                                fill: true,
                                tension: 0.4,
                                pointRadius: 3,
                                pointBackgroundColor: '#10B981',
                                borderWidth: 2,
                                yAxisID: 'y1',
                                order: 1
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: {
                                position: 'top',
                                align: 'end',
                                labels: { font: { family: 'Inter', size: 11 }, boxWidth: 8, boxHeight: 8, usePointStyle: true }
                            },
                            tooltip: {
                                backgroundColor: '#1A1A2E',
                                titleFont: { family: 'Inter', size: 12 },
                                bodyFont: { family: 'Inter', size: 11 },
                                padding: 10,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function (ctx) {
                                        if (ctx.dataset.yAxisID === 'y1') {
                                            return 'Ingresos: S/ ' + Number(ctx.raw).toLocaleString('es-PE', { minimumFractionDigits: 2 });
                                        }
                                        return ctx.raw + ' proformas';
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                ticks: { font: { family: 'Inter', size: 11 }, color: '#6B7280' },
                                grid: { display: false },
                                border: { display: false }
                            },
                            y: {
                                beginAtZero: true,
                                position: 'left',
                                ticks: { font: { family: 'Inter', size: 11 }, color: '#9CA3AF', stepSize: 1 },
                                grid: { color: '#F0F0F0', drawBorder: false },
                                border: { display: false }
                            },
                            y1: {
                                beginAtZero: true,
                                position: 'right',
                                ticks: {
                                    font: { family: 'Inter', size: 11 },
                                    color: '#9CA3AF',
                                    callback: v => 'S/' + (v / 1000).toFixed(0) + 'k'
                                },
                                grid: { display: false },
                                border: { display: false }
                            }
                        }
                    }
                });
            } catch (err) { console.error('Error chartMensual:', err); }
        }

        // ===== Estados Doughnut =====
        async function cargarEstados() {
            try {
                const res = await fetch('/reportes/api/proformas-por-estado');
                const json = await res.json();
                if (!json.success) return;

                const total = json.data.reduce((s, d) => s + d.cantidad, 0);
                document.getElementById('doughnutTotal').textContent = total;

                const colorMap = { PENDIENTE: COLORS.pendiente, APROBADA: COLORS.aprobada, VENDIDA: COLORS.vendida, VENCIDA: COLORS.vencida, ANULADA: COLORS.anulada };
                const labels = json.data.map(d => d.Estado);
                const data = json.data.map(d => d.cantidad);
                const colors = json.data.map(d => colorMap[d.Estado] || '#9CA3AF');

                const ctx = document.getElementById('chartEstados').getContext('2d');
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: data,
                            backgroundColor: colors,
                            borderWidth: 0,
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '72%',
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    font: { family: 'Inter', size: 11 },
                                    boxWidth: 10, boxHeight: 10,
                                    usePointStyle: true,
                                    padding: 16,
                                    generateLabels: function (chart) {
                                        const ds = chart.data.datasets[0];
                                        return chart.data.labels.map((l, i) => ({
                                            text: l + ' (' + ds.data[i] + ')',
                                            fillStyle: ds.backgroundColor[i],
                                            strokeStyle: ds.backgroundColor[i],
                                            pointStyle: 'circle',
                                            hidden: false,
                                            index: i
                                        }));
                                    }
                                }
                            },
                            tooltip: {
                                backgroundColor: '#1A1A2E',
                                titleFont: { family: 'Inter', size: 12 },
                                bodyFont: { family: 'Inter', size: 11 },
                                padding: 10,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function (ctx) {
                                        const pct = total > 0 ? ((ctx.raw / total) * 100).toFixed(1) : 0;
                                        return ctx.label + ': ' + ctx.raw + ' (' + pct + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            } catch (err) { console.error('Error chartEstados:', err); }
        }

        // ===== Top Clientes =====
        async function cargarTopClientes() {
            try {
                const res = await fetch('/reportes/api/top-clientes');
                const json = await res.json();
                if (!json.success) return;

                const totalMonto = json.data.reduce((s, d) => s + (parseFloat(d.total_ventas) || 0), 0);
                document.getElementById('topClientesTotal').textContent = 'S/ ' + Number(totalMonto).toLocaleString('es-PE', { minimumFractionDigits: 2 });

                const clientColors = [PRIMARY, '#10B981', '#F59E0B', '#8B5CF6', '#EF4444', '#6B7280', '#EC4899', '#14B8A6'];
                const list = document.getElementById('topClientesList');
                if (json.data.length === 0) {
                    list.innerHTML = '<li><span class="bl-label" style="color:var(--text-muted)">Sin datos de clientes</span></li>';
                    return;
                }
                list.innerHTML = json.data.slice(0, 7).map((c, i) => {
                    const pct = totalMonto > 0 ? ((parseFloat(c.total_ventas) / totalMonto) * 100).toFixed(0) : 0;
                    return `<li>
                        <span class="bl-label">
                            <span class="bl-dot" style="background:${clientColors[i % clientColors.length]}"></span>
                            ${c.RazonSocial}
                        </span>
                        <span>
                            <span class="bl-value">${c.total_proformas}</span>
                            <span class="bl-pct">${pct}%</span>
                        </span>
                    </li>`;
                }).join('');
            } catch (err) { console.error('Error topClientes:', err); }
        }

        // ===== Facturas Bar Chart =====
        async function cargarFacturas() {
            try {
                const res = await fetch('/reportes/api/ventas-por-mes');
                const json = await res.json();
                if (!json.success) return;

                const totalIngresos = json.data.reduce((s, d) => s + (parseFloat(d.total_ventas) || 0), 0);
                document.getElementById('resumenFacturasTotal').textContent = 'S/ ' + Number(totalIngresos).toLocaleString('es-PE', { minimumFractionDigits: 2 });

                const labels = json.data.map(d => {
                    const [y, m] = d.mes.split('-');
                    return new Date(y, m - 1).toLocaleDateString('es-PE', { month: 'short' });
                });

                const ctx = document.getElementById('chartFacturas').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Ventas (S/)',
                            data: json.data.map(d => parseFloat(d.total_ventas) || 0),
                            backgroundColor: COLORS.facturas,
                            borderRadius: 4,
                            barPercentage: 0.5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1A1A2E',
                                callbacks: {
                                    label: ctx => 'S/ ' + Number(ctx.raw).toLocaleString('es-PE', { minimumFractionDigits: 2 })
                                }
                            }
                        },
                        scales: {
                            x: {
                                ticks: { font: { family: 'Inter', size: 10 }, color: '#6B7280' },
                                grid: { display: false },
                                border: { display: false }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    font: { family: 'Inter', size: 10 },
                                    color: '#9CA3AF',
                                    callback: v => 'S/' + (v / 1000).toFixed(0) + 'k'
                                },
                                grid: { color: '#F0F0F0', drawBorder: false },
                                border: { display: false }
                            }
                        }
                    }
                });
            } catch (err) { console.error('Error chartFacturas:', err); }
        }

        // ===== Recent Proformas Table =====
        async function cargarRecentProformas() {
            try {
                const res = await fetch('/reportes/api/proformas-por-mes');
                // We need a separate endpoint for recent proformas; use top-clientes as fallback
                // Actually, let's fetch from proformas-por-estado for now and build from existing data
                const res2 = await fetch('/reportes/api/top-clientes');
                const json2 = await res2.json();

                // Fetch actual recent proformas via the menu's controller data style
                const res3 = await fetch('/reportes/api/proformas-recientes');
                const json3 = await res3.json();

                const tbody = document.getElementById('recentProformasTable');
                if (!json3.success || json3.data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; color: var(--text-muted); padding: 24px;">No hay proformas registradas</td></tr>';
                    return;
                }

                tbody.innerHTML = json3.data.map(p => {
                    let badgeClass = 'amber';
                    if (p.Estado === 'APROBADA' || p.Estado === 'VENDIDA') badgeClass = 'green';
                    else if (p.Estado === 'VENCIDA' || p.Estado === 'ANULADA') badgeClass = 'red';
                    else if (p.Estado === 'PENDIENTE') badgeClass = 'amber';

                    const fecha = p.FechaEmision ? new Date(p.FechaEmision).toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' }) : '-';
                    const total = p.Total ? Number(p.Total).toLocaleString('es-PE', { minimumFractionDigits: 2 }) : '0.00';

                    return `<tr>
                        <td><strong>${p.Codigo || '#' + p.IdProforma}</strong></td>
                        <td>${p.ClienteNombre || '-'}</td>
                        <td>${fecha}</td>
                        <td><span class="rp-badge ${badgeClass}">${p.Estado}</span></td>
                        <td style="text-align:right"><span class="rp-amount">S/ ${total}</span></td>
                    </tr>`;
                }).join('');
            } catch (err) {
                console.error('Error recentProformas:', err);
                document.getElementById('recentProformasTable').innerHTML =
                    '<tr><td colspan="5" style="text-align:center; color: var(--text-muted); padding: 24px;">Error al cargar datos</td></tr>';
            }
        }
    </script>
</body>

</html>