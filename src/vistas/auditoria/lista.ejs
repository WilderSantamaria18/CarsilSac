<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bitacora de Auditoria - CARSIL</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            theme: { extend: {
                colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                fontFamily: { "display": ["Inter", "sans-serif"] },
            }}
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
        .badge-crear       { background:#dcfce7; color:#15803d; }
        .badge-actualizar  { background:#dbeafe; color:#1d4ed8; }
        .badge-eliminar    { background:#fee2e2; color:#dc2626; }
        .badge-login       { background:#f0fdf4; color:#166534; }
        .badge-login_fallido { background:#fef9c3; color:#854d0e; }
        .badge-logout      { background:#f1f5f9; color:#475569; }
        .badge-default     { background:#f3f4f6; color:#374151; }
    </style>
</head>
<body class="bg-[#f6f6f8] text-slate-900 font-display">

    <div class="wrapper">
        <%- include("../parciales/sidebar") %>
        <div class="main-content" id="main-content">
            <div class="p-8">
                <!-- Page Title -->
                <div class="mb-6">
                        <h2 class="text-2xl font-bold text-slate-900 mb-1">Bitácora de Auditoría</h2>
                    <p class="text-slate-500 text-sm">Registro completo de todas las acciones realizadas en el sistema.</p>
                </div>

                <!-- Stats Row -->
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-xl border border-slate-100 shadow-sm p-4 border-t-4 border-t-[#3b4bc9]">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Registros</p>
                        <p class="text-3xl font-black text-[#3b4bc9]"><%= total %></p>
                    </div>
                    <div class="bg-white rounded-xl border border-slate-100 shadow-sm p-4 border-t-4 border-t-emerald-500">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Pagina</p>
                        <p class="text-3xl font-black text-emerald-600"><%= pagina %> / <%= paginas %></p>
                    </div>
                    <div class="bg-white rounded-xl border border-slate-100 shadow-sm p-4 border-t-4 border-t-amber-500">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Modulo</p>
                        <p class="text-lg font-bold text-amber-700 truncate"><%= modulo || 'Todos' %></p>
                    </div>
                    <div class="bg-white rounded-xl border border-slate-100 shadow-sm p-4 border-t-4 border-t-violet-500">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Accion</p>
                        <p class="text-lg font-bold text-violet-700 truncate"><%= accion || 'Todas' %></p>
                    </div>
                </div>

                <!-- Filters -->
                <form method="GET" action="/auditoria" class="bg-white rounded-xl border border-slate-100 shadow-sm p-4 mb-6 flex flex-wrap gap-3 items-end">
                    <div class="flex-1 min-w-[200px]">
                        <label class="text-xs font-semibold text-slate-500 block mb-1">Buscar</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                            <input type="text" name="busqueda" value="<%= busqueda %>" placeholder="Usuario o descripcion..."
                                class="w-full pl-9 pr-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                        </div>
                    </div>
                    <div class="min-w-[150px]">
                        <label class="text-xs font-semibold text-slate-500 block mb-1">Modulo</label>
                        <select name="modulo" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                            <option value="">Todos</option>
                            <% filtros.modulos.forEach(m => { %>
                                <option value="<%= m %>" <%= modulo === m ? 'selected' : '' %>><%= m %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="min-w-[150px]">
                        <label class="text-xs font-semibold text-slate-500 block mb-1">Accion</label>
                        <select name="accion" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none">
                            <option value="">Todas</option>
                            <% filtros.acciones.forEach(a => { %>
                                <option value="<%= a %>" <%= accion === a ? 'selected' : '' %>><%= a %></option>
                            <% }) %>
                        </select>
                    </div>
                    <button type="submit" class="px-5 py-2 bg-[#3b4bc9] text-white text-sm font-semibold rounded-lg hover:bg-[#3b4bc9]/90 transition-all">
                        <span class="material-symbols-outlined text-sm align-middle mr-1">filter_alt</span>Filtrar
                    </button>
                    <a href="/auditoria" class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-200 transition-all">Limpiar</a>
                </form>

                <!-- Table -->
                <div class="bg-white rounded-xl border border-slate-100 shadow-md overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200">
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">#</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Fecha / Hora</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Usuario</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Modulo</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Accion</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Descripcion</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-widest">IP</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% if (registros && registros.length > 0) { %>
                                    <% registros.forEach((r, i) => {
                                        const accionKey = (r.Accion || '').toLowerCase().replace(/_/g, '');
                                        const badgeClass = ['crear','actualizar','eliminar','login','login_fallido','loginfallido','logout'].includes((r.Accion||'').toLowerCase()) ? 'badge-' + (r.Accion||'').toLowerCase() : 'badge-default';
                                    %>
                                    <tr class="hover:bg-slate-50/60 transition-colors">
                                        <td class="px-4 py-3 text-xs text-slate-400 font-mono"><%= r.IdAuditoria %></td>
                                        <td class="px-4 py-3 whitespace-nowrap">
                                            <p class="text-sm font-semibold text-slate-700">
                                                <%= r.FechaHora ? new Date(r.FechaHora).toLocaleDateString('es-PE', {day:'2-digit',month:'short',year:'numeric'}) : '-' %>
                                            </p>
                                            <p class="text-xs text-slate-400">
                                                <%= r.FechaHora ? new Date(r.FechaHora).toLocaleTimeString('es-PE', {hour:'2-digit',minute:'2-digit',second:'2-digit'}) : '' %>
                                            </p>
                                        </td>
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-2">
                                                <div class="w-7 h-7 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] text-xs font-bold flex-shrink-0">
                                                    <%= (r.NombreUsuario || 'S').charAt(0).toUpperCase() %>
                                                </div>
                                                <span class="text-sm font-medium text-slate-700"><%= r.NombreUsuario || 'Sistema' %></span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-slate-100 text-slate-600 uppercase tracking-wider">
                                                <%= r.Modulo %>
                                            </span>
                                        </td>
                                        <td class="px-4 py-3">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-bold uppercase tracking-wider <%= badgeClass %>">
                                                <%= r.Accion %>
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-slate-600 max-w-xs truncate" title="<%= r.Descripcion %>">
                                            <%= r.Descripcion %>
                                        </td>
                                        <td class="px-4 py-3 text-xs text-slate-400 font-mono"><%= r.IP || '-' %></td>
                                    </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-16">
                                            <span class="material-symbols-outlined text-5xl text-slate-300 block mb-3">history</span>
                                            <p class="text-slate-500 font-semibold">Sin registros de auditoria</p>
                                            <p class="text-slate-400 text-sm">Las acciones del sistema apareceran aqui.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <% if (paginas > 1) { %>
                    <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                        <p class="text-sm text-slate-500">Mostrando pagina <strong><%= pagina %></strong> de <strong><%= paginas %></strong> &mdash; <%= total %> registros</p>
                        <div class="flex gap-2">
                            <% if (pagina > 1) { %>
                                <a href="/auditoria?pagina=<%= pagina-1 %>&modulo=<%= modulo %>&accion=<%= accion %>&busqueda=<%= busqueda %>"
                                   class="px-3 py-1.5 text-xs font-semibold bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition-all">Anterior</a>
                            <% } %>
                            <% if (pagina < paginas) { %>
                                <a href="/auditoria?pagina=<%= pagina+1 %>&modulo=<%= modulo %>&accion=<%= accion %>&busqueda=<%= busqueda %>"
                                   class="px-3 py-1.5 text-xs font-semibold bg-[#3b4bc9] text-white rounded-lg hover:bg-[#3b4bc9]/90 transition-all">Siguiente</a>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>

            </div><!-- /p-8 -->
        </div><!-- /main-content -->
    </div><!-- /wrapper -->

    <script src="/publico/js/layout.js?v=1"></script>
</body>
</html>
